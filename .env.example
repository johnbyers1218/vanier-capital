# ============================================================================
# Vanier Capital — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in the values for your environment.
#   cp .env.example .env
#
# Variables marked [REQUIRED] must be set for the app to start.
# Variables marked [OPTIONAL] enhance functionality but have sensible defaults.
# Variables marked [TEST ONLY] are used exclusively in the test suite.
# ============================================================================

# ── Core Application ────────────────────────────────────────────────────────

# [OPTIONAL] Node environment: development | production | test
NODE_ENV=development

# [OPTIONAL] HTTP port (default: 3000)
PORT=3000

# [OPTIONAL] HTTPS port — only used when local TLS certs are present
# HTTPS_PORT=3443

# ── Database ────────────────────────────────────────────────────────────────

# [REQUIRED] MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/vaniercapital_dev

# ── Session & Cookies ──────────────────────────────────────────────────────

# [REQUIRED] Secret used to sign the Express session cookie
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# [REQUIRED] Secret used to sign cookies (cookie-parser)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=

# [OPTIONAL] Legacy JWT secret — still referenced in session config fallback
# JWT_SECRET=

# ── Authentication (Clerk) ──────────────────────────────────────────────────

# [REQUIRED] Clerk secret key (from Clerk Dashboard → API Keys)
CLERK_SECRET_KEY=

# [REQUIRED] Clerk publishable key (from Clerk Dashboard → API Keys)
CLERK_PUBLISHABLE_KEY=

# [REQUIRED] Enable Clerk authentication (set to "1" to enable)
USE_CLERK=1

# [OPTIONAL] Custom Clerk sign-in URL (default: https://accounts.clerk.dev/sign-in)
# CLERK_SIGN_IN_URL=

# ── Email — SendGrid ───────────────────────────────────────────────────────
# App degrades gracefully when these are missing — email features are disabled.

# [OPTIONAL] SendGrid API key
SENDGRID_API_KEY=

# [OPTIONAL] Verified sender email address (SendGrid → Sender Authentication)
SENDGRID_FROM_EMAIL=

# [OPTIONAL] Display name for outbound emails (default: "Vanier Capital")
# SENDGRID_FROM_NAME=Vanier Capital

# [OPTIONAL] Email address receiving contact-form and inquiry notifications
# CONTACT_TEAM_EMAIL=

# [OPTIONAL] Email address receiving investor-club application alerts
# Falls back to CONTACT_TEAM_EMAIL → SENDGRID_FROM_EMAIL
# INVESTOR_CLUB_NOTIFY_EMAIL=

# ── Image CDN — Cloudinary ──────────────────────────────────────────────────
# Required for admin image uploads (blog hero images, property photos).

# [OPTIONAL] Cloudinary connection URL (alternative to individual keys below)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# [OPTIONAL] Cloudinary individual credentials (from Cloudinary Dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Rich Text Editor — TinyMCE ─────────────────────────────────────────────

# [OPTIONAL] TinyMCE API key for the admin WYSIWYG editor
# Falls back to "no-api-key" (limited community mode)
TINYMCE_API_KEY=

# ── Analytics — Google Analytics 4 ─────────────────────────────────────────

# [OPTIONAL] GA4 Measurement ID (only loaded in production)
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site URLs & CORS ────────────────────────────────────────────────────────

# [OPTIONAL] Canonical public site URL — used for sitemaps, OG tags, email links
# PUBLIC_SITE_URL=https://www.vaniercapital.com

# [OPTIONAL] Fallback for PUBLIC_SITE_URL in sitemap generation
# SITE_URL=https://www.vaniercapital.com

# [OPTIONAL] Site base URL used in public route OG meta (falls back to req.protocol://req.host)
# SITE_BASE_URL=https://www.vaniercapital.com

# [OPTIONAL] CORS allowed origin — also injected into Helmet CSP directives
# CORS_ORIGIN=https://www.vaniercapital.com

# [OPTIONAL] CDN base URL for static assets (passed to views as `cdnUrl`)
# CDN_URL=

# [OPTIONAL] Heroku app name — used as CORS fallback (https://<name>.herokuapp.com)
# HEROKU_APP_NAME=

# ── Admin Bootstrap (dev only) ──────────────────────────────────────────────
# Used by `npm run setup-admin` to seed the first AdminUser record.

# [OPTIONAL] Clerk user ID for the initial admin account
# INITIAL_ADMIN_USER=

# [OPTIONAL] Display name for the initial admin account
# INITIAL_ADMIN_FULLNAME=

# ── Testing ─────────────────────────────────────────────────────────────────
# These should NOT be set in production. Used by Jest / Playwright only.

# [TEST ONLY] Bypass Clerk auth in integration tests (set to "1")
# BYPASS_AUTH=0

# [TEST ONLY] Use mongodb-memory-server instead of real MongoDB
# USE_IN_MEMORY_DB=0

# [TEST ONLY] Enable smoke-test mode (minimal route loading)
# SMOKE=0

# [TEST ONLY] Allow Express server to listen during test runs
# ALLOW_SERVER_IN_TEST=0

# [TEST ONLY] Playwright base URL
# E2E_BASE_URL=http://localhost:3000
