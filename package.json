{
  "type": "module",
  "name": "vanier-capital-webapp",
  "version": "1.0.0",
  "private": true,
  "description": "Web application for Vanier Capital, Real Estate Investment Firm, featuring public site and admin CMS.",
  "main": "app.js",
  "migrate-mongo": {
    "config": "./migrate-mongo-config.js"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "cross-env NODE_ENV=development nodemon app.js",
    "dev:kill": "fkill :3000 :443 --force --silent || echo 'No process found on ports or fkill failed.'",
    "setup-admin": "cross-env NODE_ENV=development node setupAdmin.js",
    "build:css": "npx tailwindcss -i ./public/css/tailwind.css -o ./public/css/tailwind.min.css --watch",
    "build:css:prod": "npx tailwindcss -i ./public/css/tailwind.css -o ./public/css/tailwind.min.css --minify",
    "build:admin-css": "npx tailwindcss -i ./public/css/admin-input.css -o ./public/css/admin-style.css --watch",
    "build:public-css": "npx tailwindcss -i ./public/css/main-input.css -o ./public/css/style.css --watch",
    "build:public-css:once": "npx @tailwindcss/cli -i ./public/css/main-input.css -o ./public/css/style.css --minify",
    "dev:css:public": "npx @tailwindcss/cli -i ./public/css/main-input.css -o ./public/css/style.css -w",
    "dev:css": "concurrently \"npm:build:admin-css\" \"npm:build:public-css\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "optimize:images": "node scripts/optimize-images.cjs",
    "seed:taxonomy": "node scripts/seed-taxonomy.mjs",
    "set:legal-dates": "node scripts/set-legal-updated.mjs",
    "migrate:create": "npx migrate-mongo create",
    "migrate:up": "npx migrate-mongo up",
    "migrate:down": "npx migrate-mongo down"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-github-username/fnd-automations-repo.git"
  },
  "keywords": [
    "automation",
    "ai",
    "web",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Vanier Capital <info@vaniercapital.com>",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/your-github-username/fnd-automations-repo/issues"
  },
  "homepage": "https://github.com/your-github-username/fnd-automations-repo#readme",
  "dependencies": {
    "@clerk/clerk-sdk-node": "^4.13.23",
    "@mailchimp/mailchimp_marketing": "^3.0.80",
    "@sendgrid/mail": "^8.1.3",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.2.0",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dompurify": "^3.1.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.1.0",
    "ffmpeg": "^0.0.4",
    "google-auth-library": "^9.9.0",
    "googleapis": "^137.1.0",
    "helmet": "^7.1.0",
    "jsdom": "^24.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.6.1",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "repomix": "^0.3.5",
    "slugify": "^1.6.6",
    "validator": "^13.15.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/preset-env": "^7.28.3",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^30.0.5",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "d3-geo": "^3.1.0",
    "d3-geo-projection": "^4.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.2.0",
    "nodemon": "^3.1.2",
    "postcss": "^8.5.6",
    "sharp": "^0.33.4",
    "supertest": "^6.3.4",
    "tailwindcss": "^4.1.11",
    "topojson-client": "^3.1.0"
  },
  "engines": {
    "node": "18.x || 20.x"
  }
}
