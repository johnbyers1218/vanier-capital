<!-- views/contact.ejs (Two-Paths Redesign) -->
<%- include('partials/header', {
    pageTitle: 'Contact Us - FND Automations',
    pageDescription: 'Ready to talk or just have a question? Choose how you want to connect with FND Automations—schedule a live consultation or send us a message.'
}) %>

<!-- Hero -->
<section class="section contact-hero">
    <div class="container">
        <div class="section-header">
            <h1 class="section-title">Ready to Transform Your Business?</h1>
            <p class="section-description">Whether you're ready to book a strategic consultation or just have a question, we're here to help. Choose the best way to connect with our team below.</p>
        </div>
    </div>
    </section>

    <!-- Map moved to homepage for Credibility Sandwich -->

<!-- Choose Your Path -->
<section class="section contact-paths">
    <div class="container">
        <div class="choose-paths-grid">
            <!-- High-Intent: Schedule Meeting -->
            <div class="path-card primary">
                <div class="path-card-body">
                    <h2 class="path-title">Schedule a Live Consultation</h2>
                      <p class="path-text">Book a complimentary strategy session (up to 60 minutes) directly on our calendar. We'll dive into your specific challenges and explore how AI and automation can drive tangible results for your business.</p>
                    <div class="team-avatars" aria-label="You may meet with these team members">
                        <% if (typeof teamUsers !== 'undefined' && teamUsers && teamUsers.length) { %>
                            <% teamUsers.forEach(function(u){
                                var name = (u.fullName || u.username || '').trim();
                                var initials = name ? name.split(/\s+/).map(p=>p[0]).slice(0,2).join('').toUpperCase() : 'U';
                            %>
                                <div class="avatar" title="<%= name %>">
                                    <% var avatarSrc = u.avatarUrl; if (avatarSrc && !/^https?:\/\//i.test(avatarSrc) && avatarSrc.charAt(0) !== '/') { avatarSrc = '/images/' + avatarSrc; } %>
                                    <% if (avatarSrc) { %>
                                        <img src="<%= avatarSrc %>" alt="<%= name %>" loading="lazy"/>
                                    <% } else { %>
                                        <div class="avatar-fallback" aria-hidden="true"><%= initials %></div>
                                    <% } %>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <!-- Fallback static faces if no team data available -->
                            <img src="/images/Logan.png" alt="Logan" loading="lazy"/>
                            <img src="/images/John.png" alt="John" loading="lazy"/>
                            <img src="/images/Haidan.png" alt="Haidan" loading="lazy"/>
                            <img src="/images/Moe.png" alt="Moe" loading="lazy"/>
                        <% } %>
                    </div>
                                <div class="expectations">
                                    <h3 class="expect-title">In this complimentary session, we will:</h3>
                                    <ul class="expect-list">
                                        <li><i class="fas fa-check"></i> Analyze your current operational challenges.</li>
                                        <li><i class="fas fa-check"></i> Identify key opportunities for automation and AI.</li>
                                        <li><i class="fas fa-check"></i> Outline a potential roadmap for implementation.</li>
                                        <li><i class="fas fa-check"></i> Provide an initial estimate of potential ROI.</li>
                                    </ul>
                                </div>
                                <div class="path-actions">
                                    <button type="button" id="openScheduleModal" class="cta-button primary-btn">Find a Time</button>
                                </div>
                </div>
            </div>

            <!-- General Inquiry: Message Form -->
            <div class="path-card secondary">
                <div class="path-card-body">
                    <h2 class="path-title">Send Us a Message</h2>
                    <p class="path-text">Have a general question, a project inquiry, or a media request? Fill out the form, and a member of our team will get back to you within one business day.</p>
                    <div id="contact-form-message" style="margin-bottom: 1rem;"></div>
                    <form id="contact-form">
                        <input type="hidden" id="requestedMeeting" name="requestedMeeting" value="false" />
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="name">Your Name <span style="color:#dc3545">*</span></label>
                                <input type="text" id="name" name="name" placeholder="Enter your full name" required>
                            </div>
                            <div class="form-group">
                                <label for="email">Email Address <span style="color:#dc3545">*</span></label>
                                <input type="email" id="email" name="email" placeholder="Enter your email address" required>
                            </div>
                            <div class="form-group">
                                <label for="phone">Phone Number (Optional)</label>
                                <input type="tel" id="phone" name="phone" placeholder="Enter your phone number">
                            </div>
                            <div class="form-group">
                                <label for="subject">Subject <span style="color:#dc3545">*</span></label>
                                <select id="subject" name="subject" required>
                                    <option value disabled selected>-- Select a Subject --</option>
                                    <option value="General Inquiry">General Inquiry</option>
                                    <option value="Service Information">Service Information</option>
                                    <option value="Request Quote/Consultation">Request Quote/Consultation</option>
                                    <option value="Partnership Inquiry">Partnership Inquiry</option>
                                    <option value="Other">Other</option>
                                </select>
                            </div>
                            <div class="form-group form-group-full">
                                <label for="message">Your Message <span style="color:#dc3545">*</span></label>
                                <textarea id="message" name="message" placeholder="Tell us about your project or question..." rows="6" required></textarea>
                            </div>
                                            <div class="policy-agreement form-group-full">
                                                <input type="checkbox" id="privacy" name="privacy" required>
                                                <label for="privacy">I agree to the <a href="/privacy-policy" target="_blank">Privacy Policy</a> and <a href="/terms-of-service" target="_blank">Terms of Service</a> <span style="color:#dc3545">*</span></label>
                                            </div>
                        </div>
                        <div class="submit-btn-container">
                            <button type="submit" class="submit-btn cta-button primary-btn"><i class="fas fa-paper-plane"></i> Send Message</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Scheduling Modal -->
<div id="scheduleModal" class="schedule-modal" aria-hidden="true" role="dialog" aria-labelledby="scheduleModalTitle">
    <div class="schedule-modal__backdrop" data-close-modal></div>
    <div class="schedule-modal__dialog" role="document">
        <div class="schedule-modal__header">
            <h2 id="scheduleModalTitle">Book a Consultation</h2>
            <button type="button" class="schedule-modal__close" aria-label="Close" data-close-modal>&times;</button>
        </div>
        <div class="schedule-modal__body">
            <iframe id="scheduleIframe" title="Scheduling" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
        </div>
    </div>
</div>

<style>
    .schedule-modal { position:fixed; inset:0; display:none; z-index:12000; }
    .schedule-modal.is-open { display:block; }
    .schedule-modal__backdrop { position:absolute; inset:0; background:rgba(0,0,0,.55); backdrop-filter:blur(2px); }
    .schedule-modal__dialog { position:relative; margin:4vh auto; width:min(1100px,95%); height:88vh; background:#0f172a; border:1px solid #1e293b; border-radius:14px; box-shadow:0 10px 40px -5px rgba(0,0,0,.6); display:flex; flex-direction:column; }
    .schedule-modal__header { padding:12px 18px; border-bottom:1px solid #1e293b; display:flex; align-items:center; justify-content:space-between; }
    .schedule-modal__header h2 { font-size:1rem; font-weight:600; color:#f1f5f9; }
    .schedule-modal__close { background:transparent; border:none; color:#94a3b8; font-size:1.6rem; line-height:1; cursor:pointer; padding:4px 8px; border-radius:6px; }
    .schedule-modal__close:hover { color:#fff; background:#334155; }
    .schedule-modal__body { flex:1; padding:0; }
    .schedule-modal__body iframe { width:100%; height:100%; border:0; background:#fff; border-bottom-left-radius:14px; border-bottom-right-radius:14px; }
    @media (max-width: 680px) { .schedule-modal__dialog { height:94vh; margin:2vh auto; } .schedule-modal__header h2 { font-size:.95rem; } }
</style>

<script>
    (function(){
        const openBtn = document.getElementById('openScheduleModal');
        const modal = document.getElementById('scheduleModal');
        const iframe = document.getElementById('scheduleIframe');
        const CLOSE_ATTR = '[data-close-modal]';
        const scheduleURL = 'https://calendar.google.com/calendar/appointments/schedules/AcZssZ335AVuGBH_NJglKI3iiThB8cP6sHwnzkeg6aJjyEGEKEVJkIQuUCWFOaL1UpBPp_YbVAfTY4dI?gv=true&embed=true';
        function open(){
            if(!modal.classList.contains('is-open')){
                iframe.src = scheduleURL;
                modal.classList.add('is-open');
                document.body.style.overflow='hidden';
                prevActive = document.activeElement; 
                modal.querySelector('.schedule-modal__close').focus();
            }
        }
        function close(){
            modal.classList.remove('is-open');
            document.body.style.overflow='';
            iframe.removeAttribute('src');
            if(prevActive) try{ prevActive.focus(); }catch(_){ }
        }
        let prevActive=null;
        openBtn?.addEventListener('click', open);
        modal?.addEventListener('click', (e)=>{ if(e.target.matches(CLOSE_ATTR)) close(); });
        window.addEventListener('keydown', (e)=>{ if(e.key==='Escape' && modal.classList.contains('is-open')) close(); });
    })();
</script>

