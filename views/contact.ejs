<!-- views/contact.ejs -->
<%# Institutional Contact / Connect Page %>

<%- include('partials/header', {
    pageTitle: 'Connect - Vanier Capital',
    pageDescription: 'Reach out to the Vanier Capital leadership team regarding capital partnerships, asset acquisitions, or general inquiries.',
    path: '/contact',
    isHeroPage: true
}) %>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="bg-[#0f2e22] pt-24 md:pt-32 pb-14 md:pb-20 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white tracking-tight mb-6">Connect</h1>
        <p class="font-sans text-xl text-white/80 max-w-3xl leading-relaxed">Reach out to our leadership team regarding capital partnerships, asset acquisitions, or general inquiries.</p>
    </div>
</section>

<!-- ═══════════════ MAIN CONTENT ═══════════════ -->
<section class="bg-white">
    <div class="max-w-screen-xl mx-auto px-6 md:px-16 py-12 md:py-20 grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16">

        <!-- LEFT COLUMN: Directory -->
        <div class="md:col-span-4">
            <h2 class="font-serif text-2xl text-[#0f2e22] mb-8">Directory</h2>

            <div class="space-y-10">
                <!-- Investor Relations -->
                <div class="border-t border-[#0f2e22]/20 pt-6">
                    <h3 class="font-serif text-lg text-[#1a1a1a] mb-2">Investor Relations</h3>
                    <p class="font-sans text-sm text-gray-500 mb-3">Distribution list, portfolio updates, and future capital partnerships.</p>
                    <a href="mailto:ir@vaniercapital.com" class="font-sans text-sm text-[#0f2e22] hover:underline block mb-1">ir@vaniercapital.com</a>
                    <a href="/contact/investor-relations" class="font-sans text-xs text-[#0f2e22] hover:underline">Dedicated IR Page &rarr;</a>
                </div>

                <!-- Acquisitions -->
                <div class="border-t border-[#0f2e22]/20 pt-6">
                    <h3 class="font-serif text-lg text-[#1a1a1a] mb-2">Acquisitions</h3>
                    <p class="font-sans text-sm text-gray-500 mb-3">Off-market deal flow, broker submissions, and asset evaluations.</p>
                    <a href="mailto:acquisitions@vaniercapital.com" class="font-sans text-sm text-[#0f2e22] hover:underline block mb-1">acquisitions@vaniercapital.com</a>
                    <a href="/contact/acquisitions" class="font-sans text-xs text-[#0f2e22] hover:underline">Submit a Deal &rarr;</a>
                </div>

                <!-- General -->
                <div class="border-t border-[#0f2e22]/20 pt-6">
                    <h3 class="font-serif text-lg text-[#1a1a1a] mb-2">General Inquiries</h3>
                    <p class="font-sans text-sm text-gray-500 mb-3">Media requests, career opportunities, and general correspondence.</p>
                    <a href="mailto:info@vaniercapital.com" class="font-sans text-sm text-[#0f2e22] hover:underline">info@vaniercapital.com</a>
                </div>
            </div>

            <!-- Office Hours -->
            <div class="border-t border-[#0f2e22]/20 pt-6 mt-10">
                <h3 class="font-serif text-lg text-[#1a1a1a] mb-2">Office Hours</h3>
                <p class="font-sans text-sm text-gray-500">Monday – Friday</p>
                <p class="font-sans text-sm text-gray-500">9:00 AM – 6:00 PM EST</p>
            </div>
        </div>

        <!-- RIGHT COLUMN: Form -->
        <div class="md:col-span-8">
            <h2 class="font-serif text-2xl text-[#0f2e22] mb-8">Send a Message</h2>

            <div id="contact-form-message" class="mb-6"></div>

            <form id="contact-form" class="space-y-6">
                <input type="hidden" id="requestedMeeting" name="requestedMeeting" value="false" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Name -->
                    <div>
                        <label for="name" class="block font-sans text-sm font-medium text-[#1a1a1a] mb-2">Full Name <span class="text-red-600">*</span></label>
                        <input type="text" id="name" name="name" required
                               class="w-full font-sans text-base px-4 py-3 border border-gray-300 rounded-none bg-white text-[#1a1a1a] placeholder-gray-400 focus:outline-none focus:border-[#0f2e22] focus:ring-0 transition-colors"
                               placeholder="Enter your full name">
                    </div>

                    <!-- Email -->
                    <div>
                        <label for="email" class="block font-sans text-sm font-medium text-[#1a1a1a] mb-2">Email Address <span class="text-red-600">*</span></label>
                        <input type="email" id="email" name="email" required
                               class="w-full font-sans text-base px-4 py-3 border border-gray-300 rounded-none bg-white text-[#1a1a1a] placeholder-gray-400 focus:outline-none focus:border-[#0f2e22] focus:ring-0 transition-colors"
                               placeholder="you@company.com">
                    </div>

                    <!-- Phone -->
                    <div>
                        <label for="phone" class="block font-sans text-sm font-medium text-[#1a1a1a] mb-2">Phone Number</label>
                        <input type="tel" id="phone" name="phone"
                               class="w-full font-sans text-base px-4 py-3 border border-gray-300 rounded-none bg-white text-[#1a1a1a] placeholder-gray-400 focus:outline-none focus:border-[#0f2e22] focus:ring-0 transition-colors"
                               placeholder="(Optional)">
                    </div>

                    <!-- Topic -->
                    <div>
                        <label for="subject" class="block font-sans text-sm font-medium text-[#1a1a1a] mb-2">Topic <span class="text-red-600">*</span></label>
                        <select id="subject" name="subject" required
                                class="w-full font-sans text-base px-4 py-3 border border-gray-300 rounded-none bg-white text-[#1a1a1a] focus:outline-none focus:border-[#0f2e22] focus:ring-0 transition-colors appearance-none">
                            <option value="" disabled selected>Select a topic</option>
                            <option value="Investor Relations">Investor Relations</option>
                            <option value="Acquisitions">Acquisitions</option>
                            <option value="General Inquiry">General Inquiry</option>
                            <option value="Media">Media &amp; Press</option>
                            <option value="Careers">Careers</option>
                        </select>
                    </div>
                </div>

                <!-- Message -->
                <div>
                    <label for="message" class="block font-sans text-sm font-medium text-[#1a1a1a] mb-2">Message <span class="text-red-600">*</span></label>
                    <textarea id="message" name="message" rows="6" required
                              class="w-full font-sans text-base px-4 py-3 border border-gray-300 rounded-none bg-white text-[#1a1a1a] placeholder-gray-400 focus:outline-none focus:border-[#0f2e22] focus:ring-0 transition-colors resize-vertical"
                              placeholder="How can we assist you?"></textarea>
                </div>

                <!-- Privacy -->
                <div class="flex items-start gap-3">
                    <input type="checkbox" id="privacy" name="privacy" required
                           class="mt-1 w-4 h-4 border border-gray-300 rounded-none text-[#0f2e22] focus:ring-0 focus:ring-offset-0">
                    <label for="privacy" class="font-sans text-sm text-gray-600">
                        I agree to the <a href="/privacy-policy" target="_blank" class="text-[#0f2e22] underline">Privacy Policy</a> and <a href="/terms-of-service" target="_blank" class="text-[#0f2e22] underline">Terms of Service</a> <span class="text-red-600">*</span>
                    </label>
                </div>

                <!-- Submit -->
                <div>
                    <button type="submit"
                            class="w-full md:w-auto font-sans text-sm font-bold uppercase tracking-wider text-white bg-[#0f2e22] px-10 py-4 rounded-none hover:bg-[#1a1a1a] transition-colors">
                        Submit Inquiry
                    </button>
                </div>
            </form>
        </div>

    </div>
</section>

<!-- ═══════════════ GENERAL FAQ ═══════════════ -->
<section class="bg-white border-t border-[#0f2e22]/10">
    <div class="max-w-3xl mx-auto px-6 md:px-16 pt-14 md:pt-24 pb-10 md:pb-16">
        <h2 class="font-serif text-3xl text-[#0f2e22] border-b border-[#0f2e22]/20 pb-4 mb-8">Frequently Asked Questions</h2>

        <details class="group border-b border-gray-200 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between py-5 font-sans text-sm font-bold uppercase tracking-widest text-[#1a1a1a] hover:text-[#0f2e22] transition-colors">
                <span>Where is Vanier Capital headquartered?</span>
                <span class="transition group-open:rotate-180 shrink-0 ml-4">
                    <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
            </summary>
            <p class="font-sans text-gray-600 leading-relaxed pb-6 pr-8 text-sm">
                Our leadership and operations are headquartered in Columbus, Georgia, with an acquisition focus spanning the broader Chattahoochee Valley and surrounding Southeast markets. Operating regionally ensures we have direct, hands-on oversight of our portfolio and established vendor network.
            </p>
        </details>

        <details class="group border-b border-gray-200 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between py-5 font-sans text-sm font-bold uppercase tracking-widest text-[#1a1a1a] hover:text-[#0f2e22] transition-colors">
                <span>Do you provide third-party property management services?</span>
                <span class="transition group-open:rotate-180 shrink-0 ml-4">
                    <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
            </summary>
            <p class="font-sans text-gray-600 leading-relaxed pb-6 pr-8 text-sm">
                No. Vanier Capital is a vertically integrated firm. We exclusively manage assets held within our own portfolio to ensure that our standard operating procedures and quality controls remain consistent across every property.
            </p>
        </details>

        <details class="group border-b border-gray-200 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between py-5 font-sans text-sm font-bold uppercase tracking-widest text-[#1a1a1a] hover:text-[#0f2e22] transition-colors">
                <span>How should press or media inquiries be directed?</span>
                <span class="transition group-open:rotate-180 shrink-0 ml-4">
                    <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
            </summary>
            <p class="font-sans text-gray-600 leading-relaxed pb-6 pr-8 text-sm">
                All media, press, and academic inquiries should be directed to <a href="mailto:info@vaniercapital.com" class="text-[#0f2e22] underline hover:no-underline">info@vaniercapital.com</a>. A member of our team will route the request to the appropriate founding partner.
            </p>
        </details>

        <details class="group border-b border-gray-200 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between py-5 font-sans text-sm font-bold uppercase tracking-widest text-[#1a1a1a] hover:text-[#0f2e22] transition-colors">
                <span>Is Vanier Capital currently hiring?</span>
                <span class="transition group-open:rotate-180 shrink-0 ml-4">
                    <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
            </summary>
            <p class="font-sans text-gray-600 leading-relaxed pb-6 pr-8 text-sm">
                We selectively recruit professionals who demonstrate exceptional analytical rigor, operational discipline, and alignment with our institutional culture. Open positions, when available, are communicated through our network. Qualified candidates may submit a résumé and cover letter to <a href="mailto:info@vaniercapital.com" class="text-[#0f2e22] underline hover:no-underline">info@vaniercapital.com</a>.
            </p>
        </details>

        <details class="group border-b border-gray-200 [&_summary::-webkit-details-marker]:hidden">
            <summary class="flex cursor-pointer items-center justify-between py-5 font-sans text-sm font-bold uppercase tracking-widest text-[#1a1a1a] hover:text-[#0f2e22] transition-colors">
                <span>What markets does Vanier Capital operate in?</span>
                <span class="transition group-open:rotate-180 shrink-0 ml-4">
                    <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                </span>
            </summary>
            <p class="font-sans text-gray-600 leading-relaxed pb-6 pr-8 text-sm">
                We currently operate across the Chattahoochee Valley and surrounding Southeast markets. We believe in building deep, localized operational density — maintaining hands-on oversight of every asset — rather than spreading resources across disparate geographies. Our market thesis and selection criteria are detailed on our <a href="/strategy" class="text-[#0f2e22] underline hover:no-underline">Investment Strategy</a> page.
            </p>
        </details>
    </div>
</section>

<!-- ═══════════════ CTA BLOCK ═══════════════ -->
<section class="bg-slate-50 border-t border-[#0f2e22]/10">
    <div class="max-w-screen-xl mx-auto px-6 md:px-16 py-14 md:py-20 text-center">
        <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl text-[#0f2e22] mb-4">Explore Our Platform</h2>
        <p class="font-sans text-lg text-gray-600 max-w-2xl mx-auto mb-10">Learn more about our investment philosophy, current portfolio, and market perspectives.</p>
        <div class="flex flex-wrap items-center justify-center gap-6">
            <a href="/strategy" class="font-sans text-sm font-bold uppercase tracking-wider text-white bg-[#0f2e22] px-8 py-4 rounded-none hover:bg-[#1a3a2a] transition-colors">Investment Strategy</a>
            <a href="/portfolio" class="font-sans text-sm font-bold uppercase tracking-wider text-[#0f2e22] border border-[#0f2e22] px-8 py-4 rounded-none hover:bg-[#0f2e22] hover:text-white transition-colors">View Portfolio</a>
        </div>
    </div>
</section>

<!-- Topic auto-select from URL params -->
<script>
(function() {
    var params = new URLSearchParams(window.location.search);
    var topic = (params.get('topic') || '').toLowerCase().trim();
    if (!topic) return;
    var select = document.getElementById('subject');
    if (!select) return;
    var map = {
        'investor-relations': 'Investor Relations',
        'ir': 'Investor Relations',
        'acquisitions': 'Acquisitions',
        'general': 'General Inquiry',
        'media': 'Media',
        'careers': 'Careers'
    };
    var value = map[topic];
    if (value) {
        for (var i = 0; i < select.options.length; i++) {
            if (select.options[i].value === value) {
                select.selectedIndex = i;
                break;
            }
        }
    }
})();
</script>

<%- include('partials/footer') %>