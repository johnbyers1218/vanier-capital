<!-- views/contact.ejs (UPDATED for combined form structure) -->
<%- include('partials/header', { /* ... */ }) %>

<section class="page-header">
    <div class="container">
        <h1>Contact Us</h1>
        <div class="breadcrumbs">
            <a href="/">Home</a> <span class="separator">/</span> <span class="current">Contact</span>
        </div>
    </div>
</section>

<section id="contact-section" class="section contact-section">
    <div class="container">
        <div class="contact-intro section-header" style="margin-bottom: 3rem;">
            <h2 class="section-title">Get In Touch</h2>
            <p class="section-description">Have questions or want to discuss your automation needs? Reach out using the form below.</p>
        </div>

        <div class="contact-form-container">
            <div class="form-header">
                <h3>Send Us a Message</h3>
            </div>

            <div id="contact-form-message" style="margin-bottom: 1.5rem;"></div>

            <form id="contact-form"> 
      
                <div class="form-group">
                  <label for="name">Your Name <span style="color: #dc3545;">*</span></label>
                  <input type="text" id="name" name="name" placeholder="Enter your full name" required>
                </div>
                <div class="form-group">
                  <label for="email">Email Address <span style="color: #dc3545;">*</span></label>
                  <input type="email" id="email" name="email" placeholder="Enter your email address" required>
                </div>
                <div class="form-group">
                  <label for="phone">Phone Number (Optional)</label>
                  <input type="tel" id="phone" name="phone" placeholder="Enter your phone number">
                </div>
                <div class="form-group">
                  <label for="subject">Subject <span style="color: #dc3545;">*</span></label>
                  <select id="subject" name="subject" required>
                    <option value="" disabled selected>-- Select a Subject --</option>
                    <option value="General Inquiry">General Inquiry</option>
                    <option value="Service Information">Service Information</option>
                    <option value="Request Quote/Consultation">Request Quote/Consultation</option>
                    <option value="Partnership Inquiry">Partnership Inquiry</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
                <div class="form-group form-group-full"> 
                  <label for="message">Your Message <span style="color: #dc3545;">*</span></label>
                  <textarea id="message" name="message" placeholder="Tell us about your project or question..." rows="6" required></textarea>
                </div>

              
                <div class="form-group form-checkbox form-group-full" style="border-bottom: 1px solid var(--card-border); padding-bottom: 1.5rem; margin-bottom: 1.5rem;">
                    <input type="checkbox" id="request-meeting-checkbox" name="requestMeetingToggle">
                    <label for="request-meeting-checkbox">I'd also like to suggest some meeting times.</label>
                </div>

                
                <div id="schedule-fields-container" style="display: none;" class="form-group-full">
                  
                    <div class="schedule-fields-inner-grid"> 
                        <input type="hidden" id="schedule-contactName-mirror" name="contactNameMirror">
                        <input type="hidden" id="schedule-contactEmail-mirror" name="contactEmailMirror">

                        <h4 style="grid-column: span 2; text-align:center; margin-bottom:1rem; color:var(--light-text);">Suggest Meeting Times (Optional)</h4>

                        <div class="form-group">
                            <label for="schedule-companyName">Your Company Name (for meeting) <span class="schedule-required-indicator" style="color: #dc3545; display:none;">*</span></label>
                            <input type="text" id="schedule-companyName" name="scheduleCompanyName" placeholder="Your Company Name">
                        </div>
                        <div class="form-group">
                           <label for="schedule-preferredTimes">Suggest 1-3 Preferred Times/Days</label>
                           <textarea id="schedule-preferredTimes" name="schedulePreferredTimes" rows="3" placeholder="e.g., Tuesday 2 PM EST..."></textarea>
                           <small>Please include your timezone if known.</small>
                        </div>
                         <div class="form-group">
                             <label for="schedule-date">Select Specific Date <span class="schedule-required-indicator" style="color: #dc3545; display:none;">*</span></label>
                             <input type="date" id="schedule-date" name="scheduleSelectedDate">
                         </div>
                          <div class="form-group">
                             <label for="schedule-time">Select Specific Time <span class="schedule-required-indicator" style="color: #dc3545; display:none;">*</span></label>
                             <input type="time" id="schedule-time" name="scheduleSelectedTime">
                          </div>
                          <div class="form-group form-group-full">
                              <label for="schedule-timezone">Your Timezone <span class="schedule-required-indicator" style="color: #dc3545; display:none;">*</span></label>
                              <select id="schedule-timezone" name="scheduleTimeZone">
                                   <option value="" disabled selected>-- Select Your Timezone --</option>
                              </select>
                          </div>
                    </div> 
                </div>
                

                <div class="form-group form-checkbox form-group-full" style="margin-top: 1.5rem;">
                  <input type="checkbox" id="privacy" name="privacy" required>
                  <label for="privacy">I agree to the <a href="/privacy-policy" target="_blank">Privacy Policy</a> and <a href="/terms-of-service" target="_blank">Terms of Service</a> <span style="color: #dc3545;">*</span></label>
                </div>

                <div class="submit-btn-container form-group-full">
                    <button type="submit" class="submit-btn cta-button primary-btn">
                        <i class="fas fa-paper-plane"></i> Send Message
                    </button>
                </div>
            </form>
        </div>


        <!-- Contact Information Section -->
        <div class="contact-info-container">
            <!-- <div class="contact-info-item">
                <h3><i class="fas fa-map-marker-alt fa-fw"></i> Location</h3>
                <p>123 Automation Avenue</p>
                <p>Tech District, CA 94103</p>
            </div> -->
            <div class="contact-info-item">
                <h3><i class="fas fa-phone fa-fw"></i> Phone</h3>
                <p>Main: <a href="tel:+11234567890">(209) 402-0089</a></p>
                <p>Support: <a href="tel:+11234567891">(443) 643-6044</a></p> <!-- Update numbers -->
            </div>
            <div class="contact-info-item">
                <h3><i class="fas fa-envelope fa-fw"></i> Email</h3>
                <p><a href="mailto:info@fndautomations.com">logan.mayfield@fndautomations.com</a></p>
                <!-- <p><a href="mailto:support@fndautomations.com">support@fndautomations.com</a></p> Update emails -->
            </div>
            <div class="contact-info-item">
                <h3><i class="fas fa-clock fa-fw"></i> Hours</h3>
                <p>Sunday - Saturday</p> <!-- Add timezone -->
                <p>9AM - 6PM EST</p>
            </div>
        </div>

        <!-- Social Media Section -->
        <div class="social-section" style="margin-bottom: 3rem; text-align: center;">
            <h3><i class="fas fa-share-alt"></i> Connect With Us</h3>
            <div class="social-icons" style="justify-content: center;">
                <!-- <a href="https://www.facebook.com/yourprofile" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a> -->
                <!-- <a href="https://twitter.com/yourprofile" target="_blank" rel="noopener noreferrer" aria-label="Twitter"><i class="fab fa-twitter"></i></a> -->
                <a href="https://www.instagram.com/fndautomations/" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
                <!-- <a href="https://www.linkedin.com/in/yourprofile" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a> -->
                <a href="https://www.tiktok.com/@fnd.automations?lang=en" target="_blank" rel="noopener noreferrer" aria-label="TikTok"><i class="fa-brands fa-tiktok"></i></a>
            </div>
        </div>

