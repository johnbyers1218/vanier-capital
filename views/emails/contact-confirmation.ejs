<!doctype html>
<html lang="en">
  <head>
              <div class="h1">Thanks, <%= name || 'there' %>. We've received your message.</div> <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>We've received your message</title>
    <style>
      /* Basic email-safe resets */
      body { margin: 0; padding: 0; background: #f6f8fb; -webkit-text-size-adjust: 100%; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }
      img { border: 0; outline: none; text-decoration: none; display: block; max-width: 100%; }
  a { color: #00a8e8; text-decoration: none; }
      /* Container */
      .container { width: 100%; background: #f6f8fb; padding: 24px 0; }
      .card { width: 100%; max-width: 640px; margin: 0 auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 18px rgba(0,0,0,0.08); }
  /* brand bar */
  .topbar { height: 4px; background: #00a8e8; }
      .inner { padding: 24px; }
      .header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
      .brand { font-size: 14px; color: #111827; font-weight: 600; letter-spacing: 0.2px; }
      .h1 { font-size: 22px; line-height: 1.3; color: #0b1220; margin: 8px 0 12px; font-weight: 700; }
      .p { color: #4b5563; font-size: 15px; line-height: 1.6; margin: 0 0 12px; }
      .muted { color: #6b7280; }
      .summary { background: #f9fafb; border: 1px solid #eef2f7; border-radius: 10px; padding: 16px; margin: 16px 0; }
      .summary h3 { margin: 0 0 10px; font-size: 14px; color: #111827; letter-spacing: 0.3px; text-transform: uppercase; }
      .summary dt { font-weight: 600; color: #374151; font-size: 14px; }
      .summary dd { margin: 2px 0 10px; color: #111827; font-size: 14px; }
      .cta-row { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 8px; margin: 16px 0 8px; }
      .cta { display: block; text-align: center; border: 1px solid #e5e7eb; padding: 10px 12px; border-radius: 8px; color: #0b1220; font-weight: 600; font-size: 14px; background: #ffffff; }
  .cta.primary { background: #00a8e8; color: #ffffff; border-color: #00a8e8; }
  .cta.primary { background: #00a8e8; color: #ffffff; border-color: #00a8e8; }
      .footer { padding: 16px 24px 24px; text-align: center; color: #6b7280; font-size: 12px; }
      .sig { margin-top: 12px; color: #111827; }
      @media (max-width: 480px) { .inner { padding: 18px; } .cta-row { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <div class="container">
      <table role="presentation" class="card" cellspacing="0" cellpadding="0" border="0" align="center">
        <tr><td class="topbar"></td></tr>
        <tr>
          <td class="inner">
            <div class="header">
              <div class="brand">Vanier Capital</div>
            </div>
            <div class="h1">Thanks, <%= name || 'there' %> — we’ve received your message</div>
            <p class="p">We’re glad you reached out. A team member will get back to you shortly. In the meantime, here’s a quick summary of what you sent us:</p>

            <div class="summary">
              <h3>Your submission</h3>
              <dl>
                <% if (subjectText) { %>
                  <dt>Subject</dt>
                  <dd><%= subjectText %></dd>
                <% } %>
                <% if (messageText) { %>
                  <dt>Message</dt>
                  <dd><pre style="white-space:pre-wrap; word-wrap:break-word; font-family: ui-sans-serif, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; font-size:14px; margin:0; color:#111827"><%= messageText %></pre></dd>
                <% } %>
                <% if (email) { %>
                  <dt>Contact</dt>
                  <dd><%= email %><% if (phone) { %> · <%= phone %><% } %></dd>
                <% } %>
              </dl>
            </div>

            <p class="p muted">While you wait, you might like these resources:</p>
            <div class="cta-row">
              <% if (blogUrl) { %><a class="cta" href="<%= blogUrl %>" target="_blank" rel="noopener">Explore the Blog</a><% } %>
              <% if (caseStudiesUrl) { %><a class="cta" href="<%= caseStudiesUrl %>" target="_blank" rel="noopener">See Case Studies</a><% } %>
              <% if (servicesUrl) { %><a class="cta" href="<%= servicesUrl %>" target="_blank" rel="noopener">Our Services</a><% } %>
              <% if (contactUrl) { %><a class="cta primary" href="<%= contactUrl %>" target="_blank" rel="noopener">Book a Call</a><% } %>
            </div>

            <p class="p sig">The Vanier Capital Team</p>
          </td>
        </tr>
        <tr>
          <td class="footer">
            <% if (siteUrl) { %>
              <a href="<%= siteUrl %>" target="_blank" rel="noopener"><%= siteUrl.replace('https://','').replace('http://','') %></a>
            <% } %>
            <% if (supportEmail) { %>
              · <a href="mailto:<%= supportEmail %>"><%= supportEmail %></a>
            <% } %>
          </td>
        </tr>
      </table>
    </div>
  </body>
  </html>
