<!doctype html>
<html lang="en">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>You're in</title>
    <style>
      body { margin:0; padding:0; background:#f6f8fb; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif; }
      a { color:#0369a1; text-decoration:none; }
      .container { width:100%; padding:28px 0; }
      .card { width:100%; max-width:640px; margin:0 auto; background:#ffffff; border-radius:12px; overflow:hidden; box-shadow:0 4px 18px rgba(0,0,0,0.08); }
      .topbar { height:4px; background:#00a8e8; }
      .inner { padding:32px 32px 28px; }
      .brand { font-size:14px; font-weight:600; letter-spacing:.2px; color:#111827; text-transform:uppercase; }
      .h1 { font-size:22px; line-height:1.3; font-weight:700; margin:10px 0 14px; color:#0b1220; }
      .p { font-size:15px; line-height:1.55; color:#374151; margin:0 0 14px; }
      .muted { color:#6b7280; }
      .cta-row { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:8px; margin:18px 0 6px; }
      .cta { display:block; text-align:center; border:1px solid #e5e7eb; padding:10px 12px; border-radius:8px; font-weight:600; font-size:14px; color:#0b1220; background:#ffffff; }
      .cta.primary { background:#00a8e8; color:#ffffff; border-color:#00a8e8; }
      .footer { padding:16px 28px 28px; text-align:center; font-size:12px; color:#6b7280; }
      .sig { margin:18px 0 0; font-weight:500; color:#111827; }
      @media (max-width:520px){ .inner{ padding:24px 20px 22px; } .cta-row{ grid-template-columns:1fr; } }
    </style>
  </head>
  <body>
    <div class="container">
      <table role="presentation" class="card" cellspacing="0" cellpadding="0" border="0" align="center">
        <tr><td class="topbar"></td></tr>
        <tr>
          <td class="inner">
            <div class="brand">Vanier Capital</div>
            <div class="h1">Welcome<% if (firstName) { %>, <%= firstName %><% } %> — you're in</div>
            <p class="p">Thanks for subscribing. Expect concise, practical real estate insights — no recycled fluff. We send issues that highlight market moves, investment theses, and lessons learned.</p>
            <% if (role || companyName) { %>
              <p class="p">The context you shared helps us tune what we send. Appreciate it.</p>
            <% } %>
            <p class="p muted" style="margin-top:20px;">While you wait for the next issue, you might like:</p>
            <div class="cta-row">
              <% if (blogUrl) { %><a class="cta" href="<%= blogUrl %>" target="_blank" rel="noopener">Latest Blog Posts</a><% } %>
              <% if (caseStudiesUrl) { %><a class="cta" href="<%= caseStudiesUrl %>" target="_blank" rel="noopener">Case Studies</a><% } %>
              <% if (servicesUrl) { %><a class="cta" href="<%= servicesUrl %>" target="_blank" rel="noopener">What We Do</a><% } %>
              <% if (contactUrl) { %><a class="cta primary" href="<%= contactUrl %>" target="_blank" rel="noopener">Ask a Question</a><% } %>
            </div>
            <p class="p" style="font-size:13px; color:#6b7280; margin-top:18px;">You can unsubscribe any time — link is in every email. We aim to be worth the space.</p>
            <p class="p sig">— The Vanier Capital Team</p>
          </td>
        </tr>
        <tr>
          <td class="footer">
            <span>Sent to <%= email %></span>
            <% if (siteUrl) { %>
              · <a href="<%= siteUrl %>" target="_blank" rel="noopener"><%= siteUrl.replace('https://','').replace('http://','') %></a>
            <% } %>
          </td>
        </tr>
      </table>
    </div>
  </body>
</html>
