<!-- views/about.ejs -->
<%# About Us Page for FND Automations %>

<%- include('partials/header', {
    pageTitle: 'About FND Automations',
    pageDescription: 'Learn about the mission, vision, team, and expertise behind FND Automations, your partner in business automation and AI solutions.',
    path: '/about'
}) %>

<!-- Page Header removed per request; 'Our Story' serves as the page title. -->

<!-- Our Story Section -->
<section class="section our-story-section">
    <div class="container">
        <div class="section-header" style="margin-bottom: 2rem;">
            <h2 class="section-title">The Expertise Behind Your Automation</h2>
            <p class="section-description">Built on experience, driven by results.</p>
            <p class="section-description">A mission to modernize business.</p>
        </div>

    <!-- Narrative layout (single column) -->
    <div class="our-story-grid single">
            <div class="our-story-copy">
                <p>
                    FND Automations was founded with a clear mission: to help businesses leverage the power of automation to increase efficiency, reduce costs, and drive growth. What started as a small team of passionate automation experts has grown into a trusted partner for organizations across multiple industries.
                </p>
                <p>
                    We recognized early that businesses needed custom solutions tailored to their workflows — not one-size-fits-all tools. Today, we design pragmatic end‑to‑end systems that combine AI agents, workflow automation, and robust web applications to deliver tangible results.
                </p>
            </div>
        </div>

        <!-- Mission / Vision cards -->
        <div class="mv-grid">
            <div class="mv-card">
                <div class="mv-header">
                    <span class="mv-icon" aria-hidden="true"><i class="fas fa-cogs"></i></span>
                    <h3 class="mv-title">Our Mission</h3>
                </div>
                <p class="mv-text">Empower teams with reliable, well‑designed automation that eliminates busywork and unlocks higher‑value work.</p>
            </div>
            <div class="mv-card">
                <div class="mv-header">
                    <span class="mv-icon" aria-hidden="true"><i class="fas fa-chart-line"></i></span>
                    <h3 class="mv-title">Our Vision</h3>
                </div>
                <p class="mv-text">A world where AI‑assisted operations are accessible to every business, driving smarter decisions and sustainable growth.</p>
            </div>
        </div>

        <!-- At a Glance / Quick Facts -->
        <div class="quick-facts-container">
            <div class="stat-item">
                <div class="stat-number" data-count="<%= aboutStats ? (aboutStats.valuedPartners || 0) : 0 %>" data-suffix="+">0</div>
                <div class="stat-label">Valued Partners</div>
            </div>
            <div class="stat-item">
                <div class="stat-number" data-count="<%= aboutStats ? (aboutStats.projectsCompleted || 0) : 0 %>" data-suffix="+">0</div>
                <div class="stat-label">Projects Completed</div>
            </div>
            <div class="stat-item">
                <div class="stat-number" data-count="<%= aboutStats ? (aboutStats.yearsCombinedExpertise || 0) : 0 %>" data-suffix="+">0</div>
                <div class="stat-label">Years Combined Expertise</div>
            </div>
        </div>

        <% if (visibleClients && visibleClients.length) { %>
    <div class="client-logos about-page-client-logos" style="margin-top:1.75rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:1.75rem;align-items:center;justify-items:center;">
            <% visibleClients.forEach(cl => { %>
        <div class="client-logo">
            <img src="<%= cl.logoUrl %>" alt="<%= cl.name %> logo" onerror="this.onerror=null;this.src='/images/FND_LOGO_SVG_BLACK.svg';">
                </div>
            <% }) %>
        </div>
        <% } %>
    </div>
</section>

