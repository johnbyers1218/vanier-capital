<!-- views/about.ejs -->
<%# About Us Page for Vanier Capital %>

<%- include('partials/header', {
    pageTitle: 'About Vanier Capital',
    pageDescription: 'Learn about the mission, vision, growth story, and team behind Vanier Capital, a multifamily investment firm focused on disciplined acquisitions and operational excellence.',
    path: '/about'
}) %>

<!-- Page Header removed per request; 'Our Story' serves as the page title. -->

<!-- Our Story Section -->
<section class="section our-story-section" style="background-color: #f8fafc; padding: 5rem 0;">
    <div class="container">
        <div class="section-header" style="text-align: center; margin-bottom: 4rem;">
            <h2 class="section-title" style="font-family: 'Merriweather', serif; color: #0b4d3a; font-size: 2.5rem; margin-bottom: 1rem;">The Vanier Capital Story</h2>
            <p class="section-description" style="font-size: 1.25rem; color: #64748b; max-width: 700px; margin: 0 auto;">Built on the principles of disciplined acquisition, operational excellence, and unwavering stewardship.</p>
        </div>

        <div class="story-grid" style="display: grid; grid-template-columns: 1fr; gap: 3rem;">
            <div class="story-card" style="background: white; padding: 2.5rem; border-radius: 0.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border-left: 4px solid #0b4d3a;">
                <h3 style="font-family: 'Merriweather', serif; font-size: 1.5rem; color: #1e293b; margin-bottom: 1rem;">A Foundation of Discipline</h3>
                <p style="color: #475569; line-height: 1.7;">
                    Vanier Capital was founded with a singular mandate: to acquire resilient single-family and multifamily assets and operate them with institutional rigor. In a market often driven by speculation, we chose a different path—focusing on fundamentals, data-driven underwriting, and the creation of durable cash flow.
                </p>
            </div>

            <div class="story-card" style="background: white; padding: 2.5rem; border-radius: 0.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border-left: 4px solid #0b4d3a;">
                <h3 style="font-family: 'Merriweather', serif; font-size: 1.5rem; color: #1e293b; margin-bottom: 1rem;">Operational Excellence</h3>
                <p style="color: #475569; line-height: 1.7;">
                    Our edge lies in our operational execution. By pairing institutional-grade diligence with entrepreneurial agility, we identify markets with strong fundamentals and unlock value through hands-on management. Every decision is grounded in conservative assumptions and a commitment to transparency.
                </p>
            </div>
            
            <div class="story-card" style="background: white; padding: 2.5rem; border-radius: 0.5rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border-left: 4px solid #0b4d3a;">
                <h3 style="font-family: 'Merriweather', serif; font-size: 1.5rem; color: #1e293b; margin-bottom: 1rem;">Rapid, Sustainable Growth</h3>
                <p style="color: #475569; line-height: 1.7;">
                    Since our launch in March 2025, we have rapidly scaled our portfolio to over $1M in assets under management, achieving positive cash flow within our first year. This trajectory is a testament to our thesis: that disciplined underwriting and resident-focused operations are the keys to outperformance.
                </p>
            </div>
        </div>

        <!-- Mission / Vision cards (Refined) -->
        <div class="mv-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; margin-top: 4rem;">
            <div class="mv-card" style="text-align: center; padding: 2rem;">
                <div class="mv-icon" style="font-size: 2.5rem; color: #0b4d3a; margin-bottom: 1.5rem;"><i class="fas fa-landmark"></i></div>
                <h3 class="mv-title" style="font-family: 'Merriweather', serif; font-size: 1.5rem; color: #1e293b; margin-bottom: 1rem;">Our Mission</h3>
                <p class="mv-text" style="color: #64748b;">To acquire and operate single-family and multifamily communities that generate resilient cash flow while elevating the resident experience.</p>
            </div>
            <div class="mv-card" style="text-align: center; padding: 2rem;">
                <div class="mv-icon" style="font-size: 2.5rem; color: #0b4d3a; margin-bottom: 1.5rem;"><i class="fas fa-chart-line"></i></div>
                <h3 class="mv-title" style="font-family: 'Merriweather', serif; font-size: 1.5rem; color: #1e293b; margin-bottom: 1rem;">Our Vision</h3>
                <p class="mv-text" style="color: #64748b;">To build a portfolio recognized for stability, transparency, and long-term value creation.</p>
            </div>
        </div>
    </div>
</section>

