<!-- views/about.ejs -->
<%# About Us Page for FND Automations %>

<%- include('partials/header', {
    pageTitle: 'About FND Automations',
    pageDescription: 'Learn about the mission, vision, team, and expertise behind FND Automations, your partner in business automation and AI solutions.',
    path: '/about'
}) %>

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1>About Us</h1>
        <div class="breadcrumbs">
            <a href="/">Home</a>
            <span class="separator">/</span>
            <span class="current">About Us</span>
        </div>
    </div>
</section>

<!-- Our Story Section -->
<section class="section our-story-section"> <!-- Consider removing class if .section styling sufficient -->
    <div class="container">
        <div class="section-header" style="margin-bottom: 2rem;">
            <h2 class="section-title">Our Story</h2>
            <!-- <div class="our-story-divider"></div> Combined with section title ::after -->
            <h3 style="font-size: 1.5rem; color: var(--light-text); font-weight: 400; margin-top: 2rem;">From vision to reality: The journey of FND Automations</h3>
        </div>

        <div style="max-width: 850px; margin: 0 auto 3rem auto; text-align: left;">
            <p>
                FND Automations was founded with a clear mission: to help businesses leverage the power of automation to increase efficiency, reduce costs, and drive growth. What started as a small team of passionate automation experts has grown into a leading consulting firm serving clients across multiple industries.
            </p>
            <p>
                Our journey began when our founders recognized a critical gap in the market – businesses needed custom automation solutions that addressed their specific challenges, not one-size-fits-all approaches. This insight has guided our development and remains at the core of our philosophy today.
            </p>
        </div>

        <!-- Quick Facts -->
        <div class="grid-container grid-3-col quick-facts-container" style="gap: 1.5rem;"> <!-- Use grid -->
            <div class="quick-fact content-card"> <!-- Reuse card styling -->
                <div class="quick-fact-number" style="font-size: 2.5rem; font-weight: 700; color: var(--primary-color); margin-bottom: 0.5rem;">10+</div>
                <div class="quick-fact-text" style="font-size: 1.1rem; color: var(--light-text);">Clients Served</div>
            </div>
            <div class="quick-fact content-card">
                <div class="quick-fact-number" style="font-size: 2.5rem; font-weight: 700; color: var(--primary-color); margin-bottom: 0.5rem;">15+</div>
                <div class="quick-fact-text" style="font-size: 1.1rem; color: var(--light-text);">Projects Completed</div>
            </div>
            <div class="quick-fact content-card">
                <div class="quick-fact-number" style="font-size: 2.5rem; font-weight: 700; color: var(--primary-color); margin-bottom: 0.5rem;">1+</div> <!-- Update as needed -->
                <div class="quick-fact-text" style="font-size: 1.1rem; color: var(--light-text);">Year of Experience</div>
            </div>
        </div>
    </div>
</section>

