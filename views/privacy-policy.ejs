<section class="legal-hero">
    <div class="container">
        <h1>Privacy Policy</h1>
        <p class="legal-updated">Last Updated: <%= typeof lastUpdated !== 'undefined' ? lastUpdated : 'May 15, 2025' %></p>
    </div>
