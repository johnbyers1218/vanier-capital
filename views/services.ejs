<!-- views/services.ejs -->
<%# Services Page for Vanier Capital %>

<%- include('partials/header', {
    pageTitle: 'Our Services - Investment & Property Operations',
    pageDescription: 'Explore the comprehensive suite of investment and property services offered by Vanier Capital, including acquisition support, underwriting, and asset operations.',
    path: '/services' /* Pass path for active nav highlighting */
}) %>

<!-- Structured Data: Service (generic umbrella) -->
<script type="application/ld+json">
<%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Investment and Property Services",
    "provider": {
        "@type": "Organization",
        "name": "Vanier Capital",
        "url": "https://www.vaniercapital.com/",
        "logo": "https://www.vaniercapital.com/images/logo.svg"
    },
    "areaServed": "Global",
    "serviceType": [
        "Acquisition Strategy",
        "Underwriting & Diligence",
        "Portfolio Management",
        "Data Analytics",
        "Risk Management",
        "Operations Consulting"
    ]
}, null, 2) %>
</script>

<!-- Page Header / Services Hero -->
<section id="services-hero" class="section services-hero-section">
    <div class="container">
        <div class="services-hero">
            <!-- Left: Headline + Copy -->
            <div class="services-hero-copy">
                <p class="eyebrow">Our Services</p>
                <h1 class="hero-title-text">Empowering Your Business</h1>
                <p class="hero-sub-text">We provide disciplined investment and property operations that protect capital, drive cash flow, and compound long‑term value.</p>
                <div class="hero-actions">
                    <a href="#services-grid-details" class="cta-button primary-btn glow-button">Explore Core Services</a>
                    <a href="/contact" class="cta-button secondary-btn">Talk to an Expert</a>
                </div>
            </div>
            <!-- Right: Abstract Visual (decorative) -->
            <div class="services-visual" aria-hidden="true">
                <svg class="services-visual-svg" viewBox="0 0 480 360" xmlns="http://www.w3.org/2000/svg" role="img">
                    <defs>
                        <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#00a8e8" stop-opacity="0.95"/>
                            <stop offset="100%" stop-color="#0077b6" stop-opacity="0.85"/>
                        </linearGradient>
                        <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                            <feGaussianBlur stdDeviation="6" result="coloredBlur"/>
                            <feMerge>
                                <feMergeNode in="coloredBlur"/>
                                <feMergeNode in="SourceGraphic"/>
                            </feMerge>
                        </filter>
                    </defs>
                    <g fill="none" stroke="url(#grad)" stroke-width="1.5" opacity="0.9">
                        <path d="M30,300 C120,200 180,260 260,200 S400,120 450,160" stroke-dasharray="4 6"/>
                        <path d="M20,220 C110,140 180,160 260,120 S390,70 470,110" stroke-dasharray="3 7" opacity="0.6"/>
                        <path d="M10,150 C120,110 180,100 250,80 S380,50 470,60" stroke-dasharray="2 6" opacity="0.45"/>
                    </g>
                    <g fill="#00a8e8" filter="url(#glow)">
                        <circle cx="90" cy="240" r="5"/>
                        <circle cx="170" cy="210" r="4"/>
                        <circle cx="240" cy="170" r="6"/>
                        <circle cx="320" cy="140" r="4"/>
                        <circle cx="400" cy="130" r="5"/>
                    </g>
                </svg>
            </div>
        </div>
    </div>
    <!-- Subtle contrasting band to introduce next section -->
    <div class="section-separator" aria-hidden="true"></div>
    
</section>

<!-- Services Grid Section - Detailed Offerings -->
<section id="services-grid-details" class="section">
    <div class="container">
         <div class="section-header" style="margin-bottom: 1.75rem;">
             <h2 class="section-title">Core Real Estate Services</h2>
             <p class="section-description">We deliver disciplined execution across the full investment lifecycle.</p>
         </div>
        <div class="grid-container grid-3-col services-grid">

            <!-- Service Card 1: Acquisitions -->
            <div id="acquisitions" class="content-card service-card core-service">
                <div class="card-icon icon-wrap"><i class="fas fa-building fa-fw"></i></div>
                <h3 class="service-title">Acquisitions</h3>
                <p class="service-summary">Targeted sourcing, underwriting, and negotiation to secure high‑quality assets in growth markets.</p>
                <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Deal Sourcing</li>
                    <li><i class="fas fa-check-circle"></i> Underwriting & Diligence</li>
                    <li><i class="fas fa-check-circle"></i> Capital Structuring</li>
                </ul>
                <a href="/contact?subject=Acquisitions%20Inquiry" class="card-link learn-more">Learn More →</a>
            </div>

            <!-- Service Card 2: Asset Management -->
            <div id="asset-management" class="content-card service-card core-service">
                <div class="card-icon icon-wrap"><i class="fas fa-chart-line fa-fw"></i></div>
                <h3 class="service-title">Asset Management</h3>
                <p class="service-summary">Performance oversight focused on NOI growth, tenant satisfaction, and long‑term value creation.</p>
                <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Portfolio Reporting</li>
                    <li><i class="fas fa-check-circle"></i> Capital Planning</li>
                    <li><i class="fas fa-check-circle"></i> Revenue Optimization</li>
                </ul>
                <a href="/contact?subject=Asset%20Management%20Inquiry" class="card-link learn-more">Learn More →</a>
            </div>

            <!-- Service Card 3: Development -->
            <div id="development" class="content-card service-card core-service">
                <div class="card-icon icon-wrap"><i class="fas fa-hard-hat fa-fw"></i></div>
                <h3 class="service-title">Development</h3>
                <p class="service-summary">Disciplined planning, entitlement coordination, and execution to bring projects from concept to completion.</p>
                <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Entitlements & Design</li>
                    <li><i class="fas fa-check-circle"></i> Construction Oversight</li>
                    <li><i class="fas fa-check-circle"></i> Delivery & Lease‑Up</li>
                </ul>
                <a href="/contact?subject=Development%20Inquiry" class="card-link learn-more">Learn More →</a>
            </div>

            <!-- Service Card 4: Property Management -->
            <div id="property-management" class="content-card service-card">
                <div class="card-icon icon-wrap alt"><i class="fas fa-key fa-fw"></i></div>
                <h3 class="service-title">Property Management</h3>
                <p class="service-summary">Resident‑focused operations with proactive maintenance and lease management.</p>
                <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Leasing & Renewals</li>
                    <li><i class="fas fa-check-circle"></i> Maintenance Coordination</li>
                    <li><i class="fas fa-check-circle"></i> Vendor Oversight</li>
                </ul>
                <a href="/contact?subject=Property%20Management%20Inquiry" class="card-link learn-more">Learn More →</a>
            </div>

        </div> <!-- /.grid-container -->
    </div> <!-- /.container -->
</section>

<!-- Service Process Section -->
<section id="service-process" class="section service-process-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Our Collaborative Approach</h2>
            <p class="section-description">We follow a transparent, structured process focused on partnership and delivering measurable value.</p>
        </div>
          <!-- Connected steps with subtle line and animated micro-interactions -->
          <div class="process-steps-grid connected">
                 <div class="process-step">
                      <div class="step-number">1</div>
                      <h3>Discovery</h3>
                      <p>Deep dive into your goals, challenges, and current processes via collaborative workshops.</p>
                 </div>
                 <div class="process-step">
                     <div class="step-number">2</div>
                     <h3>Strategy & Design</h3>
                     <p>Identify key operational opportunities, select tools, and design the optimal solution architecture.</p>
                 </div>
                <div class="process-step">
                     <div class="step-number">3</div>
                     <h3>Implementation</h3>
                     <p>Agile development and configuration of the solution with regular check‑ins.</p>
                 </div>
                 <div class="process-step">
                     <div class="step-number">4</div>
                     <h3>Testing & Launch</h3>
                     <p>Rigorous testing, UAT, and a smooth deployment plan.</p>
                 </div>
                <div class="process-step">
                     <div class="step-number">5</div>
                     <h3>Support & Evolution</h3>
                     <p>Training, ongoing support, and continuous improvement roadmaps.</p>
                 </div>
          </div>
    </div>
</section>

<!-- Final CTA Section -->
<section id="cta" class="cta-section cta-strong full-bleed">
     <div class="container">
         <div class="cta-strong-grid">
            <div class="cta-strong-copy">
                <h2 class="cta-strong-title">Let's Design Your Growth Roadmap</h2>
                <p class="cta-strong-description">See how disciplined operations can streamline execution and compound results month after month.</p>
                <div class="cta-actions">
                    <a href="/contact" class="cta-button primary-btn glow-button">Schedule Your Free Consultation</a>
                    <a href="/portfolio" class="cta-button secondary-btn">View Case Studies</a>
                </div>
            </div>
            <div class="cta-social-proof">
                <div class="quote-mark" aria-hidden="true">“</div>
                <blockquote class="testimonial-quote">
                    <p><%= servicesTestimonial && servicesTestimonial.quote ? servicesTestimonial.quote : 'Vanier Capital delivered results beyond our expectations. The impact was immediate and measurable.' %></p>
                </blockquote>
                <div class="testimonial-signature">
                    <% if (servicesTestimonial && servicesTestimonial.clientLogoUrl) { %>
                        <img class="client-logo" src="<%= servicesTestimonial.clientLogoUrl %>" alt="<%= servicesTestimonial.clientName || servicesTestimonial.company || 'Client' %> logo" onerror="this.style.display='none'; if(this.nextElementSibling) this.nextElementSibling.querySelector('.client-badge').style.display='inline'" />
                    <% } else { %>
                        <!-- No logo available, hide img and show fallback badge via inline style below -->
                        <img class="client-logo" src="" alt="" style="display:none" />
                    <% } %>
                    <div class="sig-meta">
                        <% const __badgeLabel = (servicesTestimonial && (servicesTestimonial.clientName || servicesTestimonial.company)) ? (servicesTestimonial.clientName || servicesTestimonial.company) : 'Client'; %>
                        <% const __showBadge = !(servicesTestimonial && servicesTestimonial.clientLogoUrl); %>
                        <% if (__showBadge) { %>
                            <div class="client-badge" aria-label="<%= __badgeLabel %>">
                                <%= __badgeLabel %>
                            </div>
                        <% } %>
                        <div class="author-meta">
                            <%= servicesTestimonial && servicesTestimonial.author ? servicesTestimonial.author : 'Client Leader' %>
                            <% if (servicesTestimonial && (servicesTestimonial.position || servicesTestimonial.company)) { %>
                                — <%= [servicesTestimonial.position, servicesTestimonial.company].filter(Boolean).join(', ') %>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
         </div>
     </div>
</section>

<%- include('partials/footer') %>