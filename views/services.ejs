<!-- views/services.ejs -->
<%# Services Page for FND Automations %>

<%- include('partials/header', {
    pageTitle: 'Our Services - AI & Automation Solutions',
    pageDescription: 'Explore the comprehensive suite of AI and process automation services offered by FND Automations, including custom solutions, integration, and data analytics.',
    path: '/services' /* Pass path for active nav highlighting */
}) %>

<!-- Structured Data: Service (generic umbrella) -->
<script type="application/ld+json">
<%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "AI and Process Automation Services",
    "provider": {
        "@type": "Organization",
        "name": "FND Automations",
        "url": "https://www.fndautomations.com/",
        "logo": "https://www.fndautomations.com/images/FND_LOGO_SVG_BLACK.svg"
    },
    "areaServed": "Global",
    "serviceType": [
        "Process Automation",
        "AI Integration",
        "Custom Software",
        "Data Analytics",
        "Security Automation",
        "Automation Consulting"
    ]
}, null, 2) %>
</script>

<!-- Page Header / Services Hero -->
<section id="services-hero" class="section services-hero-section">
    <div class="container">
        <div class="services-hero">
            <!-- Left: Headline + Copy -->
            <div class="services-hero-copy">
                <p class="eyebrow">Our Services</p>
                <h1 class="hero-title-text">Empowering Your Business</h1>
                <p class="hero-sub-text">We craft automation and AI solutions that streamline operations, reduce manual work, and unlock measurable growth—tailored precisely to your goals and stack.</p>
                <div class="hero-actions">
                    <a href="#services-grid-details" class="cta-button primary-btn glow-button">Explore Core Services</a>
                    <a href="/contact" class="cta-button secondary-btn">Talk to an Expert</a>
                </div>
            </div>
            <!-- Right: Abstract Visual (decorative) -->
            <div class="automation-visual" aria-hidden="true">
                <svg class="automation-visual-svg" viewBox="0 0 480 360" xmlns="http://www.w3.org/2000/svg" role="img">
                    <defs>
                        <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#00a8e8" stop-opacity="0.95"/>
                            <stop offset="100%" stop-color="#0077b6" stop-opacity="0.85"/>
                        </linearGradient>
                        <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                            <feGaussianBlur stdDeviation="6" result="coloredBlur"/>
                            <feMerge>
                                <feMergeNode in="coloredBlur"/>
                                <feMergeNode in="SourceGraphic"/>
                            </feMerge>
                        </filter>
                    </defs>
                    <g fill="none" stroke="url(#grad)" stroke-width="1.5" opacity="0.9">
                        <path d="M30,300 C120,200 180,260 260,200 S400,120 450,160" stroke-dasharray="4 6"/>
                        <path d="M20,220 C110,140 180,160 260,120 S390,70 470,110" stroke-dasharray="3 7" opacity="0.6"/>
                        <path d="M10,150 C120,110 180,100 250,80 S380,50 470,60" stroke-dasharray="2 6" opacity="0.45"/>
                    </g>
                    <g fill="#00a8e8" filter="url(#glow)">
                        <circle cx="90" cy="240" r="5"/>
                        <circle cx="170" cy="210" r="4"/>
                        <circle cx="240" cy="170" r="6"/>
                        <circle cx="320" cy="140" r="4"/>
                        <circle cx="400" cy="130" r="5"/>
                    </g>
                </svg>
            </div>
        </div>
    </div>
    <!-- Subtle contrasting band to introduce next section -->
    <div class="section-separator" aria-hidden="true"></div>
    
</section>

<!-- Services Grid Section - Detailed Offerings -->
<section id="services-grid-details" class="section">
    <div class="container">
         <div class="section-header" style="margin-bottom: 1.75rem;">
             <h2 class="section-title">Core Automation & AI Services</h2>
             <p class="section-description">Our core capabilities are the foundation for faster delivery, lower risk, and scalable results.</p>
         </div>
        <div class="grid-container grid-3-col services-grid">

            <!-- Service Card 1: Process Automation -->
            <div id="process-automation" class="content-card service-card core-service">
                <div class="card-icon icon-wrap"><i class="fas fa-cogs fa-fw"></i></div>
                <h3 class="service-title">Process Automation</h3>
                <p class="service-summary">Eliminate bottlenecks and manual work with intelligent workflows. We connect platforms like Make.com and n8n to orchestrate processes and boost productivity.</p>
                <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Workflow Optimization</li>
                    <li><i class="fas fa-check-circle"></i> Repetitive Task Handling</li>
                    <li><i class="fas fa-check-circle"></i> Error Rate Reduction</li>
                </ul>
                <a href="/contact?subject=Process%20Automation%20Inquiry" class="card-link learn-more">Learn More →</a>
            </div>

            <!-- Service Card 2: AI Integration & Solutions -->
             <div id="ai-integration" class="content-card service-card core-service">
                 <div class="card-icon icon-wrap"><i class="fas fa-brain fa-fw"></i></div>
                 <h3 class="service-title">AI Integration Solutions</h3>
                 <p class="service-summary">Leverage GPT, Claude, and vector search for intelligent document processing, customer support, and decision support.</p>
                 <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Intelligent Document Processing</li>
                    <li><i class="fas fa-check-circle"></i> Custom AI Chatbots</li>
                    <li><i class="fas fa-check-circle"></i> Data‑driven Insights</li>
                </ul>
                 <a href="/contact?subject=AI%20Integration%20Inquiry" class="card-link learn-more">Learn More →</a>
             </div>

            <!-- Service Card 3: Custom Software & Integration -->
             <div id="custom-solutions" class="content-card service-card core-service">
                 <div class="card-icon icon-wrap"><i class="fas fa-laptop-code fa-fw"></i></div>
                 <h3 class="service-title">Custom Software</h3>
                 <p class="service-summary">Bespoke applications and robust integrations that connect CRMs, ERPs, and data platforms into seamless workflows.</p>
                 <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Tailored Application Development</li>
                    <li><i class="fas fa-check-circle"></i> API Integration & Development</li>
                    <li><i class="fas fa-check-circle"></i> Database Design (Airtable, etc.)</li>
                </ul>
                <a href="/contact?subject=Custom%20Solution%20Inquiry" class="card-link learn-more">Learn More →</a>
             </div>

            <!-- Service Card 4: Data Analytics & Reporting -->
            <div class="content-card service-card">
                <div class="card-icon icon-wrap alt"><i class="fas fa-chart-pie fa-fw"></i></div>
                <h3 class="service-title">Data Analytics Solutions</h3>
                <p class="service-summary">Turn raw data into clear dashboards and decision-ready insights with automated reporting.</p>
                 <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Automated Dashboards</li>
                    <li><i class="fas fa-check-circle"></i> Performance Tracking (KPIs)</li>
                    <li><i class="fas fa-check-circle"></i> Trend Analysis & Forecasting</li>
                </ul>
                <a href="/contact?subject=Data%20Analytics%20Inquiry" class="card-link learn-more">Learn More →</a>
            </div>

            <!-- Service Card 5: Cybersecurity Automation (Optional - Keep if offered) -->
            <div class="content-card service-card">
                <div class="card-icon icon-wrap alt"><i class="fas fa-shield-alt fa-fw"></i></div>
                <h3 class="service-title">Security Automation</h3>
                <p class="service-summary">Automate compliance checks, access reviews, and alert routing to elevate your security posture.</p>
                <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Compliance Automation</li>
                    <li><i class="fas fa-check-circle"></i> Security Workflow Orchestration</li>
                    <li><i class="fas fa-check-circle"></i> Automated Alerting</li>
                </ul>
                <a href="/contact?subject=Security%20Automation%20Inquiry" class="card-link learn-more">Learn More →</a>
            </div>

            <!-- Service Card 6: Automation Consulting -->
             <div class="content-card service-card">
                 <div class="card-icon icon-wrap alt"><i class="fas fa-comments fa-fw"></i></div>
                 <h3 class="service-title">Automation Consulting</h3>
                 <p class="service-summary">Pinpoint high‑ROI opportunities and plan phased rollouts with clear milestones and success metrics.</p>
                 <ul class="service-list">
                    <li><i class="fas fa-check-circle"></i> Opportunity Assessment</li>
                    <li><i class="fas fa-check-circle"></i> Technology Stack Evaluation</li>
                    <li><i class="fas fa-check-circle"></i> Phased Rollout Planning</li>
                </ul>
                <a href="/contact?subject=Automation%20Consulting%20Inquiry" class="card-link learn-more">Learn More →</a>
             </div>

        </div> <!-- /.grid-container -->
    </div> <!-- /.container -->
</section>

<!-- Service Process Section -->
<section id="service-process" class="section service-process-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Our Collaborative Approach</h2>
            <p class="section-description">We follow a transparent, structured process focused on partnership and delivering measurable value.</p>
        </div>
          <!-- Connected steps with subtle line and animated micro-interactions -->
          <div class="process-steps-grid connected">
                 <div class="process-step">
                      <div class="step-number">1</div>
                      <h3>Discovery</h3>
                      <p>Deep dive into your goals, challenges, and current processes via collaborative workshops.</p>
                 </div>
                 <div class="process-step">
                     <div class="step-number">2</div>
                     <h3>Strategy & Design</h3>
                     <p>Identify key automation opportunities, select tools, and design the optimal solution architecture.</p>
                 </div>
                <div class="process-step">
                     <div class="step-number">3</div>
                     <h3>Implementation</h3>
                     <p>Agile development and configuration of the solution with regular check‑ins.</p>
                 </div>
                 <div class="process-step">
                     <div class="step-number">4</div>
                     <h3>Testing & Launch</h3>
                     <p>Rigorous testing, UAT, and a smooth deployment plan.</p>
                 </div>
                <div class="process-step">
                     <div class="step-number">5</div>
                     <h3>Support & Evolution</h3>
                     <p>Training, ongoing support, and continuous improvement roadmaps.</p>
                 </div>
          </div>
    </div>
</section>

<!-- Industries Served Section (Could be simplified or removed if redundant) -->
<!-- Kept for now -->
<section id="industries-served" class="section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Industries We Empower</h2>
             <p class="section-description">While adaptable to any sector, we bring deep experience to these industries:</p>
        </div>
        <div class="industries-grid grid-container industries-grid-services">
            <a class="industry-item content-card" href="/projects?industry=Manufacturing" aria-label="Manufacturing case studies">
                <div class="card-icon xl"><i class="fas fa-industry fa-fw"></i></div>
                <h4>Manufacturing</h4>
            </a>
            <a class="industry-item content-card" href="/projects?industry=Retail%20%26%20E-commerce" aria-label="Retail and E-commerce case studies">
                <div class="card-icon xl"><i class="fas fa-cash-register fa-fw"></i></div>
                <h4>Retail & E-commerce</h4>
            </a>
            <a class="industry-item content-card" href="/projects?industry=Healthcare" aria-label="Healthcare case studies">
                <div class="card-icon xl"><i class="fas fa-heartbeat fa-fw"></i></div>
                <h4>Healthcare</h4>
            </a>
            <a class="industry-item content-card" href="/projects?industry=Finance" aria-label="Finance case studies">
                <div class="card-icon xl"><i class="fas fa-university fa-fw"></i></div>
                <h4>Finance</h4>
            </a>
            <a class="industry-item content-card" href="/projects?industry=Professional%20Services" aria-label="Professional Services case studies">
                 <div class="card-icon xl"><i class="fas fa-users fa-fw"></i></div>
                 <h4>Professional Services</h4>
            </a>
            <a class="industry-item content-card" href="/projects?industry=Logistics" aria-label="Logistics case studies">
                <div class="card-icon xl"><i class="fas fa-truck fa-fw"></i></div>
                <h4>Logistics</h4>
            </a>
        </div>
    </div>
</section>

<!-- Final CTA Section -->
<section id="cta" class="cta-section cta-strong full-bleed">
     <div class="container">
         <div class="cta-strong-grid">
            <div class="cta-strong-copy">
                <h2 class="cta-strong-title">Let's Design Your Automation Roadmap</h2>
                <p class="cta-strong-description">See how intelligent automation can streamline your operations and compound results month after month.</p>
                <div class="cta-actions">
                    <a href="/contact" class="cta-button primary-btn glow-button">Schedule Your Free Consultation</a>
                    <a href="/projects" class="cta-button secondary-btn">View Case Studies</a>
                </div>
            </div>
            <div class="cta-social-proof">
                <div class="quote-mark" aria-hidden="true">“</div>
                <blockquote class="testimonial-quote">
                    <p><%= servicesTestimonial && servicesTestimonial.quote ? servicesTestimonial.quote : 'FND Automations delivered results beyond our expectations. The impact was immediate and measurable.' %></p>
                </blockquote>
                <div class="testimonial-signature">
                    <% if (servicesTestimonial && servicesTestimonial.clientLogoUrl) { %>
                        <img class="client-logo" src="<%= servicesTestimonial.clientLogoUrl %>" alt="<%= servicesTestimonial.clientName || servicesTestimonial.company || 'Client' %> logo" onerror="this.style.display='none'; if(this.nextElementSibling) this.nextElementSibling.querySelector('.client-badge').style.display='inline'" />
                    <% } else { %>
                        <!-- No logo available, hide img and show fallback badge via inline style below -->
                        <img class="client-logo" src="" alt="" style="display:none" />
                    <% } %>
                    <div class="sig-meta">
                        <% const __badgeLabel = (servicesTestimonial && (servicesTestimonial.clientName || servicesTestimonial.company)) ? (servicesTestimonial.clientName || servicesTestimonial.company) : 'Client'; %>
                        <% const __showBadge = !(servicesTestimonial && servicesTestimonial.clientLogoUrl); %>
                        <% if (__showBadge) { %>
                            <div class="client-badge" aria-label="<%= __badgeLabel %>">
                                <%= __badgeLabel %>
                            </div>
                        <% } %>
                        <div class="author-meta">
                            <%= servicesTestimonial && servicesTestimonial.author ? servicesTestimonial.author : 'Client Leader' %>
                            <% if (servicesTestimonial && (servicesTestimonial.position || servicesTestimonial.company)) { %>
                                — <%= [servicesTestimonial.position, servicesTestimonial.company].filter(Boolean).join(', ') %>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
         </div>
     </div>
</section>

<%- include('partials/footer') %>