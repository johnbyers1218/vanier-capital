<!-- views/firm-communications-show.ejs -->
<%# Executive Communication — Single Post with PDF Embed %>

<%- include('partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: '/firm',
    isHeroPage: false
}) %>

<!-- Structured Data: Article -->
<script type="application/ld+json">
<%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.title,
    "description": pageDescription,
    "datePublished": post.publishedAt || post.publishedDate || undefined,
    "dateModified": post.updatedAt || post.publishedAt || post.publishedDate || undefined,
    "author": {
        "@type": "Organization",
        "name": "Vanier Capital"
    },
    "publisher": {
        "@type": "Organization",
        "name": "Vanier Capital",
        "logo": {
            "@type": "ImageObject",
            "url": "https://www.vaniercapital.com/images/vanier-logo.svg"
        }
    }
}, null, 2) %>
</script>

<!-- ═══════════════ COMMUNICATION HEADER ═══════════════ -->
<section class="bg-[#f9f8f6] pt-24 md:pt-32 pb-10 md:pb-16 px-6 md:px-16">
    <div class="max-w-3xl mx-auto">
        <!-- Breadcrumb -->
        <nav class="mb-8">
            <a href="/firm/communications" class="font-sans text-xs font-bold text-[#0f2e22] uppercase tracking-[0.15em] hover:underline">&larr; Executive Communications</a>
        </nav>

        <!-- Date -->
        <% if (post.publishedAt || post.publishedDate) { %>
        <p class="font-sans text-sm font-bold text-gray-500 uppercase tracking-widest mb-4"><%= new Date(post.publishedAt || post.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
        <% } %>

        <!-- Title -->
        <h1 class="font-serif text-2xl md:text-3xl lg:text-4xl text-[#0f2e22] font-bold tracking-tight leading-tight"><%= typeof decodeHtmlEntities === 'function' ? decodeHtmlEntities(post.title) : post.title %></h1>

        <!-- Subtitle -->
        <% if (post.subtitle) { %>
        <p class="font-serif text-lg md:text-2xl text-gray-500 italic font-light tracking-wide border-t border-[#0f2e22]/10 pt-6 mt-6"><%= typeof decodeHtmlEntities === 'function' ? decodeHtmlEntities(post.subtitle) : post.subtitle %></p>
        <% } %>
    </div>
</section>

<!-- ═══════════════ COMMUNICATION BODY ═══════════════ -->
<section class="bg-white px-6 md:px-16 py-12 md:py-20">
    <div class="max-w-3xl mx-auto">

        <% if (post.pdfDocumentUrl) { %>
        <!-- PDF Viewer -->
        <div class="mb-10">
            <% const cleanPdfUrl = post.pdfDocumentUrl.includes('/upload/') ? post.pdfDocumentUrl.replace('/upload/', '/upload/fl_attachment:false/') : post.pdfDocumentUrl; %>
            <div class="w-full border border-gray-200 bg-[#f9f8f6] flex justify-center" style="min-height: 900px;">
                <embed src="<%= cleanPdfUrl %>#toolbar=0&navpanes=0&scrollbar=0" type="application/pdf" width="100%" height="900px" class="border-0">
            </div>
            <div class="mt-4 flex items-center gap-4">
                <a href="<%= post.pdfDocumentUrl %>" target="_blank" rel="noopener noreferrer" class="inline-block font-sans text-sm font-bold text-[#0f2e22] uppercase tracking-wider border-b border-[#0f2e22] pb-1 hover:text-slate-600 hover:border-slate-600 transition-colors">Download PDF &rarr;</a>
            </div>
        </div>
        <% } %>

        <% if (post.content) { %>
        <!-- HTML Content -->
        <article class="editorial-content prose prose-lg max-w-none font-sans text-[#1a1a1a] leading-relaxed">
            <%- post.content %>
        </article>
        <style>
            .editorial-content table { display: block; overflow-x: auto; max-width: 100%; }
            .editorial-content img { max-width: 100%; height: auto; border-radius: 0; }
        </style>
        <% } %>

        <% if (!post.pdfDocumentUrl && !post.content) { %>
        <div class="py-16 text-center">
            <p class="font-sans text-lg text-gray-500">Content for this communication is not yet available.</p>
        </div>
        <% } %>

    </div>
</section>

<!-- ═══════════════ BACK NAVIGATION ═══════════════ -->
<section class="bg-[#f9f8f6] border-t border-[#0f2e22]/10 px-6 md:px-16 py-12">
    <div class="max-w-3xl mx-auto text-center">
        <a href="/firm/communications" class="inline-block font-sans text-sm font-bold text-[#0f2e22] uppercase tracking-wider border-b border-[#0f2e22] pb-1 hover:text-slate-600 hover:border-slate-600 transition-colors">&larr; All Executive Communications</a>
    </div>
</section>

<%- include('partials/footer') %>
