<!-- Investment Focus Section (refactored from Services Preview) -->
<section id="investment-focus" class="section section-muted">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title" style="font-family:'Merriweather',serif;">Our Investment Focus</h2>
            <p class="section-description">We specialize in identifying and acquiring high-potential assets in growing markets.</p>
        </div>
        <div class="grid-container grid-3-col">
            <div class="content-card service-card" tabindex="0" role="group" aria-label="Multi-Family Residential" style="padding:0;overflow:hidden;display:flex;flex-direction:column;">
