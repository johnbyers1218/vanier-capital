<!-- views/index.ejs -->
<%# Homepage for Vanier Capital %>

<%- include('partials/header', {
    pageTitle: 'Vanier Capital | Real Estate Investment & Asset Management',
    pageDescription: 'Vanier Capital is a real estate investment firm focused on building long-term, risk-adjusted returns through strategic acquisition and disciplined management of single-family and multifamily assets.',
    path: '/'
}) %>

<!-- Hero Section: full-bleed with static investment image -->
<section id="hero" class="hero-section hero-fullbleed">
    <div class="hero-viewport">
        <!-- Static background image replacing video -->
        <div class="hero-image-background" role="img" aria-label="Aerial view of established residential neighborhood" style="position:absolute;inset:0;background-image:url('/images/hero-real-estate.jpg');background-size:cover;background-position:center;background-repeat:no-repeat;transform:scale(1.04);"></div>
        <!-- Dark gradient overlay for readability -->
        <div class="hero-overlay" style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,30,25,0.60),rgba(10,30,25,0.55) 38%,rgba(255,255,255,0) 90%);mix-blend-mode:normal;"></div>
        <!-- Hero content -->
        <div class="hero-content" style="position:relative;z-index:10;display:flex;align-items:center;justify-content:flex-start;min-height:62vh;padding:4rem 1.25rem 3rem;max-width:1280px;margin:0 auto;">
            <div class="hero-text-block" style="max-width:760px;">
                <div class="eyebrow" style="background:rgba(11,77,58,0.15);border-color:rgba(11,77,58,0.35);color:#0b4d3a;">Long-Term Value</div>
                <h1 class="hero-title hero-title-strong" style="font-family:'Merriweather',serif;font-weight:700;font-size:clamp(2.35rem,4.6vw,3.25rem);line-height:1.12;letter-spacing:-0.015em;color:#ffffff;text-shadow:0 3px 22px rgba(0,0,0,0.35);">Investing in Your Future.</h1>
                <p class="hero-subtitle hero-subtitle-lg" style="margin-top:1.1rem;font-size:clamp(1.15rem,1.65vw,1.45rem);line-height:1.55;font-weight:500;color:#e4efe9;max-width:60ch;">Building generational wealth through strategic investments in resilient single-family and multifamily assets across targeted U.S. growth markets.</p>
                <div class="hero-buttons hero-buttons-spaced" style="margin-top:1.85rem;display:flex;flex-wrap:wrap;gap:.9rem;">
                    <a href="/portfolio" class="cta-button primary-btn" style="background-color:#0b4d3a;--tw-shadow:0 8px 30px -6px rgba(11,77,58,0.55);box-shadow:0 8px 30px -6px rgba(11,77,58,0.55);">Explore Portfolio</a>
                    <a href="/for-rent" class="cta-button secondary-btn" style="background-color:#ffffff;color:#0b4d3a;border:1px solid rgba(11,77,58,0.35);">Rent a Property</a>
                </div>
            </div>
        </div>
        <!-- Curved divider -->
        <div class="hero-divider" aria-hidden="true">
            <svg viewBox="0 0 1440 120" preserveAspectRatio="none" focusable="false" xmlns="http://www.w3.org/2000/svg">
                <path d="M0,80 C360,20 1080,20 1440,80 L1440,120 L0,120 Z" fill="#ffffff" />
            </svg>
        </div>
    </div>
</section>

<!-- Sell Your Home Process -->
<section id="sell-process" class="section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title" style="font-family:'Merriweather',serif;">Sell Your Home Fast</h2>
            <p class="section-description">We make selling your property simple, transparent, and stress-free.</p>
        </div>
        <div class="process-steps" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:2rem;margin-top:3rem;">
            <div class="process-step" style="text-align:center;">
                <div class="step-icon" style="width:64px;height:64px;background:rgba(11,77,58,0.1);color:#0b4d3a;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:1.5rem;">
                    <i class="fas fa-home"></i>
                </div>
                <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;color:#1e293b;">1. Submit Your Property</h3>
                <p style="color:#64748b;line-height:1.6;">Tell us about your home and its condition. It takes less than 5 minutes.</p>
            </div>
            <div class="process-step" style="text-align:center;">
                <div class="step-icon" style="width:64px;height:64px;background:rgba(11,77,58,0.1);color:#0b4d3a;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:1.5rem;">
                    <i class="fas fa-file-invoice-dollar"></i>
                </div>
                <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;color:#1e293b;">2. Get A Cash Offer</h3>
                <p style="color:#64748b;line-height:1.6;">We'll review your property and provide a fair, no-obligation cash offer within 72 hours.</p>
            </div>
            <div class="process-step" style="text-align:center;">
                <div class="step-icon" style="width:64px;height:64px;background:rgba(11,77,58,0.1);color:#0b4d3a;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;font-size:1.5rem;">
                    <i class="fas fa-handshake"></i>
                </div>
                <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;color:#1e293b;">3. Close On Your Terms</h3>
                <p style="color:#64748b;line-height:1.6;">Choose your closing date. We handle the paperwork and make the process seamless.</p>
            </div>
        </div>
        <div style="text-align:center;margin-top:3rem;">
            <a href="/sell-your-home" class="cta-button primary-btn" style="background-color:#0b4d3a;color:white;padding:1rem 2rem;border-radius:0.5rem;font-weight:600;text-decoration:none;display:inline-block;">Get My Cash Offer</a>
        </div>
    </div>
</section>

<!-- Our Process Section -->
<section id="our-process" class="section section-tight-top">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title" style="font-family:'Merriweather',serif;">Our Investment Process</h2>
            <p class="section-description">A disciplined, data-driven approach to identifying high-value properties and maximizing investor returns.</p>
        </div>
        <div class="process-steps" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;margin-top:3rem;">
            <!-- Step 1 -->
            <div class="process-card" style="background:white;border-radius:1rem;overflow:hidden;box-shadow:0 10px 15px -3px rgba(0,0,0,0.1);display:flex;flex-direction:column;">
                <div class="card-image" style="height:200px;background:#f1f5f9;">
                    <img src="/images/Analysis.png" alt="Market Analysis" style="width:100%;height:100%;object-fit:cover;">
                </div>
                <div class="card-content" style="padding:2rem;flex-grow:1;display:flex;flex-direction:column;">
                    <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;color:#1e293b;">1. Market Analysis</h3>
                    <p style="color:#64748b;line-height:1.6;">We evaluate demographic trends, supply-demand dynamics, and off‑market deal flow to surface resilient target submarkets and properties.</p>
                </div>
            </div>
            <!-- Step 2 -->
            <div class="process-card" style="background:white;border-radius:1rem;overflow:hidden;box-shadow:0 10px 15px -3px rgba(0,0,0,0.1);display:flex;flex-direction:column;">
                <div class="card-image" style="height:200px;background:#f1f5f9;">
                    <img src="/images/Underwriting.png" alt="Due Diligence" style="width:100%;height:100%;object-fit:cover;">
                </div>
                <div class="card-content" style="padding:2rem;flex-grow:1;display:flex;flex-direction:column;">
                    <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;color:#1e293b;">2. Due Diligence</h3>
                    <p style="color:#64748b;line-height:1.6;">Comprehensive underwriting, financial modeling, inspections, and capital structuring culminating in disciplined acquisition.</p>
                </div>
            </div>
            <!-- Step 3 -->
            <div class="process-card" style="background:white;border-radius:1rem;overflow:hidden;box-shadow:0 10px 15px -3px rgba(0,0,0,0.1);display:flex;flex-direction:column;">
                <div class="card-image" style="height:200px;background:#f1f5f9;">
                    <img src="/images/Value add.png" alt="Value Add" style="width:100%;height:100%;object-fit:cover;">
                </div>
                <div class="card-content" style="padding:2rem;flex-grow:1;display:flex;flex-direction:column;">
                    <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;color:#1e293b;">3. Value-Add</h3>
                    <p style="color:#64748b;line-height:1.6;">Renovation, repositioning, and professional asset management to drive NOI growth and long‑term appreciation.</p>
                </div>
            </div>
            <!-- Step 4 -->
            <div class="process-card" style="background:white;border-radius:1rem;overflow:hidden;box-shadow:0 10px 15px -3px rgba(0,0,0,0.1);display:flex;flex-direction:column;">
                <div class="card-image" style="height:200px;background:#f1f5f9;">
                    <img src="/images/Disposition.png" alt="Disposition" style="width:100%;height:100%;object-fit:cover;">
                </div>
                <div class="card-content" style="padding:2rem;flex-grow:1;display:flex;flex-direction:column;">
                    <h3 style="font-size:1.25rem;font-weight:700;margin-bottom:0.75rem;color:#1e293b;">4. Disposition</h3>
                    <p style="color:#64748b;line-height:1.6;">Strategic exit timing, optimized sales process, and distribution of realized gains back to investors.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Testimonial Highlight -->
<section id="featured-testimonial" class="section section-muted">
    <div class="container">
        <div class="section-header" style="text-align:center;">
            <h2 class="section-title" style="font-family:'Merriweather',serif;">What Our Renters Say</h2>
            <p class="section-description">We pride ourselves on providing exceptional living experiences for our tenants.</p>
        </div>
        
        <!-- Testimonial Carousel -->
        <div class="testimonial-carousel" style="max-width:800px;margin:0 auto;position:relative;">
            
            <!-- Slides Container -->
            <div class="carousel-slides" style="overflow:hidden;position:relative;border-radius:1rem;background:white;box-shadow:0 10px 30px -5px rgba(0,0,0,0.05);border:1px solid rgba(0,0,0,0.05);">
                <div class="slides-track" style="display:flex;transition:transform 0.5s ease-in-out;">
                    <% if (typeof testimonials !== 'undefined' && testimonials.length > 0) { %>
                        <% testimonials.forEach(t => { %>
                            <div class="slide" style="min-width:100%;padding:3rem 5rem;box-sizing:border-box;text-align:center;">
                                <div style="color:#0b4d3a;font-size:1.5rem;margin-bottom:1.5rem;">
                                    <% for(let i=0; i < (t.rating || 5); i++) { %><i class="fas fa-star"></i><% } %>
                                </div>
                                <blockquote style="font-size:1.25rem;line-height:1.6;color:#334155;font-style:italic;margin-bottom:1.5rem;">
                                    "<%= t.content %>"
                                </blockquote>
                                <cite style="font-weight:700;color:#0b4d3a;font-style:normal;display:block;"><%= t.author %></cite>
                                <% if (t.position || t.company) { %>
                                    <span style="font-size:0.875rem;color:#64748b;"><%= t.position ? t.position : '' %><%= (t.position && t.company) ? ' - ' : '' %><%= t.company ? t.company : '' %></span>
                                <% } %>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <!-- Fallback/Placeholder Slide -->
                        <div class="slide" style="min-width:100%;padding:3rem 5rem;box-sizing:border-box;text-align:center;">
                            <div style="color:#0b4d3a;font-size:1.5rem;margin-bottom:1.5rem;">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            </div>
                            <blockquote style="font-size:1.25rem;line-height:1.6;color:#334155;font-style:italic;margin-bottom:1.5rem;">
                                "The maintenance team is always so quick to respond. I love living here! The apartment was spotless when I moved in and the management team has been incredibly helpful."
                            </blockquote>
                            <cite style="font-weight:700;color:#0b4d3a;font-style:normal;display:block;">Sarah M.</cite>
                            <span style="font-size:0.875rem;color:#64748b;">Resident since 2022</span>
                        </div>
                    <% } %>
                </div>
            </div>

            <!-- Navigation Buttons -->
            <button class="carousel-prev" aria-label="Previous Slide" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);background:white;border:1px solid #e2e8f0;width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 6px -1px rgba(0,0,0,0.1);color:#0b4d3a;transition:all 0.2s;">
                <i class="fas fa-chevron-left"></i>
            </button>
            <button class="carousel-next" aria-label="Next Slide" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:white;border:1px solid #e2e8f0;width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 6px -1px rgba(0,0,0,0.1);color:#0b4d3a;transition:all 0.2s;">
                <i class="fas fa-chevron-right"></i>
            </button>

        </div>
    </div>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const track = document.querySelector('.slides-track');
            const slides = document.querySelectorAll('.slide');
            const nextBtn = document.querySelector('.carousel-next');
            const prevBtn = document.querySelector('.carousel-prev');
            let currentIndex = 0;

            function updateSlide() {
                track.style.transform = `translateX(-${currentIndex * 100}%)`;
            }

            nextBtn.addEventListener('click', () => {
                currentIndex = (currentIndex + 1) % slides.length;
                updateSlide();
            });

            prevBtn.addEventListener('click', () => {
                currentIndex = (currentIndex - 1 + slides.length) % slides.length;
                updateSlide();
            });
            
            // Auto advance every 5 seconds
            setInterval(() => {
                currentIndex = (currentIndex + 1) % slides.length;
                updateSlide();
            }, 5000);
        });
    </script>
</section>

 

<!-- Removed lower Trusted By section to consolidate social proof into the hero -->

