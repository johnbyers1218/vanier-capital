                </div>
                <div style="padding:2rem;flex-grow:1;display:flex;flex-direction:column;">
                    <h3 style="margin-top:0;">Single Family Homes</h3>
                    <p style="flex-grow:1;">Aggregating scattered-site single-family rentals in high-demand neighborhoods to build scalable, high-yield portfolios.</p>
                    <span class="card-link reveal-on-hover" aria-hidden="true" style="margin-top:1rem;display:inline-block;">Growth Strategy</span>
                </div>
            </div>
        </div>
        <div style="text-align:center;margin-top:3rem;">
            <a href="/services" class="cta-button secondary-btn">Explore Our Strategy</a>
        </div>
    </div>
</section>

<!-- Featured Properties Section (refactored from Recent Projects) -->
<section id="featured-properties" class="section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title" style="font-family:'Merriweather',serif;">Properties For Rent</h2>
            <p class="section-description">Find your next home in one of our professionally managed properties.</p>
        </div>
        <div class="grid-container grid-3-col">
            <% if (typeof properties !== 'undefined' && properties.length > 0) { %>
                <% properties.forEach(property => { %>
                    <div class="content-card project-card" role="group" aria-label="<%= property.title %>">
                        <div style="aspect-ratio:16/9;border-radius:.6rem;overflow:hidden;position:relative;background:#e2e8f0;display:flex;align-items:center;justify-content:center;">
                            <img src="<%= property.image %>" alt="<%= property.title %>" style="width:100%;height:100%;object-fit:cover;object-position:center;" onerror="this.src='https://placehold.co/600x400/0b4d3a/ffffff?text=<%= encodeURIComponent(property.title) %>'">
                            <div style="position: absolute; top: 1rem; right: 1rem; background: rgba(11, 77, 58, 0.9); color: white; padding: 0.25rem 0.75rem; border-radius: 0.25rem; font-size: 0.875rem; font-weight: 600;">For Rent</div>
                        </div>
                        <div style="padding: 1.5rem;">
                            <h3 class="client-name" style="margin-top:0;margin-bottom:0.5rem;"><%= property.title %></h3>
                            <div style="font-size:.75rem;text-transform:uppercase;letter-spacing:.08em;font-weight:600;color:var(--color-primary);margin-bottom:0.5rem;"><%= property.address %></div>
                            <p class="success-snippet" style="color:var(--color-text-muted);margin-bottom:1rem;"><%= property.description %></p>
                            <div style="font-weight: 700; color: #0b4d3a; margin-bottom: 1rem;"><%= property.price %></div>
                            <div>
                                <a href="/contact?property=<%= encodeURIComponent(property.title) %>" class="cta-button primary-btn" style="width:100%;text-align:center;display:block;">Inquire Now</a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p>No properties currently available.</p>
            <% } %>
        </div>
        <div style="text-align:center;margin-top:3rem;">
            <a href="/for-rent" class="cta-button secondary-btn">View All Rentals</a>
        </div>
    </div>
</section>

<style>
    /* Homepage Scroll Effect Styles */
    body {
        transition: background-color 0.8s ease, color 0.8s ease;
    }
    
    /* Dark Theme State (triggered by scroll) */
    body.theme-dark-green {
        background-color: #0b4d3a !important;
        color: #ffffff !important;
    }

    /* Text Color Overrides for Dark Theme */
    body.theme-dark-green .section-title { color: #ffffff !important; }
    body.theme-dark-green .section-description { color: #e4efe9 !important; }
    
    /* Testimonial/Card Styling in Dark Theme */
    /* Make testimonial container transparent so text floats */
    body.theme-dark-green .carousel-slides {
        background-color: transparent !important;
        border: none !important;
        box-shadow: none !important;
    }
    body.theme-dark-green .slide blockquote { color: #ffffff !important; font-weight: 300; }
    body.theme-dark-green .slide cite { color: #fbbf24 !important; } /* Gold name */
    body.theme-dark-green .slide span { color: #cbd5e1 !important; }
    body.theme-dark-green .slide .fa-star { color: #fbbf24 !important; } /* Gold stars */

    /* Investment Process Cards - Keep White in Dark Mode */
    body.theme-dark-green .process-card {
        background-color: #ffffff !important;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2) !important;
    }
    body.theme-dark-green .process-card h3 { color: #1e293b !important; }
    body.theme-dark-green .process-card p { color: #64748b !important; }
    body.theme-dark-green .process-card .step-icon {
        background: rgba(11,77,58,0.1) !important;
        color: #0b4d3a !important;
    }

    /* Property Cards in Dark Theme - Keep Light */
    body.theme-dark-green .content-card {
        background-color: #f8fafc !important;
        border: none !important;
    }
    body.theme-dark-green .content-card h3 { color: #1e293b !important; }
    body.theme-dark-green .content-card p { color: #64748b !important; }
    body.theme-dark-green .content-card div { color: #0b4d3a !important; } /* Price/Address */
    
    /* Buttons in Dark Theme */
    body.theme-dark-green .secondary-btn {
        background-color: #ffffff !important;
        border-color: #ffffff !important;
        color: #0b4d3a !important;
    }
    body.theme-dark-green .secondary-btn:hover {
        background-color: #f1f5f9 !important;
    }

    /* Footer in Dark Theme */
    body.theme-dark-green footer {
        background-color: #062c21 !important; /* Darker green for separation */
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Trigger at Testimonials section
        const triggerSection = document.getElementById('featured-testimonial');
        const body = document.body;
        
        if (triggerSection) {
            // Initial check
            checkScroll();
            
            // Scroll listener
            window.addEventListener('scroll', checkScroll);
            
            function checkScroll() {
                const rect = triggerSection.getBoundingClientRect();
                // Trigger when the section is 50% up the viewport
                const triggerPoint = window.innerHeight * 0.5;
                
                if (rect.top <= triggerPoint) {
                    body.classList.add('theme-dark-green');
                } else {
                    body.classList.remove('theme-dark-green');
                }
            }
        }
    });
</script>

