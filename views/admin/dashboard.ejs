<%# views/admin/dashboard.ejs %>
<%# Admin Dashboard - Main landing page after login %>

<%- include('partials/header', { pageTitle }) %> <%# Includes admin header/nav %>

<div class="space-y-8">

        <%# Welcome message using res.locals.adminUser %>
        <% if (isAuthenticated && adminUser) { %>
            <h2 class="text-xl font-light text-[#1a1a1a]">Welcome back, <strong class="font-semibold"><%= adminUser.fullName || adminUser.username %></strong>.</h2>
        <% } else { %>
            <h2 class="text-xl font-light text-[#1a1a1a]">Admin Dashboard</h2>
            <div class="flex items-center gap-2 border border-red-300 bg-red-50 text-red-800 px-3 py-2 text-sm mt-4">
                <i class="fas fa-exclamation-circle"></i>
                <span>Error: User data not found. Please try logging in again.</span>
            </div>
        <% } %>

    <p class="text-gray-600 mb-6 text-base">
            Manage your website content and view recent activity from the sidebar navigation.
        </p>

    <!-- Quick Action Links Section -->
    <section id="widget-quick-actions" class="border border-[#0f2e22]/20 bg-white p-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-xl font-semibold text-[#1a1a1a]">Quick Actions</h2>
                <button id="dashCustomizeBtn" type="button" class="text-sm text-gray-500 hover:text-[#1a1a1a]">Customize</button>
            </div>
            <div id="dashCustomizePanel" class="hidden mb-4 border border-[#0f2e22]/20 p-3 bg-[#f9f8f6]">
                <div class="text-xs text-gray-500 mb-2">Show/Hide widgets</div>
                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2 text-sm" id="dashCustomizeList">
                    <!-- checkboxes injected by script -->
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
                <a id="widget-quick-newpost" href="/admin/blog/new" class="inline-flex items-center justify-center gap-2 bg-[#0f2e22] text-white font-bold py-3 px-6 border border-[#0f2e22] hover:bg-[#1a1a1a] uppercase tracking-widest text-xs transition">
                    <i class="fas fa-plus-circle"></i>
                    <span>New Perspective</span>
                </a>
                <a id="widget-quick-newproperty" href="/admin/properties/new" class="inline-flex items-center justify-center gap-2 bg-[#0f2e22] text-white font-bold py-3 px-6 border border-[#0f2e22] hover:bg-[#1a1a1a] uppercase tracking-widest text-xs transition">
                    <i class="fas fa-plus-circle"></i>
                    <span>New Asset</span>
                </a>
                <% const hasDrafts = typeof draftPostCount === 'number' && draftPostCount > 0; %>
                <a id="widget-quick-viewdrafts" href="<%= hasDrafts ? '/admin/blog?status=draft' : 'javascript:void(0)' %>" class="inline-flex items-center justify-center gap-2 font-bold py-3 px-6 border uppercase tracking-widest text-xs transition <%= hasDrafts ? 'bg-white text-[#0f2e22] border-[#0f2e22] hover:bg-[#f9f8f6]' : 'bg-gray-100 text-gray-400 border-gray-200 cursor-not-allowed opacity-70' %>" aria-disabled="<%= hasDrafts ? 'false' : 'true' %>">
                    <i class="fas fa-pencil-alt"></i>
                    <span>View Drafts</span>
                </a>
            </div>
        </section>

    <!-- Fund Overview / Stats Section -->
                <section id="widget-stats" class="border border-[#0f2e22]/20 bg-white p-6">
            <h2 class="text-xl font-semibold text-[#1a1a1a] mb-4">Fund Overview</h2>
                        <div id="stats" class="grid grid-cols-2 md:grid-cols-5 gap-4">
                                <a href="/admin/settings/kpi" class="border border-[#0f2e22]/20 bg-[#f9f8f6] p-4 text-center hover:bg-gray-50 transition">
                    <h4 class="text-gray-500 text-xs font-bold uppercase tracking-widest mb-2">AUM</h4>
                                        <span class="block text-3xl font-semibold text-[#0f2e22]"><%= (typeof siteSettings !== 'undefined' && siteSettings.aum) ? siteSettings.aum : '$1M+' %></span>
                                </a>
                                <a href="/admin/properties" class="border border-[#0f2e22]/20 bg-[#f9f8f6] p-4 text-center hover:bg-gray-50 transition">
                    <h4 class="text-gray-500 text-xs font-bold uppercase tracking-widest mb-2">Total Assets</h4>
                                        <span class="block text-3xl font-semibold text-[#0f2e22]" data-stat="propertyCount"><%= (typeof propertyCount === 'number') ? propertyCount : '--' %></span>
                                </a>
                                <a href="/admin/settings/kpi" class="border border-[#0f2e22]/20 bg-[#f9f8f6] p-4 text-center hover:bg-gray-50 transition">
                    <h4 class="text-gray-500 text-xs font-bold uppercase tracking-widest mb-2">Avg Portfolio Occupancy</h4>
                                        <span class="block text-3xl font-semibold text-[#0f2e22]"><%= (typeof siteSettings !== 'undefined' && siteSettings.occupancyRate) ? siteSettings.occupancyRate : '96%' %></span>
                                </a>
                                <a href="/admin/applicants" class="border border-[#0f2e22]/20 bg-[#f9f8f6] p-4 text-center hover:bg-gray-50 transition">
                    <h4 class="text-gray-500 text-xs font-bold uppercase tracking-widest mb-2">Vetting Applications</h4>
                                        <span class="block text-3xl font-semibold text-[#0f2e22]" data-stat="applicantCount"><%= (typeof applicantCount === 'number') ? applicantCount : '--' %></span>
                                </a>

                <a href="/admin/inquiries?status=New" class="border border-[#0f2e22]/20 bg-[#f9f8f6] p-4 text-center hover:bg-gray-50 transition">
            <h4 class="text-gray-500 text-xs font-bold uppercase tracking-widest mb-2">New Inquiries</h4>
                    <span class="block text-3xl font-semibold text-[#0f2e22]" data-stat="newInquiries">--</span>
                </a>
            </div>
        </section>

        <!-- Charts Row: compact cards -->
        <section class="grid grid-cols-1 xl:grid-cols-3 gap-6">


            <!-- Content Pipeline Chart (smaller donut) -->
            <div id="widget-chart-pipeline" class="border border-[#0f2e22]/20 bg-white p-4">
                <h2 class="text-lg font-semibold text-[#1a1a1a] mb-2">Content Pipeline</h2>
                <div class="h-40 flex items-center justify-center" id="pipeline-skeleton">
                    <div class="w-28 h-28 bg-gray-100 animate-pulse rounded-full"></div>
                </div>
                <div class="relative max-w-[220px] mx-auto">
                    <div id="pipelineTotal" class="absolute inset-0 flex items-center justify-center text-2xl font-bold text-[#1a1a1a] pointer-events-none hidden">0</div>
                    <canvas id="pipelineChart" class="hidden" height="120"></canvas>
                </div>
            </div>

            <!-- Contact Forms (30d) -->
            <div id="widget-chart-contacts" class="border border-[#0f2e22]/20 bg-white p-4">
                <h2 class="text-lg font-semibold text-[#1a1a1a] mb-2">Contact Forms (30d)</h2>
                <div class="h-40 flex items-center justify-center" id="contacts-skeleton">
                    <div class="w-full h-32 bg-gray-100 animate-pulse"></div>
                </div>
                <canvas id="contactsChart" class="hidden" height="120"></canvas>
            </div>
        </section>

        <!-- Recent Asset Activity (replaces Content Health + Blog Views) -->
        <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Capital Pipeline -->
            <div id="widget-health" class="border border-[#0f2e22]/20 bg-white p-6">
                <h2 class="text-xl font-semibold text-[#1a1a1a] mb-4">Capital Pipeline</h2>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="bg-[#f9f8f6] border-y border-[#0f2e22]/20">
                                <th class="px-4 py-3 text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Metric</th>
                                <th class="px-4 py-3 text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest text-right">Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="bg-white border-b border-gray-200">
                                <td class="px-4 py-3 text-sm text-[#1a1a1a]">Published Perspectives</td>
                                <td class="px-4 py-3 text-sm text-[#1a1a1a] text-right font-semibold" data-stat="blogPostCount"><%= (typeof blogPostCount === 'number') ? blogPostCount : '--' %></td>
                            </tr>
                            <tr class="bg-white border-b border-gray-200">
                                <td class="px-4 py-3 text-sm text-[#1a1a1a]">Draft Perspectives</td>
                                <td class="px-4 py-3 text-sm text-[#1a1a1a] text-right font-semibold" data-stat="draftPostCount"><%= (typeof draftPostCount === 'number') ? draftPostCount : '--' %></td>
                            </tr>
                            <tr class="bg-white border-b border-gray-200">
                                <td class="px-4 py-3 text-sm text-[#1a1a1a]">Perspectives Missing Featured Image</td>
                                <td class="px-4 py-3 text-sm text-[#1a1a1a] text-right font-semibold"><%= (contentHealth && typeof contentHealth.postsMissingFeatured === 'number') ? contentHealth.postsMissingFeatured : 0 %></td>
                            </tr>
                            <tr class="bg-white border-b border-gray-200">
                                <td class="px-4 py-3 text-sm text-[#1a1a1a]">Stale Drafts (30d+)</td>
                                <td class="px-4 py-3 text-sm text-[#1a1a1a] text-right font-semibold"><%= (contentHealth && typeof contentHealth.staleDrafts === 'number') ? contentHealth.staleDrafts : 0 %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- User Roles -->
            <div id="widget-team" class="border border-[#0f2e22]/20 bg-white p-6">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-xl font-semibold text-[#1a1a1a]">Team</h2>
                      <a href="/admin/settings/team" class="text-sm text-[#0f2e22] hover:underline">Manage Team</a>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <% (teamUsers || []).forEach(function(u){
                        var avatarSrc = u.avatarUrl;
                        if (avatarSrc && !/^https?:\/\//i.test(avatarSrc) && avatarSrc.charAt(0) !== '/') {
                            avatarSrc = '/images/' + avatarSrc;
                        }
                    %>
                        <div class="flex items-center gap-3 p-3 border border-[#0f2e22]/20 bg-[#f9f8f6]">
                            <div class="w-10 h-10 overflow-hidden bg-gray-200 flex items-center justify-center text-gray-500">
                                <% if (avatarSrc) { %>
                                    <img src="<%= avatarSrc %>" alt="<%= u.fullName || u.username %>" class="w-full h-full object-cover" />
                                <% } else { %>
                                    <i class="fas fa-user"></i>
                                <% } %>
                            </div>
                            <div class="min-w-0">
                                <div class="font-medium text-[#1a1a1a] truncate"><%= u.fullName || u.username %></div>
                                <div class="text-xs text-gray-500 uppercase tracking-wide"><%= u.role %></div>
                            </div>
                        </div>
                    <% }) %>
                    <% if (!teamUsers || teamUsers.length === 0) { %>
                        <p class="text-gray-500">No team members found.</p>
                    <% } %>
                </div>
            </div>
        </section>

        <!-- Recent Admin Activity -->
        <section id="widget-activity" class="border border-[#0f2e22]/20 bg-white p-6">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-xl font-semibold text-[#1a1a1a]">Recent Admin Activity</h2>
                <div>
                    <div class="inline-flex bg-[#f9f8f6] border border-[#0f2e22]/20 p-1 text-sm" id="activityFilter">
                        <button data-filter="all" class="px-3 py-1.5 bg-[#0f2e22] text-white">All Activity</button>
                        <button data-filter="mine" class="px-3 py-1.5 text-gray-600 hover:text-[#1a1a1a]">My Activity</button>
                    </div>
                </div>
            </div>
            <div class="border border-[#0f2e22]/20 bg-[#f9f8f6] overflow-hidden">
                <% if (typeof recentLogs !== 'undefined' && recentLogs && recentLogs.length > 0) { %>
                    <ul class="divide-y divide-gray-200 max-h-[450px] overflow-y-auto" id="activityList">
                        <% recentLogs.forEach(function(log){
                            var actor = log.adminUser || {};
                            var name = actor.fullName || actor.username || 'System';
                            var avatar = actor.avatarUrl;
                            // Extract a readable detail without username prefixes or query strings
                            var detail = (log.details || '').replace(/User '\w+'.\s*/, '').replace(/\?.*$/, '');
                            var ts = log.createdAt ? new Date(log.createdAt) : null;
                            // Attempt to parse title/id from details to build an edit link where possible
                            var editHref = null;
                            if (/create_blog_post|update_blog_post|delete_blog_post/.test(log.action)) {
                                var m = detail.match(/ID:\s*([0-9a-fA-F]{24})/);
                                if (m) editHref = '/admin/blog/edit/' + m[1];
                            }
                            if (/create_project|update_project|delete_project/.test(log.action)) {
                                var pm = detail.match(/ID:\s*([0-9a-fA-F]{24})/);
                                if (pm) editHref = '/admin/properties/edit/' + pm[1];
                            }
                            // Try to find "Title: ..."
                            var titleMatch = detail.match(/Title:\s*([^,]+)/);
                            var title = titleMatch ? titleMatch[1].trim() : detail || log.action;
                        %>
                        <li class="flex items-start gap-4 px-4 py-3 text-sm bg-white" data-actor="<%= actor.username || '' %>">
                            <div class="w-9 h-9 overflow-hidden bg-gray-200 flex items-center justify-center shrink-0">
                                <% if (avatar) { %>
                                    <img src="<%= avatar %>" alt="<%= name %>" class="w-full h-full object-cover" />
                                <% } else { %>
                                    <i class="fas fa-user text-gray-400"></i>
                                <% } %>
                            </div>
                            <div class="grow min-w-0">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <span class="text-[#0f2e22] font-medium"><%= name %></span>
                                    <span class="text-gray-400">•</span>
                                    <span class="text-[#1a1a1a]"><%= log.action.replace(/_/g,' ').replace(/\b\w/g, s=>s.toUpperCase()) %></span>
                                </div>
                                <div class="mt-1 truncate">
                                    <% if (editHref) { %>
                                        <a href="<%= editHref %>" class="font-semibold hover:underline"><%= title %></a>
                                    <% } else { %>
                                        <span class="font-semibold"><%= title %></span>
                                    <% } %>
                                </div>
                                <% if (log.ipAddress || ts) { %>
                                    <div class="mt-1 text-xs text-gray-500">
                                        <% if (ts) { %>
                                            <i class="far fa-clock"></i>
                                            <time class="activity-time" datetime="<%= ts.toISOString() %>" title="<%= ts.toLocaleString('en-US', { dateStyle: 'full', timeStyle: 'long'}) %>">...</time>
                                        <% } %>
                                        <% if (log.ipAddress) { %> <span class="ml-2"><i class="fas fa-network-wired"></i> <%= log.ipAddress %></span><% } %>
                                    </div>
                                <% } %>
                            </div>
                        </li>
                        <% }) %>
                    </ul>
                <% } else { %>
                    <p class="text-gray-500 text-center p-6">No recent admin activity recorded.</p>
                <% } %>
            </div>
        </section>

</div>

<%- include('partials/footer') %> <%# Includes admin footer %>

<!-- Page scripts: charts + activity filter + lazy stats refresh -->
<script src="https://unpkg.com/chart.js@4.4.1/dist/chart.umd.js"></script>
<script>
    (function(){
        const qs = (s, r=document) => r.querySelector(s);
        const qsa = (s, r=document) => Array.from(r.querySelectorAll(s));
        const statEls = {
            propertyCount: qs('[data-stat="propertyCount"]'),
            blogPostCount: qs('[data-stat="blogPostCount"]'),
            draftPostCount: qs('[data-stat="draftPostCount"]'),
            applicantCount: qs('[data-stat="applicantCount"]')
        };
        // Refresh stats in background to avoid layout shift
        fetch('/admin/dashboard/api/stats').then(r=>r.json()).then(data=>{
            Object.keys(statEls).forEach(k=>{ if (statEls[k] && typeof data[k] !== 'undefined') statEls[k].textContent = data[k]; });
            const newInquiriesEl = qs('[data-stat="newInquiries"]'); if (newInquiriesEl && typeof data.newInquiries !== 'undefined') newInquiriesEl.textContent = data.newInquiries;
        }).catch(()=>{});

        // Activity filter
        const filterWrap = qs('#activityFilter');
        const list = qs('#activityList');
        if (filterWrap && list) {
            filterWrap.addEventListener('click', (e)=>{
                const btn = e.target.closest('button[data-filter]');
                if (!btn) return;
                qsa('button', filterWrap).forEach(b=>{b.classList.remove('bg-[#0f2e22]','text-white');b.classList.add('text-gray-600');});
                btn.classList.add('bg-[#0f2e22]','text-white');
                btn.classList.remove('text-gray-600');
                const mode = btn.getAttribute('data-filter');
            const me = `<%= adminUser ? (adminUser.username) : '' %>`;
                qsa('li[data-actor]', list).forEach(li=>{
                    const actor = li.getAttribute('data-actor');
                    const show = (mode === 'all') || (actor === me);
                    li.style.display = show ? '' : 'none';
                });
            });
        }

        // Charts
    const pipeCtx = qs('#pipelineChart');
        const pipeSkeleton = qs('#pipeline-skeleton');
            fetch('/admin/dashboard/api/posts/pipeline').then(r=>r.json()).then(({published, drafts})=>{
            if (pipeCtx) {
                    pipeCtx.classList.remove('hidden');
                    if (pipeSkeleton) pipeSkeleton.classList.add('hidden');
                    const total = (published||0)+(drafts||0);
                    const totalEl = qs('#pipelineTotal'); if (totalEl) { totalEl.textContent = String(total); totalEl.classList.remove('hidden'); }
                    const chart = new Chart(pipeCtx, {
                    type: 'doughnut',
                    data: { labels: ['Published','Drafts'], datasets: [{ data: [published, drafts], backgroundColor: ['#0f2e22','#9ca3af'] }] },
                    options: { plugins: { legend: { position: 'bottom' } }, cutout: '60%' }
                });
                    // Make legend interactive: navigate on click
                    // Using a simple delegated click on labels rendered in canvas legend isn't trivial; instead, add external legend
                    const legendMap = [
                        { label: 'Published', href: '/admin/blog?status=published' },
                        { label: 'Drafts', href: '/admin/blog?status=draft' }
                    ];
                    // If Chart.js draws internal legend, we can't easily hook it; add small inline links under chart
                    const wrapper = pipeCtx.parentElement;
                    if (wrapper && !wrapper.querySelector('.pipeline-links')) {
                        const div = document.createElement('div');
                        div.className = 'pipeline-links mt-2 text-sm text-center';
                        div.innerHTML = `<a class="text-[#0f2e22] hover:underline mx-2" href="${legendMap[0].href}">Published</a>
                                                         <a class="text-gray-500 hover:underline mx-2" href="${legendMap[1].href}">Drafts</a>`;
                        wrapper.appendChild(div);
                    }
            }
        }).catch(()=>{});

        // Contact forms (30d)
        const contactsCtx = qs('#contactsChart');
        const contactsSkeleton = qs('#contacts-skeleton');
        fetch('/admin/dashboard/api/contacts/last-30-days').then(r=>r.json()).then(({labels, data})=>{
            if (contactsCtx) {
                contactsCtx.classList.remove('hidden');
                if (contactsSkeleton) contactsSkeleton.classList.add('hidden');
                new Chart(contactsCtx, {
                    type: 'line',
                    data: { labels, datasets: [{ label: 'Submissions', data, borderColor: '#0f2e22', backgroundColor: 'rgba(15,46,34,0.1)', tension: 0.3, fill: true, pointRadius: 0 }] },
                    options: { responsive: true, plugins: { legend: { display: false } }, scales: { x: { ticks: { maxTicksLimit: 6 } }, y: { beginAtZero: true, ticks: { precision: 0, stepSize: 1 } } } }
                });
            }
        }).catch(()=>{});

        // Relative timestamps for activity list
        const rel = (date) => {
            const d = (typeof date === 'string') ? new Date(date) : date;
            const diff = Date.now() - d.getTime();
            const sec = Math.floor(diff/1000);
            if (sec < 60) return `${sec}s ago`;
            const min = Math.floor(sec/60);
            if (min < 60) return `${min}m ago`;
            const hr = Math.floor(min/60);
            if (hr < 24) return `${hr}h ago`;
            const day = Math.floor(hr/24);
            if (day < 7) return `${day}d ago`;
            const wk = Math.floor(day/7);
            if (wk < 5) return `${wk}w ago`;
            const mo = Math.floor(day/30);
            if (mo < 12) return `${mo}mo ago`;
            const yr = Math.floor(day/365);
            return `${yr}y ago`;
        };
        const updateTimes = () => {
            qsa('time.activity-time').forEach(t => {
                const dt = t.getAttribute('datetime');
                if (dt) t.textContent = rel(dt);
            });
        };
        updateTimes();
        setInterval(updateTimes, 30000);

        // Simple dashboard customization: show/hide widgets with persistence
    const widgetIds = ['widget-quick-actions','widget-quick-newpost','widget-quick-newproject','widget-quick-viewdrafts','widget-stats','widget-chart-subs','widget-chart-pipeline','widget-chart-contacts','widget-health','widget-team','widget-activity'];
        const storageKey = 'adminDashWidgets:v2';
        const loadPrefs = () => {
            try { return JSON.parse(localStorage.getItem(storageKey)) || {}; } catch { return {}; }
        };
        const savePrefs = (prefs) => {
            try { localStorage.setItem(storageKey, JSON.stringify(prefs)); } catch {}
        };
        const applyPrefs = (prefs) => {
            widgetIds.forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                const visible = prefs[id] !== false; // default true
                el.style.display = visible ? '' : 'none';
            });
        };
        const prefs = loadPrefs();
        applyPrefs(prefs);
        const btn = qs('#dashCustomizeBtn');
        const panel = qs('#dashCustomizePanel');
        const listEl = qs('#dashCustomizeList');
        if (btn && panel && listEl) {
            btn.addEventListener('click', ()=> panel.classList.toggle('hidden'));
            listEl.innerHTML = '';
            widgetIds.forEach(id => {
                const target = document.getElementById(id);
                if (!target) return; // skip missing widget
                const label = id.replace('widget-','').replace(/-/g,' ');
                const wrap = document.createElement('label');
                wrap.className = 'flex items-center gap-2 p-2 hover:bg-[#f9f8f6] cursor-pointer';
                const cb = document.createElement('input');
                cb.type = 'checkbox';
                cb.className = 'accent-[#0f2e22]';
                cb.checked = prefs[id] !== false;
                cb.addEventListener('change', ()=>{
                    prefs[id] = cb.checked;
                    applyPrefs(prefs);
                    savePrefs(prefs);
                });
                const span = document.createElement('span');
                span.textContent = label;
                wrap.appendChild(cb);
                wrap.appendChild(span);
                listEl.appendChild(wrap);
            });
        }
    })();
</script>