<%# views/admin/forbidden.ejs %>
<%# Access Denied Page for Admin Panel %>

<%# Set default title and message if not provided %>
<% const displayTitle = typeof pageTitle !== 'undefined' ? pageTitle : 'Access Denied'; %>
<% const displayMessage = typeof message !== 'undefined' ? message : 'You do not have sufficient permissions to access this resource or perform this action.'; %>

<%- include('partials/header', { pageTitle: displayTitle }) %>

<div class="admin-error-container forbidden-container"> <%# Reuse error container style, add specific class %>
    <div class="error-icon">
        <i class="fas fa-user-lock"></i> <%# Specific icon for forbidden access %>
    </div>

    <h2 class="error-title">Access Denied</h2>

    <p class="error-message-text">
        <%= displayMessage %>
    </p>

    <div class="error-actions">
        <a href="javascript:history.back()" class="cta-button secondary-btn">
             <i class="fas fa-arrow-left"></i> Go Back
        </a>
        <a href="/admin/dashboard" class="cta-button primary-btn">
            <i class="fas fa-tachometer-alt"></i> Go to Dashboard
        </a>
    </div>

     <p class="error-support-info">
         If you believe you should have access, please contact John.
         <br>
         Your current role: <%= adminUser && adminUser.role ? adminUser.role.toUpperCase() : 'Unknown' %>
         <%# Displaying the role helps the user understand why access might be denied %>
     </p>

</div>

<%- include('partials/footer') %>

<%# Add specific styles here or preferably in admin-style.css %>
<style>
    /* Inherit styles from .admin-error-container */
    .forbidden-container .error-icon {
        color: #dc3545; /* Keep consistent error/warning color */
    }
    /* Optional: Slightly different styling if needed */
    .forbidden-container {
         border-color: rgba(255, 193, 7, 0.3); /* Maybe a warning border color instead */
    }
     .forbidden-container .error-icon .fa-user-lock {
         color: #ffc107; /* Warning color for icon */
     }
</style>