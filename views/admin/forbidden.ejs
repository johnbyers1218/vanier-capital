<%# views/admin/forbidden.ejs %>
<%# Access Denied Page for Admin Panel %>

<%# Set default title and message if not provided %>
<% const displayTitle = typeof pageTitle !== 'undefined' ? pageTitle : 'Access Denied'; %>
<% const displayMessage = typeof message !== 'undefined' ? message : 'You do not have sufficient permissions to access this resource or perform this action.'; %>

<%- include('partials/header', { pageTitle: displayTitle }) %>

<div class="max-w-2xl mx-auto my-8 p-8 bg-[#1a1a1a] border border-neutral-700 rounded-lg text-center">
    <div class="text-4xl mb-4 text-red-400">
        <i class="fas fa-user-lock"></i>
    </div>
    <h2 class="text-xl font-semibold text-gray-100 mb-3">Access Denied</h2>
    <p class="text-gray-300 mb-4"><%= displayMessage %></p>
    <div class="flex items-center justify-center gap-3 mt-4">
        <a href="javascript:history.back()" class="inline-flex items-center gap-2 bg-neutral-700 text-gray-100 font-semibold py-2 px-4 rounded-md border border-neutral-600 shadow-sm hover:bg-neutral-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-arrow-left"></i> Go Back
        </a>
        <a href="/admin/dashboard" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-md shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-tachometer-alt"></i> Go to Dashboard
        </a>
    </div>
    <p class="text-sm text-gray-400 mt-4">
        If you believe you should have access, please contact John.<br>
        Your current role: <%= adminUser && adminUser.role ? adminUser.role.toUpperCase() : 'Unknown' %>
    </p>
</div>

<%- include('partials/footer') %>

