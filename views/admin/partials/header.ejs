<%# views/admin/partials/header.ejs %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <%# IMPORTANT: Prevent search engine indexing/following for all admin pages %>
    <meta name="robots" content="noindex, nofollow">


     <!-- ========== FAVICON LINKS START (Same as public or specific admin one) ========== -->
    <link rel="icon" href="/images/vanier-logo.svg" sizes="any">
    <!-- ========== FAVICON LINKS END ========== -->

    <%# Set a dynamic page title, defaulting to "Vanier Capital Admin" %>
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Vanier Capital Admin' %> | Vanier Capital</title>

    <%# Admin Tailwind compiled styles %>

    <%# Link to Font Awesome (used for icons in admin nav/UI) %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" integrity="sha512-MV7K8+y+gLIBoVD59lQIYicR65iaqukzvf/nwasF0nqhPay5w/9lJmVM2hMDcnK1OnMGCdVK+iQrJ7lzPJQd1w==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <%# Admin-specific compiled styles %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin-style.css?v=<%= typeof assetVersion !== 'undefined' ? assetVersion : '' %>">

    <%# Include basic admin layout styles directly here if not using admin-style.css %>
    <%# (Styles from previous examples for .admin-body, .admin-page-wrapper, etc.) %>
    <%# It's generally better to put these in admin-style.css %>
        <style>
            :root { color-scheme: light; }
        </style>
</head>
<body class="bg-[#f9f8f6] text-[#1a1a1a] font-sans">
    <div class="admin-layout min-h-screen flex">
        <%- include('sidebar') %>
        <main class="flex-1 overflow-y-auto bg-[#f9f8f6] text-[#1a1a1a] min-h-screen p-8">
            <header class="flex items-center justify-between gap-4 bg-white px-5 py-4 border-b border-[#0f2e22] mb-6">
                <h1 class="text-2xl md:text-3xl font-bold text-[#1a1a1a] truncate"><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Vanier Capital Admin' %></h1>
                <form action="/admin/search" method="get" class="hidden sm:flex items-center gap-2 flex-1 max-w-xl ml-4 relative">
                    <label for="adminGlobalSearch" class="sr-only">Search</label>
                    <input id="adminGlobalSearch" name="q" type="search" placeholder="Search properties, posts, investors..." class="w-full px-3 py-2 bg-white text-[#1a1a1a] placeholder-gray-400 border border-[#0f2e22]/20 focus:outline-none focus:ring-2 focus:ring-primary" autocomplete="off" />
                    <button type="submit" class="px-3 py-2 bg-[#0f2e22] text-white hover:bg-[#1a1a1a]"><i class="fas fa-search"></i></button>
                    <div id="adminSearchDropdown" class="absolute top-full left-0 mt-1 w-full bg-white border border-[#0f2e22]/20 hidden z-40">
                        <ul class="max-h-72 overflow-auto divide-y divide-gray-200" role="listbox"></ul>
                    </div>
                </form>
                <% if (typeof isAuthenticated !== 'undefined' && isAuthenticated && typeof adminUser !== 'undefined' && adminUser) { %>
                    <span class="text-sm text-gray-600 whitespace-nowrap">Welcome, <strong class="text-[#1a1a1a] font-medium"><%= adminUser.fullName || adminUser.username %></strong></span>
                <% } %>
            </header>

            <%# Toast container (messages will be rendered via JS for non-blocking UX) %>
            <div id="toast-root" class="fixed top-4 right-4 z-50 space-y-2 pointer-events-none"></div>

            <div class="max-w-7xl mx-auto space-y-6">

    <%# Start of page-specific content (comes after this include in other files) %>