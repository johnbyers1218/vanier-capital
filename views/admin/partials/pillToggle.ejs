<%# views/admin/partials/pillToggle.ejs %>
<%# Generic pill toggle group
    Props:
      - basePath: string (e.g., '/admin/clients')
      - paramName: string (e.g., 'status' or 'size')
      - items: Array<{ label: string, value: string }>
      - currentValue: string | undefined
      - preserve: Record<string, string | undefined> (optional) - other query params to keep
%>

<div class="inline-flex items-center gap-2 bg-[#f9f8f6] border border-[#0f2e22]/20 p-1">
  <% (items || []).forEach(function(it){
      var isAll = (it.value === '' || it.value === 'all');
      var isActive = currentValue ? (String(currentValue) === String(it.value)) : isAll;
      var pairs = [];
      var __preserve = (typeof preserve !== 'undefined') ? preserve : null;
      if (__preserve && typeof __preserve === 'object') {
        Object.keys(preserve).forEach(function(key){
          var v = preserve[key];
          if (v !== undefined && v !== null && String(v) !== '') {
            if (!(key === paramName && isAll)) {
              pairs.push(encodeURIComponent(key) + '=' + encodeURIComponent(String(v)));
            }
          }
        });
      }
      if (!isAll) {
        pairs.push(encodeURIComponent(paramName) + '=' + encodeURIComponent(String(it.value)));
      }
      var href = pairs.length ? (basePath + '?' + pairs.join('&')) : basePath;
  %>
    <a href="<%= href %>" class="px-3 py-1.5 text-sm <%= isActive ? 'bg-[#0f2e22] text-white' : 'text-gray-600 hover:text-[#1a1a1a]' %>"><%= it.label %></a>
  <% }) %>
</div>
