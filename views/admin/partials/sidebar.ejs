<!-- views/admin/partials/sidebar.ejs -->
<aside class="w-64 shrink-0 flex flex-col bg-[#0b4d3a] text-gray-100 min-h-screen border-r border-[#093d2d] sticky top-0 h-screen" style="background-color: #0b4d3a;">
  <div class="px-5 py-6 border-b border-[#093d2d]">
    <a href="/admin/dashboard" class="block">
      <img src="/images/vanier-logo.svg" alt="Vanier Capital Logo" class="h-10 w-auto" />
    </a>
  </div>
  <nav class="flex-1 px-2 py-4">
    <ul class="space-y-1">
      <li>
        <% const isDashboard = (typeof path === 'string' && path === '/admin/dashboard'); %>
  <a href="/admin/dashboard" class="flex items-center gap-3 px-3 py-2 rounded-md border border-transparent hover:bg-[#093d2d] hover:text-white <%= isDashboard ? 'bg-[#093d2d] text-white border-[#093d2d]' : 'text-gray-100' %>">
          <i class="fas fa-tachometer-alt w-5 text-center"></i>
          <span>Dashboard</span>
        </a>
      </li>
      <li>
  <% const isProjects = (typeof path === 'string' && path.startsWith('/admin/properties')); %>
  <a href="/admin/properties" class="flex items-center gap-3 px-3 py-2 rounded-md border border-transparent hover:bg-[#093d2d] hover:text-white <%= isProjects ? 'bg-[#093d2d] text-white border-[#093d2d]' : 'text-gray-100' %>">
          <i class="fas fa-project-diagram w-5 text-center"></i>
          <span>Properties</span>
        </a>
      </li>
      <li>
        <% const isTestimonials = (typeof path === 'string' && path.startsWith('/admin/testimonials')); %>
  <a href="/admin/testimonials" class="flex items-center gap-3 px-3 py-2 rounded-md border border-transparent hover:bg-[#093d2d] hover:text-white <%= isTestimonials ? 'bg-[#093d2d] text-white border-[#093d2d]' : 'text-gray-100' %>">
          <i class="fas fa-comment-dots w-5 text-center"></i>
          <span>Reviews</span>
        </a>
      </li>
      <li>
        <% const isBlog = (typeof path === 'string' && path.startsWith('/admin/blog')); %>
  <a href="/admin/blog" class="flex items-center gap-3 px-3 py-2 rounded-md border border-transparent hover:bg-[#093d2d] hover:text-white <%= isBlog ? 'bg-[#093d2d] text-white border-[#093d2d]' : 'text-gray-100' %>">
          <i class="fas fa-newspaper w-5 text-center"></i>
          <span>Articles</span>
        </a>
      </li>
      <li>
        <!-- Intentionally left blank: Site Management links moved below divider -->
      </li>
    </ul>

    <div class="mt-8 border-t border-[#093d2d] pt-4 space-y-2">
      <% const isCategories = (typeof path === 'string' && path.startsWith('/admin/categories')); %>
      <% const isMarkets = (typeof path === 'string' && path.startsWith('/admin/markets')); %>
      <% const isSettings = (typeof path === 'string' && path.startsWith('/admin/settings')); %>
      <% const isInquiries = (typeof path === 'string' && path.startsWith('/admin/inquiries')); %>
      <a href="/admin/inquiries" class="flex items-center gap-3 px-3 py-2 rounded-md border border-transparent hover:bg-[#093d2d] hover:text-white <%= isInquiries ? 'bg-[#093d2d] text-white border-[#093d2d]' : 'text-gray-100' %>">
        <i class="fas fa-inbox w-5 text-center"></i>
        <span>Inquiries</span>
      </a>

      <a href="/admin/categories" class="flex items-center gap-3 px-3 py-2 rounded-md border border-transparent hover:bg-[#093d2d] hover:text-white <%= isCategories ? 'bg-[#093d2d] text-white border-[#093d2d]' : 'text-gray-100' %>">
        <i class="fas fa-tags w-5 text-center"></i>
        <span>Article Categories</span>
      </a>

      <a href="/admin/markets" class="flex items-center gap-3 px-3 py-2 rounded-md border border-transparent hover:bg-[#093d2d] hover:text-white <%= isMarkets ? 'bg-[#093d2d] text-white border-[#093d2d]' : 'text-gray-100' %>">
        <i class="fas fa-globe w-5 text-center"></i>
        <span>Markets</span>
      </a>

      <div class="border-t border-[#093d2d] pt-3 space-y-2">
  <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2 rounded-md border border-transparent hover:bg-[#093d2d] hover:text-white <%= isSettings ? 'bg-[#093d2d] text-white border-[#093d2d]' : 'text-gray-100' %>">
          <i class="fas fa-cogs w-5 text-center"></i>
          <span>Settings</span>
        </a>
      </div>

      <a href="/" target="_blank" class="flex items-center gap-3 px-3 py-2 rounded-md text-gray-300 hover:text-gray-100 hover:bg-[#0b4d3a]">
        <i class="fas fa-external-link-alt w-5 text-center"></i>
        <span>View Public Site</span>
      </a>
    </div>
  </nav>
</aside>
