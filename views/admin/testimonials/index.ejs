<%# views/admin/testimonials/index.ejs %>
<%# Admin page to list and manage testimonials %>

<%- include('../partials/header', { pageTitle: 'Manage Reviews' }) %>

<div class="flex items-start justify-between mb-6">
    <div>
        <h2 class="text-2xl font-bold text-gray-100">Manage Reviews</h2>
        <p class="text-gray-400 mt-1">Review, edit, and curate tenant reviews.</p>
                <%- include('../partials/pillToggle', {
                        basePath: '/admin/testimonials',
                        paramName: 'status',
                        items: [
                            { label: 'All', value: '' },
                            { label: 'Visible', value: 'visible' },
                            { label: 'Hidden', value: 'hidden' }
                        ],
                        currentValue: (status||'')
                }) %>
    </div>
    <div>
        <a href="/admin/testimonials/new" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-lg shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-plus"></i> Add New Review
        </a>
    </div>
</div>

<div>
    <% if (testimonials && testimonials.length > 0) { %>
        <div class="overflow-x-auto md:overflow-x-visible bg-[#1a1a1a] rounded-lg shadow-md border border-neutral-700">
            <table class="min-w-full divide-y divide-neutral-700">
                <thead class="bg-[#1a1a1a]/60">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Author</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Company</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Content (Excerpt)</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Visible</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Featured</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Rating</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-[#1a1a1a] divide-y divide-neutral-700">
                    <% testimonials.forEach(testimonial => { %>
                        <tr class="hover:bg-[#1a1a1a]/70">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-100"><%= testimonial.author %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300"><%= testimonial.company || 'N/A' %></td>
                            <td class="px-6 py-4 whitespace-normal break-words text-sm text-gray-300 max-w-[70ch]">
                                <%= testimonial.contentExcerpt %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                                <% if (testimonial.isVisible) { %>
                                    <i class="fas fa-eye text-green-400" title="Visible"></i>
                                <% } else { %>
                                    <i class="fas fa-eye-slash text-gray-500" title="Hidden"></i>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                                <% if (testimonial.isFeatured) { %>
                                    <i class="fas fa-star text-yellow-400" title="Featured"></i>
                                <% } else { %>
                                    <i class="far fa-star text-gray-500" title="Not Featured"></i>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-center text-gray-300"><%= testimonial.rating ? `${testimonial.rating} / 5` : '-' %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400"><%= testimonial.createdAt ? new Date(testimonial.createdAt).toLocaleDateString() : '-' %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                <div class="inline-flex items-center gap-2">
                                    <a href="/admin/testimonials/edit/<%= testimonial._id %>" class="inline-flex items-center gap-1 bg-neutral-700 text-gray-100 font-semibold py-1.5 px-3 rounded-lg border border-neutral-600 shadow-sm hover:bg-neutral-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" title="Edit Testimonial">
                                        <i class="fas fa-edit"></i>
                                        <span>Edit</span>
                                    </a>
                                    <form action="/admin/testimonials/delete/<%= testimonial._id %>" method="POST" class="delete-form inline-block">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="inline-flex items-center gap-1 bg-danger text-white font-semibold py-1.5 px-3 rounded-lg shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-danger delete-btn" title="Delete Testimonial">
</div>
<script>
// Remove inline delete confirmation, use delegated event listener
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.delete-form .delete-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            if (!confirm('Are you sure you want to delete this testimonial? This action cannot be undone.')) {
                e.preventDefault();
            }
        });
    });
});
</script>
                                            <i class="fas fa-trash-alt"></i>
                                            <span>Delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="bg-[#1a1a1a] rounded-lg shadow-md border border-neutral-700 p-8 text-center">
            <div class="mx-auto mb-3 h-12 w-12 rounded-full bg-neutral-700 flex items-center justify-center text-gray-300">
                <i class="fas fa-comment-dots"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-100">No Testimonials Yet</h3>
            <p class="text-gray-400 mt-1">Add your first testimonial to get started.</p>
            <a href="/admin/testimonials/new" class="mt-4 inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-lg shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                <i class="fas fa-plus"></i> Add First Testimonial
            </a>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>