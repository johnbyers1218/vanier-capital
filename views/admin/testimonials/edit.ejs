<%# views/admin/testimonials/edit.ejs %>
<%# Form for adding or editing a testimonial %>

<%- include('../partials/header', { pageTitle: editing ? 'Edit Review' : 'Add New Review' }) %>

<div class="max-w-4xl mx-auto">
    <style>
        /* Toggle styles are centralized in admin-style.css */
    </style>
    <% if (typeof errorMessages !== 'undefined' && errorMessages && errorMessages.length > 0) { %>
        <div class="rounded-lg border border-red-700/40 bg-red-900/20 text-red-200 p-4 mb-4" role="alert" aria-live="polite">
            <p class="font-semibold mb-2">Please correct the following errors:</p>
            <ul class="list-disc pl-5 space-y-1">
                <% errorMessages.forEach(err => { %>
                    <li><%= err.msg %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form action="<%= editing ? '/admin/testimonials/edit/' + testimonial._id : '/admin/testimonials' %>" method="POST" id="testimonialForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="bg-[#1a1a1a] border border-neutral-700 rounded-lg shadow-sm p-5 space-y-4">
            <div>
                <label for="author" class="block text-sm text-gray-300 mb-1">Author Name <span class="text-red-400">*</span></label>
                <input id="author" name="author" type="text" required maxlength="100" value="<%= testimonial && testimonial.author ? testimonial.author : '' %>" class="w-full bg-[#111] border border-neutral-700 rounded-md px-3 py-2 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary">
            </div>

            <div>
                <label for="content" class="block text-sm text-gray-300 mb-1">Review Content <span class="text-red-400">*</span></label>
                <textarea id="content" name="content" rows="7" required maxlength="2000" class="w-full bg-[#111] border border-neutral-700 rounded-md px-3 py-2 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"><%= testimonial && testimonial.content ? testimonial.content : '' %></textarea>
                <p class="text-xs text-gray-400 mt-1">Max 2000 characters. Plain text only.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="company" class="block text-sm text-gray-300 mb-1">Property Name (Optional)</label>
                    <input id="company" name="company" type="text" maxlength="100" value="<%= testimonial && testimonial.company ? testimonial.company : '' %>" class="w-full bg-[#111] border border-neutral-700 rounded-md px-3 py-2 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary">
                </div>
                <div>
                    <label for="position" class="block text-sm text-gray-300 mb-1">Unit Number (Optional)</label>
                    <input id="position" name="position" type="text" maxlength="100" value="<%= testimonial && testimonial.position ? testimonial.position : '' %>" class="w-full bg-[#111] border border-neutral-700 rounded-md px-3 py-2 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="property" class="block text-sm text-gray-300 mb-1">Linked Property (Optional)</label>
                    <select id="property" name="property" class="w-full bg-[#111] border border-neutral-700 rounded-md px-3 py-2 text-gray-100 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary">
                        <option value="">— Select property —</option>
                        <% if (Array.isArray(properties)) { properties.forEach(p => { %>
                            <option value="<%= p._id %>" <%= (testimonial && testimonial.property && String(testimonial.property) === String(p._id)) ? 'selected' : '' %>><%= p.title %></option>
                        <% }) } %>
                    </select>
                    <p class="text-xs text-gray-400 mt-1">If set, the card can include a "View Property" link.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="rating" class="block text-sm text-gray-300 mb-1">Rating (Optional)</label>
                    <select id="rating" name="rating" class="w-full bg-[#111] border border-neutral-700 rounded-md px-3 py-2 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="" <%= (!testimonial || !testimonial.rating) ? 'selected' : '' %>>-- No Rating --</option>
                        <% for (let i = 1; i <= 5; i++) { %>
                            <option value="<%= i %>" <%= (testimonial && testimonial.rating == i) ? 'selected' : '' %>><%= i %> Star<%= i > 1 ? 's' : '' %></option>
                        <% } %>
                    </select>
                    <p class="text-xs text-gray-400 mt-1">Select a rating from 1 to 5 stars.</p>
                </div>

                <div class="space-y-3">
                    <div class="flex items-center gap-3">
                        <label class="switch">
                            <input type="checkbox" id="isFeatured" name="isFeatured" value="true" <%= (testimonial && testimonial.isFeatured) ? 'checked' : '' %>>
                            <span class="slider"></span>
                        </label>
                        <label for="isFeatured" class="text-sm text-gray-300">Feature this testimonial?</label>
                    </div>
                    <p class="text-xs text-gray-400">Mark as featured for potential homepage display.</p>

                    <div class="flex items-center gap-3">
                        <label class="switch">
                            <input type="checkbox" id="isVisible" name="isVisible" value="true" <%= (testimonial && testimonial.isVisible !== undefined) ? (testimonial.isVisible ? 'checked' : '') : 'checked' %>>
                            <span class="slider"></span>
                        </label>
                        <label for="isVisible" class="text-sm text-gray-300">Make this testimonial visible?</label>
                    </div>
                    <p class="text-xs text-gray-400">Uncheck to hide from the public site without deleting.</p>
                </div>
            </div>
        </div>

            <div class="flex items-center gap-2 mt-4">
                <button type="submit" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-lg shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                    <i class="fas fa-save"></i>
                    <span><%= editing ? 'Update Testimonial' : 'Save New Testimonial' %></span>
                </button>
                <a href="/admin/testimonials" class="inline-flex items-center gap-2 border border-neutral-600 text-gray-200 font-semibold py-2 px-4 rounded-lg shadow-sm hover:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                    <i class="fas fa-times"></i>
                    <span>Cancel</span>
                </a>
            </div>
    </form>
</div>

<%- include('../partials/footer') %>