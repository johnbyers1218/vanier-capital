<%# views/admin/projects/index.ejs %>
<%# Admin page to list and manage projects %>

<%- include('../partials/header', { pageTitle: 'Manage Projects' }) %>

<div class="flex items-start justify-between mb-6">
    <div>
        <h2 class="text-2xl font-bold text-gray-100">Manage Projects</h2>
        <p class="text-gray-400 mt-1">Create, edit, and manage your project portfolio.</p>
                <%- include('../partials/pillToggle', {
                        basePath: '/admin/projects',
                        paramName: 'status',
                        items: [
                            { label: 'All', value: '' },
                            { label: 'Public', value: 'public' },
                            { label: 'Hidden', value: 'hidden' }
                        ],
                        currentValue: (status||'')
                }) %>
    </div>
    <div>
        <a href="/admin/projects/new" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-lg shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-plus"></i> Add New Project
        </a>
    </div>
</div>

<div>
    <% if (projects && projects.length > 0) { %>
        <div class="overflow-x-auto bg-gray-800 rounded-lg shadow-md border border-gray-700">
            <table class="min-w-full divide-y divide-gray-700">
                <thead class="bg-gray-800/60">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Title</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Industries</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Featured</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Last Updated</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-gray-800 divide-y divide-gray-700">
                    <% projects.forEach(project => { %>
                        <tr class="hover:bg-gray-800/70">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-100"><%= project.title %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
                                <% if (Array.isArray(project.industries) && project.industries.length) { %>
                                    <%= project.industries.map(i => (i.name || i)).join(', ') %>
                                <% } else { %>
                                    <span class="text-gray-500">—</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                                <% if (project.isFeatured) { %>
                                    <i class="fas fa-check-circle text-green-400" title="Featured"></i>
                                <% } else { %>
                                    <i class="fas fa-times-circle text-gray-500" title="Not Featured"></i>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400"><%= project.createdAt ? new Date(project.createdAt).toLocaleDateString() : '-' %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400"><%= project.updatedAt ? new Date(project.updatedAt).toLocaleDateString() : '-' %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                <div class="inline-flex items-center gap-2">
                                    <a href="/admin/projects/edit/<%= project._id %>" class="inline-flex items-center gap-1 bg-gray-700 text-gray-100 font-semibold py-1.5 px-3 rounded-lg border border-gray-600 shadow-sm hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" title="Edit Project">
                                        <i class="fas fa-edit"></i>
                                        <span>Edit</span>
                                    </a>
                                    <form action="/admin/projects/delete/<%= project._id %>" method="POST" class="delete-form inline-block">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="inline-flex items-center gap-1 bg-danger text-white font-semibold py-1.5 px-3 rounded-lg shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-danger delete-btn" title="Delete Project">
</div>
<script>
// Remove inline delete confirmation, use delegated event listener
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.delete-form .delete-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            if (!confirm('Are you sure you want to delete this project? This action cannot be undone.')) {
                e.preventDefault();
            }
        });
    });
});
</script>
                                            <i class="fas fa-trash-alt"></i>
                                            <span>Delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="bg-gray-800 rounded-lg shadow-md border border-gray-700 p-8 text-center">
            <div class="mx-auto mb-3 h-12 w-12 rounded-full bg-gray-700 flex items-center justify-center text-gray-300">
                <i class="fas fa-project-diagram"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-100">No Projects Yet</h3>
            <p class="text-gray-400 mt-1">Start your portfolio by adding your first project.</p>
            <a href="/admin/projects/new" class="mt-4 inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-lg shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                <i class="fas fa-plus"></i> Add First Project
            </a>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>