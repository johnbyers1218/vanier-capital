<%# views/admin/projects/edit.ejs %>
<%# Form for adding or editing a project with Rich Text Editor & Cover Image Upload %>

<%- include('../partials/header', { pageTitle: editing ? 'Edit Project' : 'Add New Project' }) %>

<div class="admin-form-container">
    <h2><%= editing ? 'Edit Project' : 'Add New Project' %></h2>

    <div class="info-panel" style="margin: 12px 0 20px 0; padding: 12px 14px; border: 1px solid #374151; border-radius: 8px; background: #111827; color: #d1d5db;">
        <strong style="color:#93c5fd;">Tip:</strong> Blog Categories organize blog posts. Projects use curated Industries and Service Types instead. Pick one or more Industries the project belongs to, and Service Types delivered. There's no legacy "project category" anymore.
    </div>

    <% const __errorMap = (typeof errorMap !== 'undefined' && errorMap) ? errorMap : {}; %>

    <% if (typeof errorMessages !== 'undefined' && errorMessages && errorMessages.length > 0) { %>
        <div class="error-summary" role="alert" aria-live="assertive">
            <div class="error-summary-icon" aria-hidden="true"><i class="fas fa-exclamation-triangle"></i></div>
            <div>
                <p class="error-summary-title">Please correct the following errors:</p>
                <ul class="error-summary-list">
                    <% errorMessages.forEach(err => { %>
                        <li><strong><%= err.param %>:</strong> <%= err.msg %></li>
                    <% }) %>
                </ul>
            </div>
        </div>
    <% } %>

    <form action="<%= editing ? '/admin/projects/edit/' + project._id : '/admin/projects' %>" method="POST" class="admin-form" id="projectForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group <%= __errorMap.title ? 'has-error' : '' %>">
            <label for="title" class="<%= __errorMap.title ? 'label-error' : '' %>">Project Title <span style="color: #dc3545;">*</span></label>
            <input type="text" id="title" name="title" value="<%= project && project.title ? project.title : '' %>" required maxlength="150" class="<%= __errorMap.title ? 'input-error' : '' %>">
            <% if (__errorMap.title) { %><div class="field-error"><%= __errorMap.title[0] %></div><% } %>
        </div>

    <div class="form-group <%= __errorMap.slug ? 'has-error' : '' %>">
            <label for="slug">URL Slug</label>
            <input type="text" id="slug" name="slug" value="<%= project && project.slug ? project.slug : '' %>" maxlength="200" pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$" placeholder="auto-generated-if-blank-from-title" class="<%= __errorMap.slug ? 'input-error' : '' %>">
            <small>URL-friendly ID. Leave blank to auto-generate from title. Unique, lowercase, numbers, hyphens only.</small>
            <% if (__errorMap.slug) { %><div class="field-error"><%= __errorMap.slug[0] %></div><% } %>
        </div>

        <%# ****** COVER IMAGE UPLOAD SECTION FOR PROJECTS ****** %>
        <div class="form-group">
            <label for="projectCoverImageFile">Upload Cover Image (for Main Project Image)</label>
            <input type="file" id="projectCoverImageFile" name="projectCoverImageFile" accept="image/jpeg,image/png,image/gif,image/webp">
            <small>This will populate the 'Main Project Image URL' below. Max 5MB. Overwrites existing URL if a new file is uploaded.</small>
            <div id="projectCoverImagePreviewContainer" style="margin-top: 10px;">
                <% if (project && project.image) { %>
                    <img src="<%= project.image %>" alt="Current Project Image" style="max-width: 200px; max-height: 200px; border-radius: 4px; display: block;">
                    <button type="button" id="removeProjectCoverImageBtn" class="delete-btn" style="font-size: 0.8em; padding: 4px 8px; margin-top: 5px;">Remove Image</button>
                <% } %>
            </div>
            <div id="projectCoverImageUploadStatus" style="font-size: 0.85em; margin-top: 5px;"></div>
        </div>

    <div class="form-group <%= __errorMap.image ? 'has-error' : '' %>">
            <label for="image">Main Project Image URL (Thumbnail)</label>
            <input type="url" id="image" name="image" value="<%= project && project.image ? project.image : '' %>" placeholder="Auto-populated by upload or enter URL manually" class="<%= __errorMap.image ? 'input-error' : '' %>">
            <small>Main image shown in listings. Can be auto-filled by "Upload Cover Image" above.</small>
            <% if (__errorMap.image) { %><div class="field-error"><%= __errorMap.image[0] %></div><% } %>
        </div>
        <%# ****** END COVER IMAGE SECTION ****** %>

    <div class="form-group <%= __errorMap.description ? 'has-error' : '' %>">
            <label for="project-description-editor">Full Description / Case Study <span style="color: #dc3545;">*</span></label>
            <textarea id="project-description-editor" name="description" class="richtext-editor <%= __errorMap.description ? 'input-error' : '' %>" style="visibility: hidden; min-height: 400px;" required minlength="50"><%= project && project.description ? project.description : '' %></textarea>
            <small>Detailed project information. Use the editor for formatting. <a href="https://github.com/johnbyers1218/fnd-automations-webapp/blob/main/AUTHORING_GUIDE.md" target="_blank" rel="noopener noreferrer">Authoring Guide</a></small>
            <% if (__errorMap.description) { %><div class="field-error"><%= __errorMap.description[0] %></div><% } %>
        </div>

        <div class="form-group <%= __errorMap.excerpt ? 'has-error' : '' %>">
            <label for="projectExcerpt">Excerpt / Summary <span style="color:#dc3545">*</span></label>
            <textarea id="projectExcerpt" name="excerpt" rows="3" maxlength="250" required oninput="document.getElementById('projectExcerptCounter').textContent = this.value.length + '/250'"><%= project && project.excerpt ? project.excerpt : '' %></textarea>
            <div class="muted" style="display:flex;justify-content:space-between;">
                <small>Appears on cards and previews (max 250 chars).</small>
                <small id="projectExcerptCounter"><%= project && project.excerpt ? project.excerpt.length : 0 %>/250</small>
            </div>
            <% if (__errorMap.excerpt) { %><div class="field-error"><%= __errorMap.excerpt[0] %></div><% } %>
        </div>

        <div class="form-group">
            <label for="technologiesUsed">Technologies Used (comma-separated)</label>
            <input type="text" id="technologiesUsed" name="technologiesUsed" value="<%= project && project.technologiesUsed ? project.technologiesUsed : '' %>" placeholder="e.g., node.js, express, mongodb">
            <small>Enter a comma-separated list. Example: node.js, express, mongodb</small>
        </div>

        <% const __projectDateISO = (project && project.projectDate) ? new Date(project.projectDate).toISOString().split('T')[0] : ''; %>
        <div class="form-group">
            <label for="projectDateDisplay">Completion Date</label>
            <input type="hidden" id="projectDate" name="projectDate" value="<%= __projectDateISO %>">
            <input type="text" id="projectDateDisplay" placeholder="Select a date" value="<%= __projectDateISO %>" readonly style="cursor:pointer; background:#1f2937; color:#e5e7eb;">
            <small>The date the project was substantially completed.</small>
        </div>

        <div class="form-group">
            <label for="industries">Industries (curated)</label>
            <select id="industries" name="industries" multiple class="form-control">
                <% if (typeof industries !== 'undefined' && industries && industries.length) { %>
                    <% industries.forEach(function(ind) { %>
                        <option value="<%= ind._id %>" <%= (project && Array.isArray(project.industries) && project.industries.includes(String(ind._id))) ? 'selected' : '' %>><%= ind.name %></option>
                    <% }) %>
                <% } %>
            </select>
            <small>Select one or more industries for this project.</small>
        </div>
        <div class="form-group">
            <label for="serviceTypes">Service Types (curated)</label>
            <select id="serviceTypes" name="serviceTypes" multiple class="form-control">
                <% if (typeof services !== 'undefined' && services && services.length) { %>
                    <% services.forEach(function(svc) { %>
                        <option value="<%= svc._id %>" <%= (project && Array.isArray(project.serviceTypes) && project.serviceTypes.includes(String(svc._id))) ? 'selected' : '' %>><%= svc.name %></option>
                    <% }) %>
                <% } %>
            </select>
            <small>Select one or more service types delivered.</small>
        </div>
        

    <div class="form-group <%= (__errorMap.image || __errorMap.link) ? 'has-error' : '' %>">
            <label for="link">External Project Link (Optional)</label>
            <input type="url" id="link" name="link" value="<%= project && project.link ? project.link : '' %>" placeholder="https://live-project-example.com" class="<%= __errorMap.link ? 'input-error' : '' %>">
            <small>Link to a live version or client site if applicable.</small>
            <% if (__errorMap.link) { %><div class="field-error"><%= __errorMap.link[0] %></div><% } %>
        </div>

        <!-- Client Selection (Optional Association) -->
    <div class="form-group <%= __errorMap.client ? 'has-error' : '' %>">
            <label for="client">Client <span style="color:#6b7280; font-weight: normal;">(optional)</span></label>
            <select id="client" name="client" class="form-control <%= __errorMap.client ? 'input-error' : '' %>">
                <option value="">No client / Confidential</option>
                <% if (clients && clients.length > 0) { %>
                    <% clients.forEach(client => { %>
                        <option value="<%= client._id %>" 
                            <%= (project && project.client && (project.client._id || project.client) == client._id) ? 'selected' : '' %>>
                            <%= client.name %>
                        </option>
                    <% }); %>
                <% } %>
            </select>
            <small>You can leave this blank for anonymous or internal projects. If needed, <a href="/admin/clients/new" target="_blank">add a new client</a>.</small>
            <% if (__errorMap.client) { %><div class="field-error"><%= __errorMap.client[0] %></div><% } %>
        </div>

        <!-- Success Snippet -->
        <div class="form-group">
            <label for="successSnippet">Success Snippet</label>
            <textarea id="successSnippet" name="successSnippet" class="form-control" rows="3" placeholder="Brief description of project success or impact..."><%= project.successSnippet || '' %></textarea>
            <small>Optional: A brief description of the project's success or impact (max 500 characters).</small>
        </div>

        <!-- Services -->
        <div class="form-group">
            <label for="services">Services (comma-separated)</label>
            <input type="text" id="services" name="services" value="<%= project && project.services ? project.services : '' %>" placeholder="e.g., workflow automation, rpa, data integration">
            <small>Shown in the Project Snapshot. Example: workflow automation, rpa, data integration</small>
        </div>

        <!-- Key Results -->
        <div class="form-group">
            <label>Key Results</label>
            <div id="keyResultsContainer">
                <% if (project && project.keyResults && project.keyResults.length) { %>
                    <% project.keyResults.forEach(function(kr, idx) { %>
                        <div class="kr-row" style="display:flex; gap:8px; margin-bottom:8px; align-items:center;">
                            <input type="text" name="keyResultsValues" value="<%= kr.value %>" placeholder="Value (e.g., 3x)" style="flex:0 0 140px;">
                            <input type="text" name="keyResultsLabels" value="<%= kr.label %>" placeholder="Label (e.g., Productivity)" style="flex:1;">
                            <button type="button" class="delete-btn" onclick="this.parentElement.remove()">Remove</button>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="kr-row" style="display:flex; gap:8px; margin-bottom:8px; align-items:center;">
                        <input type="text" name="keyResultsValues" placeholder="Value (e.g., 3x)" style="flex:0 0 140px;">
                        <input type="text" name="keyResultsLabels" placeholder="Label (e.g., Productivity)" style="flex:1;">
                        <button type="button" class="delete-btn" onclick="this.parentElement.remove()">Remove</button>
                    </div>
                <% } %>
            </div>
            <button type="button" class="admin-btn admin-btn--ghost" id="addKeyResultBtn" style="margin-top:6px;">Add Result</button>
            <small>Displayed as "Measurable Impact" on the public page.</small>
        </div>

        <!-- Toggles -->
    <div class="form-group <%= __errorMap.isFeatured ? 'has-error' : '' %>">
            <div class="checkbox-inline">
                <input type="checkbox" id="isFeatured" name="isFeatured" <%= project.isFeatured ? 'checked' : '' %> class="<%= __errorMap.isFeatured ? 'input-error' : '' %>">
                <label for="isFeatured" class="<%= __errorMap.isFeatured ? 'label-error' : '' %>">Feature this Project</label>
            </div>
            <% if (__errorMap.isFeatured) { %><div class="field-error"><%= __errorMap.isFeatured[0] %></div><% } %>
        </div>
        <div class="form-group <%= __errorMap.isPubliclyVisible ? 'has-error' : '' %>">
            <div class="checkbox-inline">
                <input type="checkbox" id="isPubliclyVisible" name="isPubliclyVisible" <%= project.isPubliclyVisible ? 'checked' : '' %> class="<%= __errorMap.isPubliclyVisible ? 'input-error' : '' %>">
                <label for="isPubliclyVisible" class="<%= __errorMap.isPubliclyVisible ? 'label-error' : '' %>">Make Publicly Visible</label>
            </div>
            <% if (__errorMap.isPubliclyVisible) { %><div class="field-error"><%= __errorMap.isPubliclyVisible[0] %></div><% } %>
        </div>
        <div class="form-group <%= __errorMap.isFeaturedOnHomepage ? 'has-error' : '' %>">
            <div class="checkbox-inline">
                <input type="checkbox" id="isFeaturedOnHomepage" name="isFeaturedOnHomepage" <%= project.isFeaturedOnHomepage ? 'checked' : '' %> class="<%= __errorMap.isFeaturedOnHomepage ? 'input-error' : '' %>">
                <label for="isFeaturedOnHomepage" class="<%= __errorMap.isFeaturedOnHomepage ? 'label-error' : '' %>">Feature on Homepage</label>
            </div>
            <% if (__errorMap.isFeaturedOnHomepage) { %><div class="field-error"><%= __errorMap.isFeaturedOnHomepage[0] %></div><% } %>
        </div>

        <div class="form-actions">
            <div class="admin-btn-group">
              <button type="submit" class="admin-btn">
                  <i class="fas fa-save"></i> <%= editing ? 'Update Project' : 'Save New Project' %>
              </button>
              <% if (editing && project && project.isPubliclyVisible && project.slug) { %>
                  <a href="/projects/<%= project.slug %>" target="_blank" class="admin-btn admin-btn--ghost">
                      <i class="fas fa-eye"></i> View Live
                  </a>
              <% } %>
              <a href="/admin/projects" class="admin-btn admin-btn--ghost" style="--btn-accent:#6b7280;"><i class="fas fa-times"></i> Cancel</a>
            </div>
        </div>
    </form>
</div>

<%# TinyMCE Initialization Script %>
<script src="https://cdn.tiny.cloud/1/<%= typeof tinymceApiKey !== 'undefined' ? tinymceApiKey : 'no-api-key' %>/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<!-- Choices.js for enhanced multi-selects -->
<link rel="stylesheet" href="/vendor/choices/choices.min.css" />
<script src="/vendor/choices/choices.min.js"></script>
<!-- Override Choices.js styles for higher contrast (must come AFTER vendor CSS) -->
<style>
    /* Base input area */
    .choices__inner { background:#ffffff; color:#111; border:1px solid #444; min-height:42px; }
    .choices.is-disabled .choices__inner { background:#f3f4f6; color:#666; }
    .choices__input { color:#111 !important; }

    /* Dropdown list container */
    .choices__list--dropdown { background:#ffffff; border:1px solid #444; }
    .choices__list--dropdown .choices__item { color:#111 !important; font-weight:500; }
    .choices__list--dropdown .choices__item.is-highlighted { background:#e5e7eb; color:#111 !important; }
    .choices__list--dropdown .choices__item.is-selected { background:#2563eb; color:#fff !important; }
    .choices__list--dropdown .choices__item.is-disabled { color:#9ca3af !important; }

    /* Selected pills (multi select) */
    .choices__list--multiple .choices__item { background:#2563eb; border:1px solid #1d4ed8; color:#fff; font-weight:500; }
    .choices__list--multiple .choices__item.is-highlighted { background:#1d4ed8; border-color:#1e40af; }
    .choices[data-type*="select-multiple"] .choices__button { border-left-color:rgba(255,255,255,0.5); }

    /* Focus ring */
    .choices.is-focused .choices__inner, .choices:focus .choices__inner { box-shadow:0 0 0 3px rgba(37,99,235,0.35); }

    /* Dark mode safeguard: force light dropdown for readability if parent has dark bg */
    body.dark .choices__inner, body.dark .choices__list--dropdown { background:#ffffff; color:#111; }
    body.dark .choices__list--dropdown .choices__item.is-selected { background:#2563eb; color:#fff !important; }

    /* Ensure scrollbar (if any) contrasts */
    .choices__list--dropdown::-webkit-scrollbar { width:10px; }
    .choices__list--dropdown::-webkit-scrollbar-track { background:#f3f4f6; }
    .choices__list--dropdown::-webkit-scrollbar-thumb { background:#9ca3af; border-radius:5px; }
    .choices__list--dropdown::-webkit-scrollbar-thumb:hover { background:#6b7280; }
</style>
<!-- Flatpickr for a consistent calendar UI (progressive enhancement) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<!-- Fallback / override Flatpickr minimal styles (in case CDN CSS fails to load) -->
<style>
    .flatpickr-calendar { position:absolute; visibility:hidden; opacity:0; background:#1f2937; color:#e5e7eb; border:1px solid #374151; box-shadow:0 4px 16px rgba(0,0,0,.4); border-radius:8px; padding:6px 8px 10px; width:300px; z-index:9999; font-size:13px; line-height:1.2; }
    .flatpickr-calendar.open { visibility:visible; opacity:1; transition:opacity .15s ease; }
    .flatpickr-months { display:flex; align-items:center; justify-content:space-between; margin-bottom:4px; }
    .flatpickr-months .flatpickr-prev-month, .flatpickr-months .flatpickr-next-month { cursor:pointer; padding:4px 6px; border-radius:4px; user-select:none; }
        .flatpickr-months .flatpickr-prev-month, .flatpickr-months .flatpickr-next-month { color:#f3f4f6; }
        .flatpickr-months .flatpickr-prev-month:hover, .flatpickr-months .flatpickr-next-month:hover { background:#374151; color:#fff; }
        .flatpickr-current-month { flex:1; text-align:center; font-weight:600; display:flex; gap:6px; align-items:center; justify-content:center; }
        .flatpickr-current-month .flatpickr-monthDropdown-months,
        .flatpickr-current-month input.cur-year { background:#111827; color:#f9fafb; border:1px solid #4b5563; border-radius:4px; padding:4px 6px; font-size:13px; font-weight:600; }
        .flatpickr-current-month .flatpickr-monthDropdown-months { appearance:none; -webkit-appearance:none; cursor:pointer; }
        .flatpickr-current-month .flatpickr-monthDropdown-months:focus,
        .flatpickr-current-month input.cur-year:focus { outline:2px solid #2563eb; outline-offset:2px; }
        .flatpickr-current-month input.cur-year { width:70px; }
        .flatpickr-weekdays { display:grid; grid-template-columns:repeat(7,1fr); gap:0; }
        .flatpickr-weekday { text-align:center; font-size:11px; font-weight:600; padding:2px 0 4px; color:#9ca3af; }
        .flatpickr-days { width:100%; }
        .dayContainer { display:grid; grid-template-columns:repeat(7,1fr); grid-auto-rows:34px; width:100%; }
        .flatpickr-day { width:100%; height:34px; line-height:34px; text-align:center; cursor:pointer; border-radius:4px; margin:0; border:1px solid transparent; box-sizing:border-box; font-size:12px; }
    .flatpickr-day:hover { background:#374151; }
    .flatpickr-day.today { border-color:#3b82f6; }
    .flatpickr-day.selected { background:#2563eb; color:#fff; border-color:#1d4ed8; }
    .flatpickr-day.disabled, .flatpickr-day.nextMonthDay, .flatpickr-day.prevMonthDay { opacity:.35; cursor:not-allowed; }
    .flatpickr-calendar.arrowTop:before, .flatpickr-calendar.arrowTop:after { display:none; }
    /* Ensure container relative for appendTo positioning */
    .form-group { position:relative; }
</style>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const checkTinyMCE = setInterval(() => {
        if (typeof tinymce !== 'undefined') {
            clearInterval(checkTinyMCE);
            initializeTinyMCE();
        }
    }, 100);

    function initializeTinyMCE() {
        tinymce.init({
            selector: 'textarea#project-description-editor', // Target the project description editor
            promotion: false,
            plugins: 'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount codesample',
            toolbar: 'undo redo | blocks | bold italic underline strikethrough | link image media table | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | removeformat | styles | code codesample | preview fullscreen | help',
            content_style: 'body { font-family:Montserrat,Arial,sans-serif; font-size:16px; line-height: 1.7; color: #ccc; background-color: #2d2d2d; } a { color: #00a8e8; } code { background-color: rgba(255,255,255,0.1); padding: 0.1em 0.3em; border-radius: 3px; } pre code { background-color: transparent; padding: 0;} .callout,.info,.warning,.tip{padding:1rem 1.125rem;border-radius:.5rem;margin:1rem 0;border:1px solid transparent}.callout{background:rgba(0,168,232,.08);border-color:rgba(0,168,232,.35)}.info{background:rgba(99,102,241,.1);border-color:rgba(99,102,241,.35)}.warning{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.4)}.tip{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.4)} .callout-title{font-weight:700;margin-bottom:.25rem}',
            style_formats: [
                { title: 'Callout', block: 'div', classes: 'callout', wrapper: true },
                { title: 'Info', block: 'div', classes: 'info', wrapper: true },
                { title: 'Warning', block: 'div', classes: 'warning', wrapper: true },
                { title: 'Tip', block: 'div', classes: 'tip', wrapper: true },
                { title: 'Callout Title', inline: 'strong', classes: 'callout-title' }
            ],
            height: 600, // Taller editor for better editing comfort
            menubar: false,
            statusbar: true,
            skin: (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'oxide-dark' : 'oxide', // Auto dark/light mode
            content_css: (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'default',
            images_upload_url: '/admin/blog/upload-image', // Can reuse blog image uploader for in-content images
            images_upload_credentials: true,
            automatic_uploads: true,
            file_picker_types: 'image',
            file_picker_callback: function (cb, value, meta) {
                 if (meta.filetype === 'image') {
                    var input = document.createElement('input');
                    input.setAttribute('type', 'file');
                    input.setAttribute('accept', 'image/jpeg,image/png,image/gif,image/webp');
                    input.onchange = function () {
                        var file = this.files[0];
                        const maxSize = 5 * 1024 * 1024;
                        const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                        if (!allowedTypes.includes(file.type)) { tinymce.activeEditor.notificationManager.open({ text: 'Invalid file type.', type: 'error' }); return; }
                        if (file.size > maxSize) { tinymce.activeEditor.notificationManager.open({ text: `Image too large (Max ${maxSize / 1024 / 1024}MB).`, type: 'error'}); return; }
                        var reader = new FileReader();
                        reader.onload = function () {
                            var id = 'blobid' + (new Date()).getTime();
                            var blobCache = tinymce.activeEditor.editorUpload.blobCache;
                            var base64 = reader.result.split(',')[1];
                            var blobInfo = blobCache.create(id, file, base64);
                            blobCache.add(blobInfo);
                            cb(blobInfo.blobUri(), { title: file.name });
                        };
                        reader.readAsDataURL(file);
                    };
                    input.click();
                }
            },
            setup: function (editor) {
                editor.on('init', function () { editor.getContainer().style.visibility = 'visible'; });
                editor.on('change', function () { editor.save(); }); // Keep textarea updated
            }
        });
    }
    setTimeout(() => {
        if (typeof tinymce === 'undefined') {
             console.error("TinyMCE failed to load for projects.");
             const editorTextarea = document.getElementById('project-description-editor');
             if(editorTextarea) { editorTextarea.style.visibility = 'visible'; editorTextarea.placeholder = "Error loading Rich Text Editor. Basic textarea enabled."; }
        }
    }, 5000);
  });
</script>

<%# ****** JAVASCRIPT FOR PROJECT COVER IMAGE UPLOAD ****** %>
<script>
document.addEventListener('DOMContentLoaded', () => {
    const coverImageFileInput = document.getElementById('projectCoverImageFile');
    const imageInput = document.getElementById('image'); // Target 'image' field for projects (main project image URL)
    const previewContainer = document.getElementById('projectCoverImagePreviewContainer');
    const uploadStatusDiv = document.getElementById('projectCoverImageUploadStatus');
    const removeCoverImageBtn = document.getElementById('removeProjectCoverImageBtn'); // Button for an initially loaded image
    const form = document.getElementById('projectForm'); // Ensure the form has this ID
    const addKeyResultBtn = document.getElementById('addKeyResultBtn');
    const keyResultsContainer = document.getElementById('keyResultsContainer');

    // Helper function to re-attach event listener to a dynamically created remove button
    function attachRemoveListener(buttonId) {
        const btn = document.getElementById(buttonId);
        if (btn) {
            btn.addEventListener('click', handleRemoveProjectImage);
        }
    }

    function handleRemoveProjectImage() {
        if (imageInput) imageInput.value = ''; // Clear the URL input field
        if (previewContainer) previewContainer.innerHTML = ''; // Clear the preview
        if (uploadStatusDiv) {
            uploadStatusDiv.textContent = 'Image removed. Save the project to confirm changes.';
            uploadStatusDiv.style.color = 'var(--gray-text)';
        }
        if (coverImageFileInput) coverImageFileInput.value = null; // Reset the file input so the same file can be re-selected if needed
    }

    // Attach to existing remove button if present on page load
    if (removeCoverImageBtn) {
        removeCoverImageBtn.addEventListener('click', handleRemoveProjectImage);
    }

    if (coverImageFileInput && imageInput && previewContainer && uploadStatusDiv && form) {
        coverImageFileInput.addEventListener('change', async function(event) {
            const file = event.target.files[0];
            if (!file) {
                uploadStatusDiv.textContent = '';
                return;
            }
            uploadStatusDiv.textContent = 'Uploading...';
            uploadStatusDiv.style.color = 'var(--gray-text)';

            const formData = new FormData();
            formData.append('coverImageFile', file); // This name 'coverImageFile' must match Multer on backend
            const csrfToken = form.querySelector('input[name="_csrf"]')?.value;

            if (!csrfToken) {
                console.error('CSRF token not found for cover image upload!');
                uploadStatusDiv.textContent = 'Error: Missing security token. Please refresh.';
                uploadStatusDiv.style.color = 'var(--danger-color)';
                return;
            }

            try {
                const response = await fetch('/admin/projects/upload-cover-image', { // Ensure this endpoint is correct
                    method: 'POST',
                    body: formData,
                    headers: {
                        'CSRF-Token': csrfToken // Send CSRF token as a header
                    }
                });

                const result = await response.json();

                if (response.ok && result.success && result.location) {
                    imageInput.value = result.location; // Populate the main image URL field
                    previewContainer.innerHTML = `<img src="${result.location}" alt="Cover Image Preview" style="max-width: 200px; max-height: 200px; border-radius: 4px; display: block;"> <button type="button" id="newRemoveProjectCoverBtn" class="delete-btn" style="font-size: 0.8em; padding: 4px 8px; margin-top: 5px;">Remove Image</button>`;
                    uploadStatusDiv.textContent = 'Upload successful!';
                    uploadStatusDiv.style.color = 'var(--success-color)';
                    attachRemoveListener('newRemoveProjectCoverBtn'); // Attach listener to the NEW remove button
                } else {
                    uploadStatusDiv.textContent = `Upload failed: ${result.message || 'Server error or invalid response'}`;
                    uploadStatusDiv.style.color = 'var(--danger-color)';
                }
            } catch (error) {
               console.error('Project cover image upload fetch error:', error);
                uploadStatusDiv.textContent = 'Upload network error. See console.';
                uploadStatusDiv.style.color = 'var(--danger-color)';
            }
        });
    } else {
        // Log if any critical elements for the upload script are missing
        if (!form) console.warn("Project form with ID 'projectForm' not found for cover image uploader.");
        if (!coverImageFileInput) console.warn("File input 'projectCoverImageFile' not found.");
        if (!imageInput) console.warn("URL input 'image' not found for cover image uploader.");
        if (!previewContainer) console.warn("Preview container 'projectCoverImagePreviewContainer' not found.");
        if (!uploadStatusDiv) console.warn("Upload status div 'projectCoverImageUploadStatus' not found.");
    }

    // Add Key Result row
    if (addKeyResultBtn && keyResultsContainer) {
        addKeyResultBtn.addEventListener('click', () => {
            const row = document.createElement('div');
            row.className = 'kr-row';
            row.style.cssText = 'display:flex; gap:8px; margin-bottom:8px; align-items:center;';
            row.innerHTML = `
                <input type="text" name="keyResultsValues" placeholder="Value (e.g., 120%)" style="flex:0 0 140px;">
                <input type="text" name="keyResultsLabels" placeholder="Label (e.g., Efficiency Increase)" style="flex:1;">
                <button type="button" class="delete-btn">Remove</button>
            `;
            keyResultsContainer.appendChild(row);
        });
        }

    // Remove inline row removal, use delegated event listener
    document.addEventListener('click', function(e) {
        if (e.target && e.target.classList.contains('delete-btn')) {
            const row = e.target.closest('.kr-row');
            if (row) row.remove();
        }
    });
});
</script>
<%# ****** END JAVASCRIPT FOR PROJECT COVER IMAGE UPLOAD ****** %>

    <script>
    // Enhance multi-selects and date input after DOM load
    document.addEventListener('DOMContentLoaded', () => {
        // Choices.js for Industries and Service Types
        const industriesSelect = document.getElementById('industries');
        const serviceTypesSelect = document.getElementById('serviceTypes');
        if (window.Choices) {
            try {
                if (industriesSelect) {
                    new Choices(industriesSelect, {
                        removeItemButton: true,
                        shouldSort: false,
                        itemSelectText: ''
                    });
                }
                if (serviceTypesSelect) {
                    new Choices(serviceTypesSelect, {
                        removeItemButton: true,
                        shouldSort: false,
                        itemSelectText: ''
                    });
                }
            } catch (e) {
                console.warn('Choices.js init failed:', e);
            }
        }

        // Flatpickr for Completion Date (keeps underlying value as YYYY-MM-DD)
        const dateHidden = document.getElementById('projectDate');
        const dateDisplay = document.getElementById('projectDateDisplay');
        if (dateDisplay && window.flatpickr) {
            try {
                const fp = flatpickr(dateDisplay, {
                    dateFormat: 'Y-m-d',
                    defaultDate: dateHidden.value || null,
                    allowInput: false,
                    clickOpens: true,
                    disableMobile: true,
                    appendTo: document.body, // detach from form flow to avoid pushing layout
                    prevArrow: '&larr;',
                    nextArrow: '&rarr;',
                    onOpen: () => { try { fp._positionElement = dateDisplay; fp.positionCalendar(); } catch(_){} },
                    onChange: (selectedDates, dateStr) => { dateHidden.value = dateStr; }
                });
                dateDisplay.addEventListener('click', () => { try { fp.open(); } catch(_){} });
                window.addEventListener('scroll', () => { if (fp.isOpen) try { fp.positionCalendar(); } catch(_){} }, true);
                window.addEventListener('resize', () => { if (fp.isOpen) try { fp.positionCalendar(); } catch(_){} });
                dateDisplay.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); try { fp.open(); } catch(_){} } });
            } catch (e) {
                console.warn('Flatpickr init failed:', e);
            }
        }
    });
    </script>

