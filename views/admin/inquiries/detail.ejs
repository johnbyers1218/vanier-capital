<%- include('../partials/header', { pageTitle: 'Inquiry Detail' }) %>
<div class="space-y-6">
  <a href="/admin/inquiries" class="text-sm text-primary hover:underline">← Back to Inquiries</a>
  <div class="rounded border border-gray-700 p-4">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-semibold text-gray-100">Inquiry</h1>
      <form method="POST" action="/admin/inquiries/<%= inquiry._id %>/responded">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="px-3 py-1.5 rounded bg-emerald-600 text-white hover:bg-emerald-500">Mark as Responded</button>
      </form>
    </div>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="text-gray-400 text-xs uppercase">Name</div>
        <div class="text-gray-100"><%= inquiry.name %></div>
      </div>
      <div>
        <div class="text-gray-400 text-xs uppercase">Email</div>
        <div class="text-gray-100"><a href="mailto:<%= inquiry.email %>" class="text-primary hover:underline"><%= inquiry.email %></a></div>
      </div>
      <div>
        <div class="text-gray-400 text-xs uppercase">Phone</div>
        <div class="text-gray-100"><%= inquiry.phone || '—' %></div>
      </div>
      <div>
        <div class="text-gray-400 text-xs uppercase">Status</div>
        <div class="text-gray-100"><%= inquiry.status %></div>
      </div>
    </div>
    <div class="mt-4">
      <div class="text-gray-400 text-xs uppercase">Subject</div>
      <div class="text-gray-100 font-medium"><%= inquiry.subject %></div>
    </div>
    <div class="mt-4">
      <div class="text-gray-400 text-xs uppercase">Message</div>
      <div class="text-gray-100 whitespace-pre-wrap"><%= inquiry.message %></div>
    </div>
    <div class="mt-4 text-gray-400 text-sm">
      Received: <%= new Date(inquiry.createdAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
