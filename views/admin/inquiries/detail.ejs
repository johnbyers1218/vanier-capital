<%- include('../partials/header', { pageTitle: 'Inquiry Detail' }) %>
<div class="space-y-6">
  <a href="/admin/inquiries" class="text-sm text-[#0f2e22] font-medium hover:underline">← Back to Inquiries</a>
  <div class="border border-[#0f2e22]/20 bg-white p-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-semibold text-[#1a1a1a]">Inquiry</h1>
      <form method="POST" action="/admin/inquiries/<%= inquiry._id %>/responded">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="bg-[#0f2e22] text-white font-bold py-1.5 px-4 border border-[#0f2e22] hover:bg-[#1a1a1a] text-xs uppercase tracking-widest">Mark as Responded</button>
      </form>
    </div>
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <div class="text-gray-500 text-xs font-bold uppercase tracking-widest">Name</div>
        <div class="text-[#1a1a1a]"><%= inquiry.name %></div>
      </div>
      <div>
        <div class="text-gray-500 text-xs font-bold uppercase tracking-widest">Email</div>
        <div class="text-[#1a1a1a]"><a href="mailto:<%= inquiry.email %>" class="text-[#0f2e22] hover:underline"><%= inquiry.email %></a></div>
      </div>
      <div>
        <div class="text-gray-500 text-xs font-bold uppercase tracking-widest">Phone</div>
        <div class="text-[#1a1a1a]"><%= inquiry.phone || '—' %></div>
      </div>
      <div>
        <div class="text-gray-500 text-xs font-bold uppercase tracking-widest">Status</div>
        <div class="text-[#1a1a1a]"><%= inquiry.status %></div>
      </div>
    </div>
    <div class="mt-4">
      <div class="text-gray-500 text-xs font-bold uppercase tracking-widest">Subject</div>
      <div class="text-[#1a1a1a] font-medium"><%= inquiry.subject %></div>
    </div>
    <div class="mt-4">
      <div class="text-gray-500 text-xs font-bold uppercase tracking-widest">Message</div>
      <div class="text-[#1a1a1a] whitespace-pre-wrap"><%= inquiry.message %></div>
    </div>
    <div class="mt-4 text-gray-500 text-sm">
      Received: <%= new Date(inquiry.createdAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
