<%- include('../partials/header', { pageTitle: 'Inquiries' }) %>
<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold text-[#1a1a1a]">Inquiries</h1>
    <div class="flex items-center gap-1">
      <a href="/admin/inquiries" class="px-3 py-1.5 text-xs font-bold uppercase tracking-widest border border-[#0f2e22]/20 <%= !status ? 'bg-[#0f2e22] text-white border-[#0f2e22]' : 'bg-white text-gray-600 hover:text-[#1a1a1a]' %>">All</a>
      <a href="/admin/inquiries?status=New" class="px-3 py-1.5 text-xs font-bold uppercase tracking-widest border border-[#0f2e22]/20 <%= status==='New' ? 'bg-[#0f2e22] text-white border-[#0f2e22]' : 'bg-white text-gray-600 hover:text-[#1a1a1a]' %>">New</a>
      <a href="/admin/inquiries?status=Viewed" class="px-3 py-1.5 text-xs font-bold uppercase tracking-widest border border-[#0f2e22]/20 <%= status==='Viewed' ? 'bg-[#0f2e22] text-white border-[#0f2e22]' : 'bg-white text-gray-600 hover:text-[#1a1a1a]' %>">Viewed</a>
      <a href="/admin/inquiries?status=Responded" class="px-3 py-1.5 text-xs font-bold uppercase tracking-widest border border-[#0f2e22]/20 <%= status==='Responded' ? 'bg-[#0f2e22] text-white border-[#0f2e22]' : 'bg-white text-gray-600 hover:text-[#1a1a1a]' %>">Responded</a>
    </div>
  </div>

  <div class="overflow-x-auto border border-[#0f2e22]/20">
    <table class="min-w-full text-sm">
      <thead>
        <tr class="bg-[#f9f8f6] border-y border-[#0f2e22]/20">
          <th class="px-4 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Status</th>
          <th class="px-4 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Name</th>
          <th class="px-4 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Subject</th>
          <th class="px-4 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Date</th>
        </tr>
      </thead>
      <tbody>
        <% (inquiries || []).forEach(function(i){ %>
          <tr class="bg-white border-b border-gray-200 hover:bg-gray-50">
            <td class="px-4 py-3">
              <% const cls = i.status==='New' ? 'bg-amber-50 text-amber-700 border border-amber-300' : (i.status==='Viewed' ? 'bg-blue-50 text-blue-700 border border-blue-300' : 'bg-green-50 text-green-700 border border-green-300'); %>
              <span class="px-2 py-0.5 text-xs font-bold uppercase tracking-widest <%= cls %>"><%= i.status %></span>
            </td>
            <td class="px-4 py-3 text-[#1a1a1a]"><a class="text-[#0f2e22] font-medium hover:underline" href="/admin/inquiries/<%= i._id %>"><%= i.name %></a></td>
            <td class="px-4 py-3 text-[#1a1a1a]"><%= i.subject %></td>
            <td class="px-4 py-3 text-gray-500"><%= new Date(i.createdAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
          </tr>
        <% }) %>
        <% if (!inquiries || inquiries.length === 0) { %>
          <tr><td class="px-4 py-8 text-gray-500 text-center" colspan="4">No inquiries found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
