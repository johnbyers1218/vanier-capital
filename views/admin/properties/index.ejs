<%# views/admin/properties/index.ejs %>
<%# Admin page to list and manage properties %>

<%- include('../partials/header', { pageTitle: 'Manage Properties' }) %>

<div class="flex items-start justify-between mb-6">
    <div>
        <h2 class="text-2xl font-bold text-gray-100">Manage Properties</h2>
        <p class="text-gray-400 mt-1">Create, edit, and manage your property portfolio.</p>
                <%- include('../partials/pillToggle', {
                        basePath: '/admin/properties',
                        paramName: 'status',
                        items: [
                            { label: 'All', value: '' },
                            { label: 'Public', value: 'public' },
                            { label: 'Hidden', value: 'hidden' }
                        ],
                        currentValue: (status||'')
                }) %>
    </div>
    <div>
        <a href="/admin/properties/new" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-lg shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-plus"></i> Add New Property
        </a>
    </div>
</div>

<div>
    <% if (properties && properties.length > 0) { %>
        <div class="overflow-x-auto bg-[#1a1a1a] rounded-lg shadow-md border border-neutral-700">
            <table class="min-w-full divide-y divide-neutral-700">
                <thead class="bg-[#1a1a1a]/60">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Title</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Property Type</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">For Rent</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-400 uppercase tracking-wider">Featured</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Created</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Last Updated</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-400 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-[#1a1a1a] divide-y divide-neutral-700">
                    <% properties.forEach(property => { %>
                        <tr class="hover:bg-[#1a1a1a]/70">
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-100"><%= property.title %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-300">
                                <% if (property.propertyType) { %>
                                    <%= property.propertyType %>
                                <% } else { %>
                                    <span class="text-gray-500">—</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                                <% if (property.isAvailableForRent) { %>
                                    <i class="fas fa-check-circle text-green-400" title="Available For Rent"></i>
                                <% } else { %>
                                    <i class="fas fa-times-circle text-gray-500" title="Not For Rent"></i>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                                <% if (property.isFeatured) { %>
                                    <i class="fas fa-check-circle text-green-400" title="Featured"></i>
                                <% } else { %>
                                    <i class="fas fa-times-circle text-gray-500" title="Not Featured"></i>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400"><%= property.createdAt ? new Date(property.createdAt).toLocaleDateString() : '-' %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-400"><%= property.updatedAt ? new Date(property.updatedAt).toLocaleDateString() : '-' %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                <div class="inline-flex items-center gap-2">
                                    <a href="/admin/properties/edit/<%= property._id %>" class="inline-flex items-center gap-1 bg-neutral-700 text-gray-100 font-semibold py-1.5 px-3 rounded-lg border border-neutral-600 shadow-sm hover:bg-neutral-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary" title="Edit Property">
                                        <i class="fas fa-edit"></i>
                                        <span>Edit</span>
                                    </a>
                                    <form action="/admin/properties/delete/<%= property._id %>" method="POST" class="delete-form inline-block">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="inline-flex items-center gap-1 bg-danger text-white font-semibold py-1.5 px-3 rounded-lg shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-danger delete-btn" title="Delete Property">
                                            <i class="fas fa-trash-alt"></i>
                                            <span>Delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="bg-[#1a1a1a] rounded-lg shadow-md border border-neutral-700 p-8 text-center">
            <div class="mx-auto mb-3 h-12 w-12 rounded-full bg-neutral-700 flex items-center justify-center text-gray-300">
                <i class="fas fa-building"></i>
            </div>
            <h3 class="text-lg font-semibold text-gray-100">No Properties Yet</h3>
            <p class="text-gray-400 mt-1">Get started by adding your first property.</p>
            <div class="mt-6">
                <a href="/admin/properties/new" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-lg shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                    <i class="fas fa-plus"></i> Add New Property
                </a>
            </div>
        </div>
    <% } %>
</div>
<script>
// Remove inline delete confirmation, use delegated event listener
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.delete-form .delete-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            if (!confirm('Are you sure you want to delete this property? This action cannot be undone.')) {
                e.preventDefault();
            }
        });
    });
});
</script>
