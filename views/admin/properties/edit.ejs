<%# views/admin/properties/edit.ejs %>
<%# Form for adding or editing a property with Rich Text Editor & Cover Image Upload %>

<%- include('../partials/header', { pageTitle: editing ? 'Edit Property' : 'Add New Property' }) %>

<div class="admin-form-container">
    <h2><%= editing ? 'Edit Property' : 'Add New Property' %></h2>

    <div class="info-panel" style="margin: 12px 0 20px 0; padding: 12px 14px; border: 1px solid #374151; border-radius: 8px; background: #111827; color: #d1d5db;">
        <strong style="color:#93c5fd;">Tip:</strong> Properties use curated Property Types and optional rental details to help power the public listings.
    </div>

    <% const __errorMap = (typeof errorMap !== 'undefined' && errorMap) ? errorMap : {}; %>

    <% if (typeof errorMessages !== 'undefined' && errorMessages && errorMessages.length > 0) { %>
        <div class="error-summary" role="alert" aria-live="assertive">
            <div class="error-summary-icon" aria-hidden="true"><i class="fas fa-exclamation-triangle"></i></div>
            <div>
                <p class="error-summary-title">Please correct the following errors:</p>
                <ul class="error-summary-list">
                    <% errorMessages.forEach(err => { %>
                        <li><strong><%= err.param %>:</strong> <%= err.msg %></li>
                    <% }) %>
                </ul>
            </div>
        </div>
    <% } %>

    <form action="<%= editing ? '/admin/properties/edit/' + property._id : '/admin/properties' %>" method="POST" class="admin-form" id="propertyForm" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group <%= __errorMap.title ? 'has-error' : '' %>">
            <label for="title" class="<%= __errorMap.title ? 'label-error' : '' %>">Property Title <span style="color: #dc3545;">*</span></label>
            <input type="text" id="title" name="title" value="<%= property && property.title ? property.title : '' %>" required maxlength="150" class="<%= __errorMap.title ? 'input-error' : '' %>">
            <% if (__errorMap.title) { %><div class="field-error"><%= __errorMap.title[0] %></div><% } %>
        </div>

    <div class="form-group <%= __errorMap.slug ? 'has-error' : '' %>">
            <label for="slug">URL Slug</label>
            <input type="text" id="slug" name="slug" value="<%= property && property.slug ? property.slug : '' %>" maxlength="200" pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$" placeholder="auto-generated-if-blank-from-title" class="<%= __errorMap.slug ? 'input-error' : '' %>">
            <small>URL-friendly ID. Leave blank to auto-generate from title. Unique, lowercase, numbers, hyphens only.</small>
            <% if (__errorMap.slug) { %><div class="field-error"><%= __errorMap.slug[0] %></div><% } %>
        </div>

        <%# ****** PROPERTY PHOTOS SECTION ****** %>
        <div class="form-group">
            <label for="image">Cover Photo (Optional)</label>
            <% if (property && property.image) { %>
                <div style="margin-bottom: 10px;">
                    <img src="<%= property.image %>" alt="Current Cover" style="max-width: 200px; border-radius: 4px;">
                    <input type="hidden" name="image" value="<%= property.image %>">
                    <p style="font-size: 0.9em; color: #9ca3af;">Current Cover Photo</p>
                </div>
            <% } %>
            <input type="file" id="image" name="image" accept="image/*">
            <small>Upload a new file to replace the current cover photo. This photo will be used on homepage cards.</small>
            <% if (__errorMap.image) { %><div class="field-error"><%= __errorMap.image[0] %></div><% } %>
        </div>

        <div class="form-group">
            <label for="galleryImages">Property Gallery Photos</label>
            <input type="file" id="galleryImages" name="galleryImages" multiple accept="image/*">
            <small>Select multiple photos to add to the gallery.</small>
            
            <% if (property && property.galleryImages && property.galleryImages.length > 0) { %>
                <div style="margin-top: 15px; display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px;">
                    <% property.galleryImages.forEach((img, index) => { %>
                        <div style="border: 1px solid #374151; padding: 5px; border-radius: 4px; background: #1f2937;">
                            <img src="<%= img %>" alt="Gallery Image" style="width: 100%; height: 100px; object-fit: cover; border-radius: 2px;">
                            <div style="margin-top: 5px;">
                                <label style="display: flex; align-items: center; font-size: 0.9em; cursor: pointer;">
                                    <input type="checkbox" name="galleryImages" value="<%= img %>" checked style="margin-right: 5px;">
                                    Keep
                                </label>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
        <%# ****** END PROPERTY PHOTOS SECTION ****** %>

        <div class="form-group <%= __errorMap.description ? 'has-error' : '' %>">
            <label for="property-description-editor">Full Description / Case Study</label>
            <textarea id="property-description-editor" name="description" class="richtext-editor <%= __errorMap.description ? 'input-error' : '' %>" style="visibility: hidden; min-height: 400px;"><%= property && property.description ? property.description : '' %></textarea>
            <small>Detailed property information. Use the editor for formatting. <a href="/AUTHORING_GUIDE.md" target="_blank" rel="noopener noreferrer">Authoring Guide</a></small>
            <% if (__errorMap.description) { %><div class="field-error"><%= __errorMap.description[0] %></div><% } %>
        </div>

        <div class="form-group <%= __errorMap.excerpt ? 'has-error' : '' %>">
            <label for="propertyExcerpt">Excerpt / Summary</label>
            <textarea id="propertyExcerpt" name="excerpt" rows="3" maxlength="250" oninput="document.getElementById('propertyExcerptCounter').textContent = this.value.length + '/250'"><%= property && property.excerpt ? property.excerpt : '' %></textarea>
            <div class="muted" style="display:flex;justify-content:space-between;">
                <small>Appears on cards and previews (max 250 chars).</small>
                <small id="propertyExcerptCounter"><%= property && property.excerpt ? property.excerpt.length : 0 %>/250</small>
            </div>
            <% if (__errorMap.excerpt) { %><div class="field-error"><%= __errorMap.excerpt[0] %></div><% } %>
        </div>

        <div class="form-group">
            <label for="link">Property Link (Optional)</label>
            <input type="url" id="link" name="link" value="<%= property && property.link ? property.link : '' %>" placeholder="https://example.com">
            <small>External link to the live property or case study.</small>
        </div>

        <div class="form-group">
            <label for="propertyType">Property Type</label>
            <select id="propertyType" name="propertyType">
                <option value="">Select Type...</option>
                <% const types = ['Multifamily', 'Single Family', 'Industrial', 'Office', 'Retail', 'Hospitality', 'Mixed-Use', 'Land', 'Special Purpose']; %>
                <% types.forEach(type => { %>
                    <option value="<%= type %>" <%= (property && property.propertyType === type) ? 'selected' : '' %>><%= type %></option>
                <% }); %>
            </select>
        </div>

        <div class="form-group">
            <label for="value">Property Value (AUM)</label>
            <input type="number" id="value" name="value" value="<%= property && property.value ? property.value : '' %>" placeholder="e.g. 1500000">
        </div>

        <div class="form-group">
            <label for="monthlyRent">Monthly Rent</label>
            <input type="number" id="monthlyRent" name="monthlyRent" value="<%= property && property.monthlyRent ? property.monthlyRent : '' %>" placeholder="e.g. 1200">
        </div>

        <div class="form-group">
            <label for="ltv">Loan-to-Value (LTV)</label>
            <input type="text" id="ltv" name="ltv" value="<%= property && property.ltv ? property.ltv : '' %>" placeholder="e.g. 75%">
        </div>

        <div class="form-group">
            <label for="noi">Net Operating Income (NOI)</label>
            <input type="number" id="noi" name="noi" value="<%= property && property.noi ? property.noi : '' %>" placeholder="e.g. 25000">
        </div>

        <div class="form-group">
            <label for="capRate">Cap Rate</label>
            <input type="text" id="capRate" name="capRate" value="<%= property && property.capRate ? property.capRate : '' %>" placeholder="e.g. 7.5%">
        </div>

        <div class="form-group">
            <label for="bedrooms">Bedrooms</label>
            <input type="number" id="bedrooms" name="bedrooms" value="<%= property && property.bedrooms ? property.bedrooms : '' %>" placeholder="e.g. 3">
        </div>

        <div class="form-group">
            <label for="bathrooms">Bathrooms</label>
            <input type="number" id="bathrooms" name="bathrooms" value="<%= property && property.bathrooms ? property.bathrooms : '' %>" placeholder="e.g. 2" step="0.5">
        </div>

        <div class="form-group">
            <label for="sqft">Square Footage</label>
            <input type="number" id="sqft" name="sqft" value="<%= property && property.sqft ? property.sqft : '' %>" placeholder="e.g. 1500">
        </div>

        <div class="checkbox-group">
            <label class="checkbox-container">
                <input type="checkbox" name="isAvailableForRent" id="isAvailableForRent" <%= property && property.isAvailableForRent ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Available For Rent (Currently Vacant)
            </label>
        </div>

        <div class="form-group" id="rentalApplicationUrlGroup" style="display: none;">
            <label for="rentalApplicationUrl">Rental Application Link</label>
            <input type="url" id="rentalApplicationUrl" name="rentalApplicationUrl" value="<%= property && property.rentalApplicationUrl ? property.rentalApplicationUrl : '' %>" placeholder="https://apply.example.com">
            <small>Shown as an “Apply Here” button on the For Rent page.</small>
        </div>

        <div class="checkbox-group">
            <label class="checkbox-container">
                <input type="checkbox" name="isFeatured" <%= property && property.isFeatured ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Featured Property (Show at top of lists)
            </label>
        </div>

        <div class="checkbox-group">
            <label class="checkbox-container">
                <input type="checkbox" name="isFeaturedOnHomepage" <%= property && property.isFeaturedOnHomepage ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Show on Homepage
            </label>
        </div>

        <div class="checkbox-group">
            <label class="checkbox-container">
                <input type="checkbox" name="isPubliclyVisible" <%= (property && property.isPubliclyVisible !== false) ? 'checked' : '' %>>
                <span class="checkmark"></span>
                Publicly Visible (Uncheck to hide from visitors)
            </label>
        </div>

        <div class="form-actions">
            <a href="/admin/properties" class="btn-secondary">Cancel</a>
            <button type="submit" class="btn-primary"><%= editing ? 'Update Property' : 'Create Property' %></button>
        </div>
    </form>
</div>

<%- include('../partials/tinymce-setup', { selector: '.richtext-editor', apiKey: tinymceApiKey }) %>
<%- include('../partials/footer') %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const rentCheckbox = document.getElementById('isAvailableForRent');
        const rentalLinkGroup = document.getElementById('rentalApplicationUrlGroup');
        const toggleRentalLink = () => {
            if (!rentCheckbox || !rentalLinkGroup) return;
            rentalLinkGroup.style.display = rentCheckbox.checked ? 'block' : 'none';
        };
        toggleRentalLink();
        if (rentCheckbox) {
            rentCheckbox.addEventListener('change', toggleRentalLink);
        }
    });
</script>
