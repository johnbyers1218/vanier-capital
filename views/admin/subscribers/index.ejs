<%- include('../partials/header', { pageTitle: 'Subscribers' }) %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold">Subscribers</h1>
    <div class="flex items-center gap-3">
      <div class="rounded-md border border-neutral-700 bg-[#1a1a1a]/50 px-3 py-2 text-sm text-gray-200">
        Total Subscribers: <strong><%= typeof totalSubscribed === 'number' ? totalSubscribed : 0 %></strong>
      </div>
      <a href="/admin/subscribers/export.csv" class="inline-flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-md"><i class="fas fa-file-csv"></i> Export CSV</a>
      <% if (mcEnabled) { %>
      <form method="post" action="/admin/subscribers/sync" class="inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="inline-flex items-center gap-2 bg-secondary text-white px-4 py-2 rounded-md"><i class="fas fa-sync"></i> Sync Now</button>
      </form>
      <% } %>
    </div>
  </div>

  <form method="get" action="/admin/subscribers" class="flex items-center gap-2">
    <input type="text" name="q" value="<%= q || '' %>" placeholder="Search by email or first name" class="rounded bg-[#111] border border-neutral-700 px-3 py-2 w-72" />
    <% if (pageSize) { %>
      <input type="hidden" name="pageSize" value="<%= pageSize %>" />
    <% } %>
    <button class="px-3 py-2 rounded bg-neutral-700 text-white">Search</button>
  </form>

  <div class="rounded-lg border border-neutral-700 bg-[#1a1a1a] p-4 overflow-x-auto">
    <% if (processed) { %>
      <div class="mb-3 rounded-md border border-neutral-600 bg-[#111] px-3 py-2 text-sm text-gray-200">
        <% if (processed === 'unsubscribed') { %>
          <strong><%= processedCount %></strong> subscriber(s) unsubscribed.
        <% } else if (processed === 'deleted') { %>
          <strong><%= processedCount %></strong> subscriber(s) deleted.
        <% } else if (processed === 'none') { %>
          No subscribers selected.
        <% } else if (processed === 'invalid') { %>
          Invalid selection.
        <% } else if (processed === 'synced') { %>
          Mailchimp sync complete. <strong><%= processedCount %></strong> subscriber(s) synced.
        <% } else if (processed === 'mc-disabled') { %>
          Mailchimp sync is disabled. Set MAILCHIMP_SYNC_ENABLED=true to enable.
        <% } else { %>
          Action completed.
        <% } %>
      </div>
    <% } %>

    <form method="post" action="/admin/subscribers/bulk" id="bulkForm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <table class="min-w-full text-sm">
      <thead>
        <tr class="text-left text-gray-300">
          <th class="px-3 py-2"><input type="checkbox" id="checkAll" /></th>
          <th class="px-3 py-2">Email</th>
          <th class="px-3 py-2">First Name</th>
          <th class="px-3 py-2">Status</th>
          <th class="px-3 py-2">Role</th>
          <th class="px-3 py-2">Company</th>
          <th class="px-3 py-2">Subscribed</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-neutral-700">
        <% if (subscribers && subscribers.length) { %>
          <% subscribers.forEach(s => { %>
            <tr>
              <td class="px-3 py-2"><input type="checkbox" name="ids" value="<%= s._id %>" class="rowCheck" /></td>
              <td class="px-3 py-2"><%= s.email %></td>
              <td class="px-3 py-2"><%= s.firstName || '' %></td>
              <td class="px-3 py-2"><span class="inline-block px-2 py-0.5 rounded bg-neutral-700 text-gray-200"><%= s.status || 'Subscribed' %></span></td>
              <td class="px-3 py-2"><%= s.role || '' %></td>
              <td class="px-3 py-2"><%= s.companyName || '' %></td>
              <td class="px-3 py-2"><%= s.createdAt ? s.createdAt.toLocaleString('en-US', { dateStyle: 'medium' }) : '' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td class="px-3 py-3 text-center text-gray-400" colspan="6">No subscribers found.</td></tr>
        <% } %>
      </tbody>
    </table>

      <div class="mt-3 flex items-center gap-2">
        <select name="action" class="rounded bg-[#111] border border-neutral-700 px-3 py-2">
          <option value="unsubscribe">Unsubscribe</option>
          <option value="delete">Delete</option>
        </select>
        <button type="submit" class="px-3 py-2 rounded bg-primary text-white">Apply</button>
      </div>
    </form>
  </div>

  <div class="flex items-center justify-end gap-3">
    <% const totalPages = Math.ceil((total || 0) / (pageSize || 20)); %>
    <% if (page > 1) { %>
      <a href="/admin/subscribers?page=<%= page - 1 %>&pageSize=<%= pageSize %><%= q ? '&q=' + encodeURIComponent(q) : '' %>" class="px-3 py-1 border border-neutral-600 rounded-md">Previous</a>
    <% } %>
    <span class="text-gray-300">Page <%= page %> of <%= totalPages || 1 %></span>
    <% if (page < totalPages) { %>
      <a href="/admin/subscribers?page=<%= page + 1 %>&pageSize=<%= pageSize %><%= q ? '&q=' + encodeURIComponent(q) : '' %>" class="px-3 py-1 border border-neutral-600 rounded-md">Next</a>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>

<script>
  (function(){
    const checkAll = document.getElementById('checkAll');
    const rowChecks = Array.from(document.querySelectorAll('.rowCheck'));
    const form = document.getElementById('bulkForm');
    if (checkAll) {
      checkAll.addEventListener('change', () => {
        rowChecks.forEach(c => { c.checked = checkAll.checked; });
      });
    }
    if (form) {
      form.addEventListener('submit', (e) => {
        const anyChecked = rowChecks.some(c => c.checked);
        if (!anyChecked) {
          e.preventDefault();
          alert('Please select at least one subscriber.');
          return;
        }
        const actionSel = form.querySelector('select[name="action"]');
        if (actionSel && actionSel.value === 'delete') {
          if (!confirm('Permanently delete selected subscribers? This cannot be undone.')) {
            e.preventDefault();
          }
        }
      });
    }
  })();
</script>
