<%# views/admin/error.ejs %>
<%# Generic Error Page for Admin Panel %>

<%# Set default title and message if not provided %>
<% const displayTitle = typeof pageTitle !== 'undefined' ? pageTitle : 'An Error Occurred'; %>
<% const displayMessage = typeof message !== 'undefined' ? message : 'An unexpected error occurred while processing your request.'; %>
<%# Determine a status code if possible (passed from route handler) %>
<% const statusCode = typeof status !== 'undefined' ? status : 500; %>

<%- include('partials/header', { pageTitle: displayTitle }) %>

<div class="max-w-2xl mx-auto my-8 p-8 bg-white border border-[#0f2e22]/20 text-center">
    <div class="text-4xl mb-4">
        <% if (statusCode === 404) { %>
            <i class="fas fa-search text-amber-500"></i>
        <% } else if (statusCode === 403) { %>
             <i class="fas fa-user-lock text-red-600"></i>
        <% } else if (statusCode >= 400 && statusCode < 500) { %>
            <i class="fas fa-exclamation-triangle text-amber-500"></i>
        <% } else { %>
            <i class="fas fa-server text-gray-400"></i>
        <% } %>
    </div>

    <h2 class="text-xl font-semibold text-[#1a1a1a] mb-3">
        <% if (statusCode === 404) { %>
            Resource Not Found
        <% } else if (statusCode === 403) { %>
             Access Denied
        <% } else { %>
             Oops! Something Went Wrong
        <% } %>
    </h2>

    <p class="text-gray-600 mb-4"><%= displayMessage %></p>

    <%# Optionally display more details in development %>
    <% if (process.env.NODE_ENV !== 'production' && typeof error !== 'undefined' && error && error.stack) { %>
        <pre class="text-left text-sm bg-[#f9f8f6] border border-[#0f2e22]/20 p-4 text-[#1a1a1a] max-h-64 overflow-y-auto whitespace-pre-wrap break-all mb-4"><%= error.stack %></pre>
    <% } %>

    <div class="flex items-center justify-center gap-3 mt-4">
        <a href="javascript:history.back()" class="inline-flex items-center gap-2 bg-white text-[#0f2e22] font-bold py-2 px-4 border border-[#0f2e22]/20 hover:bg-[#f9f8f6] text-xs uppercase tracking-widest">
            <i class="fas fa-arrow-left"></i> Go Back
        </a>
        <a href="/admin/dashboard" class="inline-flex items-center gap-2 bg-[#0f2e22] text-white font-bold py-2 px-4 border border-[#0f2e22] hover:bg-[#1a1a1a] text-xs uppercase tracking-widest">
            <i class="fas fa-tachometer-alt"></i> Go to Dashboard
        </a>
    </div>

     <p class="text-sm text-gray-500 mt-4">
         If the problem persists, please contact technical support or your administrator.
         <br>
         <% if (typeof errorId !== 'undefined' && errorId) { %>
              Error Reference: <%= errorId %>
         <% } %>
     </p>

</div>

<%- include('partials/footer') %>