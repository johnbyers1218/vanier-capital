<%# views/admin/error.ejs %>
<%# Generic Error Page for Admin Panel %>

<%# Set default title and message if not provided %>
<% const displayTitle = typeof pageTitle !== 'undefined' ? pageTitle : 'An Error Occurred'; %>
<% const displayMessage = typeof message !== 'undefined' ? message : 'An unexpected error occurred while processing your request.'; %>
<%# Determine a status code if possible (passed from route handler) %>
<% const statusCode = typeof status !== 'undefined' ? status : 500; %>

<%- include('partials/header', { pageTitle: displayTitle }) %> <%# Includes admin header/nav %>

<div class="max-w-2xl mx-auto my-8 p-8 bg-[#1a1a1a] border border-neutral-700 rounded-lg text-center">
    <div class="text-4xl mb-4">
        <% if (statusCode === 404) { %>
            <i class="fas fa-search text-yellow-400"></i>
        <% } else if (statusCode === 403) { %>
             <i class="fas fa-user-lock text-red-400"></i>
        <% } else if (statusCode >= 400 && statusCode < 500) { %>
            <i class="fas fa-exclamation-triangle text-yellow-400"></i>
        <% } else { %>
            <i class="fas fa-server text-gray-400"></i>
        <% } %>
    </div>

    <h2 class="text-xl font-semibold text-gray-100 mb-3">
        <% if (statusCode === 404) { %>
            Resource Not Found
        <% } else if (statusCode === 403) { %>
             Access Denied
        <% } else { %>
             Oops! Something Went Wrong
        <% } %>
    </h2>

    <p class="text-gray-300 mb-4"><%= displayMessage %></p>

    <%# Optionally display more details in development %>
    <% if (process.env.NODE_ENV !== 'production' && typeof error !== 'undefined' && error && error.stack) { %>
        <pre class="text-left text-sm bg-[#111] border border-neutral-700 rounded p-4 text-gray-300 max-h-64 overflow-y-auto whitespace-pre-wrap break-all mb-4"><%= error.stack %></pre>
    <% } %>

    <div class="flex items-center justify-center gap-3 mt-4">
        <a href="javascript:history.back()" class="inline-flex items-center gap-2 bg-neutral-700 text-gray-100 font-semibold py-2 px-4 rounded-md border border-neutral-600 shadow-sm hover:bg-neutral-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-arrow-left"></i> Go Back
        </a>
        <a href="/admin/dashboard" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-md shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-tachometer-alt"></i> Go to Dashboard
        </a>
    </div>

     <p class="error-support-info">
         If the problem persists, please contact technical support or your administrator.
         <br> <!-- Standard HTML line break -->
         <!-- Correctly check if errorId exists and has a value before displaying -->
         <% if (typeof errorId !== 'undefined' && errorId) { %>
              Error Reference: <%= errorId %>
         <% } %>
     </p>

</div>

<%- include('partials/footer') %> <%# Includes admin footer %>