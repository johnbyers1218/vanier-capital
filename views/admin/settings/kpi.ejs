<%- include('../partials/header', { pageTitle: 'KPI Manager' }) %>

<div class="max-w-3xl mx-auto">
  <div class="bg-white border border-[#0f2e22]/20">
    <div class="px-6 py-5 border-b border-[#0f2e22]/20">
      <h2 class="text-2xl font-bold text-[#1a1a1a]">KPI Manager</h2>
      <p class="text-gray-600 mt-1">Manage public KPIs and other site-wide values.</p>
    </div>

    <div class="p-6 space-y-6">

      <% if (Array.isArray(errorMessages) && errorMessages.length) { %>
        <div class="border border-red-300 bg-red-50 text-red-800 px-4 py-3">
          <p class="font-medium">Please correct the following errors:</p>
          <ul class="list-disc list-inside mt-2 space-y-1 text-sm">
            <% errorMessages.forEach(err => { %>
              <li><%= err.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (successMessage && successMessage.length) { %>
        <div class="bg-green-50 border-l-4 border-green-500 text-green-800 p-4">
          <%= successMessage %>
        </div>
      <% } %>

      <form method="POST" action="/admin/settings/kpi/save" class="space-y-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <!-- Occupancy Rate -->
        <div>
          <label for="occupancyRate" class="block text-sm font-semibold text-[#1a1a1a]">Occupancy Rate</label>
          <input type="text" id="occupancyRate" name="occupancyRate" value="<%= settings && settings.occupancyRate !== undefined ? settings.occupancyRate : '' %>" placeholder="e.g. 98%" class="mt-1 block w-full max-w-xs border border-[#0f2e22]/20 bg-white text-[#1a1a1a] placeholder-gray-400 font-medium focus:border-[#0f2e22] px-3 py-2">
          <p class="text-sm text-gray-600 mt-1">Portfolio-wide occupancy rate.</p>
          <hr class="mt-4 border-t border-[#0f2e22]/10">
        </div>

        <!-- Portfolio Cap Rate -->
        <div>
          <label for="capRate" class="block text-sm font-semibold text-[#1a1a1a]">Portfolio Cap Rate</label>
          <input type="text" id="capRate" name="capRate" value="<%= settings && settings.capRate !== undefined ? settings.capRate : '' %>" placeholder="e.g. 7.5%" class="mt-1 block w-full max-w-xs border border-[#0f2e22]/20 bg-white text-[#1a1a1a] placeholder-gray-400 font-medium focus:border-[#0f2e22] px-3 py-2">
          <p class="text-sm text-gray-600 mt-1">Average or target cap rate for the portfolio.</p>
          <hr class="mt-4 border-t border-[#0f2e22]/10">
        </div>

        <!-- Assets Under Management (AUM) -->
        <div>
          <label for="aum" class="block text-sm font-semibold text-[#1a1a1a]">Assets Under Management (AUM)</label>
          <input type="text" id="aum" name="aum" value="<%= settings && settings.aum !== undefined ? settings.aum : '' %>" placeholder="e.g. $50M+" class="mt-1 block w-full max-w-xs border border-[#0f2e22]/20 bg-white text-[#1a1a1a] placeholder-gray-400 font-medium focus:border-[#0f2e22] px-3 py-2">
          <p class="text-sm text-gray-600 mt-1">Total value of assets under management.</p>
          <hr class="mt-4 border-t border-[#0f2e22]/10">
        </div>

        <!-- Firm Inception Year -->
        <div>
          <label for="firmInceptionYear" class="block text-sm font-semibold text-[#1a1a1a]">Firm Inception Year</label>
          <input type="text" id="firmInceptionYear" name="firmInceptionYear" value="<%= settings && settings.firmInceptionYear !== undefined ? settings.firmInceptionYear : '' %>" placeholder="e.g. 2025" class="mt-1 block w-full max-w-xs border border-[#0f2e22]/20 bg-white text-[#1a1a1a] placeholder-gray-400 font-medium focus:border-[#0f2e22] px-3 py-2">
          <p class="text-sm text-gray-600 mt-1">Year the firm was founded (shown on Firm Overview).</p>
          <hr class="mt-4 border-t border-[#0f2e22]/10">
        </div>

        <!-- Maintenance Response -->
        <div>
          <label for="maintenanceResponse" class="block text-sm font-semibold text-[#1a1a1a]">Maintenance Response Time</label>
          <input type="text" id="maintenanceResponse" name="maintenanceResponse" value="<%= settings && settings.maintenanceResponse !== undefined ? settings.maintenanceResponse : '' %>" placeholder="e.g. <24hr" class="mt-1 block w-full max-w-xs border border-[#0f2e22]/20 bg-white text-[#1a1a1a] placeholder-gray-400 font-medium focus:border-[#0f2e22] px-3 py-2">
          <p class="text-sm text-gray-600 mt-1">Average maintenance response time (shown on Stewardship page).</p>
          <hr class="mt-4 border-t border-[#0f2e22]/10">
        </div>

        <!-- Avg Resident Tenure -->
        <div>
          <label for="avgResidentTenure" class="block text-sm font-semibold text-[#1a1a1a]">Avg. Resident Tenure</label>
          <input type="text" id="avgResidentTenure" name="avgResidentTenure" value="<%= settings && settings.avgResidentTenure !== undefined ? settings.avgResidentTenure : '' %>" placeholder="e.g. 18mo" class="mt-1 block w-full max-w-xs border border-[#0f2e22]/20 bg-white text-[#1a1a1a] placeholder-gray-400 font-medium focus:border-[#0f2e22] px-3 py-2">
          <p class="text-sm text-gray-600 mt-1">Average resident tenure across portfolio (shown on Stewardship page).</p>
          <hr class="mt-4 border-t border-[#0f2e22]/10">
        </div>

        <!-- Rent Collection Rate -->
        <div>
          <label for="rentCollectionRate" class="block text-sm font-semibold text-[#1a1a1a]">Rent Collection Rate</label>
          <input type="text" id="rentCollectionRate" name="rentCollectionRate" value="<%= settings && settings.rentCollectionRate !== undefined ? settings.rentCollectionRate : '' %>" placeholder="e.g. 98%" class="mt-1 block w-full max-w-xs border border-[#0f2e22]/20 bg-white text-[#1a1a1a] placeholder-gray-400 font-medium focus:border-[#0f2e22] px-3 py-2">
          <p class="text-sm text-gray-600 mt-1">Rent collection rate (shown on Stewardship page).</p>
        </div>

        <div class="pt-2 flex items-center gap-3 justify-end">
          <button type="submit" class="inline-flex items-center gap-2 bg-[#0f2e22] text-white font-bold py-2.5 px-5 border border-[#0f2e22] hover:bg-[#1a1a1a] text-xs uppercase tracking-widest">
            <i class="fas fa-save"></i>
            Save
          </button>
          <a href="/admin/settings" class="inline-flex items-center gap-2 bg-white text-[#0f2e22] font-bold py-2.5 px-5 border border-[#0f2e22]/20 hover:bg-[#f9f8f6] text-xs uppercase tracking-widest">
            <i class="fas fa-arrow-left"></i>
            Back to Settings
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
