<%- include('../partials/header', { pageTitle: 'KPI Manager' }) %>

<div class="max-w-3xl mx-auto">
  <div class="bg-neutral-700/70 rounded-xl shadow-lg border border-neutral-600">
    <div class="px-6 py-5 border-b border-neutral-600">
      <h2 class="text-2xl font-bold text-gray-100">KPI Manager</h2>
      <p class="text-gray-300 mt-1">Manage public KPIs and other site-wide values.</p>
    </div>

    <div class="p-6 space-y-6">

      <% if (Array.isArray(errorMessages) && errorMessages.length) { %>
        <div class="rounded-md border-l-4 border-red-500 bg-red-900/30 text-red-200 px-4 py-3">
          <p class="font-medium">Please correct the following errors:</p>
          <ul class="list-disc list-inside mt-2 space-y-1 text-sm">
            <% errorMessages.forEach(err => { %>
              <li><%= err.msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <% if (successMessage && successMessage.length) { %>
        <div class="bg-green-900/30 border-l-4 border-success text-green-200 p-4 rounded-md">
          <%= successMessage %>
        </div>
      <% } %>

      <form method="POST" action="/admin/settings/kpi/save" class="space-y-6">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <!-- Occupancy Rate -->
        <div>
          <label for="occupancyRate" class="block text-sm font-semibold text-gray-100">Occupancy Rate</label>
          <input type="text" id="occupancyRate" name="occupancyRate" value="<%= settings && settings.occupancyRate !== undefined ? settings.occupancyRate : '' %>" placeholder="e.g. 98%" style="color: #000000 !important; background-color: #ffffff !important;" class="mt-1 block w-full max-w-xs rounded-md border border-neutral-600 bg-white text-black placeholder-gray-500 font-medium focus:border-primary focus:ring-primary px-3 py-2">
          <p class="text-sm text-gray-300 mt-1">Portfolio-wide occupancy rate.</p>
          <hr class="mt-4 border-t border-neutral-600/60">
        </div>

        <!-- Portfolio Cap Rate -->
        <div>
          <label for="capRate" class="block text-sm font-semibold text-gray-100">Portfolio Cap Rate</label>
          <input type="text" id="capRate" name="capRate" value="<%= settings && settings.capRate !== undefined ? settings.capRate : '' %>" placeholder="e.g. 7.5%" style="color: #000000 !important; background-color: #ffffff !important;" class="mt-1 block w-full max-w-xs rounded-md border border-neutral-600 bg-white text-black placeholder-gray-500 font-medium focus:border-primary focus:ring-primary px-3 py-2">
          <p class="text-sm text-gray-300 mt-1">Average or target cap rate for the portfolio.</p>
          <hr class="mt-4 border-t border-neutral-600/60">
        </div>

        <!-- Assets Under Management (AUM) -->
        <div>
          <label for="aum" class="block text-sm font-semibold text-gray-100">Assets Under Management (AUM)</label>
          <input type="text" id="aum" name="aum" value="<%= settings && settings.aum !== undefined ? settings.aum : '' %>" placeholder="e.g. $50M+" style="color: #000000 !important; background-color: #ffffff !important;" class="mt-1 block w-full max-w-xs rounded-md border border-neutral-600 bg-white text-black placeholder-gray-500 font-medium focus:border-primary focus:ring-primary px-3 py-2">
          <p class="text-sm text-gray-300 mt-1">Total value of assets under management.</p>
        </div>

        <div class="pt-2 flex items-center gap-3 justify-end">
          <button type="submit" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2.5 px-5 rounded-md shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-save"></i>
            Save
          </button>
          <a href="/admin/settings" class="inline-flex items-center gap-2 bg-transparent text-gray-100 font-semibold py-2.5 px-5 rounded-md border border-gray-500 hover:bg-neutral-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
            <i class="fas fa-arrow-left"></i>
            Back to Settings
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
