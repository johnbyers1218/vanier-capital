<%- include('../partials/header', { pageTitle: 'Team Management' }) %>

<div class="max-w-5xl mx-auto space-y-6">
  <!-- Header Bar -->
  <div class="flex items-center justify-between border-b border-[#0f2e22]/20 pb-4">
    <div>
      <h1 class="text-2xl font-bold text-[#1a1a1a]">Team Management</h1>
      <p class="text-gray-500 text-sm mt-1">Administrative users and access control.</p>
    </div>
    <div class="flex items-center gap-3">
      <a href="/admin/settings" class="inline-flex items-center gap-2 bg-white text-[#0f2e22] font-bold py-2.5 px-5 border border-[#0f2e22]/20 hover:bg-[#f9f8f6] text-xs uppercase tracking-widest">
        <i class="fas fa-arrow-left"></i> Back
      </a>
    </div>
  </div>

  <!-- Team Table -->
  <div class="bg-white border border-[#0f2e22]/20">
    <table class="w-full text-left">
      <thead>
        <tr class="bg-[#f9f8f6] border-b border-[#0f2e22]/20">
          <th class="px-6 py-4 text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">User</th>
          <th class="px-6 py-4 text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Role</th>
          <th class="px-6 py-4 text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Last Login</th>
        </tr>
      </thead>
      <tbody>
        <% (teamUsers || []).forEach(function(u){ %>
          <tr class="bg-white border-b border-gray-200 hover:bg-gray-50">
            <td class="px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 overflow-hidden bg-gray-200 flex items-center justify-center text-gray-500 shrink-0">
                  <% if (u.avatarUrl) { %>
                    <img src="<%= u.avatarUrl %>" alt="<%= u.fullName || u.username %>" class="w-full h-full object-cover">
                  <% } else { %>
                    <i class="fas fa-user text-sm"></i>
                  <% } %>
                </div>
                <div class="min-w-0">
                  <p class="font-semibold text-[#1a1a1a] truncate"><%= u.fullName || u.username %></p>
                  <p class="text-xs text-gray-500"><%= u.username %></p>
                </div>
              </div>
            </td>
            <td class="px-6 py-4">
              <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-widest border <%= u.role === 'admin' ? 'bg-[#0f2e22]/5 text-[#0f2e22] border-[#0f2e22]/20' : 'bg-gray-100 text-gray-600 border-gray-200' %>"><%= u.role %></span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600">
              <% if (u.lastLogin) { %>
                <%= new Date(u.lastLogin).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                <span class="text-xs text-gray-400 ml-1"><%= new Date(u.lastLogin).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
              <% } else { %>
                <span class="text-gray-400">Never</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
        <% if (!teamUsers || teamUsers.length === 0) { %>
          <tr>
            <td colspan="3" class="px-6 py-12 text-center text-gray-500">No team members found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Info Box -->
  <div class="bg-[#0f2e22]/5 border border-[#0f2e22]/20 p-4">
    <p class="text-xs text-gray-600"><strong class="text-[#1a1a1a]">Note:</strong> Authentication and team access control are managed via Clerk. To invite new administrators, enforce 2FA, or revoke access, visit your <a href="https://dashboard.clerk.com" target="_blank" rel="noopener noreferrer" class="text-[#0f2e22] underline hover:no-underline">Clerk Dashboard</a>.</p>
  </div>
</div>

<%- include('../partials/footer') %>
