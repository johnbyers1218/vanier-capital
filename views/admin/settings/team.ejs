<%- include('../partials/header', { pageTitle: 'Team Management' }) %>

<div class="max-w-4xl mx-auto space-y-6">
  <div class="rounded-lg border border-neutral-700 bg-[#1a1a1a] p-6">
    <h2 class="text-xl font-semibold text-gray-100 mb-4">Team Members</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <% (teamUsers || []).forEach(function(u){ %>
        <div class="flex items-center gap-3 p-3 rounded-md border border-neutral-700 bg-[#1a1a1a]/40">
          <div class="w-12 h-12 rounded-full overflow-hidden bg-neutral-700 flex items-center justify-center text-gray-300">
            <% if (u.avatarUrl) { %>
              <img src="<%= u.avatarUrl %>" alt="<%= u.fullName || u.username %>" class="w-full h-full object-cover" />
            <% } else { %>
              <i class="fas fa-user"></i>
            <% } %>
          </div>
          <div class="min-w-0">
            <div class="font-medium truncate"><%= u.fullName || u.username %></div>
            <div class="text-xs text-gray-400 uppercase tracking-wide"><%= u.role %></div>
          </div>
        </div>
      <% }) %>
      <% if (!teamUsers || teamUsers.length === 0) { %>
        <p class="text-gray-400">No team members found.</p>
      <% } %>
    </div>
    <div class="mt-4 text-sm text-gray-400">Role editing UI can be added here (promote/demote), and avatar can be updated if necessary.</div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <a href="/admin/settings" class="inline-flex items-center gap-2 bg-transparent text-gray-100 font-semibold py-2.5 px-5 rounded-md border border-gray-500 hover:bg-neutral-700">
      <i class="fas fa-arrow-left"></i>
      Back to Settings
    </a>
  </div>
</div>

<%- include('../partials/footer') %>
