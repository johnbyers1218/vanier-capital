<%- include('../partials/header', { pageTitle }) %>
<section class="max-w-3xl mx-auto bg-gray-700/40 border border-gray-700 rounded-lg shadow-sm p-6">
  <h2 class="text-2xl font-semibold mb-4"><%= pageTitle %></h2>

  <!-- Info box for Industries/Services guidance -->
  <div class="mb-4 rounded-md border border-blue-800/60 bg-blue-900/20 text-blue-200 p-4 flex gap-3">
    <i class="fa-solid fa-circle-info mt-0.5"></i>
    <p class="text-sm leading-6">
      These curated <%= entity === 'industry' ? 'Industries' : 'Services' %> power the public filters and badges on Projects.
      Keep names concise and use a clear, lowercase hyphenated slug.
    </p>
  </div>

  <% if (typeof errorMessages !== 'undefined' && errorMessages && errorMessages.length > 0) { %>
    <div class="rounded-md border-l-4 border-red-500 bg-red-900/30 text-red-200 px-4 py-3 text-sm mb-4" role="alert" aria-live="assertive">
      <p class="font-medium mb-2">Please correct the following errors:</p>
      <ul class="list-disc list-inside space-y-1">
        <% errorMessages.forEach(err => { %>
          <li><strong><%= err.param %>:</strong> <%= err.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form action="<%= editing ? path + '/edit/' + item._id : path %>" method="POST" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div>
      <label for="name" class="block text-sm mb-1">Name</label>
      <input type="text" id="name" name="name" value="<%= item && item.name ? item.name : '' %>" required maxlength="80" class="w-full bg-gray-900 border border-gray-700 rounded-md px-3 py-2 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
    </div>

    <div>
      <label for="slug" class="block text-sm mb-1">Slug</label>
      <input type="text" id="slug" name="slug" value="<%= item && item.slug ? item.slug : '' %>" required maxlength="120" pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$" class="w-full bg-gray-900 border border-gray-700 rounded-md px-3 py-2 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="auto-generated from name">
      <p class="text-xs text-gray-400 mt-1">Lowercase, hyphen-separated. Example: real-estate, workflow-automation</p>
    </div>

    <div>
      <label class="block text-sm mb-1">Active</label>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="isActive" name="isActive" class="sr-only" <%= item && item.isActive ? 'checked' : '' %>>
        <button type="button" id="isActiveToggle" class="inline-flex items-center w-12 h-6 rounded-full border border-gray-600 <%= item && item.isActive ? 'bg-blue-600' : 'bg-gray-600' %>" aria-pressed="<%= item && item.isActive ? 'true' : 'false' %>" aria-label="Toggle Active">
          <span id="isActiveKnob" class="block h-5 w-5 bg-white rounded-full shadow"></span>
        </button>
        <label for="isActive" class="text-sm select-none"><%= (item && item.isActive) ? 'Active' : 'Hidden' %></label>
      </div>
    </div>

    <div class="pt-2 flex items-center gap-2">
      <button type="submit" class="cta-button primary-btn">
        <i class="fa-solid fa-floppy-disk"></i>
        <span><%= editing ? 'Update' : 'Create' %></span>
      </button>
      <a href="<%= path %>" class="cta-button secondary-btn">
        <i class="fa-solid fa-xmark"></i>
        <span>Cancel</span>
      </a>
    </div>
  </form>
</section>

<script>
  // Slug auto-generation with manual override
  (function(){
    const nameEl = document.getElementById('name');
    const slugEl = document.getElementById('slug');
    if (!nameEl || !slugEl) return;
    let slugDirty = false;
    slugEl.addEventListener('input', () => { slugDirty = true; });
    function slugify(str){
      return String(str || '')
        .toLowerCase()
        .replace(/&/g, ' and ')
        .normalize('NFKD').replace(/[\u0300-\u036f]/g,'')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }
    nameEl.addEventListener('input', () => {
      if (slugDirty) return;
      slugEl.value = slugify(nameEl.value);
    });
  })();

  // Accessible toggle switch bound to hidden checkbox
  (function(){
    const cb = document.getElementById('isActive');
    const btn = document.getElementById('isActiveToggle');
    const knob = document.getElementById('isActiveKnob');
    if (!cb || !btn || !knob) return;
    function sync(){
      const on = cb.checked;
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      btn.classList.toggle('bg-blue-600', on);
      btn.classList.toggle('bg-gray-600', !on);
      knob.style.marginLeft = on ? 'calc(100% - 1.375rem)' : '0.125rem';
    }
    btn.addEventListener('click', () => { cb.checked = !cb.checked; sync(); });
    cb.addEventListener('change', sync);
    sync();
  })();
</script>
