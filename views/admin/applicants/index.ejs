<%- include('../partials/header', { pageTitle: 'Investor Applicants' }) %>

<div class="space-y-6">
  <!-- Header -->
  <div class="flex items-center justify-between border-b border-[#0f2e22]/20 pb-4">
    <div>
      <h1 class="text-2xl font-bold text-[#1a1a1a]">Investor Applicants</h1>
      <p class="text-gray-500 text-sm mt-1">Accreditation requests from the public investor application form.</p>
    </div>
    <span class="text-sm text-gray-500"><%= statusCounts.All || 0 %> total</span>
  </div>

  <% if (typeof successMessage !== 'undefined' && successMessage && successMessage.length) { %>
    <div class="bg-green-50 border-l-4 border-green-500 text-green-800 p-4 text-sm"><%= successMessage %></div>
  <% } %>
  <% if (typeof errorMessage !== 'undefined' && errorMessage && errorMessage.length) { %>
    <div class="border border-red-300 bg-red-50 text-red-800 p-4 text-sm"><%= errorMessage %></div>
  <% } %>

  <!-- Status Filter Bar -->
  <div class="flex items-center gap-2 flex-wrap">
    <% const statuses = ['All','New','Contacted','Qualified','Closed','Archived']; %>
    <% statuses.forEach(function(s) { %>
      <a href="/admin/applicants<%= s === 'All' ? '' : '?status=' + s %>"
         class="font-sans text-xs font-bold uppercase tracking-widest px-4 py-2 border transition-colors no-underline
                <%= activeStatus === s ? 'bg-[#0f2e22] text-white border-[#0f2e22]' : 'bg-white text-[#1a1a1a] border-[#0f2e22]/20 hover:bg-[#f9f8f6]' %>">
        <%= s %><% if (typeof statusCounts[s] !== 'undefined') { %> (<%= statusCounts[s] %>)<% } %>
      </a>
    <% }); %>
  </div>

  <% if (!applicants || applicants.length === 0) { %>
    <div class="bg-white border border-[#0f2e22]/20 p-12 text-center">
      <p class="text-gray-500 text-sm">No applicants found<%= activeStatus !== 'All' ? ' with status "' + activeStatus + '"' : '' %>.</p>
    </div>
  <% } else { %>

  <!-- Table -->
  <div class="bg-white border border-[#0f2e22]/20 overflow-x-auto">
    <table class="w-full text-left">
      <thead>
        <tr class="bg-[#0f2e22] text-white">
          <th class="font-sans text-[10px] font-bold uppercase tracking-widest px-4 py-3">Name</th>
          <th class="font-sans text-[10px] font-bold uppercase tracking-widest px-4 py-3">Email</th>
          <th class="font-sans text-[10px] font-bold uppercase tracking-widest px-4 py-3">Type</th>
          <th class="font-sans text-[10px] font-bold uppercase tracking-widest px-4 py-3">Capital</th>
          <th class="font-sans text-[10px] font-bold uppercase tracking-widest px-4 py-3">Accredited</th>
          <th class="font-sans text-[10px] font-bold uppercase tracking-widest px-4 py-3">Status</th>
          <th class="font-sans text-[10px] font-bold uppercase tracking-widest px-4 py-3">Date</th>
          <th class="font-sans text-[10px] font-bold uppercase tracking-widest px-4 py-3 text-right">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% applicants.forEach(function(a) { %>
        <tr class="hover:bg-[#f9f8f6] transition-colors">
          <td class="px-4 py-3 font-sans text-sm font-medium text-[#1a1a1a] whitespace-nowrap"><%= a.fullName %></td>
          <td class="px-4 py-3 font-sans text-sm text-gray-600 whitespace-nowrap"><%= a.email %></td>
          <td class="px-4 py-3 font-sans text-xs uppercase tracking-wider text-gray-500 whitespace-nowrap"><%= a.investorType %></td>
          <td class="px-4 py-3 font-sans text-sm text-gray-600 whitespace-nowrap"><%= a.capitalInterest || '—' %></td>
          <td class="px-4 py-3 whitespace-nowrap">
            <% if (a.accredited) { %>
              <span class="inline-block bg-green-100 text-green-800 text-[10px] font-bold uppercase tracking-widest px-2 py-1">Yes</span>
            <% } else { %>
              <span class="inline-block bg-red-100 text-red-800 text-[10px] font-bold uppercase tracking-widest px-2 py-1">No</span>
            <% } %>
          </td>
          <td class="px-4 py-3 whitespace-nowrap">
            <%
              const statusColors = {
                'New': 'bg-blue-100 text-blue-800',
                'Contacted': 'bg-yellow-100 text-yellow-800',
                'Qualified': 'bg-green-100 text-green-800',
                'Closed': 'bg-gray-100 text-gray-600',
                'Archived': 'bg-gray-100 text-gray-400'
              };
              const sc = statusColors[a.status] || 'bg-gray-100 text-gray-600';
            %>
            <span class="inline-block text-[10px] font-bold uppercase tracking-widest px-2 py-1 <%= sc %>"><%= a.status %></span>
          </td>
          <td class="px-4 py-3 font-sans text-xs text-gray-400 whitespace-nowrap"><%= new Date(a.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
          <td class="px-4 py-3 text-right whitespace-nowrap">
            <a href="/admin/applicants/<%= a._id %>" class="font-sans text-xs font-bold uppercase tracking-widest text-[#0f2e22] hover:underline no-underline">Review</a>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
