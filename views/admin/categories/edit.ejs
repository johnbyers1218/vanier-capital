<%- include('../partials/header', { pageTitle: editing ? 'Edit Category' : 'New Category' }) %>
<section class="max-w-3xl mx-auto bg-gray-700/40 border border-gray-700 rounded-lg shadow-sm p-6">
  <h2 class="text-2xl font-semibold mb-4"><%= editing ? 'Edit Category' : 'New Category' %></h2>

  <% if (errorMessages && errorMessages.length) { %>
    <div class="rounded-md border-l-4 border-red-500 bg-red-900/30 text-red-200 px-4 py-3 text-sm mb-4" role="alert">
      <ul class="list-disc list-inside space-y-1">
        <% errorMessages.forEach(e => { %>
          <li><%= e.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form class="space-y-4" action="<%= editing ? '/admin/categories/edit/' + category._id : '/admin/categories' %>" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div>
      <label for="name" class="block text-sm mb-1">Name</label>
      <input id="name" name="name" type="text" required maxlength="100" value="<%= category && category.name ? category.name : '' %>" class="w-full bg-gray-900 border border-gray-700 rounded-md px-3 py-2 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
    </div>
    <div>
      <label for="slug" class="block text-sm mb-1">Slug</label>
      <input id="slug" name="slug" type="text" required pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$" value="<%= category && category.slug ? category.slug : '' %>" class="w-full bg-gray-900 border border-gray-700 rounded-md px-3 py-2 text-gray-100 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="auto-generated from name">
      <p class="text-xs text-gray-400 mt-1">Lowercase with hyphens. Example: marketing-ops</p>
    </div>
    <div>
      <label class="block text-sm mb-1">Active</label>
      <div class="flex items-center gap-3">
        <input type="checkbox" id="isActive" name="isActive" class="sr-only" <%= category && category.isActive ? 'checked' : '' %> >
        <button type="button" id="isActiveToggle" class="inline-flex items-center w-12 h-6 rounded-full border border-gray-600 <%= category && category.isActive ? 'bg-blue-600' : 'bg-gray-600' %>" aria-pressed="<%= category && category.isActive ? 'true' : 'false' %>" aria-label="Toggle Active">
          <span id="isActiveKnob" class="block h-5 w-5 bg-white rounded-full shadow"></span>
        </button>
        <label class="text-sm select-none" for="isActive"><%= category && category.isActive ? 'Active' : 'Hidden' %></label>
      </div>
    </div>

    <div class="pt-2 flex items-center gap-2">
      <button type="submit" class="cta-button primary-btn">
        <i class="fa-solid fa-floppy-disk"></i>
        <span><%= editing ? 'Update' : 'Create' %></span>
      </button>
      <a href="/admin/categories" class="cta-button secondary-btn">
        <i class="fa-solid fa-xmark"></i>
        <span>Cancel</span>
      </a>
    </div>
  </form>
</section>
<%- include('../partials/footer') %>

<script>
  // Slug auto-generation with manual override
  (function(){
    const nameEl = document.getElementById('name');
    const slugEl = document.getElementById('slug');
    if (!nameEl || !slugEl) return;
    let slugDirty = false;
    slugEl.addEventListener('input', () => { slugDirty = true; });
    function slugify(str){
      return String(str || '')
        .toLowerCase()
        .replace(/&/g, ' and ')
        .normalize('NFKD').replace(/[\u0300-\u036f]/g,'')
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }
    nameEl.addEventListener('input', () => {
      if (slugDirty) return;
      slugEl.value = slugify(nameEl.value);
    });
  })();

  // Accessible toggle switch bound to hidden checkbox
  (function(){
    const cb = document.getElementById('isActive');
    const btn = document.getElementById('isActiveToggle');
    const knob = document.getElementById('isActiveKnob');
    if (!cb || !btn || !knob) return;
    function sync(){
      const on = cb.checked;
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      btn.classList.toggle('bg-blue-600', on);
      btn.classList.toggle('bg-gray-600', !on);
      knob.style.marginLeft = on ? 'calc(100% - 1.375rem)' : '0.125rem';
    }
    btn.addEventListener('click', () => { cb.checked = !cb.checked; sync(); });
    cb.addEventListener('change', sync);
    sync();
  })();
</script>
