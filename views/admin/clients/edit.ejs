<%# views/admin/clients/edit.ejs %>
<%# Form for adding or editing a client %>

<%- include('../partials/header', { pageTitle: (editing ? 'Edit Client' : 'Add New Client') }) %>

<div class="max-w-3xl mx-auto space-y-6">
	<div>
		<h2 class="text-2xl font-bold text-gray-100"><%= editing ? 'Edit Client' : 'Add New Client' %></h2>
		<p class="text-gray-400 mt-1">Provide client details. Logo is optional.</p>
	</div>

	<% if (typeof errorMessages !== 'undefined' && errorMessages && errorMessages.length > 0) { %>
		<div class="rounded-md border-l-4 border-red-500 bg-red-900/30 text-red-200 px-4 py-3">
			<p class="font-medium">Please correct the following errors:</p>
			<ul class="list-disc list-inside mt-2 space-y-1 text-sm">
				<% errorMessages.forEach(err => { %>
					<li><%= err.msg %> <%= err.param ? '('+err.param+')' : '' %></li>
				<% }) %>
			</ul>
		</div>
	<% } %>

	<form action="<%= editing && clientData && clientData._id ? ('/admin/clients/edit/' + clientData._id) : '/admin/clients' %>" method="POST" enctype="multipart/form-data" class="space-y-5 admin-form">
		<input type="hidden" name="_csrf" value="<%= csrfToken %>">

		<div>
			<label for="name" class="block text-sm font-medium text-gray-200">Client Name <span class="text-red-400">*</span></label>
			<input type="text" id="name" name="name" required minlength="3" maxlength="100" value="<%= clientData && clientData.name ? clientData.name : '' %>"
				class="mt-1" aria-describedby="name-help">
			<p id="name-help" class="help-text mt-1">3–100 characters. Must be unique.</p>
		</div>

		<div>
			<label for="logoFile" class="block text-sm font-medium text-gray-200">Client Logo (Optional)</label>
			<% if (editing && clientData && clientData.logoUrl) { %>
				<div class="mt-2">
					<img src="<%= clientData.logoUrl %>" alt="Current Logo" class="max-h-16 bg-white p-1 rounded border border-gray-700">
				</div>
			<% } %>
			<input type="hidden" id="logoUrl" name="logoUrl" value="<%= clientData && clientData.logoUrl ? clientData.logoUrl : '' %>">
			<input type="hidden" id="logoPublicId" name="logoPublicId" value="<%= clientData && clientData.logoPublicId ? clientData.logoPublicId : '' %>">
			<input type="hidden" id="removeLogo" name="removeLogo" value="false">
			<div class="mt-2 flex flex-wrap items-center gap-3">
				<input type="file" id="logoFile" name="logoFile" accept="image/jpeg,image/png,image/gif,image/webp,image/svg+xml" class="block w-full sm:w-auto text-sm text-gray-300 file:mr-3 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-gray-700 file:text-gray-100 hover:file:bg-gray-600 cursor-pointer" aria-describedby="logo-help">
				<button type="button" id="uploadLogoBtn" class="inline-flex items-center gap-2 bg-gray-700 text-gray-100 font-semibold py-2 px-4 rounded-md border border-gray-600 shadow-sm hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
					<i class="fas fa-cloud-upload-alt"></i>
					Upload
				</button>
				<% if (editing) { %>
				<button type="button" id="removeLogoBtn" class="inline-flex items-center gap-2 bg-red-700 text-white font-semibold py-2 px-4 rounded-md border border-red-600 shadow-sm hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-400">
					<i class="fas fa-times-circle"></i>
					Remove Logo
				</button>
				<% } %>
				<span id="uploadLogoStatus" class="text-sm text-gray-400"></span>
			</div>
			<div id="logoPreview" class="mt-2">
				<% if (clientData && clientData.logoUrl) { %>
					<img src="<%= clientData.logoUrl %>" alt="Logo Preview" class="max-h-16 bg-white p-1 rounded border border-gray-700">
				<% } %>
			</div>
			<p id="logo-help" class="mt-1 text-xs text-gray-400">Upload a logo (Max 5MB). Supported types: JPG, PNG, GIF, WEBP, SVG.</p>
		</div>

		<div>
			<label for="websiteUrl" class="block text-sm font-medium text-gray-200">Website URL (Optional)</label>
			<input type="url" id="websiteUrl" name="websiteUrl" placeholder="https://client-website.com" value="<%= clientData && clientData.websiteUrl ? clientData.websiteUrl : '' %>"
				class="mt-1 block w-full rounded-md border-gray-700 bg-gray-800 text-gray-100 placeholder-gray-500 focus:border-primary focus:ring-primary">
		</div>

		<div class="form-row two-col">
			<div>
				<label for="companyValuation" class="block text-sm font-medium text-gray-200">Company Valuation (USD, Optional)</label>
				<input type="number" id="companyValuation" name="companyValuation" min="0" step="1" placeholder="e.g., 25000000" value="<%= (clientData && clientData.companyValuation) ? clientData.companyValuation : '' %>"
					class="mt-1" aria-describedby="valuation-help">
				<p id="valuation-help" class="help-text mt-1">Enter as a whole number in USD (e.g., 25000000 for $25M).</p>
			</div>
			<div>
				<label for="annualRevenue" class="block text-sm font-medium text-gray-200">Annual Revenue (USD, Optional)</label>
				<input type="number" id="annualRevenue" name="annualRevenue" min="0" step="1" placeholder="e.g., 5000000" value="<%= (clientData && clientData.annualRevenue) ? clientData.annualRevenue : '' %>"
					class="mt-1" aria-describedby="revenue-help">
				<p id="revenue-help" class="help-text mt-1">Enter as a whole number in USD (e.g., 5000000 for $5M).</p>
			</div>
		</div>

		<div>
			<label for="industry" class="block text-sm font-medium text-gray-200">Industry (curated)</label>
			<select id="industry" name="industry" class="mt-1 block w-full rounded-md border-gray-700 bg-gray-800 text-gray-100 focus:border-primary focus:ring-primary">
				<option value="">— Select an industry —</option>
				<% if (Array.isArray(industries)) { %>
					<% industries.forEach(ind => { %>
						<option value="<%= ind.name %>" <%= (clientData && clientData.industry === ind.name) ? 'selected' : '' %>><%= ind.name %></option>
					<% }) %>
				<% } %>
			</select>
			<p class="help-text mt-1">Used for analytics and the public metrics counter (Industries Served). Manage options in Admin > Industries.</p>
		</div>

		<div>
			<label for="location" class="block text-sm font-medium text-gray-200">Location (for public map)</label>
			<input type="text" id="location" name="location" placeholder="e.g., New York, NY, United States or United Kingdom" value="<%= clientData && clientData.location ? clientData.location : '' %>"
				class="mt-1" aria-describedby="location-help">
			<p id="location-help" class="help-text mt-1">Use a city + country, state + country, or just a country. Examples: "London, United Kingdom", "California, United States", "Singapore".</p>
		</div>

		<div class="checkbox-inline">
			<input type="checkbox" id="isPubliclyVisible" name="isPubliclyVisible" <%= (clientData && clientData.isPubliclyVisible) ? 'checked' : '' %>>
			<label for="isPubliclyVisible" class="text-sm">Show this client publicly</label>
		</div>

		<div class="flex items-center gap-3 pt-2">
			<button type="submit" class="inline-flex items-center gap-2 bg-primary text-white font-semibold py-2 px-4 rounded-md shadow-sm hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
				<i class="fas fa-save"></i>
				<%= editing ? 'Update Client' : 'Save New Client' %>
			</button>
			<a href="/admin/clients" class="inline-flex items-center gap-2 bg-gray-700 text-gray-100 font-semibold py-2 px-4 rounded-md border border-gray-600 shadow-sm hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">Cancel</a>
		</div>
	</form>
</div>

<%- include('../partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
	const uploadBtn = document.getElementById('uploadLogoBtn');
	const fileInput = document.getElementById('logoFile');
	const statusEl = document.getElementById('uploadLogoStatus');
	const logoUrlInput = document.getElementById('logoUrl');
	const preview = document.getElementById('logoPreview');
	const form = document.querySelector('form.admin-form');
	const logoPublicIdInput = document.getElementById('logoPublicId');
	const removeLogoInput = document.getElementById('removeLogo');
	const removeBtn = document.getElementById('removeLogoBtn');

	if (uploadBtn && fileInput && statusEl && logoUrlInput && form) {
		uploadBtn.addEventListener('click', async () => {
			statusEl.textContent = '';
			const file = fileInput.files && fileInput.files[0];
			if (!file) { statusEl.textContent = 'Select a file first.'; return; }

			const max = 5 * 1024 * 1024;
			const allowed = ['image/jpeg','image/png','image/gif','image/webp','image/svg+xml'];
			if (!allowed.includes(file.type)) { statusEl.textContent = 'Invalid file type.'; return; }
			if (file.size > max) { statusEl.textContent = 'File too large (max 5MB).'; return; }

			const data = new FormData();
			data.append('logoFile', file);
			const csrf = form.querySelector('input[name="_csrf"]').value;
			statusEl.textContent = 'Uploading...';
			try {
				const resp = await fetch('/admin/clients/upload-logo', {
					method: 'POST',
					body: data,
					headers: { 'CSRF-Token': csrf }
				});
				const json = await resp.json();
				if (resp.ok && json.success && json.location) {
					logoUrlInput.value = json.location;
					if (json.publicId) { logoPublicIdInput.value = json.publicId; }
					if (removeLogoInput) removeLogoInput.value = 'false';
					preview.innerHTML = `<img src="${json.location}" alt="Logo Preview" class="max-h-16 bg-white p-1 rounded border border-gray-700" />`;
					statusEl.textContent = 'Upload successful!';
					statusEl.className = 'text-sm text-green-300';
				} else {
					statusEl.textContent = json.message || 'Upload failed';
					statusEl.className = 'text-sm text-red-300';
				}
			} catch (e) {
				console.error('Logo upload error', e);
				statusEl.textContent = 'Network error during upload.';
				statusEl.className = 'text-sm text-red-300';
			}
		});
	}

	if (removeBtn && removeLogoInput && preview && logoUrlInput && logoPublicIdInput) {
		removeBtn.addEventListener('click', () => {
			// Clear fields and mark for removal on submit
			logoUrlInput.value = '';
			logoPublicIdInput.value = '';
			removeLogoInput.value = 'true';
			preview.innerHTML = '';
			if (statusEl) { statusEl.textContent = 'Logo will be removed on save.'; statusEl.className = 'text-sm text-yellow-300'; }
		});
	}
});
</script>
