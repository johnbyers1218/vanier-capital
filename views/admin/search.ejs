<%- include('partials/header', { pageTitle }) %>

<div class="space-y-6">
	<form action="/admin/search" method="get" class="flex items-center gap-2">
		<input type="search" name="q" value="<%= q || '' %>" placeholder="Search..." class="w-full px-3 py-2 rounded-md bg-gray-700 text-gray-100 placeholder-gray-400 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-primary" />
		<button class="px-3 py-2 rounded-md bg-primary text-white">Search</button>
	</form>

	<% if ((results||[]).length === 0) { %>
		<p class="text-gray-400">No results.</p>
	<% } else { %>
		<ul class="divide-y divide-gray-800 rounded-md border border-gray-800">
			<% results.forEach(function(r){ %>
				<li class="p-3 flex items-center justify-between">
					<div>
						<div class="text-xs text-gray-400"><%= r.type %></div>
						<div class="font-medium"><%= r.title %></div>
					</div>
					<a href="<%= r.href %>" class="text-primary hover:underline">Open</a>
				</li>
			<% }) %>
		</ul>
	<% } %>
</div>

<%- include('partials/footer') %>
