<%# views/admin/blog/edit.ejs %>
<%# Two-column editor layout with settings sidebar & enhanced UX %>

<%- include('../partials/header', { pageTitle: editing ? 'Edit Perspective' : 'Add New Perspective' }) %>

<style>
  /* Two-column editor layout */
  .editor-container { max-width: 1280px; margin: 0 auto; padding: 0 1rem 2rem; }
  .editor-title { text-align: center; margin: 1.25rem 0 1.75rem; }
  .editor-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 1.25rem; align-items: start; }
  @media (max-width: 1024px) { .editor-grid { grid-template-columns: 1fr; } }
  .editor-card { background: #ffffff; border: 1px solid rgba(15,46,34,0.2); border-radius: 0; padding: 1rem; }
  .editor-main .form-group { margin-bottom: 1rem; }
  .editor-sidebar details { border: 1px solid rgba(15,46,34,0.2); border-radius: 0; background: #ffffff; }
  .editor-sidebar details + details { margin-top: 0.75rem; }
  .editor-sidebar summary { cursor: pointer; list-style: none; padding: 0.85rem 1rem; font-weight: 600; display: flex; align-items: center; justify-content: space-between; color: #1a1a1a; }
  .editor-sidebar summary::-webkit-details-marker { display: none; }
  .editor-sidebar .panel-body { padding: 0.5rem 1rem 1rem; }
  .muted { color: #6b7280; font-size: 0.9em; }
  .toggle-row { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.5rem; }
  .toggle-label { margin-left: 0.5rem; font-size: 0.95em; }

  /* Buttons hierarchy */
  .actions { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; margin-top: 1.25rem; }
  .btn { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1rem; border-radius: 0; text-decoration: none; border: 1px solid transparent; font-weight: 600; }
  .btn-primary { background: #0f2e22; color: white; border-color: #0f2e22; }
  .btn-secondary-outline { background: #ffffff; color: #0f2e22; border-color: rgba(15,46,34,0.2); }
  .btn-secondary-outline:hover { background: #f9f8f6; }
  .btn-danger { background: rgba(239,68,68,0.1); color: #ef4444; border-color: rgba(239,68,68,0.35); padding: 0.35rem 0.6rem; font-size: 0.85em; }

  /* Image preview */
  .image-preview img { max-width: 320px; max-height: 220px; border-radius: 0; display:block; }

  /* Choices overrides moved to admin-style.css */
</style>

<div class="editor-container">
  <h2 class="editor-title" style="color: #1a1a1a;"><%= editing ? 'Edit Perspective' : 'Add New Perspective' %></h2>

  <% if (typeof errorMessages !== 'undefined' && errorMessages && errorMessages.length > 0) { %>
    <div class="validation-errors editor-card" role="alert" aria-live="polite">
  <p><strong>Please correct the following errors:</strong></p>
  <ul><% errorMessages.forEach(err => { %><li><%= err.msg %> <%= err.param ? '('+err.param+')' : '' %></li><% }) %></ul>
    </div>
  <% } %>

  <form action="<%= editing ? '/admin/blog/edit/' + post._id : '/admin/blog' %>" method="POST" class="admin-form" id="blogPostForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="editor-grid">
      <!-- Left: Main Content -->
      <div class="editor-main editor-card" aria-label="Main editor">
        <div class="form-group">
          <label for="publicationType">Publication Type <span style="color:#dc3545">*</span></label>
          <select id="publicationType" name="publicationType" style="border-radius:0; border:1px solid rgba(15,46,34,0.2); padding:0.5rem 0.75rem; width:100%; font-size:0.95rem; outline:none;" onfocus="this.style.boxShadow='0 0 0 2px #0f2e22'" onblur="this.style.boxShadow='none'">
            <% const pubTypes = ['Market Research', 'Case Studies', 'Firm Updates']; %>
            <% pubTypes.forEach(function(pt) { %>
              <option value="<%= pt %>" <%= (post && post.publicationType === pt) ? 'selected' : '' %>><%= pt %></option>
            <% }); %>
          </select>
          <small class="muted">Classifies this publication for public filtering and the research index.</small>
        </div>

        <div class="form-group">
          <label for="title">Publication Title <span style="color:#dc3545">*</span></label>
          <input type="text" id="title" name="title" value="<%= post && post.title ? post.title : '' %>" required maxlength="200">
        </div>

        <div class="form-group">
          <label for="subtitle">Subtitle</label>
          <input type="text" id="subtitle" name="subtitle" value="<%= post && post.subtitle ? post.subtitle : '' %>" maxlength="300" placeholder="e.g. A Deep Dive into Southeast Multifamily Fundamentals">
          <small class="muted">Optional: Appears below the title on the article page.</small>
        </div>

        <div class="form-group">
          <label for="slug">URL Slug</label>
          <input type="text" id="slug" name="slug" value="<%= post && post.slug ? post.slug : '' %>" maxlength="250" pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$" placeholder="auto-generated-if-blank">
          <small class="muted">URL-friendly ID. Leave blank to auto-generate. Unique, lowercase, numbers, hyphens only.</small>
        </div>

        <div class="form-group">
          <label for="blog-content-editor">Content <span style="color:#dc3545">*</span></label>
          <textarea id="blog-content-editor" name="content" class="richtext-editor" style="visibility:hidden; min-height: 500px;"><%= post && post.content ? post.content : '' %></textarea>
          <small class="muted">Use the editor toolbar for formatting.</small>
        </div>
      </div>

      <!-- Right: Settings Sidebar -->
      <aside class="editor-sidebar" aria-label="Settings sidebar">
        <details class="editor-card" open>
          <summary>Publish</summary>
          <div class="panel-body">
            <div class="toggle-row">
              <div>
                <label class="switch">
                  <input type="checkbox" id="isPublished" name="isPublished" value="true" <%= (post && post.isPublished) ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
                <label for="isPublished" class="toggle-label">Publish this publication?</label>
              </div>
            </div>
            <div class="muted" style="margin-bottom:0.5rem;">Make the publication visible on the public Perspectives index.</div>

            <div class="toggle-row">
              <div>
                <label class="switch">
                  <input type="checkbox" id="isFeatured" name="isFeatured" value="true" <%= (post && post.isFeatured) ? 'checked' : '' %>>
                  <span class="slider"></span>
                </label>
                <label for="isFeatured" class="toggle-label">Feature this publication?</label>
              </div>
            </div>
            <div class="muted" style="margin-bottom:0.75rem;">Featured publications can appear in spotlight sections.</div>

            <div class="form-group" style="margin-top:0.5rem;">
              <label for="author">Author <span style="color:#dc3545">*</span></label>
              <% const authorOptions = [
                  'John Byers - Partner, Chief Investment Officer',
                  'Matthew Moellering - Partner, Chief Executive Officer',
                  'Logan Mayfield - Partner, Chief Operating Officer',
                  'Vanier Capital'
              ]; %>
              <select id="author" name="author" style="border-radius:0; border:1px solid rgba(15,46,34,0.2); padding:0.5rem 0.75rem; width:100%; font-size:0.95rem; outline:none;" onfocus="this.style.boxShadow='0 0 0 2px #0f2e22'" onblur="this.style.boxShadow='none'">
                <% authorOptions.forEach(function(opt) { %>
                  <option value="<%= opt %>" <%= (post && post.author === opt) ? 'selected' : '' %>><%= opt %></option>
                <% }); %>
              </select>
              <small class="muted">Byline displayed on the public publication page.</small>
            </div>

            <div class="form-group" style="margin-top:0.5rem;">
              <label for="publishedAt">Publication Date</label>
              <input type="date" id="publishedAt" name="publishedAt" value="<%= (post && post.publishedAt) ? new Date(post.publishedAt).toISOString().split('T')[0] : '' %>" style="border-radius:0; border:1px solid rgba(15,46,34,0.2); padding:0.5rem 0.75rem; width:100%; font-size:0.95rem; outline:none;" onfocus="this.style.boxShadow='0 0 0 2px #0f2e22'" onblur="this.style.boxShadow='none'">
              <small class="muted">Override the publication date for historical case studies or firm updates. Defaults to today if left blank.</small>
            </div>

            <% if (editing && typeof post !== 'undefined') { %>
            <div class="form-group" style="margin-top:0.5rem;">
              <label>View Count</label>
              <input type="text" value="<%= typeof post.viewCount !== 'undefined' ? post.viewCount : 0 %>" readonly>
              <small class="muted">Automatically increments on public views.</small>
            </div>
            <% } %>
          </div>
        </details>

        <details class="editor-card" open>
          <summary>Featured Image</summary>
          <div class="panel-body">
            <div class="form-group">
              <label for="coverImageFile">Upload Cover Image</label>
              <input type="file" id="coverImageFile" name="coverImageFile" accept="image/jpeg,image/png,image/gif,image/webp">
              <small class="muted">Populates the Featured Image URL below. Max 5MB.</small>
              <div id="coverImagePreviewContainer" class="image-preview" style="margin-top:10px;">
                <% if (post && post.featuredImage) { %>
                  <img src="<%= post.featuredImage %>" alt="Current Cover Image">
                  <button type="button" id="removeCoverImageBtn" class="btn btn-danger" style="margin-top:6px;">Remove Image</button>
                <% } %>
              </div>
              <div id="coverImageUploadStatus" class="muted" style="margin-top:6px;"></div>
            </div>
            <div class="form-group">
              <label for="featuredImage">Featured Image URL (Optional)</label>
              <input type="url" id="featuredImage" name="featuredImage" value="<%= post && post.featuredImage ? post.featuredImage : '' %>" placeholder="Auto-populated by upload or enter URL manually">
            </div>
          </div>
        </details>

        <details class="editor-card" open>
          <summary>Attached Document (PDF)</summary>
          <div class="panel-body">
            <div class="form-group">
              <label for="pdfDocumentFile">Upload PDF</label>
              <input type="file" id="pdfDocumentFile" name="pdfDocumentFile" accept="application/pdf" style="border-radius:0;">
              <small class="muted">Upload a Quarterly Letter, research memo, or report. Max 10 MB.</small>
              <div id="pdfUploadStatus" class="muted" style="margin-top:6px;"></div>
            </div>
            <div class="form-group">
              <label for="pdfDocumentUrl">PDF Document URL</label>
              <input type="url" id="pdfDocumentUrl" name="pdfDocumentUrl" value="<%= post && post.pdfDocumentUrl ? post.pdfDocumentUrl : '' %>" placeholder="Auto-populated by upload or enter URL manually" style="border-radius:0; border:1px solid rgba(15,46,34,0.2);">
              <small class="muted">Direct link to the PDF. Populated automatically on upload.</small>
            </div>
            <% if (post && post.pdfDocumentUrl) { %>
              <div class="form-group" style="margin-top:0.5rem;">
                <a href="<%= post.pdfDocumentUrl %>" target="_blank" rel="noopener noreferrer" class="btn btn-secondary-outline" style="font-size:0.85em;">
                  <i class="fas fa-file-pdf"></i> View Current PDF
                </a>
              </div>
            <% } %>
          </div>
        </details>

        <details class="editor-card" open>
          <summary>Excerpt</summary>
          <div class="panel-body">
            <div class="form-group">
              <label for="excerpt">Excerpt / Summary</label>
              <textarea id="excerpt" name="excerpt" rows="4" maxlength="250" oninput="document.getElementById('excerptCounter').textContent = this.value.length + '/250'"><%= post && post.excerpt ? post.excerpt : '' %></textarea>
              <p class="text-xs text-gray-500 mt-1">Optional for Executive Communications.</p>
              <div class="muted" style="display:flex;justify-content:space-between;">
                <small>Short summary for the publication index (max 250 chars).</small>
                <small id="excerptCounter"><%= post && post.excerpt ? post.excerpt.length : 0 %>/250</small>
              </div>
            </div>
          </div>
        </details>
      </aside>
    </div>

    <div class="mt-8 flex items-center justify-end space-x-4 border-t border-gray-200 pt-6">
      <a href="/admin/blog" role="button" class="inline-flex items-center gap-2 border border-[#0f2e22]/20 bg-white py-2.5 px-6 text-sm font-bold text-[#1a1a1a] hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-[#0f2e22] focus:ring-offset-2 transition-colors uppercase tracking-wider"><i class="fas fa-times mr-1"></i>Cancel</a>
      <% if (editing && post && post.isPublished && post.slug) { %>
        <a href="/blog/<%= post.slug %>" target="_blank" class="inline-flex items-center gap-2 border border-[#0f2e22]/20 bg-white py-2.5 px-5 text-sm font-bold text-[#0f2e22] hover:bg-[#f9f8f6] transition-colors uppercase tracking-wider">
          <i class="fas fa-eye"></i> View Live
        </a>
      <% } %>
      <button type="submit" class="inline-flex items-center gap-2 justify-center border border-transparent bg-[#0f2e22] py-2.5 px-6 text-sm font-bold text-white shadow-sm hover:bg-[#1a3a2a] focus:outline-none focus:ring-2 focus:ring-[#0f2e22] focus:ring-offset-2 transition-colors uppercase tracking-wider">
        <i class="fas fa-save"></i> <%= editing ? 'Update Publication' : 'Publish Perspective' %>
      </button>
    </div>
  </form>
</div>

<script src="https://cdn.tiny.cloud/1/<%= typeof tinymceApiKey !== 'undefined' ? tinymceApiKey : 'no-api-key' %>/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
    // --- TinyMCE Initialization ---
    const checkTinyMCE = setInterval(() => {
        if (typeof tinymce !== 'undefined') {
            clearInterval(checkTinyMCE);
            initializeTinyMCE();
        }
    }, 100);

    function initializeTinyMCE() {
        tinymce.init({
            selector: 'textarea#blog-content-editor',
            promotion: false,
            plugins: 'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount codesample',
            toolbar: 'undo redo | blocks | bold italic underline strikethrough | link image media table | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | removeformat | styles | code codesample | preview fullscreen | help',
            content_style: 'body { font-family:Montserrat,Arial,sans-serif; font-size:16px; line-height: 1.7; color: #1a1a1a; background-color: #ffffff; } a { color: #0f2e22; } code { background-color: rgba(0,0,0,0.06); padding: 0.1em 0.3em; border-radius: 3px; } pre code { background-color: transparent; padding: 0;} .callout,.info,.warning,.tip{padding:1rem 1.125rem;border-radius:.5rem;margin:1rem 0;border:1px solid transparent}.callout{background:rgba(0,168,232,.08);border-color:rgba(0,168,232,.35)}.info{background:rgba(99,102,241,.1);border-color:rgba(99,102,241,.35)}.warning{background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.4)}.tip{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.4)} .callout-title{font-weight:700;margin-bottom:.25rem}',
            style_formats: [
                { title: 'Callout', block: 'div', classes: 'callout', wrapper: true },
                { title: 'Info', block: 'div', classes: 'info', wrapper: true },
                { title: 'Warning', block: 'div', classes: 'warning', wrapper: true },
                { title: 'Tip', block: 'div', classes: 'tip', wrapper: true },
                { title: 'Callout Title', inline: 'strong', classes: 'callout-title' }
            ],
            height: 600,
            menubar: false,
            statusbar: true,
            skin: 'oxide',
            content_css: 'default',
            images_upload_url: '/admin/blog/upload-image', // For in-content images
            images_upload_credentials: true,
            automatic_uploads: true,
            file_picker_types: 'image',
            file_picker_callback: function (cb, value, meta) {
                 if (meta.filetype === 'image') {
                    var input = document.createElement('input');
                    input.setAttribute('type', 'file');
                    input.setAttribute('accept', 'image/jpeg,image/png,image/gif,image/webp');
                    input.onchange = function () {
                        var file = this.files[0];
                        const maxSize = 5 * 1024 * 1024;
                        const allowedTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                        if (!allowedTypes.includes(file.type)) { tinymce.activeEditor.notificationManager.open({ text: 'Invalid file type.', type: 'error' }); return; }
                        if (file.size > maxSize) { tinymce.activeEditor.notificationManager.open({ text: `Image too large (Max ${maxSize / 1024 / 1024}MB).`, type: 'error'}); return; }
                        var reader = new FileReader();
                        reader.onload = function () {
                            var id = 'blobid' + (new Date()).getTime();
                            var blobCache = tinymce.activeEditor.editorUpload.blobCache;
                            var base64 = reader.result.split(',')[1];
                            var blobInfo = blobCache.create(id, file, base64);
                            blobCache.add(blobInfo);
                            cb(blobInfo.blobUri(), { title: file.name });
                        };
                        reader.readAsDataURL(file);
                    };
                    input.click();
                }
            },
            setup: function (editor) {
                editor.on('init', function () { editor.getContainer().style.visibility = 'visible'; });
                editor.on('change', function () { editor.save(); });
            }
        });
    }
    setTimeout(() => {
        if (typeof tinymce === 'undefined') {
             console.error("TinyMCE failed to load for blog posts.");
             const editorTextarea = document.getElementById('blog-content-editor');
             if(editorTextarea) { editorTextarea.style.visibility = 'visible'; editorTextarea.placeholder = "Error loading Rich Text Editor."; }
        }
    }, 5000);

    // --- Cover Image Upload Logic ---
    const coverImageFileInput = document.getElementById('coverImageFile');
    const featuredImageInput = document.getElementById('featuredImage'); // The URL input field
    const previewContainer = document.getElementById('coverImagePreviewContainer');
    const uploadStatusDiv = document.getElementById('coverImageUploadStatus');
    const removeCoverImageBtn = document.getElementById('removeCoverImageBtn'); // For initially loaded image
    const form = document.getElementById('blogPostForm'); // Get the form element

    // --- TinyMCE Sync on Submit (prevents "click Save twice" bug) ---
    if (form) {
        form.addEventListener('submit', function(e) {
            if (typeof tinymce !== 'undefined') {
                tinymce.triggerSave();
            }
        });
    }

    function attachRemoveListenerToNewButton() {
        const newRemoveBtn = document.getElementById('newRemoveCoverImageBtn');
        if (newRemoveBtn) {
            newRemoveBtn.addEventListener('click', handleRemoveImage);
        }
    }

    function handleRemoveImage() {
        if (featuredImageInput) featuredImageInput.value = '';
        if (previewContainer) previewContainer.innerHTML = '';
        if (uploadStatusDiv) {
            uploadStatusDiv.textContent = 'Image removed. Save post to confirm changes.';
            uploadStatusDiv.style.color = 'var(--gray-text)';
        }
        if (coverImageFileInput) coverImageFileInput.value = null; // Reset the file input
    }

    if (removeCoverImageBtn) { // Attach to existing remove button on page load
        removeCoverImageBtn.addEventListener('click', handleRemoveImage);
    }

    if (coverImageFileInput && featuredImageInput && previewContainer && uploadStatusDiv && form) {
        coverImageFileInput.addEventListener('change', async function(event) {
            const file = event.target.files[0];
            if (!file) {
                uploadStatusDiv.textContent = '';
                return;
            }

            uploadStatusDiv.textContent = 'Uploading...';
            uploadStatusDiv.style.color = 'var(--gray-text)';

            const formData = new FormData();
            formData.append('coverImageFile', file); // Must match Multer field name on backend
            const csrfToken = form.querySelector('input[name="_csrf"]')?.value;

            if (!csrfToken) {
                console.error('CSRF token not found for blog cover image upload!');
                uploadStatusDiv.textContent = 'Error: Missing security token. Please refresh.';
                uploadStatusDiv.style.color = 'var(--danger-color)';
                return;
            }

            try {
                const response = await fetch('/admin/blog/upload-cover-image', { // Correct endpoint for blog covers
                    method: 'POST',
                    body: formData,
                    headers: {
                        'CSRF-Token': csrfToken // Send CSRF token as a header
                    }
                });

                const result = await response.json();

                if (response.ok && result.success && result.location) {
                    featuredImageInput.value = result.location;
                    previewContainer.innerHTML = `<img src="${result.location}" alt="Cover Image Preview"> <button type="button" id="newRemoveCoverImageBtn" class="btn btn-danger" style="margin-top:6px;">Remove Image</button>`;
                    uploadStatusDiv.textContent = 'Upload successful!';
                    uploadStatusDiv.style.color = 'var(--success-color)';
                    attachRemoveListenerToNewButton(); // Attach listener for the new button
                } else {
                    uploadStatusDiv.textContent = `Upload failed: ${result.message || 'Server error or invalid response'}`;
                    uploadStatusDiv.style.color = 'var(--danger-color)';
                }
            } catch (error) {
                console.error('Blog cover image upload fetch error:', error);
                uploadStatusDiv.textContent = 'Upload network error. See console.';
                uploadStatusDiv.style.color = 'var(--danger-color)';
            }
        });
    } else {
        if (!form) console.warn("Blog form with ID 'blogPostForm' not found for cover image uploader.");
        if (!coverImageFileInput) console.warn("File input 'coverImageFile' for blog not found.");
        // ...existing code...
    }

    // --- PDF Document Upload Logic ---
    const pdfFileInput = document.getElementById('pdfDocumentFile');
    const pdfUrlInput = document.getElementById('pdfDocumentUrl');
    const pdfUploadStatus = document.getElementById('pdfUploadStatus');

    if (pdfFileInput && pdfUrlInput && pdfUploadStatus && form) {
        pdfFileInput.addEventListener('change', async function(event) {
            const file = event.target.files[0];
            if (!file) { pdfUploadStatus.textContent = ''; return; }
            if (file.type !== 'application/pdf') {
                pdfUploadStatus.textContent = 'Invalid file type. Only PDF files allowed.';
                pdfUploadStatus.style.color = 'var(--danger-color)';
                return;
            }
            if (file.size > 10 * 1024 * 1024) {
                pdfUploadStatus.textContent = 'File too large. Max 10 MB.';
                pdfUploadStatus.style.color = 'var(--danger-color)';
                return;
            }

            pdfUploadStatus.textContent = 'Uploading PDF...';
            pdfUploadStatus.style.color = 'var(--gray-text)';

            const formData = new FormData();
            formData.append('pdfDocumentFile', file);
            const csrfToken = form.querySelector('input[name="_csrf"]')?.value;

            if (!csrfToken) {
                pdfUploadStatus.textContent = 'Error: Missing security token. Please refresh.';
                pdfUploadStatus.style.color = 'var(--danger-color)';
                return;
            }

            try {
                const response = await fetch('/admin/blog/upload-pdf', {
                    method: 'POST',
                    body: formData,
                    headers: { 'CSRF-Token': csrfToken }
                });
                const result = await response.json();
                if (response.ok && result.success && result.location) {
                    pdfUrlInput.value = result.location;
                    pdfUploadStatus.textContent = 'PDF uploaded successfully!';
                    pdfUploadStatus.style.color = 'var(--success-color)';
                } else {
                    pdfUploadStatus.textContent = `Upload failed: ${result.message || 'Server error'}`;
                    pdfUploadStatus.style.color = 'var(--danger-color)';
                }
            } catch (error) {
                console.error('PDF upload error:', error);
                pdfUploadStatus.textContent = 'Upload network error. See console.';
                pdfUploadStatus.style.color = 'var(--danger-color)';
            }
        });
    }
});
</script>

<script>
// no-op: curated tag chips removed in favor of categories
</script>

<%- include('../partials/footer') %>