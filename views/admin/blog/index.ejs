<%# views/admin/blog/index.ejs %>
<%# Admin page to list and manage blog posts %>

<%- include('../partials/header', { pageTitle: 'Manage Perspectives' }) %>

<div class="flex items-start justify-between mb-6">
    <div>
        <h2 class="text-2xl font-bold text-[#1a1a1a]">Manage Perspectives</h2>
        <p class="text-gray-600 mt-1">Create, edit, and publish institutional publications and perspectives.</p>
        <div class="mt-3 inline-flex items-center gap-2 bg-[#f9f8f6] border border-[#0f2e22]/20 p-1">
            <% const baseSort = sort || 'publishedDate'; const baseOrder = order || 'desc'; %>
            <a href="/admin/blog?<%= new URLSearchParams({ sort: baseSort, order: baseOrder, status: '' }).toString() %>" class="px-3 py-1.5 text-sm <%= (!status || status==='all') ? 'bg-[#0f2e22] text-white' : 'text-gray-600 hover:text-[#1a1a1a]' %>">All</a>
            <a href="/admin/blog?<%= new URLSearchParams({ sort: baseSort, order: baseOrder, status: 'published' }).toString() %>" class="px-3 py-1.5 text-sm <%= status==='published' ? 'bg-[#0f2e22] text-white' : 'text-gray-600 hover:text-[#1a1a1a]' %>">Published</a>
            <a href="/admin/blog?<%= new URLSearchParams({ sort: baseSort, order: baseOrder, status: 'draft' }).toString() %>" class="px-3 py-1.5 text-sm <%= status==='draft' ? 'bg-[#0f2e22] text-white' : 'text-gray-600 hover:text-[#1a1a1a]' %>">Draft</a>
        </div>
    </div>
    <div>
        <a href="/admin/blog/new" class="inline-flex items-center gap-2 bg-[#0f2e22] text-white font-bold py-3 px-6 border border-[#0f2e22] hover:bg-[#1a1a1a] uppercase tracking-widest text-xs transition">
            <i class="fas fa-plus"></i> Add New Perspective
        </a>
    </div>
</div>

<div>
    <% if (posts && posts.length > 0) { %>
        <div class="overflow-x-auto bg-white border border-[#0f2e22]/20">
            <table class="min-w-full">
                                <thead>
                    <tr class="bg-[#f9f8f6] border-y border-[#0f2e22]/20">
                                                <th class="px-6 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Title & Slug</th>
                        <th class="px-6 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Type</th>
                        <th class="px-6 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Author</th>
                        <th class="px-6 py-3 text-center text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Status</th>
                                                <th class="px-6 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">
                                                    <a href="/admin/blog?<%= new URLSearchParams({ sort: 'publishedDate', order: (sort==='publishedDate' && order==='desc') ? 'asc' : 'desc', status: (status||'') }).toString() %>" class="inline-flex items-center gap-1 hover:text-[#0f2e22]">
                                                        Published Date
                                                        <% if (sort==='publishedDate') { %>
                                                            <i class="fas fa-sort-<%= order==='desc' ? 'down' : 'up' %>"></i>
                                                        <% } else { %>
                                                            <i class="fas fa-sort text-gray-400"></i>
                                                        <% } %>
                                                    </a>
                                                </th>
                                                <th class="px-6 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">
                                                    <a href="/admin/blog?<%= new URLSearchParams({ sort: 'viewCount', order: (sort==='viewCount' && order==='desc') ? 'asc' : 'desc', status: (status||'') }).toString() %>" class="inline-flex items-center gap-1 hover:text-[#0f2e22]">
                                                        Views
                                                        <% if (sort==='viewCount') { %>
                                                            <i class="fas fa-sort-<%= order==='desc' ? 'down' : 'up' %>"></i>
                                                        <% } else { %>
                                                            <i class="fas fa-sort text-gray-400"></i>
                                                        <% } %>
                                                    </a>
                                                </th>
                        <th class="px-6 py-3 text-left text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Last Updated</th>
                        <th class="px-6 py-3 text-right text-[#1a1a1a] font-sans text-xs font-bold uppercase tracking-widest">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% posts.forEach(post => { %>
                        <tr class="bg-white border-b border-gray-200 text-[#1a1a1a] hover:bg-gray-50">
                            <td class="px-6 py-4 text-sm text-[#1a1a1a]">
                                <a href="/admin/blog/edit/<%= post._id %>" class="font-medium text-[#1a1a1a] hover:text-[#0f2e22]">
                                    <%= post.title %>
                                </a>
                                <div class="text-xs text-gray-500">Slug: <%= post.slug %>
                                    <% if(post.isPublished && post.slug) { %>
                                        <a href="/blog/<%= post.slug %>" target="_blank" class="ml-2 text-[#0f2e22] hover:underline"><i class="fas fa-external-link-alt fa-xs"></i> View</a>
                                    <% } %>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="inline-flex items-center bg-[#0f2e22]/5 text-[#0f2e22] border border-[#0f2e22]/20 px-2 py-1 text-[10px] font-bold uppercase tracking-widest"><%= post.publicationType || 'Market Research' %></span>
                                <% if (post.pdfDocumentUrl) { %>
                                    <span class="ml-1 text-[#0f2e22]" title="Has PDF attachment"><i class="fas fa-file-pdf"></i></span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600"><%= post.authorDisplayName || (post.author ? (post.author.fullName || post.author.username) : 'N/A') %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-center">
                                <% if (post.isPublished) { %>
                                    <span class="inline-flex items-center bg-green-50 text-green-700 border border-green-300 px-2 py-1 text-xs font-bold uppercase tracking-widest">Published</span>
                                <% } else { %>
                                    <span class="inline-flex items-center bg-amber-50 text-amber-700 border border-amber-300 px-2 py-1 text-xs font-bold uppercase tracking-widest">Draft</span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                <% if (post.publishedDate) { %>
                                    <%= new Date(post.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600"><%= typeof post.viewCount === 'number' ? post.viewCount : 0 %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= post.updatedAt ? new Date(post.updatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '-' %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                <div class="inline-flex items-center gap-3">
                                    <a href="/admin/blog/edit/<%= post._id %>" class="font-sans text-[10px] font-bold uppercase tracking-widest text-[#0f2e22] border border-[#0f2e22] px-3 py-1.5 hover:bg-[#0f2e22] hover:text-white transition-colors" title="Edit Perspective">Edit</a>
                                    <form action="/admin/blog/delete/<%= post._id %>" method="POST" class="inline m-0 p-0" onsubmit="return confirm('Are you sure you want to delete this perspective? This action cannot be undone.');">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="font-sans text-[10px] font-bold uppercase tracking-widest text-red-800 border border-red-800 px-3 py-1.5 hover:bg-red-800 hover:text-white transition-colors cursor-pointer">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="bg-white border border-[#0f2e22]/20 p-8 text-center">
            <div class="mx-auto mb-3 h-12 w-12 bg-[#f9f8f6] flex items-center justify-center text-gray-400">
                <i class="fas fa-newspaper"></i>
            </div>
            <h3 class="text-lg font-semibold text-[#1a1a1a]">No Publications Yet</h3>
            <p class="text-gray-600 mt-1">Publish your first perspective or quarterly letter to get started.</p>
            <a href="/admin/blog/new" class="mt-4 inline-flex items-center gap-2 bg-[#0f2e22] text-white font-bold py-3 px-6 border border-[#0f2e22] hover:bg-[#1a1a1a] uppercase tracking-widest text-xs transition">
                <i class="fas fa-plus"></i> Publish First Perspective
            </a>
        </div>
    <% } %>
</div>

<%- include('../partials/footer') %>