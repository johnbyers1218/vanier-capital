<%# views/admin/login.ejs — Local admin login with Clerk Google OAuth %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex, nofollow">
    <title>Admin Sign In | Vanier Capital</title>
    <link rel="icon" href="/images/vanier-logo.svg" sizes="any">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f9f8f6;
            color: #1a1a1a;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-container {
            width: 100%;
            max-width: 520px;
            padding: 0 24px;
        }
        .login-card {
            background: #fff;
            border: 1px solid rgba(15, 46, 34, 0.12);
            padding: 48px 32px 32px;
            border-radius: 0;
        }
        .brand {
            text-align: center;
            margin-bottom: 32px;
        }
        .brand-name {
            font-family: 'Merriweather', serif;
            font-size: 24px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: #0f2e22;
        }
        .brand-sub {
            font-family: 'Inter', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.4em;
            text-transform: uppercase;
            color: rgba(15, 46, 34, 0.5);
            margin-top: 6px;
        }
        .divider {
            width: 40px;
            height: 1px;
            background: rgba(15, 46, 34, 0.2);
            margin: 24px auto;
        }
        .login-heading {
            font-family: 'Inter', sans-serif;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: rgba(26, 26, 26, 0.5);
            text-align: center;
            margin-bottom: 24px;
        }
        .error-msg {
            background: rgba(220, 38, 38, 0.08);
            border-left: 3px solid #dc2626;
            padding: 12px 16px;
            margin-bottom: 24px;
            font-size: 13px;
            color: #991b1b;
        }
        #sign-in-widget {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 120px;
            width: 100%;
        }
        /* Ensure the Clerk root box fills and centers within the card */
        #sign-in-widget > div {
            width: 100%;
            display: flex;
            justify-content: center;
        }
        /* Remove Clerk card's built-in padding/shadow so it inherits our card style */
        #sign-in-widget .cl-card,
        #sign-in-widget .cl-rootBox {
            width: 100% !important;
            max-width: 100% !important;
            box-shadow: none !important;
            border: none !important;
            border-radius: 0 !important;
        }
        .loading-state {
            text-align: center;
            padding: 32px 0;
            font-size: 12px;
            color: rgba(26, 26, 26, 0.4);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        .footer-note {
            text-align: center;
            margin-top: 32px;
            font-size: 11px;
            color: rgba(26, 26, 26, 0.35);
            letter-spacing: 0.05em;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="brand">
                <div class="brand-name">Vanier</div>
                <div class="brand-sub">Capital</div>
            </div>
            <div class="divider"></div>
            <div class="login-heading">Administrative Access</div>

            <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
                <div class="error-msg"><%= error %></div>
            <% } %>

            <%# Clerk Sign-In widget mounts here %>
            <div id="sign-in-widget">
                <div class="loading-state">Loading authentication…</div>
            </div>
        </div>
        <div class="footer-note">&copy; <%= new Date().getFullYear() %> Vanier Capital, LLC</div>
    </div>

    <%# Clerk Frontend SDK — loaded from Clerk FAPI (includes UI components) %>
    <script
        async
        crossorigin="anonymous"
        data-clerk-publishable-key="<%= clerkPublishableKey %>"
        src="<%= clerkFapiUrl %>/npm/@clerk/clerk-js@latest/dist/clerk.browser.js"
        type="text/javascript"
    ></script>
    <script>
        // Wait for the Clerk SDK script to load, then initialize.
        window.addEventListener('load', async function () {
            try {
                // Clerk.load() initialises the SDK. Keep options minimal —
                // redirect URLs are set per-component via mountSignIn() below,
                // and via CLERK_* env vars read by @clerk/express on the server.
                await window.Clerk.load({
                    signInUrl: '/admin/login',
                    signUpUrl: '/admin/login',
                    signInForceRedirectUrl: '/admin/dashboard',
                    signInFallbackRedirectUrl: '/admin/dashboard',
                    afterSignOutUrl: '/admin/login',
                    routerPush: function (to) { window.location.href = to; },
                    routerReplace: function (to) { window.location.replace(to); },
                });

                // If the user is already signed in (session cookie valid),
                // redirect to the dashboard immediately.
                if (window.Clerk.user) {
                    window.location.replace('/admin/dashboard');
                    return;
                }

                // Mount the Clerk SignIn component.
                var signInDiv = document.getElementById('sign-in-widget');
                if (!signInDiv) return;
                signInDiv.innerHTML = '';

                window.Clerk.mountSignIn(signInDiv, {
                    appearance: {
                        variables: { colorPrimary: '#0f2e22' },
                        elements: {
                            card: 'shadow-none border-0',
                            rootBox: 'w-full',
                            formButtonPrimary: 'bg-[#0f2e22] hover:bg-[#1a4a38] rounded-none uppercase tracking-widest text-xs font-bold',
                        }
                    },
                    // These redirect URLs are what the SDK uses after OAuth
                    // callback is processed by handleRedirectCallback internally.
                    forceRedirectUrl: '/admin/dashboard',
                    fallbackRedirectUrl: '/admin/dashboard',
                    signUpUrl: '/admin/login',
                });

                // Listen for the user becoming authenticated (e.g. after the
                // SDK processes the OAuth callback silently). This is the
                // safety net that guarantees navigation to the dashboard.
                window.Clerk.addListener(function (emission) {
                    if (emission.user) {
                        window.location.replace('/admin/dashboard');
                    }
                });

            } catch (err) {
                console.error('[Clerk] Failed to load:', err);
                var el = document.getElementById('sign-in-widget');
                if (el) el.innerHTML = '<p style="color:#991b1b;text-align:center;">Authentication service unavailable. Please refresh.</p>';
            }
        });
    </script>
</body>
</html>
