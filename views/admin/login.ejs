<!-- views/admin/login.ejs -->
<!-- Admin Login Page - Standalone page -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Prevent indexing of admin login page -->
    <meta name="robots" content="noindex, nofollow">
    <title>Admin Login | FND Automations</title>
    <!-- Link main public CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Link optional admin-specific CSS -->
    <link rel="stylesheet" href="/css/admin-style.css">
    <style>
        /* Styles specific to the login page for centering and appearance */
        body.login-page {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: var(--dark-bg); /* Use theme background */
            padding: 1rem; /* Add padding for small screens */
        }
        .login-container {
            background-color: var(--card-bg);
            padding: 2.5rem 2rem; /* Adjusted padding */
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            width: 100%;
            max-width: 400px;
            text-align: center;
            border: 1px solid var(--card-border);
        }
        .login-container .logo {
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
            color: var(--primary-color);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .login-container h1 {
            font-size: 1.5rem;
            margin-bottom: 2rem;
            color: var(--light-text);
            font-weight: 500;
        }
        .login-form .form-group {
            margin-bottom: 1.5rem;
            text-align: left;
        }
        .login-form label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
             color: var(--light-text);
             font-size: 0.95rem;
        }
        .login-form input[type="text"],
        .login-form input[type="password"] {
            width: 100%;
            padding: 12px 15px; /* Consistent padding */
            background-color: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: var(--border-radius);
            color: var(--light-text);
            font-size: 1rem;
        }
         .login-form input:focus {
             border-color: var(--primary-color);
             outline: none;
             box-shadow: 0 0 0 3px rgba(0, 168, 232, 0.2);
         }
        .login-form .submit-btn {
            width: 100%;
            padding: 12px;
            font-size: 1.1rem;
            margin-top: 1rem;
            /* Inherits .cta-button.primary-btn styles */
        }
        /* Error message specific to login (uses flash message style) */
        .login-error-placeholder { /* Div to hold flash messages */
             min-height: 40px; /* Reserve space even when no message */
             margin-bottom: 1.5rem;
        }
        .flash-message.error { /* Style defined in header/admin-style.css */
            text-align: center;
            font-size: 0.95em;
            justify-content: center;
        }
        .flash-message.success { /* Style for success message on redirect */
             text-align: center;
             font-size: 0.95em;
             justify-content: center;
        }
    </style>
</head>
<body class="login-page">

    <div class="login-container">
        <div class="logo">FND Admin</div>
        <h1>Administrator Login</h1>

        <!-- Placeholder for Flash Messages -->
        <div class="login-error-placeholder">
             <% if (errorMessage && errorMessage.length > 0) { %>
                  <% errorMessage.forEach(msg => { %>
                      <div class="flash-message error">
                         <i></i> <span><%= msg %></span>
                      </div>
                  <% }) %>
             <% } %>
             <% if (successMessage && successMessage.length > 0) { %>
                 <% successMessage.forEach(msg => { %>
                     <div class="flash-message success">
                         <i></i> <span><%= msg %></span>
                     </div>
                 <% }) %>
            <% } %>
        </div>
        <!-- End Flash Messages -->


        <form action="/admin/login" method="POST" class="login-form">
            <!-- IMPORTANT: Include CSRF Token -->
            <!-- csrfToken is available via res.locals set in app.js -->
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="form-group">
                <label for="username">Username</label>
                <!-- Repopulate username on failed attempt (passed from route handler) -->
                <input type="text" id="username" name="username" value="<%= typeof username !== 'undefined' ? username : '' %>" required autofocus>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            <button type="submit" class="submit-btn cta-button primary-btn">Login</button>
        </form>
    </div>

</body>
</html>