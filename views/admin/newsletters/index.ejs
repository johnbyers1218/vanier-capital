<%- include('../partials/header', { pageTitle: 'Newsletters' }) %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-semibold">Newsletter Campaigns</h1>
    <div class="flex items-center gap-3">
      <span class="text-gray-300">Total Subscribers: <strong><%= (typeof totalSubscribers === 'number') ? totalSubscribers : 0 %></strong></span>
      <a href="/admin/newsletters/new" class="inline-flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-md"><i class="fas fa-plus"></i> Schedule New Campaign</a>
    </div>
  </div>

  <div class="rounded-lg border border-neutral-700 bg-[#1a1a1a] p-4 overflow-x-auto">
    <input type="hidden" id="_csrf" value="<%= csrfToken %>">
    <div class="flex items-center justify-end mb-3">
      <button id="btnRefreshAll" class="bg-neutral-700 text-white px-3 py-2 rounded text-sm">Refresh MC Status</button>
      <span id="refreshMsg" class="ml-3 text-sm"></span>
    </div>
    <table class="min-w-full text-sm">
      <thead>
        <tr class="text-left text-gray-300">
          <th class="px-3 py-2">Subject</th>
          <th class="px-3 py-2">Status</th>
          <th class="px-3 py-2">Campaign ID</th>
          <th class="px-3 py-2">MC Status</th>
          <th class="px-3 py-2">Scheduled/Sent</th>
          <th class="px-3 py-2">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-neutral-700">
        <% if (newsletters && newsletters.length) { %>
          <% newsletters.forEach(n => { %>
            <tr>
              <td class="px-3 py-2"><%= n.subject %></td>
              <td class="px-3 py-2"><span class="inline-block px-2 py-0.5 rounded bg-neutral-700 text-gray-200"><%= n.status %></span></td>
              <td class="px-3 py-2">
                <% if (n.status === 'Scheduled' && n.scheduledFor) { %>
                  <%= new Date(n.scheduledFor).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                <% } else if (n.status === 'Sent' && n.sentAt) { %>
                  <%= new Date(n.sentAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                <% } else { %>-<% } %>
              </td>
              <td class="px-3 py-2 font-mono text-xs text-gray-400">
                <% if (n.mailchimpWebId) { %>
                  <a href="https://<%= mailchimpServerPrefix %>.admin.mailchimp.com/campaigns/show/?id=<%= n.mailchimpWebId %>" target="_blank" class="underline" title="Open in Mailchimp"><%= n.mailchimpCampaignId %></a>
                <% } else if (n.mailchimpCampaignId) { %>
                  <a href="https://<%= mailchimpServerPrefix %>.admin.mailchimp.com/campaigns/" target="_blank" class="underline" title="Open campaigns in Mailchimp"><%= n.mailchimpCampaignId %></a>
                <% } else { %>
                  -
                <% } %>
              </td>
              <td class="px-3 py-2">
                <% if (n.mailchimpStatus) { %>
                  <% const s = n.mailchimpStatus; %>
                  <span class="inline-block px-2 py-0.5 rounded border text-xs <%= s==='save' ? 'bg-green-900 text-green-200 border-green-700' : 'bg-[#1a1a1a] text-gray-300 border-neutral-700' %>"><%= s %></span>
                <% } else { %>-<% } %>
              </td>
              <td class="px-3 py-2 space-x-3">
                <a href="/admin/newsletters/<%= n._id %>/edit" class="underline">Edit</a>
                <button class="underline text-blue-300 hover:text-blue-200 js-refresh-one" data-id="<%= n._id %>">Refresh</button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td class="px-3 py-3 text-center text-gray-400" colspan="5">No newsletters yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <script>
    (function(){
      const btnAll = document.getElementById('btnRefreshAll');
      const msg = document.getElementById('refreshMsg');
      async function refresh(ids){
        msg.textContent = 'Refreshing...';
        try {
          const csrf = document.getElementById('_csrf')?.value;
          const resp = await fetch('/admin/newsletters/refresh-status', {
            method: 'POST', headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrf }, body: JSON.stringify({ ids })
          });
          const data = await resp.json();
          if (data.ok) {
            msg.textContent = 'Refreshed ' + (data.updated || 0) + ' campaign(s). Reloading...';
            setTimeout(()=>window.location.reload(), 500);
          } else {
            msg.textContent = 'Failed: ' + (data.error || 'Unknown error');
          }
        } catch(e) {
          msg.textContent = 'Failed: ' + (e?.message || 'Unknown error');
        }
      }
      btnAll?.addEventListener('click', () => {
        const ids = Array.from(document.querySelectorAll('.js-refresh-one')).map(b => b.dataset.id);
        refresh(ids);
      });
      document.querySelectorAll('.js-refresh-one').forEach(btn => {
        btn.addEventListener('click', () => refresh([btn.dataset.id]));
      });
    })();
  </script>
</div>

<%- include('../partials/footer') %>
