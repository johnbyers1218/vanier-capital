<%- include('../partials/header', { pageTitle: (newsletter && newsletter._id) ? 'Edit Newsletter' : 'Create Newsletter' }) %>

<div class="space-y-6">
  <h1 class="text-2xl font-semibold"><%= (newsletter && newsletter._id) ? 'Edit Newsletter' : 'Create Newsletter' %></h1>

  <form action="/admin/newsletters/save" method="post" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% if (newsletter && newsletter._id) { %>
      <input type="hidden" name="id" value="<%= newsletter._id %>">
    <% } %>

    <div>
      <label class="block text-gray-300 mb-1">Internal Subject</label>
      <input type="text" name="subject" value="<%= newsletter.subject || '' %>" required class="w-full rounded bg-gray-900 border border-gray-700 px-3 py-2" />
    </div>

    <div>
      <label class="block text-gray-300 mb-1">Mailchimp Campaign ID</label>
      <div class="flex gap-2 items-center">
        <input type="text" name="mailchimpCampaignId" value="<%= newsletter.mailchimpCampaignId || '' %>" required class="flex-1 rounded bg-gray-900 border border-gray-700 px-3 py-2" />
        <button type="button" id="btnValidate" class="bg-blue-600 text-white px-3 py-2 rounded">Validate ID</button>
      </div>
      <div class="mt-2 flex items-center gap-2 text-xs">
        <span id="statusBadge" class="hidden inline-flex items-center gap-1 rounded px-2 py-1"></span>
        <a id="mcLink" href="#" target="_blank" class="hidden underline">Open in Mailchimp</a>
      </div>
      <p id="validateMsg" class="text-xs mt-2"></p>
      <p class="text-xs text-gray-400 mt-1">Paste the Campaign ID from your Mailchimp draft campaign URL or settings.</p>
    </div>

    <div class="flex flex-wrap gap-3">
  <button name="intent" value="validate" class="bg-blue-600 text-white px-4 py-2 rounded">Validate Campaign</button>
  <button name="intent" value="draft" class="bg-gray-600 text-white px-4 py-2 rounded">Save Draft</button>
      <button name="intent" value="send" class="bg-primary text-white px-4 py-2 rounded">Send Now</button>
      <div class="flex items-center gap-2">
        <input type="datetime-local" name="scheduledFor" id="scheduledFor" class="rounded bg-gray-900 border border-gray-700 px-3 py-2 hidden" />
        <button type="button" id="btnShowSchedule" class="bg-amber-700 text-white px-4 py-2 rounded">Schedule for Later...</button>
        <button name="intent" value="schedule" id="btnSchedule" class="bg-amber-600 text-white px-4 py-2 rounded hidden">Schedule Campaign</button>
      </div>
    </div>

    <script>
      (function(){
        const btnValidate = document.getElementById('btnValidate');
  const validateMsg = document.getElementById('validateMsg');
  const statusBadge = document.getElementById('statusBadge');
  const mcLink = document.getElementById('mcLink');
        const inputCid = document.querySelector('input[name="mailchimpCampaignId"]');
        const scheduleInput = document.getElementById('scheduledFor');
        const btnShowSchedule = document.getElementById('btnShowSchedule');
        const btnSchedule = document.getElementById('btnSchedule');
        const btnSend = document.querySelector('button[name="intent"][value="send"]');
        const btnDraft = document.querySelector('button[name="intent"][value="draft"]');
        let isValid = false;

        function setActionsEnabled(enabled) {
          if (btnSend) btnSend.disabled = !enabled;
          if (btnSchedule) btnSchedule.disabled = !enabled;
          if (btnShowSchedule) btnShowSchedule.disabled = !enabled;
        }

        function setStatusBadge(ok, status, webId) {
          statusBadge.className = 'inline-flex items-center gap-1 rounded px-2 py-1 text-xs';
          if (ok) {
            statusBadge.classList.add('bg-green-900','text-green-300','border','border-green-700');
            statusBadge.textContent = 'Valid • ' + (status || 'draft');
            statusBadge.classList.remove('hidden');
            if (webId) {
              mcLink.href = 'https://<%= mailchimpServerPrefix %>.admin.mailchimp.com/campaigns/show/?id=' + webId;
              mcLink.classList.remove('hidden');
            }
          } else {
            statusBadge.classList.add('bg-red-900','text-red-300','border','border-red-700');
            statusBadge.textContent = 'Invalid';
            statusBadge.classList.remove('hidden');
            mcLink.classList.add('hidden');
          }
        }

        async function runValidation() {
          const cid = (inputCid?.value || '').trim();
          validateMsg.textContent = '';
          validateMsg.className = 'text-xs mt-2';
          isValid = false;
          setActionsEnabled(false);
          if (!cid) {
            validateMsg.textContent = 'Please enter a Campaign ID.';
            validateMsg.classList.add('text-red-400');
            statusBadge.classList.add('hidden');
            mcLink.classList.add('hidden');
            return;
          }
          try {
            const resp = await fetch('/admin/newsletters/validate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'CSRF-Token': '<%= csrfToken %>' },
              body: JSON.stringify({ mailchimpCampaignId: cid, id: '<%= newsletter?._id || '' %>' })
            });
            const data = await resp.json();
            if (data.ok) {
              validateMsg.textContent = '✓ Valid Campaign Found! Status: ' + (data.status || 'unknown');
              validateMsg.classList.add('text-green-400');
              isValid = true;
              setActionsEnabled(true);
              setStatusBadge(true, data.status, data.webId);
            } else {
              validateMsg.textContent = '✗ Invalid ID or Campaign Not Found. ' + (data.error || '');
              validateMsg.classList.add('text-red-400');
              setStatusBadge(false);
            }
          } catch (e) {
            validateMsg.textContent = '✗ Validation failed: ' + (e?.message || 'Unknown error');
            validateMsg.classList.add('text-red-400');
            setStatusBadge(false);
          }
        }

        btnValidate?.addEventListener('click', runValidation);
        inputCid?.addEventListener('blur', runValidation);
        // Initially disable until validation passes; auto-validate on load if ID pre-filled
        setActionsEnabled(false);
        if ((inputCid?.value || '').trim()) {
          runValidation();
        }

        btnShowSchedule?.addEventListener('click', () => {
          scheduleInput?.classList.remove('hidden');
          btnSchedule?.classList.remove('hidden');
          btnShowSchedule?.classList.add('hidden');
        });
      })();
    </script>
  </form>
</div>

<%- include('../partials/footer') %>
