<!-- views/newsletter-welcome.ejs -->
<%- include('partials/header', {
  pageTitle: 'Thank You for Subscribing!',
  pageDescription: 'Thanks for joining our newsletter. You’re all set — here’s what to do next.',
  path: '/newsletter/welcome'
}) %>

<section class="section">
  <div class="container">
    <div class="content-card" style="max-width: 820px; margin-inline: auto; background: #f9fafb; border: 1px solid var(--color-border-subtle); border-radius: .875rem; box-shadow: 0 6px 30px rgba(0,0,0,.06); padding: clamp(2rem, 4vw, 3rem);">

      <div style="text-align: center; margin-bottom: 1.25rem;">
        <div aria-hidden="true" style="display:inline-flex; align-items:center; justify-content:center; width:96px; height:96px; border-radius:50%; background: #e8f7ef; color: #16a34a; box-shadow: inset 0 0 0 1px rgba(22,163,74,.15);">
          <i class="fas fa-check-circle" style="font-size: 2.5rem;"></i>
        </div>
      </div>

      <h1 class="section-title" style="text-align:center; font-size: clamp(1.75rem, 3.2vw, 2.25rem); font-weight: 800; letter-spacing: -0.01em;">Thank You for Subscribing!</h1>
      <p class="section-description" style="text-align:center; max-width: 65ch; margin: .375rem auto 0;">You're officially on the list. Your first issue will arrive this coming Monday morning.</p>

      <hr style="margin: 1.75rem 0; border-color: var(--color-border-subtle);" />

      <!-- Note from CEO -->
      <section aria-labelledby="note-from-ceo-title" style="display:grid; grid-template-columns: 72px 1fr; gap: 1rem; align-items: start; margin-bottom: 1.25rem;">
        <h2 id="note-from-ceo-title" class="sr-only">A Note from Our CEO</h2>
        <picture style="grid-row: span 2;">
          <source srcset="/images/Logan.webp" type="image/webp" />
          <img src="/images/Logan.png" width="72" height="72" alt="Logan Mayfield, CEO of FND Automations" style="display:block; width:72px; height:72px; object-fit:cover; border-radius: 9999px; box-shadow: 0 1px 2px rgba(0,0,0,.06), 0 0 0 1px rgba(0,0,0,.05) inset;" />
        </picture>
        <div style="grid-column: 2 / -1;">
          <div style="font-style: italic; color: var(--color-text-default); background: #ffffff; border: 1px solid var(--color-border-subtle); border-left-width: 4px; border-left-color: var(--color-primary); padding: .875rem 1rem; border-radius: .5rem; box-shadow: 0 2px 10px rgba(0,0,0,.03);">
            “Thank you for joining us. We founded FND Automations on a simple belief: that well-designed automation can empower teams to move beyond busywork and focus on what truly drives growth. This newsletter is where we'll share the practical strategies and insights we use to make that happen. I'm excited to have you with us.”
          </div>
          <p style="margin-top: .5rem; font-weight: 600; color: var(--color-text-headings);">Logan Mayfield, CEO of FND Automations</p>
        </div>
      </section>

  <!-- Profile form removed per two-stage flow. -->

      <hr style="margin: 1.75rem 0; border-color: var(--color-border-subtle);" />

      <section aria-labelledby="whats-next-title">
        <h2 id="whats-next-title" class="section-title" style="font-size: 1.25rem; margin-bottom: .5rem;">What’s Next?</h2>
  <div style="display: grid; grid-template-columns: repeat(1, minmax(0, 1fr)); gap: 1rem;">
          <!-- Case Studies -->
          <a href="/projects" class="action-card" style="text-decoration: none;">
            <span aria-hidden="true" style="display:inline-flex; align-items:center; justify-content:center; width:44px; height:44px; border-radius: .5rem; background: #eef2ff; color: #4338ca; box-shadow: inset 0 0 0 1px rgba(67,56,202,.2);">
              <i class="fas fa-chart-line" style="font-size: 1.25rem;"></i>
            </span>
            <span style="flex:1;">
              <span style="display:block; font-weight: 700; font-size: 1rem;">Explore Our Case Studies</span>
              <span style="display:block; color: var(--color-text-muted); margin-top: .25rem;">See real-world examples of how we've transformed businesses like yours.</span>
              <span class="action-btn" style="display:inline-flex; align-items:center; gap:.4rem; margin-top:.6rem;">See Our Work <i class="fas fa-arrow-right" aria-hidden="true"></i></span>
            </span>
          </a>

          <!-- YouTube -->
          <a href="https://www.youtube.com/@fndautomations" target="_blank" rel="noopener noreferrer" class="action-card" style="text-decoration: none;">
            <span aria-hidden="true" style="display:inline-flex; align-items:center; justify-content:center; width:44px; height:44px; border-radius: .5rem; background: #fee2e2; color: #ef4444; box-shadow: inset 0 0 0 1px rgba(239,68,68,.2);">
              <i class="fab fa-youtube" style="font-size: 1.25rem;"></i>
            </span>
            <span style="flex:1;">
              <span style="display:block; font-weight: 700; font-size: 1rem;">Watch Us on YouTube</span>
              <span style="display:block; color: var(--color-text-muted); margin-top: .25rem;">Dive into our video tutorials and expert interviews on AI and automation.</span>
              <span class="action-btn" style="display:inline-flex; align-items:center; gap:.4rem; margin-top:.6rem;">Subscribe on YouTube <i class="fas fa-arrow-right" aria-hidden="true"></i></span>
            </span>
          </a>

          <!-- Instagram -->
          <a href="https://www.instagram.com/fndautomations" target="_blank" rel="noopener noreferrer" class="action-card" style="text-decoration: none;">
            <span aria-hidden="true" style="display:inline-flex; align-items:center; justify-content:center; width:44px; height:44px; border-radius: .5rem; background: #fce7f3; color: #db2777; box-shadow: inset 0 0 0 1px rgba(219,39,119,.2);">
              <i class="fab fa-instagram" style="font-size: 1.25rem;"></i>
            </span>
            <span style="flex:1;">
              <span style="display:block; font-weight: 700; font-size: 1rem;">Follow Us on Instagram</span>
              <span style="display:block; color: var(--color-text-muted); margin-top: .25rem;">Get behind-the-scenes insights, quick tips, and company updates.</span>
              <span class="action-btn" style="display:inline-flex; align-items:center; gap:.4rem; margin-top:.6rem;">Follow on Instagram <i class="fas fa-arrow-right" aria-hidden="true"></i></span>
            </span>
          </a>
        </div>
        <style>
          .action-card { display:flex; align-items:flex-start; gap:.9rem; padding:1rem; border:1px solid var(--color-border-subtle); border-radius:.75rem; background:#fff; box-shadow:0 1px 2px rgba(0,0,0,.04); transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; cursor: pointer; }
          .action-card:hover { transform: translateY(-2px) scale(1.01); box-shadow: 0 8px 24px rgba(0,0,0,.08); border-color: rgba(0,0,0,.12); }
          @media (min-width: 720px){
            #whats-next-title + div { grid-template-columns: repeat(3, minmax(0, 1fr)); }
          }
        </style>
      </section>
    </div>
  </div>
</section>



<%- include('partials/footer') %>
