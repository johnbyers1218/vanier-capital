<%- include('partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: path,
    isHeroPage: true
}) %>

<!-- ═══════════════ HERO — WARM BEIGE ═══════════════ -->
<section class="bg-[#f9f8f6] pt-24 md:pt-32 pb-10 md:pb-16">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16">
        <!-- Breadcrumb -->
        <nav class="mb-8">
            <ol class="flex items-center space-x-2 font-sans text-sm text-gray-500">
                <li><a href="/portfolio" class="hover:text-[#0f2e22] transition-colors">Portfolio</a></li>
                <li class="select-none">/</li>
                <li class="text-[#0f2e22] font-medium"><%= asset.title %></li>
            </ol>
        </nav>

        <!-- Phase I Seed Badge -->
        <div class="inline-block bg-[#1a1a1a] text-white px-3 py-1 font-sans text-[10px] font-bold uppercase tracking-widest mb-4">Phase I Seed Asset &mdash; Closed to Capital</div>

        <!-- Eyebrow -->
        <% if (asset.subtitle || asset.strategy) { %>
        <span class="font-sans text-sm font-bold text-gray-500 uppercase tracking-widest block mb-4"><%= asset.subtitle || '' %><% if (asset.subtitle && asset.strategy) { %> | <% } %><%= asset.strategy || '' %></span>
        <% } %>

        <!-- Title -->
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-[#0f2e22] tracking-tight mb-8"><%= asset.title %></h1>

        <!-- Summary -->
        <% if (asset.summary) { %>
        <p class="font-sans text-xl text-gray-600 max-w-3xl leading-relaxed"><%= asset.summary %></p>
        <% } %>
    </div>
</section>

<!-- ═══════════════ METRICS GRID ═══════════════ -->
<section class="bg-white border-t border-[#0f2e22]/10">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16 py-8 md:py-12">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 md:gap-10">
            <% if (asset.doors) { %>
            <div>
                <p class="font-sans text-[10px] uppercase tracking-widest text-[#1a1a1a]/40 mb-2">Doors</p>
                <p class="font-serif text-2xl md:text-4xl text-[#0f2e22]"><%= asset.doors %></p>
            </div>
            <% } %>
            <% if (asset.occupancy) { %>
            <div>
                <p class="font-sans text-[10px] uppercase tracking-widest text-[#1a1a1a]/40 mb-2">Occupancy</p>
                <p class="font-serif text-2xl md:text-4xl text-[#0f2e22]"><%= asset.occupancy %></p>
            </div>
            <% } %>
            <% if (asset.strategy) { %>
            <div>
                <p class="font-sans text-[10px] uppercase tracking-widest text-[#1a1a1a]/40 mb-2">Strategy</p>
                <p class="font-serif text-2xl md:text-4xl text-[#0f2e22]"><%= asset.strategy %></p>
            </div>
            <% } %>
            <% if (asset.assetClass) { %>
            <div>
                <p class="font-sans text-[10px] uppercase tracking-widest text-[#1a1a1a]/40 mb-2">Asset Class</p>
                <p class="font-serif text-2xl md:text-4xl text-[#0f2e22]"><%= asset.assetClass %></p>
            </div>
            <% } %>
            <% if (asset.status) { %>
            <div>
                <p class="font-sans text-[10px] uppercase tracking-widest text-[#1a1a1a]/40 mb-2">Status</p>
                <p class="font-serif text-2xl md:text-4xl text-[#0f2e22]"><%= asset.status %></p>
            </div>
            <% } %>
            <% if (asset.holdPeriod) { %>
            <div>
                <p class="font-sans text-[10px] uppercase tracking-widest text-[#1a1a1a]/40 mb-2">Hold Period</p>
                <p class="font-serif text-2xl md:text-4xl text-[#0f2e22]"><%= asset.holdPeriod %></p>
            </div>
            <% } %>
        </div>
    </div>
</section>

<!-- ═══════════════ COVER IMAGE ═══════════════ -->
<% if (asset.image) { %>
<section class="bg-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16 py-8 md:py-12">
        <div class="aspect-[16/7] bg-gray-200 overflow-hidden border border-gray-200">
            <img src="<%= asset.image %>" alt="<%= asset.title %>" class="w-full h-full object-cover rounded-none">
        </div>
    </div>
</section>
<% } %>

<!-- ═══════════════ EDITORIAL BODY — 2-COL ═══════════════ -->
<section class="bg-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16 py-12 md:py-20 grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16">

        <!-- Left Column (Span 2) — Thesis & Execution -->
        <div class="md:col-span-2">
            <div class="prose max-w-none font-sans text-lg text-gray-700 leading-relaxed">

                <% if (asset.thesis) { %>
                <h3 class="font-serif text-2xl text-[#0f2e22] mb-4 mt-0">Investment Thesis</h3>
                <p class="mb-10 whitespace-pre-line"><%= asset.thesis %></p>
                <% } %>

                <% if (asset.execution) { %>
                <h3 class="font-serif text-2xl text-[#0f2e22] mb-4">Operational Execution</h3>
                <p class="mb-0 whitespace-pre-line"><%= asset.execution %></p>
                <% } %>

                <% if (asset.description) { %>
                <div class="mt-12 border-t border-[#0f2e22]/10 pt-10">
                    <%- asset.description %>
                </div>
                <% } %>

            </div>
        </div>

        <!-- Right Column (Span 1) — Current Performance Profile -->
        <div class="md:col-span-1">
            <div class="border border-[#0f2e22]/10">
                <div class="bg-[#0f2e22] px-6 py-4">
                    <h3 class="font-serif text-lg text-white font-semibold m-0">Current Performance Profile</h3>
                </div>
                <ul class="divide-y divide-[#0f2e22]/10">
                    <% if (asset.acquisitionBasis) { %>
                    <li class="px-6 py-4">
                        <p class="font-sans text-xs uppercase tracking-widest text-[#1a1a1a]/40 mb-1">Acquisition Basis</p>
                        <p class="font-sans text-sm font-medium text-[#1a1a1a]"><%= asset.acquisitionBasis %></p>
                    </li>
                    <% } %>
                    <% if (asset.capexDeployed) { %>
                    <li class="px-6 py-4">
                        <p class="font-sans text-xs uppercase tracking-widest text-[#1a1a1a]/40 mb-1">CapEx Deployed</p>
                        <p class="font-sans text-sm font-medium text-[#1a1a1a]"><%= asset.capexDeployed %></p>
                    </li>
                    <% } %>
                    <% if (asset.currentNOI) { %>
                    <li class="px-6 py-4">
                        <p class="font-sans text-xs uppercase tracking-widest text-[#1a1a1a]/40 mb-1">Current NOI</p>
                        <p class="font-sans text-sm font-medium text-[#1a1a1a]"><%= asset.currentNOI %></p>
                    </li>
                    <% } %>
                    <% if (asset.cashOnCashYield) { %>
                    <li class="px-6 py-4">
                        <p class="font-sans text-xs uppercase tracking-widest text-[#1a1a1a]/40 mb-1">Cash-on-Cash Yield</p>
                        <p class="font-sans text-sm font-medium text-[#1a1a1a]"><%= asset.cashOnCashYield %></p>
                    </li>
                    <% } %>
                    <% if (asset.targetIRR) { %>
                    <li class="px-6 py-4">
                        <p class="font-sans text-xs uppercase tracking-widest text-[#1a1a1a]/40 mb-1">Target IRR</p>
                        <p class="font-serif text-2xl font-semibold text-[#0f2e22]"><%= asset.targetIRR %></p>
                    </li>
                    <% } %>
                </ul>
            </div>
        </div>

    </div>
</section>

<!-- ═══════════════ GALLERY ═══════════════ -->
<% if (asset.galleryImages && asset.galleryImages.length > 0) { %>
<section class="bg-white border-t border-[#0f2e22]/10">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16 py-10 md:py-16">
        <h3 class="font-serif text-2xl text-[#0f2e22] mb-8">Gallery</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            <% asset.galleryImages.forEach(function(img) { %>
            <div class="aspect-[4/3] bg-gray-200 overflow-hidden border border-gray-200">
                <img src="<%= img %>" alt="<%= asset.title %> Gallery" class="w-full h-full object-cover rounded-none" loading="lazy">
            </div>
            <% }); %>
        </div>
    </div>
</section>
<% } %>

<!-- ═══════════════ SEC DISCLAIMER ═══════════════ -->
<section class="bg-white border-t border-[#0f2e22]/10">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16 py-8 md:py-12">
        <div class="border border-[#0f2e22]/10 p-5 md:p-8">
            <p class="font-sans text-[10px] font-bold uppercase tracking-widest text-[#1a1a1a]/40 mb-3">Important Disclosures</p>
            <p class="font-sans text-xs text-gray-500 leading-relaxed mb-3">This case study is provided for informational purposes only and does not constitute an offer to sell, a solicitation of an offer to buy, or a recommendation for any security or investment product. Past performance is not indicative of future results. All investments involve risk, including the possible loss of principal.</p>
            <p class="font-sans text-xs text-gray-500 leading-relaxed mb-3">The information presented herein reflects historical performance of specific assets or strategies and may not be representative of current or future investments. Financial metrics shown are based on internal calculations and have not been independently audited. Target returns are forward-looking estimates and are not guaranteed.</p>
            <p class="font-sans text-xs text-gray-500 leading-relaxed">Vanier Capital LLC does not provide tax, legal, or accounting advice. Prospective investors should consult their own advisors regarding the suitability of any investment. Securities offered, if any, are available only to accredited investors as defined under Regulation D of the Securities Act of 1933.</p>
        </div>
    </div>
</section>

<!-- ═══════════════ CTA — EXPLORE APPROACH ═══════════════ -->
<section class="bg-slate-50 border-t border-[#0f2e22]/10">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16 py-14 md:py-20 flex flex-col md:flex-row md:items-center md:justify-between gap-8">
        <div>
            <h2 class="font-serif text-3xl md:text-4xl text-[#0f2e22] mb-3">Explore Our Approach.</h2>
            <p class="font-sans text-lg text-gray-600 max-w-xl">Learn more about our investment strategy, underwriting discipline, and how we create value across our portfolio.</p>
        </div>
        <a href="/strategy" class="inline-block font-sans text-sm font-bold text-white bg-[#0f2e22] px-10 py-4 uppercase tracking-wider hover:bg-[#1a3a2a] transition-colors rounded-none whitespace-nowrap">Investment Strategy</a>
    </div>
</section>

<%- include('partials/footer') %>
