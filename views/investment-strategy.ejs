<!-- views/investment-strategy.ejs -->
<%- include('partials/header', {
  pageTitle: 'Investment Strategy | Vanier Capital',
  pageDescription: 'Our disciplined investment philosophy focuses on resilient markets, value-add opportunities, and long-term wealth creation.',
  path: '/strategy'
}) %>

<section class="section">
  <div class="container">
    <div class="section-header" style="max-width:860px;margin-inline:auto;text-align:center;">
      <p class="eyebrow" style="background:rgba(11,77,58,0.12);border-color:rgba(11,77,58,0.3);color:#0b4d3a;">Our Philosophy</p>
      <h1 class="section-title" style="font-family:'Merriweather',serif;">Disciplined, Data‑Driven, Long-Term</h1>
      <p class="section-description" style="font-size:1.15rem;color:var(--color-text-muted);margin-top:.85rem;">We target resilient cash‑flowing assets in growth corridors, applying conservative underwriting and active asset management to compound value over multi‑year hold periods.</p>
    </div>
  </div>
</section>

<section class="section section-muted">
  <div class="container">
    <div class="grid-container grid-3-col">
      <div class="content-card" role="group" aria-label="Market Selection">
        <div class="card-icon"><i class="fas fa-location-dot"></i></div>
        <h3>Market Selection</h3>
        <p>We evaluate demographic inflows, job diversity, supply pipelines, and regulatory posture to focus on durable Sun Belt and secondary markets with asymmetric growth profiles.</p>
        <ul style="margin:.75rem 0 0 1rem;font-size:.9rem;color:var(--color-text-muted);line-height:1.5;">
          <li>Population & employment momentum</li>
          <li>Constrained new supply</li>
          <li>Infrastructure & logistics linkages</li>
        </ul>
      </div>
      <div class="content-card" role="group" aria-label="Asset Criteria">
        <div class="card-icon"><i class="fas fa-building"></i></div>
        <h3>Asset Criteria</h3>
        <p>Focus on under‑managed, lightly capitalized, or repositionable assets where targeted improvements and professional management unlock NOI expansion.</p>
        <ul style="margin:.75rem 0 0 1rem;font-size:.9rem;color:var(--color-text-muted);line-height:1.5;">
          <li>Value‑add potential</li>
          <li>Operational inefficiencies</li>
          <li>Strong rent growth tailwinds</li>
        </ul>
      </div>
      <div class="content-card" role="group" aria-label="Risk Management">
        <div class="card-icon"><i class="fas fa-shield"></i></div>
        <h3>Risk Management</h3>
        <p>Conservative leverage, diversified tenant mixes, rigorous due diligence, and contingency planning are embedded at every stage of acquisition and ownership.</p>
        <ul style="margin:.75rem 0 0 1rem;font-size:.9rem;color:var(--color-text-muted);line-height:1.5;">
          <li>Stress-tested underwriting</li>
          <li>CapEx & reserve discipline</li>
          <li>Active performance monitoring</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header" style="text-align:center;max-width:800px;margin-inline:auto;">
      <h2 class="section-title" style="font-family:'Merriweather',serif;">Lifecycle Approach</h2>
      <p class="section-description">A repeatable framework that protects capital while creating upside.</p>
    </div>
    <div class="process-steps" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));">
      <div class="process-step"><div class="step-icon"><i class="fas fa-chart-line"></i></div><h3>1. Sourcing</h3><p>Broker relationships, off‑market outreach, and data tools surface mispriced or overlooked assets.</p></div>
      <div class="process-step"><div class="step-icon"><i class="fas fa-file-invoice-dollar"></i></div><h3>2. Underwriting</h3><p>Rigorous financial models stress test rent, expense, and exit assumptions under multiple scenarios.</p></div>
      <div class="process-step"><div class="step-icon"><i class="fas fa-hammer"></i></div><h3>3. Value Creation</h3><p>CapEx execution, unit upgrades, amenity enhancements, and operational efficiency initiatives.</p></div>
      <div class="process-step"><div class="step-icon"><i class="fas fa-chart-pie"></i></div><h3>4. Optimization</h3><p>Active asset management drives occupancy quality, expense control, and revenue optimization.</p></div>
      <div class="process-step"><div class="step-icon"><i class="fas fa-right-left"></i></div><h3>5. Exit Strategy</h3><p>Disposition timing informed by market cycles, stabilized yield, and alternative capital deployment.</p></div>
    </div>
  </div>
</section>

<section class="cta-section cta-alt full-bleed">
  <div class="container">
    <div class="cta-content">
      <h2 class="section-title cta-title" style="font-family:'Merriweather',serif;">Partner With a Disciplined Operator</h2>
      <p class="cta-description">Request our full strategy deck and learn about current acquisition criteria.</p>
      <a href="/contact" class="cta-button primary-btn">Request Strategy Deck</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
