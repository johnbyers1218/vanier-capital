<%- include('partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: path
}) %>

<section class="section portfolio-hero" style="background-color: #f1f5f9; color: #1e293b; padding: 4rem 0;">
    <div class="container">
        <div class="section-header" style="text-align: center;">
            <h1 class="section-title" style="color: #1e293b; font-family: 'Merriweather', serif; font-size: 2.5rem; margin-bottom: 1rem;">Available Rentals</h1>
            <p class="section-description" style="color: #64748b; max-width: 700px; margin: 0 auto;">Find your next home in one of our professionally managed properties.</p>
            
            <div style="margin-top: 2rem; display: inline-flex; align-items: center; background: white; padding: 0.75rem 1.5rem; border-radius: 9999px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                <div style="color: #0b4d3a; font-weight: 800; font-size: 1.5rem; margin-right: 0.75rem;"><%= typeof tenantSatisfaction !== 'undefined' ? tenantSatisfaction : '5.0/5' %></div>
                <div style="text-align: left; line-height: 1.2;">
                    <div style="color: #1e293b; font-weight: 700; font-size: 0.9rem;">Tenant Satisfaction</div>
                    <div style="color: #64748b; font-size: 0.8rem;">Average Rating</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section" style="background-color: #f8fafc; padding: 4rem 0;">
    <div class="container">
        
        <!-- Portfolio Grid -->
        <div class="grid-container grid-3-col" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem;">
            
            <% if (properties && properties.length > 0) { %>
                <% properties.forEach(property => { %>
                    <div class="content-card project-card" style="background: white; border-radius: 0.75rem; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                        <div style="aspect-ratio: 16/9; background: #e2e8f0; position: relative; overflow: hidden;">
                            <img src="<%= property.image %>" alt="<%= property.title %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://placehold.co/600x400/0b4d3a/ffffff?text=<%= encodeURIComponent(property.title) %>'">
                            <div style="position: absolute; top: 1rem; right: 1rem; background: rgba(11, 77, 58, 0.9); color: white; padding: 0.25rem 0.75rem; border-radius: 0.25rem; font-size: 0.875rem; font-weight: 600;">For Rent</div>
                        </div>
                        <div style="padding: 1.5rem; display: flex; flex-direction: column; height: 100%;">
                            <h3 style="font-family: 'Merriweather', serif; font-size: 1.25rem; font-weight: 700; color: #1e293b; margin-bottom: 0.5rem;"><%= property.title %></h3>
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 0.5rem;">
                                <p style="color: #0b4d3a; font-weight: 700; font-size: 1.1rem; margin:0;"><%= property.price %></p>
                                <% if (property.isAvailable) { %>
                                    <span style="background:#dcfce7; color:#166534; font-size:0.75rem; font-weight:600; padding:0.125rem 0.5rem; border-radius:9999px;">Available Now</span>
                                <% } %>
                            </div>
                            <p style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.5rem;"><i class="fas fa-map-marker-alt" style="color: #0b4d3a; margin-right: 0.5rem;"></i><%= property.address || property.location %></p>
                            
                            <% if (property.bedrooms || property.bathrooms || property.sqft) { %>
                                <div style="display:flex; gap:1rem; margin-bottom:1rem; font-size:0.875rem; color:#475569;">
                                    <% if (property.bedrooms) { %><span><i class="fas fa-bed"></i> <%= property.bedrooms %> Beds</span><% } %>
                                    <% if (property.bathrooms) { %><span><i class="fas fa-bath"></i> <%= property.bathrooms %> Baths</span><% } %>
                                    <% if (property.sqft) { %><span><i class="fas fa-ruler-combined"></i> <%= property.sqft %> sqft</span><% } %>
                                </div>
                            <% } %>

                            <p style="color: #475569; font-size: 0.95rem; line-height: 1.5; margin-bottom: 1.5rem; flex-grow: 1;"><%= property.summary %></p>
                            
                            <div style="margin-top: auto;">
                                <% if (property.rentalApplicationUrl) { %>
                                    <a href="<%= property.rentalApplicationUrl %>" class="cta-button primary-btn" style="display: block; text-align: center; background-color: #0b4d3a; color: white; padding: 0.75rem; border-radius: 0.375rem; text-decoration: none; font-weight: 600; transition: background-color 0.2s;" target="_blank" rel="noopener noreferrer">Apply Here</a>
                                <% } else { %>
                                    <a href="/contact?property=<%= encodeURIComponent(property.title) %>" class="cta-button primary-btn" style="display: block; text-align: center; background-color: #0b4d3a; color: white; padding: 0.75rem; border-radius: 0.375rem; text-decoration: none; font-weight: 600; transition: background-color 0.2s;">Inquire Now</a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                    <p>No properties currently available.</p>
                </div>
            <% } %>

        </div>
    </div>
</section>

<%- include('partials/footer') %>
