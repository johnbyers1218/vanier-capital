<!-- views/partials/header.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Skip to main content link for accessibility -->
    <a href="#main-content" class="skip-link" style="position:absolute;left:-999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:1000;background:#fff;color:#222;padding:8px 16px;border-radius:4px;box-shadow:0 2px 8px rgba(0,0,0,0.08);transition:left 0.2s;">Skip to main content</a>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <% 
            const __rawTitle = (typeof pageTitle !== 'undefined' && pageTitle) ? String(pageTitle) : 'FND Automations';
            const __title = /fnd\s+automations/i.test(__rawTitle) ? __rawTitle : (__rawTitle + ' | FND Automations');
            const __rawDesc = (typeof pageDescription !== 'undefined' && pageDescription) ? String(pageDescription) : 'FND Automations empowers businesses with AI and automation to boost efficiency, reduce costs, and drive growth.';
            const __desc = __rawDesc.length > 160 ? (__rawDesc.substring(0,157) + '...') : __rawDesc;
        %>
    <title><%= __title %></title>
    <meta name="description" content="<%= __desc %>">
    <!-- SEO: Open Graph & Twitter Card -->
    <meta property="og:title" content="<%= __title %>">
    <meta property="og:description" content="<%= __desc %>">
    <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : (typeof isBlogPost !== 'undefined' && isBlogPost ? 'article' : 'website') %>">
    <meta property="og:image" content="<%= (typeof ogImage !== 'undefined' ? (ogImage.startsWith('http') ? ogImage : (process.env.SITE_URL || 'https://www.fndautomations.com') + ogImage) : (process.env.SITE_URL || 'https://www.fndautomations.com') + '/images/FND_LOGO_SVG_BLACK.svg') %>">
        <% if (typeof isBlogPost !== 'undefined' && isBlogPost && post) { %>
            <% if (post.publishedDate) { %>
                <meta property="article:published_time" content="<%= post.publishedDate.toISOString ? post.publishedDate.toISOString() : post.publishedDate %>">
            <% } %>
            <% if (post.updatedAt) { %>
                <meta property="article:modified_time" content="<%= post.updatedAt.toISOString ? post.updatedAt.toISOString() : post.updatedAt %>">
            <% } %>
        <% } %>
        <% if (typeof robots !== 'undefined') { %>
            <meta name="robots" content="<%= robots %>">
        <% } %>
    <meta property="og:url" content="<%= typeof canonicalPath !== 'undefined' ? (process.env.SITE_URL || 'https://www.fndautomations.com') + canonicalPath : (process.env.SITE_URL || 'https://www.fndautomations.com') + (typeof req !== 'undefined' ? req.originalUrl : '') %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= __title %>">
    <meta name="twitter:description" content="<%= __desc %>">
    <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : (process.env.SITE_URL || 'https://www.fndautomations.com') + '/images/FND_LOGO_SVG_BLACK.svg' %>">
    <!-- Canonical -->
    <link rel="canonical" href="<%= typeof canonicalPath !== 'undefined' ? (process.env.SITE_URL || 'https://www.fndautomations.com') + canonicalPath : (process.env.SITE_URL || 'https://www.fndautomations.com') + (typeof req !== 'undefined' ? req.originalUrl : '') %>">
    <meta name="author" content="FND Automations">

     <!-- ========== FAVICON LINKS START ========== -->
    <link rel="icon" href="<%= cdnUrl('/images/FND_LOGO_SVG_STRIPPED.svg') %>" sizes="any"> <!-- ICO format, any size -->
    <!-- You might also have a manifest.json for PWAs which can define icons -->
    <!-- <link rel="manifest" href="/manifest.json"> -->
    <!-- ========== FAVICON LINKS END ========== -->

    <!-- Tailwind public bundle -->
    <link rel="stylesheet" href="<%= cdnUrl('/css/style.css') %>">
    <!-- Inter font for public site -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" integrity="sha512-MV7K8+y+gLIBoVD59lQIYicR65iaqukzvf/nwasF0nqhPay5w/9lJmVM2hMDcnK1OnMGCdVK+iQrJ7lzPJQd1w==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- Favicon Links -->

        <!-- Organization Structured Data -->
        <script type="application/ld+json">
        <%- JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "FND Automations",
            "url": "https://www.fndautomations.com/",
            "logo": "https://www.fndautomations.com/images/FND_LOGO_SVG_BLACK.svg",
            "sameAs": [
                "https://www.linkedin.com/company/fnd-automations"
            ],
            "contactPoint": {
                "@type": "ContactPoint",
                "contactType": "sales",
                "email": "hello@fndautomations.com"
            }
        }, null, 2) %>
        </script>
</head>
<body>
        <div class="min-h-dvh bg-white text-[#374151] font-sans">
        <header id="site-header" class="sticky top-0 z-40 transition-all" style="--header-height: 72px; backdrop-filter: blur(0px); background-color: transparent; box-shadow: none;">
                        <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4 md:py-5 flex items-center justify-between">
                <a href="/" class="inline-flex items-center" title="FND Automations Home">
                    <img src="<%= cdnUrl('/images/FND_LOGO_SVG_BLACK.svg') %>" alt="FND Automations" class="site-logo w-auto" />
                </a>
                <button class="hamburger md:hidden" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links-list">
                    <span></span><span></span><span></span>
                </button>
                                <ul class="nav-links hidden md:flex items-center gap-7 text-[15px]" id="nav-links-list">
                    <% const currentPath = typeof path !== 'undefined' ? path : ''; %>
                                        <% const active = 'text-[var(--color-primary)] font-semibold'; %>
                                        <% const base = 'text-[#374151] hover:text-[var(--color-primary)] transition-colors'; %>
                                        <li><a class="<%= currentPath === '/' ? active : base %>" href="/">Home</a></li>
                                        <li><a class="<%= currentPath === '/services' ? active : base %>" href="/services">Services</a></li>
                                        <li><a class="<%= currentPath === '/projects' ? active : base %>" href="/projects">Projects</a></li>
                                        <li><a class="<%= currentPath === '/testimonials' ? active : base %>" href="/testimonials">Testimonials</a></li>
                                        <li><a class="<%= currentPath === '/about' ? active : base %>" href="/about">About</a></li>
                                        <li><a class="<%= currentPath.startsWith('/blog') ? active : base %>" href="/blog">Blog</a></li>
                                        <li>
                                            <a class="cta-button primary-btn" href="/contact" aria-label="Contact">
                                                <span>Contact</span>
                                            </a>
                                        </li>
                </ul>
            </nav>
        </header>
    <main id="main-content" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10"> <!-- Opening main tag -->