<!-- Mega-dropdown hover engine: JS-managed for seamless cross-fade, zero dead zones -->
<style>
    /* Kill CSS group-hover so JS has full control on desktop (lg+) */
    @media (min-width: 1024px) {
        .group\/navitem > div.absolute.mega-panel {
            visibility: hidden !important;
            opacity: 0 !important;
            pointer-events: none;
            transition: opacity 180ms ease, visibility 0s linear 180ms;
        }
        .group\/navitem > div.absolute.mega-panel.mega-open {
            visibility: visible !important;
            opacity: 1 !important;
            pointer-events: auto;
            transition: opacity 180ms ease, visibility 0s linear 0s;
        }
        /* Force-open via click/touch — same as mega-open */
        .group\/navitem.force-open > div.absolute.mega-panel {
            visibility: visible !important;
            opacity: 1 !important;
            pointer-events: auto;
            transition: opacity 180ms ease, visibility 0s linear 0s;
        }
        /* Hover bridge: invisible 12px zone below each <li> to bridge to dropdown */
        .group\/navitem::after {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            top: 100%;
            height: 12px;
            background: transparent;
        }
    }
</style>

<!-- Desktop dropdown engine + mobile menu scripts -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    /* ── 1. Desktop Mega-Dropdown Engine (lg+ only) ── */
    const navGroups = document.querySelectorAll('.group\\/navitem');
    const panels = document.querySelectorAll('.mega-panel');
    let activeGroup = null;
    let closeTimer = null;
    const CLOSE_DELAY = 120; // ms grace period when mouse leaves

    function openPanel(group) {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
        if (activeGroup === group) return;
        // Close previous instantly (no fade-out overlap)
        if (activeGroup) {
            const prevPanel = activeGroup.querySelector(':scope > .mega-panel');
            if (prevPanel) prevPanel.classList.remove('mega-open');
        }
        activeGroup = group;
        const panel = group.querySelector(':scope > .mega-panel');
        if (panel) panel.classList.add('mega-open');
    }

    function scheduleClose() {
        if (closeTimer) clearTimeout(closeTimer);
        closeTimer = setTimeout(() => {
            if (activeGroup) {
                const panel = activeGroup.querySelector(':scope > .mega-panel');
                if (panel) panel.classList.remove('mega-open');
                activeGroup = null;
            }
        }, CLOSE_DELAY);
    }

    function cancelClose() {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    }

    // Only attach mouse listeners on lg+ viewports
    const mql = window.matchMedia('(min-width: 1024px)');

    function attachDesktopListeners() {
        navGroups.forEach(group => {
            group.addEventListener('mouseenter', handleGroupEnter);
            group.addEventListener('mouseleave', handleGroupLeave);
        });
        panels.forEach(panel => {
            panel.addEventListener('mouseenter', handlePanelEnter);
            panel.addEventListener('mouseleave', handlePanelLeave);
        });
    }

    function detachDesktopListeners() {
        navGroups.forEach(group => {
            group.removeEventListener('mouseenter', handleGroupEnter);
            group.removeEventListener('mouseleave', handleGroupLeave);
        });
        panels.forEach(panel => {
            panel.removeEventListener('mouseenter', handlePanelEnter);
            panel.removeEventListener('mouseleave', handlePanelLeave);
        });
        // Clean up any open state
        if (activeGroup) {
            const p = activeGroup.querySelector(':scope > .mega-panel');
            if (p) p.classList.remove('mega-open');
            activeGroup = null;
        }
    }

    function handleGroupEnter() {
        // Wipe any click-forced state when mouse enters
        navGroups.forEach(g => {
            g.classList.remove('force-open');
            const d = g.querySelector(':scope > .mega-panel');
            if (d) { d.style.visibility = ''; d.style.opacity = ''; }
        });
        openPanel(this);
    }
    function handleGroupLeave() { scheduleClose(); }
    function handlePanelEnter() { cancelClose(); }
    function handlePanelLeave() { scheduleClose(); }

    if (mql.matches) attachDesktopListeners();
    mql.addEventListener('change', (e) => {
        if (e.matches) attachDesktopListeners();
        else detachDesktopListeners();
    });

    /* ── 2. Click/Touch Toggle (fallback for touch-screen laptops) ── */
    const toggles = document.querySelectorAll('.desktop-dropdown-toggle');
    toggles.forEach(toggle => {
        toggle.addEventListener('click', (e) => {
            e.preventDefault();
            const parentGroup = toggle.closest('.group\\/navitem');
            if (!parentGroup) return;
            const dropdown = parentGroup.querySelector(':scope > .mega-panel');
            if (!dropdown) return;

            // Close all others
            navGroups.forEach(g => {
                if (g !== parentGroup) {
                    g.classList.remove('force-open');
                    const d = g.querySelector(':scope > .mega-panel');
                    if (d) { d.classList.remove('mega-open'); d.style.visibility = ''; d.style.opacity = ''; }
                }
            });

            const isOpen = parentGroup.classList.contains('force-open');
            if (isOpen) {
                parentGroup.classList.remove('force-open');
                dropdown.classList.remove('mega-open');
                dropdown.style.visibility = '';
                dropdown.style.opacity = '';
                activeGroup = null;
            } else {
                parentGroup.classList.add('force-open');
                dropdown.classList.add('mega-open');
                activeGroup = parentGroup;
            }
        });
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.group\\/navitem')) {
            navGroups.forEach(g => {
                g.classList.remove('force-open');
                const d = g.querySelector(':scope > .mega-panel');
                if (d) { d.classList.remove('mega-open'); d.style.visibility = ''; d.style.opacity = ''; }
            });
            activeGroup = null;
        }
    });

    /* ── 3. Mobile Menu Color Lock ── */
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-nav');
    const mainHeader = document.getElementById('main-header');

    if (mobileBtn && mobileMenu && mainHeader) {
        mobileBtn.addEventListener('click', () => {
            requestAnimationFrame(() => {
                const isOpen = !mobileMenu.classList.contains('hidden');
                if (isOpen) {
                    mainHeader.classList.add('bg-white', 'text-[#1a1a1a]', 'shadow-sm');
                    mainHeader.classList.remove('bg-transparent', 'text-white');
                    mainHeader.dataset.menuLocked = 'true';
                } else {
                    mainHeader.dataset.menuLocked = '';
                    window.dispatchEvent(new Event('scroll'));
                }
            });
        });
    }
});
</script>

<!-- Main Content Wrapper -->
<main class="main-content" style="<%= __isHeroPage ? '' : 'padding-top: 88px;' %>">