<!-- views/partials/header.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <% 
            const __rawTitle = (typeof pageTitle !== 'undefined' && pageTitle) ? String(pageTitle) : 'Vanier Capital, LLC';
            const __title = /vanier\s+capital/i.test(__rawTitle) ? __rawTitle : (__rawTitle + ' | Vanier Capital, LLC');
            const __rawDesc = (typeof pageDescription !== 'undefined' && pageDescription) ? String(pageDescription) : 'Vanier Capital is a real estate investment and asset management firm focused on long-term value creation through disciplined acquisition, development, and stewardship.';
            const __desc = __rawDesc.length > 160 ? (__rawDesc.substring(0,157) + '...') : __rawDesc;
        %>
    <title><%= __title %></title>
    <meta name="description" content="<%= __desc %>">
    <!-- SEO: Open Graph & Twitter Card -->
    <meta property="og:title" content="<%= __title %>">
    <meta property="og:description" content="<%= __desc %>">
    <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : (typeof isBlogPost !== 'undefined' && isBlogPost ? 'article' : 'website') %>">
    <meta property="og:image" content="<%= (typeof ogImage !== 'undefined' ? (ogImage.startsWith('http') ? ogImage : (process.env.SITE_URL || 'https://www.vaniercapital.com') + ogImage) : (process.env.SITE_URL || 'https://www.vaniercapital.com') + '/images/vanier-logo.svg') %>">
        <% if (typeof isBlogPost !== 'undefined' && isBlogPost && post) { %>
            <% if (post.publishedDate) { %>
                <meta property="article:published_time" content="<%= post.publishedDate.toISOString ? post.publishedDate.toISOString() : post.publishedDate %>">
            <% } %>
            <% if (post.updatedAt) { %>
                <meta property="article:modified_time" content="<%= post.updatedAt.toISOString ? post.updatedAt.toISOString() : post.updatedAt %>">
            <% } %>
        <% } %>
        <% if (typeof robots !== 'undefined') { %>
            <meta name="robots" content="<%= robots %>">
        <% } %>
    <meta property="og:url" content="<%= typeof canonicalPath !== 'undefined' ? (process.env.SITE_URL || 'https://www.vaniercapital.com') + canonicalPath : (process.env.SITE_URL || 'https://www.vaniercapital.com') + (typeof req !== 'undefined' ? req.originalUrl : '') %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= __title %>">
    <meta name="twitter:description" content="<%= __desc %>">
    <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : (process.env.SITE_URL || 'https://www.vaniercapital.com') + '/images/vanier-logo.svg' %>">
    <!-- Canonical -->
    <link rel="canonical" href="<%= typeof canonicalPath !== 'undefined' ? (process.env.SITE_URL || 'https://www.vaniercapital.com') + canonicalPath : (process.env.SITE_URL || 'https://www.vaniercapital.com') + (typeof req !== 'undefined' ? req.originalUrl : '') %>">
    <meta name="author" content="Vanier Capital, LLC">

    <!-- ========== FAVICON LINKS START ========== -->
    <link rel="icon" type="image/svg+xml" href="<%= cdnUrl('/images/vanier-logo.svg') %>">
    <link rel="shortcut icon" href="<%= cdnUrl('/images/vanier-logo.svg') %>">
    <link rel="alternate icon" href="<%= cdnUrl('/images/vanier-logo.svg') %>">
    <!-- ========== FAVICON LINKS END ========== -->

    <!-- Tailwind public bundle -->
    <link rel="stylesheet" href="<%= cdnUrl('/css/style.css') %>?v=<%= assetVersion %>">
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Merriweather:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css" integrity="sha512-MV7K8+y+gLIBoVD59lQIYicR65iaqukzvf/nwasF0nqhPay5w/9lJmVM2hMDcnK1OnMGCdVK+iQrJ7lzPJQd1w==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Organization Structured Data -->
    <script type="application/ld+json">
    <%- JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Vanier Capital, LLC",
        "url": "https://www.vaniercapital.com/",
        "logo": (process.env.SITE_URL || 'https://www.vaniercapital.com') + '/images/vanier-logo.svg',
        "sameAs": [
            "https://www.linkedin.com/company/vanier-capital"
        ],
        "contactPoint": {
            "@type": "ContactPoint",
            "contactType": "investor-relations",
            "email": "info@vaniercapital.com"
        }
    }, null, 2) %>
    </script>
    
    <style>
        :root { --color-primary:#0b4d3a; --color-primary-hover:#093d2d; }
        h1,h2,h3,h4,h5,h6 { font-family: 'Merriweather', serif; }
        
        /* Global Layout Fixes */
        .container {
            width: 100%;
            max-width: 1280px;
            margin-left: auto;
            margin-right: auto;
            padding-left: 1.5rem;
            padding-right: 1.5rem;
        }
        
        /* Header Styles */
        #site-header { background: var(--color-primary) !important; transition: all 0.3s ease; height: 100px; }
        #site-header.header--scrolled { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
        
        /* Navigation Links */
        .nav-links { gap: 3rem; }
        .nav-links a { color: #e5e7eb; font-weight: 500; transition: color 0.2s ease; position: relative; font-size: 1.05rem; }
        .nav-links a:hover { color: #ffffff; }
        .nav-links a.active { color: #ffffff; font-weight: 700; }
        .nav-links a.active::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 100%;
            height: 2px;
            background-color: #ffffff;
            border-radius: 2px;
        }
        
        /* CTA Button */
        .cta-btn { 
            border: 1px solid rgba(255,255,255,0.3); 
            color: #ffffff !important;
        }
        .cta-btn:hover { 
            background-color: rgba(255,255,255,0.1); 
            border-color: #ffffff;
        }
        .cta-btn.active {
            background-color: #ffffff;
            color: var(--color-primary) !important;
            border-color: #ffffff;
        }

        /* Mobile Nav */
        #mobile-nav {
            display: none;
            background-color: var(--color-primary);
            border-top: 1px solid rgba(255,255,255,0.1);
            padding: 1rem;
        }
        #mobile-nav.open { display: block; }
        #mobile-nav a {
            display: block;
            padding: 0.75rem 1rem;
            color: #e5e7eb;
            font-weight: 500;
            border-radius: 0.375rem;
        }
        #mobile-nav a:hover { background-color: rgba(255,255,255,0.05); color: #ffffff; }
        #mobile-nav a.active { background-color: rgba(255,255,255,0.1); color: #ffffff; font-weight: 600; }
    </style>
</head>
<body class="font-inter text-gray-800 antialiased flex flex-col min-h-screen">

<!-- Site Header -->
<header id="site-header" class="fixed top-0 w-full z-50 flex items-center">
    <div class="container">
        <div class="flex justify-between items-center h-full">
            <!-- Logo -->
            <div class="flex-shrink-0 flex items-center">
                <a href="/" class="flex items-center gap-2 group" aria-label="Vanier Capital Home">
                    <img src="/images/vanier-logo.svg" alt="Vanier Capital Logo" class="h-12 w-auto transition-transform duration-300 group-hover:scale-105">
                </a>
            </div>

            <!-- Desktop Navigation -->
            <nav class="hidden md:flex nav-links items-center">
                <a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a>
                <a href="/portfolio" class="<%= path === '/portfolio' ? 'active' : '' %>">Portfolio</a>
                <a href="/for-rent" class="<%= path === '/for-rent' ? 'active' : '' %>">For Rent</a>
                <a href="/sell-your-home" class="<%= path === '/sell-your-home' ? 'active' : '' %>">Sell Your Home</a>
                <a href="/blog" class="<%= path === '/blog' ? 'active' : '' %>">Articles</a>
                <a href="/about" class="<%= path === '/about' ? 'active' : '' %>">About</a>
                <a href="/contact" class="cta-btn px-6 py-2.5 rounded-full transition-all duration-300 <%= path === '/contact' ? 'active' : '' %>">Contact</a>
            </nav>

            <!-- Mobile Menu Button -->
            <div class="flex items-center md:hidden">
                <button type="button" id="mobile-menu-btn" class="text-gray-200 hover:text-white focus:outline-none p-2" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="fas fa-bars text-xl"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Navigation Panel -->
    <div id="mobile-nav">
        <a href="/" class="<%= path === '/' ? 'active' : '' %>">Home</a>
        <a href="/portfolio" class="<%= path === '/portfolio' ? 'active' : '' %>">Portfolio</a>
        <a href="/for-rent" class="<%= path === '/for-rent' ? 'active' : '' %>">For Rent</a>
        <a href="/sell-your-home" class="<%= path === '/sell-your-home' ? 'active' : '' %>">Sell Your Home</a>
        <a href="/blog" class="<%= path === '/blog' ? 'active' : '' %>">Articles</a>
        <a href="/about" class="<%= path === '/about' ? 'active' : '' %>">About</a>
        <a href="/contact" class="<%= path === '/contact' ? 'active' : '' %>">Contact</a>
    </div>
</header>

<!-- Main Content Wrapper -->
<main class="flex-grow" style="padding-top: 100px;">

<script>
    // Mobile Menu Toggle
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    
    if (mobileBtn && mobileNav) {
        mobileBtn.addEventListener('click', () => {
            mobileNav.classList.toggle('open');
            const icon = mobileBtn.querySelector('i');
            if (mobileNav.classList.contains('open')) {
                icon.classList.remove('fa-bars');
                icon.classList.add('fa-times');
            } else {
                icon.classList.remove('fa-times');
                icon.classList.add('fa-bars');
            }
        });
    }

    // Header Scroll Effect
    const header = document.getElementById('site-header');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 10) {
            header.classList.add('header--scrolled');
        } else {
            header.classList.remove('header--scrolled');
        }
    });
</script>
