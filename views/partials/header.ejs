<!-- Mega-dropdown hover engine: JS-managed for seamless cross-fade, zero dead zones -->
<style>
    @media (min-width: 1024px) {
        /* ── 1. Tight Hit Areas ──
         * Kill h-full on <li> so bounding box wraps tightly around nav text.
         * pointer-events: none on the <ul> gap space, auto only on <li> items. */
        #main-header .desktop-nav {
            pointer-events: none;          /* dead space between items is inert */
        }
        #main-header .desktop-nav > .navitem {
            pointer-events: auto;          /* only the <li> items themselves respond */
            height: auto !important;       /* override h-full — shrink-wrap to content */
            align-self: stretch;           /* still vertically center via parent align-items */
            display: flex;
            align-items: center;
        }

        /* ── 2. Shared Persistent Background ──
         * A single white rectangle behind ALL mega panels.
         * It stays mounted when switching between nav items — only content changes. */
        .mega-backdrop {
            position: fixed;
            top: 88px;                     /* header height */
            left: 0;
            width: 100%;
            background: #ffffff;
            border-top: 1px solid rgba(15, 46, 34, 0.10);
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            height: 0;
            opacity: 0;
            pointer-events: none;
            overflow: hidden;
            transition: opacity 200ms ease, height 220ms ease;
            z-index: 40;
        }
        .mega-backdrop.backdrop-open {
            opacity: 1;
            pointer-events: auto;
        }

        /* ── 3. Panel visibility (JS-controlled) ──
         * Panels use fixed positioning to break out of the <li> containing block
         * and span the full viewport width. JS toggles .mega-open to cross-fade. */
        .navitem > div.mega-panel {
            position: fixed !important;
            top: 88px !important;          /* header height */
            left: 0 !important;
            right: 0 !important;
            width: 100% !important;
            visibility: hidden !important;
            opacity: 0 !important;
            pointer-events: none;
            transition: opacity 180ms ease, visibility 0s linear 180ms;
        }
        .navitem > div.mega-panel.mega-open {
            visibility: visible !important;
            opacity: 1 !important;
            pointer-events: auto;
            transition: opacity 180ms ease, visibility 0s linear 0s;
            z-index: 50;
        }
        /* Force-open via click/touch — same as mega-open */
        .navitem.force-open > div.mega-panel {
            visibility: visible !important;
            opacity: 1 !important;
            pointer-events: auto;
            transition: opacity 180ms ease, visibility 0s linear 0s;
            z-index: 50;
        }

        /* ── 4. Hover Bridge ──
         * 16px invisible zone below each <li> to bridge mouse travel to dropdown.
         * Also extends 8px above the panel to cover any gap. */
        .navitem::after {
            content: '';
            position: absolute;
            left: 0;
            width: 100%;
            top: 100%;
            height: 16px;
            background: transparent;
            pointer-events: auto;
        }
        /* Secondary bridge on the backdrop itself — covers the 1px border gap */
        .mega-backdrop::before {
            content: '';
            position: absolute;
            top: -12px;
            left: 0;
            width: 100%;
            height: 12px;
            background: transparent;
        }

        /* ── 5. Homepage header: opaque only when mega panel is open ──
         * Replaces the old hover:bg-white on <header> which fired on empty space. */
        #main-header.header-mega-active {
            background-color: #ffffff !important;
            color: #1a1a1a !important;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }
        #main-header.header-mega-active .desktop-nav-link {
            color: #1a1a1a !important;
        }
        #main-header.header-mega-active .header-logo {
            color: #1a1a1a !important;
        }
    }
</style>

<!-- Desktop dropdown engine + mobile menu scripts -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    /* ══════════════════════════════════════════════════════════════
     * 1. DESKTOP MEGA-DROPDOWN ENGINE — "Persistent Background" Pattern
     *
     * Architecture:
     *   - One shared #mega-backdrop div stays mounted at all times
     *   - When ANY panel opens, backdrop fades in and sizes to panel height
     *   - When switching panels, backdrop stays open and morphs to new height
     *   - Only when mouse fully leaves ALL nav items + backdrop does it close
     *   - Hit areas are tight: pointer-events: none on <ul> gaps
     * ══════════════════════════════════════════════════════════════ */
    const navGroups = document.querySelectorAll('.navitem');
    const panels    = document.querySelectorAll('.mega-panel');
    const backdrop  = document.getElementById('mega-backdrop');
    const header    = document.getElementById('main-header');

    let activeGroup = null;
    let closeTimer  = null;
    const CLOSE_DELAY = 180;   // ms grace period when mouse leaves

    /**
     * Open a specific nav group's panel.
     * Cross-fades content; backdrop stays persistent.
     */
    function openPanel(group) {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }

        // Close previous panel content (NOT the backdrop)
        if (activeGroup && activeGroup !== group) {
            const prevPanel = activeGroup.querySelector(':scope > .mega-panel');
            if (prevPanel) prevPanel.classList.remove('mega-open');
        }

        activeGroup = group;
        const panel = group.querySelector(':scope > .mega-panel');
        if (!panel || !backdrop) return;

        // Measure panel height: temporarily force visibility for measurement
        panel.classList.add('mega-open');
        const panelHeight = panel.offsetHeight;

        // Size and open the shared backdrop
        backdrop.style.height = panelHeight + 'px';
        backdrop.classList.add('backdrop-open');

        // Toggle header opaque state (homepage transparent → white)
        header.classList.add('header-mega-active');
    }

    /**
     * Schedule a delayed close of everything.
     * Any re-entry cancels the timer → seamless switching.
     */
    function scheduleClose() {
        if (closeTimer) clearTimeout(closeTimer);
        closeTimer = setTimeout(() => {
            closeAll();
        }, CLOSE_DELAY);
    }

    /**
     * Immediately close all panels + backdrop.
     */
    function closeAll() {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
        if (activeGroup) {
            const panel = activeGroup.querySelector(':scope > .mega-panel');
            if (panel) panel.classList.remove('mega-open');
            activeGroup = null;
        }
        if (backdrop) {
            backdrop.classList.remove('backdrop-open');
            // Reset height after transition completes
            setTimeout(() => {
                if (!backdrop.classList.contains('backdrop-open')) {
                    backdrop.style.height = '0';
                }
            }, 250);
        }
        // Remove header opaque override (let scroll state take over)
        header.classList.remove('header-mega-active');
        // Clear any force-open states
        navGroups.forEach(g => g.classList.remove('force-open'));
        // Re-evaluate scroll state (homepage: restore transparency if at top)
        window.dispatchEvent(new Event('scroll'));
    }

    function cancelClose() {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
    }

    /* ── Event Handlers ── */
    function handleGroupEnter() {
        // Clear any click-forced state
        navGroups.forEach(g => {
            g.classList.remove('force-open');
            const d = g.querySelector(':scope > .mega-panel');
            if (d) { d.style.visibility = ''; d.style.opacity = ''; }
        });
        openPanel(this);
    }
    function handleGroupLeave()  { scheduleClose(); }
    function handleBackdropEnter() { cancelClose(); }
    function handleBackdropLeave() { scheduleClose(); }

    /* ── Viewport-Aware Listener Management ── */
    const mql = window.matchMedia('(min-width: 1024px)');

    function attachDesktopListeners() {
        navGroups.forEach(group => {
            group.addEventListener('mouseenter', handleGroupEnter);
            group.addEventListener('mouseleave', handleGroupLeave);
        });
        // Panels are fixed-positioned, so they need their own mouse listeners
        // to cancel close when mouse enters the dropdown content
        panels.forEach(panel => {
            panel.addEventListener('mouseenter', handleBackdropEnter);
            panel.addEventListener('mouseleave', handleBackdropLeave);
        });
        if (backdrop) {
            backdrop.addEventListener('mouseenter', handleBackdropEnter);
            backdrop.addEventListener('mouseleave', handleBackdropLeave);
        }
    }

    function detachDesktopListeners() {
        navGroups.forEach(group => {
            group.removeEventListener('mouseenter', handleGroupEnter);
            group.removeEventListener('mouseleave', handleGroupLeave);
        });
        panels.forEach(panel => {
            panel.removeEventListener('mouseenter', handleBackdropEnter);
            panel.removeEventListener('mouseleave', handleBackdropLeave);
        });
        if (backdrop) {
            backdrop.removeEventListener('mouseenter', handleBackdropEnter);
            backdrop.removeEventListener('mouseleave', handleBackdropLeave);
        }
        closeAll();
    }

    if (mql.matches) attachDesktopListeners();
    mql.addEventListener('change', (e) => {
        if (e.matches) attachDesktopListeners();
        else detachDesktopListeners();
    });

    /* ══════════════════════════════════════════════════════════════
     * 2. CLICK/TOUCH TOGGLE (fallback for touch-screen laptops)
     * ══════════════════════════════════════════════════════════════ */
    const toggles = document.querySelectorAll('.desktop-dropdown-toggle');
    toggles.forEach(toggle => {
        toggle.addEventListener('click', (e) => {
            e.preventDefault();
            const parentGroup = toggle.closest('.navitem');
            if (!parentGroup) return;
            const dropdown = parentGroup.querySelector(':scope > .mega-panel');
            if (!dropdown) return;

            // Close all others
            navGroups.forEach(g => {
                if (g !== parentGroup) {
                    g.classList.remove('force-open');
                    const d = g.querySelector(':scope > .mega-panel');
                    if (d) { d.classList.remove('mega-open'); d.style.visibility = ''; d.style.opacity = ''; }
                }
            });

            const isOpen = parentGroup.classList.contains('force-open');
            if (isOpen) {
                parentGroup.classList.remove('force-open');
                dropdown.classList.remove('mega-open');
                dropdown.style.visibility = '';
                dropdown.style.opacity = '';
                if (backdrop) {
                    backdrop.classList.remove('backdrop-open');
                    backdrop.style.height = '0';
                }
                header.classList.remove('header-mega-active');
                activeGroup = null;
            } else {
                parentGroup.classList.add('force-open');
                dropdown.classList.add('mega-open');
                // Size backdrop
                if (backdrop) {
                    backdrop.style.height = dropdown.scrollHeight + 'px';
                    backdrop.classList.add('backdrop-open');
                }
                header.classList.add('header-mega-active');
                activeGroup = parentGroup;
            }
        });
    });

    // Close when clicking outside header
    document.addEventListener('click', (e) => {
        if (!e.target.closest('.navitem') && !e.target.closest('#mega-backdrop')) {
            closeAll();
        }
    });

    /* ══════════════════════════════════════════════════════════════
     * 3. MOBILE MENU COLOR LOCK
     * ══════════════════════════════════════════════════════════════ */
    const mobileBtn  = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-nav');
    const mainHeader = document.getElementById('main-header');

    if (mobileBtn && mobileMenu && mainHeader) {
        mobileBtn.addEventListener('click', () => {
            requestAnimationFrame(() => {
                const isOpen = !mobileMenu.classList.contains('hidden');
                if (isOpen) {
                    mainHeader.classList.add('bg-white', 'text-[#1a1a1a]', 'shadow-sm');
                    mainHeader.classList.remove('bg-transparent', 'text-white');
                    mainHeader.dataset.menuLocked = 'true';
                } else {
                    mainHeader.dataset.menuLocked = '';
                    window.dispatchEvent(new Event('scroll'));
                }
            });
        });
    }
});
</script>

