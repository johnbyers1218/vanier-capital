<!-- views/partials/header.ejs -->
<!-- tailwind-refresh-20260311: hidden lg:flex, flex lg:hidden, hidden lg:hidden -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <% 
            const __rawTitle = (typeof pageTitle !== 'undefined' && pageTitle) ? String(pageTitle) : 'Vanier Capital, LLC';
            const __title = /vanier\s+capital/i.test(__rawTitle) ? __rawTitle : (__rawTitle + ' | Vanier Capital, LLC');
            const __rawDesc = (typeof pageDescription !== 'undefined' && pageDescription) ? String(pageDescription) : 'Vanier Capital is a real estate investment and asset management firm focused on long-term value creation through disciplined acquisition, development, and stewardship.';
            const __desc = __rawDesc.length > 160 ? (__rawDesc.substring(0,157) + '...') : __rawDesc;
            const __isHeroPage = (typeof isHeroPage !== 'undefined' && isHeroPage === true);
        %>
    <title><%= __title %></title>
    <meta name="description" content="<%= __desc %>">
    <meta name="robots" content="<%= (typeof robotsMeta !== 'undefined' && robotsMeta) ? robotsMeta : 'index, follow' %>">
    <link rel="canonical" href="https://vaniercapital.com<%= typeof path !== 'undefined' ? path : '' %>">

    <!-- Open Graph / Social -->
    <meta property="og:title" content="<%= __title %>">
    <meta property="og:description" content="<%= __desc %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://vaniercapital.com<%= typeof path !== 'undefined' ? path : '' %>">
    <meta property="og:image" content="https://vaniercapital.com/images/vanier-og-image.jpg">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/images/vanier-favicon.svg">
    <link rel="apple-touch-icon" href="/images/vanier-apple-touch-icon.png">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet">

    <!-- Stylesheets -->
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer">

    <!-- Structured Data -->
    <script type="application/ld+json">
    <%= JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Vanier Capital",
        "url": "https://vaniercapital.com",
        "logo": "https://vaniercapital.com/images/vanier-logo.svg",
        "contactPoint": {
            "@type": "ContactPoint",
            "contactType": "investor-relations",
            "email": "info@vaniercapital.com"
        }
    }, null, 2) %>
    </script>
</head>
<body class="body-institutional" data-hero-page="<%= __isHeroPage %>">

<!-- Site Header - Brookfield Institutional Mega Menu Architecture -->
<%
    const __home = (typeof isHomepage !== 'undefined' && isHomepage === true);
    let __headerClasses = 'fixed top-0 left-0 w-full z-50 transition-colors duration-300 group/header';
    let __headerBehavior = 'static-opaque';

    if (__home) {
        // Homepage only: transparent over hero image, scroll-to-opaque
        __headerClasses += ' bg-transparent text-white hover:bg-white hover:text-[#1a1a1a] hover:shadow-sm';
        __headerBehavior = 'scroll-transparent';
    } else {
        // Every other page: solid white with dark text, no scroll effects
        __headerClasses += ' bg-white text-[#1a1a1a] shadow-sm border-b border-gray-100';
    }
%>
<header id="main-header" class="<%= __headerClasses %>" data-header-behavior="<%= __headerBehavior %>" style="height: 88px;">
    <div class="flex items-center justify-between h-full max-w-[1400px] mx-auto px-4 md:px-8 lg:px-16">

        <!-- Text Logo -->
        <a href="/" class="font-serif font-bold text-lg md:text-2xl tracking-[0.15em] uppercase transition-colors duration-300 group-hover/header:text-[#1a1a1a]" aria-label="Vanier Capital Home">
            VANIER CAPITAL
        </a>

        <!-- Desktop Navigation (lg+ 1024px — tablets get mobile menu) -->
        <ul class="hidden lg:flex items-center h-full">

            <!-- FIRM — Mega Menu -->
            <li class="group/navitem h-full flex items-center px-4 xl:px-6">
                <a href="#" class="desktop-dropdown-toggle cursor-pointer text-sm font-sans font-bold uppercase tracking-wider py-8 transition-colors duration-300 group-hover/header:text-[#1a1a1a] <%= path && path.startsWith('/firm') ? 'border-b-2 border-current' : '' %>">Firm</a>
                <!-- Full-width Mega Dropdown -->
                <div class="mega-panel absolute top-full left-0 w-full bg-white border-t border-[#0f2e22]/10 shadow-xl invisible opacity-0 group-hover/navitem:visible group-hover/navitem:opacity-100 transition-all duration-300 ease-in-out z-40 group-hover/navitem:z-50 cursor-default text-[#1a1a1a]">
                    <div class="max-w-[1400px] mx-auto px-8 py-12 grid grid-cols-12 gap-12">
                        <!-- Col 1: Blurb -->
                        <div class="col-span-3">
                            <h3 class="font-serif text-xl font-bold text-[#0f2e22] mb-3">The Firm</h3>
                            <p class="text-sm text-gray-600 font-sans leading-relaxed pr-4">Building generational wealth through strategic assets and disciplined capital stewardship.</p>
                        </div>
                        <!-- Col 2: Links -->
                        <div class="col-span-6 flex flex-col space-y-4 pt-1">
                            <a href="/firm/overview" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1 border-b border-gray-100 pb-3">Firm Overview</a>
                            <a href="/firm/leadership" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1">Leadership</a>
                            <a href="/firm/stewardship" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1">Stewardship</a>
                            <a href="/firm/overview#philosophy" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1">Mission &amp; Philosophy</a>
                        </div>
                        <!-- Col 3: Featured Card -->
                        <% if (typeof latestFirmUpdate !== 'undefined' && latestFirmUpdate) { %>
                        <div class="col-span-3 bg-[#f9f8f6] p-5">
                            <p class="text-xs font-bold tracking-[0.15em] text-gray-500 uppercase mb-3">Latest Firm Update</p>
                            <a href="/blog/<%= latestFirmUpdate.slug %>" class="block group/card">
                                <% if (latestFirmUpdate.featuredImage) { %>
                                <img src="<%= latestFirmUpdate.featuredImage %>" alt="<%= latestFirmUpdate.title %>" class="h-32 w-full object-cover mb-3">
                                <% } else { %>
                                <img src="/images/hero-real-estate.jpg" alt="<%= latestFirmUpdate.title %>" class="h-32 w-full object-cover mb-3">
                                <% } %>
                                <h4 class="font-serif text-lg font-semibold text-[#1a1a1a] group-hover/card:text-[#0f2e22] transition-colors"><%= latestFirmUpdate.title %></h4>
                            </a>
                        </div>
                        <% } %>
                    </div>
                </div>
            </li>

            <!-- STRATEGIES — Mega Menu -->
            <li class="group/navitem h-full flex items-center px-4 xl:px-6">
                <a href="#" class="desktop-dropdown-toggle cursor-pointer text-sm font-sans font-bold uppercase tracking-wider py-8 transition-colors duration-300 group-hover/header:text-[#1a1a1a] <%= path === '/strategy' || path === '/strategies' ? 'border-b-2 border-current' : '' %>">Strategies</a>
                <div class="mega-panel absolute top-full left-0 w-full bg-white border-t border-[#0f2e22]/10 shadow-xl invisible opacity-0 group-hover/navitem:visible group-hover/navitem:opacity-100 transition-all duration-300 ease-in-out z-40 group-hover/navitem:z-50 cursor-default text-[#1a1a1a]">
                    <div class="max-w-[1400px] mx-auto px-8 py-12 grid grid-cols-12 gap-12">
                        <div class="col-span-3">
                            <h3 class="font-serif text-xl font-bold text-[#0f2e22] mb-3">Strategies</h3>
                            <p class="text-sm text-gray-600 font-sans leading-relaxed pr-4">Institutional discipline across resilient residential asset classes.</p>
                        </div>
                        <div class="col-span-6 flex flex-col space-y-4 pt-1">
                            <a href="/strategies" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1 border-b border-gray-100 pb-3">Strategy Overview</a>
                            <a href="/strategies#philosophy" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1">Investment Philosophy</a>
                            <a href="/strategies#market-selection" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1">Market Selection & Criteria</a>
                            <a href="/strategies#execution" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1">Execution Framework</a>
                        </div>
                        <div class="col-span-3 bg-[#0f2e22] p-5 flex flex-col justify-between">
                            <div>
                                <p class="text-xs font-bold tracking-[0.15em] text-white/60 uppercase mb-3">Value-Add Execution</p>
                                <h4 class="font-serif text-lg font-semibold text-white mb-2">Operational Alpha</h4>
                                <p class="text-sm text-white/70 font-sans leading-relaxed mb-4">We acquire middle-market residential assets and execute highly efficient renovations to force appreciation, maintain a critical cost-basis advantage, and secure resilient long-term rental yield.</p>
                            </div>
                            <a href="/strategies" class="inline-block text-center text-sm font-bold uppercase tracking-wider bg-white text-[#0f2e22] px-5 py-3 hover:bg-[#f9f8f6] transition-colors">View Strategy</a>
                        </div>
                    </div>
                </div>
            </li>

            <!-- PORTFOLIO — Mega Menu -->
            <li class="group/navitem h-full flex items-center px-4 xl:px-6">
                <a href="#" class="desktop-dropdown-toggle cursor-pointer text-sm font-sans font-bold uppercase tracking-wider py-8 transition-colors duration-300 group-hover/header:text-[#1a1a1a] <%= path === '/portfolio' ? 'border-b-2 border-current' : '' %>">Portfolio</a>
                <div class="mega-panel absolute top-full left-0 w-full bg-white border-t border-[#0f2e22]/10 shadow-xl invisible opacity-0 group-hover/navitem:visible group-hover/navitem:opacity-100 transition-all duration-300 ease-in-out z-40 group-hover/navitem:z-50 cursor-default text-[#1a1a1a]">
                    <div class="max-w-[1400px] mx-auto px-8 py-12 grid grid-cols-12 gap-12">
                        <div class="col-span-3">
                            <h3 class="font-serif text-xl font-bold text-[#0f2e22] mb-3">Portfolio</h3>
                            <p class="text-sm text-gray-600 font-sans leading-relaxed pr-4">Representative assets demonstrating our disciplined approach to capital stewardship.</p>
                        </div>
                        <div class="col-span-5 flex flex-col space-y-4 pt-1">
                            <a href="/portfolio" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1 border-b border-gray-100 pb-3">All Assets &amp; Track Record</a>
                            <% if (typeof portfolioHoldings !== 'undefined' && portfolioHoldings.length) { %>
                            <p class="font-sans text-xs font-bold uppercase tracking-widest text-gray-400 pt-2">Current Holdings</p>
                            <% portfolioHoldings.forEach(h => { %>
                            <a href="/portfolio/<%= h.slug %>" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1"><%= h.portfolioName || h.title %></a>
                            <% }); %>
                            <% } %>
                            <% if (typeof portfolioPipeline !== 'undefined' && portfolioPipeline.length) { %>
                            <p class="font-sans text-xs font-bold uppercase tracking-widest text-gray-400 pt-2">Pipeline</p>
                            <% portfolioPipeline.forEach(p => { %>
                            <a href="/portfolio/<%= p.slug %>" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1"><%= p.portfolioName || p.title %></a>
                            <% }); %>
                            <% } %>
                        </div>
                        <div class="col-span-4 bg-[#f9f8f6] p-5">
                            <p class="text-xs font-bold tracking-[0.15em] text-gray-500 uppercase mb-3">Featured Asset</p>
                            <% if (typeof featuredAsset !== 'undefined' && featuredAsset) { %>
                            <a href="/portfolio/<%= featuredAsset.slug %>" class="block group/card">
                                <img src="<%= featuredAsset.image || '/images/hero-real-estate.jpg' %>" alt="<%= featuredAsset.portfolioName || featuredAsset.title %>" class="h-32 w-full object-cover mb-3">
                                <h4 class="font-serif text-lg font-semibold text-[#1a1a1a] group-hover/card:text-[#0f2e22] transition-colors"><%= featuredAsset.portfolioName || featuredAsset.title %></h4>
                            </a>
                            <% } else { %>
                            <a href="/portfolio" class="block group/card">
                                <img src="/images/hero-real-estate.jpg" alt="View Portfolio" class="h-32 w-full object-cover mb-3">
                                <h4 class="font-serif text-lg font-semibold text-[#1a1a1a] group-hover/card:text-[#0f2e22] transition-colors">View All Assets</h4>
                            </a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </li>

            <!-- PERSPECTIVES — Mega Menu -->
            <li class="group/navitem h-full flex items-center px-4 xl:px-6">
                <a href="#" class="desktop-dropdown-toggle cursor-pointer text-sm font-sans font-bold uppercase tracking-wider py-8 transition-colors duration-300 group-hover/header:text-[#1a1a1a] <%= path === '/blog' || path === '/articles' ? 'border-b-2 border-current' : '' %>">Perspectives</a>
                <div class="mega-panel absolute top-full left-0 w-full bg-white border-t border-[#0f2e22]/10 shadow-xl invisible opacity-0 group-hover/navitem:visible group-hover/navitem:opacity-100 transition-all duration-300 ease-in-out z-40 group-hover/navitem:z-50 cursor-default text-[#1a1a1a]">
                    <div class="max-w-[1400px] mx-auto px-8 py-12 grid grid-cols-12 gap-12">
                        <div class="col-span-3">
                            <h3 class="font-serif text-xl font-bold text-[#0f2e22] mb-3">Perspectives</h3>
                            <p class="text-sm text-gray-600 font-sans leading-relaxed pr-4">Market research, operational case studies, and firm updates from our investment team.</p>
                        </div>
                        <div class="col-span-6 flex flex-col space-y-4 pt-1">
                            <a href="/blog" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1 border-b border-gray-100 pb-3">View All Perspectives</a>
                            <a href="/perspectives/market-research" class="text-base font-medium hover:text-[#0f2e22] transition-colors">Market Research</a>
                            <a href="/perspectives/case-studies" class="text-base font-medium hover:text-[#0f2e22] transition-colors">Case Studies</a>
                            <a href="/perspectives/firm-updates" class="text-base font-medium hover:text-[#0f2e22] transition-colors">Firm Updates</a>
                        </div>
                        <% if (typeof latestMarketResearch !== 'undefined' && latestMarketResearch) { %>
                        <div class="col-span-3 bg-[#f9f8f6] p-5">
                            <p class="text-xs font-bold tracking-[0.15em] text-gray-500 uppercase mb-3">Latest Insight</p>
                            <a href="/blog/<%= latestMarketResearch.slug %>" class="block group/card">
                                <% if (latestMarketResearch.featuredImage) { %>
                                <img src="<%= latestMarketResearch.featuredImage %>" alt="<%= latestMarketResearch.title %>" class="h-32 w-full object-cover mb-3">
                                <% } else { %>
                                <img src="/images/hero-real-estate.jpg" alt="<%= latestMarketResearch.title %>" class="h-32 w-full object-cover mb-3">
                                <% } %>
                                <h4 class="font-serif text-lg font-semibold text-[#1a1a1a] group-hover/card:text-[#0f2e22] transition-colors"><%= latestMarketResearch.title %></h4>
                            </a>
                        </div>
                        <% } %>
                    </div>
                </div>
            </li>

            <!-- CONTACT — Mega Menu -->
            <li class="group/navitem h-full flex items-center px-4 xl:px-6">
                <a href="#" class="desktop-dropdown-toggle cursor-pointer text-sm font-sans font-bold uppercase tracking-wider py-8 transition-colors duration-300 group-hover/header:text-[#1a1a1a] <%= path === '/contact' ? 'border-b-2 border-current' : '' %>">Contact</a>
                <div class="mega-panel absolute top-full left-0 w-full bg-white border-t border-[#0f2e22]/10 shadow-xl invisible opacity-0 group-hover/navitem:visible group-hover/navitem:opacity-100 transition-all duration-300 ease-in-out z-40 group-hover/navitem:z-50 cursor-default text-[#1a1a1a]">
                    <div class="max-w-[1400px] mx-auto px-8 py-12 grid grid-cols-12 gap-12">
                        <div class="col-span-3">
                            <h3 class="font-serif text-xl font-bold text-[#0f2e22] mb-3">Connect</h3>
                            <p class="text-sm text-gray-600 font-sans leading-relaxed pr-4">Reach out to our leadership team regarding asset acquisitions, property dispositions, or general inquiries.</p>
                        </div>
                        <div class="col-span-6 flex flex-col space-y-4 pt-1">
                            <a href="/contact" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1 border-b border-gray-100 pb-3">General Inquiry</a>
                            <a href="/contact/acquisitions" class="text-base font-medium hover:text-[#0f2e22] transition-colors">Acquisitions Team</a>
                            <a href="/contact/investor-relations" class="text-base font-medium hover:text-[#0f2e22] transition-colors">Investor Relations</a>
                        </div>
                        <div class="col-span-3 bg-[#0f2e22] p-5 flex flex-col justify-between">
                            <div>
                                <p class="text-xs font-bold tracking-[0.15em] text-white/60 uppercase mb-3">Property Owners &amp; Brokers</p>
                                <h4 class="font-serif text-lg font-semibold text-white mb-2">Direct Acquisitions</h4>
                                <p class="text-sm text-white/70 font-sans leading-relaxed mb-4">Own a property or portfolio you're considering selling? Connect with our acquisitions team for a confidential discussion.</p>
                            </div>
                            <a href="/contact/dispositions" class="inline-block text-center text-sm font-bold uppercase tracking-wider bg-white text-[#0f2e22] px-5 py-3 hover:bg-[#f9f8f6] transition-colors">Submit Property Inquiry</a>
                        </div>
                    </div>
                </div>
            </li>

            <!-- INVESTORS — Mega Menu -->
            <li class="group/navitem h-full flex items-center px-4 xl:px-6">
                <a href="#" class="desktop-dropdown-toggle cursor-pointer text-sm font-sans font-bold uppercase tracking-wider py-8 transition-colors duration-300 group-hover/header:text-[#1a1a1a] <%= path && path.startsWith('/investor') ? 'border-b-2 border-current' : '' %>">Investors</a>
                <!-- Full-width Mega Dropdown -->
                <div class="mega-panel absolute top-full left-0 w-full bg-white border-t border-[#0f2e22]/10 shadow-xl invisible opacity-0 group-hover/navitem:visible group-hover/navitem:opacity-100 transition-all duration-300 ease-in-out z-40 group-hover/navitem:z-50 cursor-default text-[#1a1a1a]">
                    <div class="max-w-[1400px] mx-auto px-8 py-12 grid grid-cols-12 gap-12">
                        <div class="col-span-3">
                            <h3 class="font-serif text-xl font-bold text-[#0f2e22] mb-3">Investors</h3>
                            <p class="text-sm text-gray-600 font-sans leading-relaxed pr-4">Vanier Capital partners with qualified investors who share our long-term, value-driven approach to real asset ownership.</p>
                        </div>
                        <div class="col-span-6 flex flex-col space-y-4 pt-1">
                            <a href="/investors" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1 border-b border-gray-100 pb-3">Capital Partnerships</a>
                            <a href="/investor-club/apply" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1">Join Distribution List</a>
                            <a href="/investors/disclosures" class="text-base font-medium text-[#1a1a1a] hover:text-[#0f2e22] transition-colors block py-1">Regulatory Disclosures &amp; Roadmap</a>
                        </div>
                        <div class="col-span-3 bg-[#0f2e22] p-5 flex flex-col justify-between">
                            <div>
                                <p class="text-xs font-bold tracking-[0.15em] text-white/60 uppercase mb-3">Private Placements</p>
                                <h4 class="font-serif text-lg font-semibold text-white mb-2">Work Toward Partnership</h4>
                                <p class="text-sm text-white/70 font-sans leading-relaxed mb-4">We are currently focused on Phase&nbsp;I portfolio stabilization. Complete our vetting form to receive quarterly research and be first notified of future private placement opportunities.</p>
                            </div>
                            <a href="/investor-club/apply" class="inline-block text-center text-sm font-bold uppercase tracking-wider bg-white text-[#0f2e22] px-5 py-3 hover:bg-[#f9f8f6] transition-colors">Investor Vetting Form</a>
                        </div>
                    </div>
                </div>
            </li>
        </ul>

        <!-- Mobile Menu Button -->
        <button type="button" id="mobile-menu-btn" class="flex lg:hidden flex-col justify-center gap-[5px] w-10 h-10 p-1.5 bg-transparent border-none cursor-pointer" aria-expanded="false" aria-label="Toggle navigation">
            <span class="hamburger-line block w-full h-[2px] bg-current transition-all duration-300 origin-center"></span>
            <span class="hamburger-line block w-full h-[2px] bg-current transition-all duration-300"></span>
            <span class="hamburger-line block w-full h-[2px] bg-current transition-all duration-300 origin-center"></span>
        </button>
    </div>

    <!-- Mobile Navigation Panel (phones + tablets, hidden on lg+ 1024px desktops) -->
    <div id="mobile-nav" class="hidden lg:hidden flex-col bg-[#0f2e22] text-white border-t border-white/10 px-8 py-8 pb-24 fixed left-0 right-0 overflow-y-auto" style="top: 88px; bottom: 0; z-index: 999;">
        <a href="/" class="font-serif text-base font-bold uppercase tracking-[0.12em] text-white py-4 border-b border-white/10 hover:text-white/80 block <%= path === '/' ? 'text-white' : '' %>">Home</a>

        <!-- Firm (with sublinks) -->
        <div class="border-b border-white/10">
            <a href="/firm/overview" class="font-serif text-base font-bold uppercase tracking-[0.12em] text-white py-4 hover:text-white/80 block <%= path && path.startsWith('/firm') ? 'text-white' : '' %>">Firm</a>
            <div class="pl-4 pb-3 flex flex-col gap-1">
                <a href="/firm/overview" class="font-sans text-sm text-white/80 py-1.5 hover:text-white block">Overview</a>
                <a href="/firm/leadership" class="font-sans text-sm text-white/80 py-1.5 hover:text-white block">Leadership</a>
                <a href="/firm/stewardship" class="font-sans text-sm text-white/80 py-1.5 hover:text-white block">Stewardship</a>
            </div>
        </div>

        <a href="/strategies" class="font-serif text-base font-bold uppercase tracking-[0.12em] text-white py-4 border-b border-white/10 hover:text-white/80 block <%= path === '/strategy' || path === '/strategies' ? 'text-white' : '' %>">Strategies</a>
        <a href="/portfolio" class="font-serif text-base font-bold uppercase tracking-[0.12em] text-white py-4 border-b border-white/10 hover:text-white/80 block <%= path === '/portfolio' ? 'text-white' : '' %>">Portfolio</a>

        <!-- Perspectives (with sublinks) -->
        <div class="border-b border-white/10">
            <a href="/perspectives" class="font-serif text-base font-bold uppercase tracking-[0.12em] text-white py-4 hover:text-white/80 block <%= path === '/blog' ? 'text-white' : '' %>">Perspectives</a>
            <div class="pl-4 pb-3 flex flex-col gap-1">
