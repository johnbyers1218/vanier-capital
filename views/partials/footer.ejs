<script>
 window.dataLayer = window.dataLayer || [];
 function gtag(){dataLayer.push(arguments);}
 gtag('js', new Date());
 gtag('config', '<%= process.env.GA_MEASUREMENT_ID %>'); // Use env variable
</script>
<% } else if (process.env.NODE_ENV === 'production' && !process.env.GA_MEASUREMENT_ID) { %>
<!-- Warning if in production but ID is missing -->
