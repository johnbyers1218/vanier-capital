<!-- JavaScript Files                       -->
<!-- ======================================== -->

<!-- Main application script (should contain most JS logic) -->
<script src="/js/apps.js"></script>

<!-- Inline script for essential immediate execution (like dynamic year) -->
<script>
 // Set Dynamic Copyright Year
 const yearSpan = document.getElementById('current-year');
 if(yearSpan) { yearSpan.textContent = new Date().getFullYear(); }

 // Basic Hamburger Menu Toggle Logic (RECOMMENDATION: Move to apps.js)
 // This ensures basic nav works even if apps.js has an error or is deferred
 const hamburger = document.querySelector('.hamburger');
 const navLinks = document.querySelector('.nav-links');
 const bodyForNav = document.body;

 if(hamburger && navLinks) {
     if (!navLinks.id) { navLinks.id = 'nav-links-list'; } // Ensure ID for aria
     hamburger.setAttribute('aria-controls', navLinks.id);
     hamburger.setAttribute('aria-expanded', 'false');

     hamburger.addEventListener('click', () => {
         const isActive = navLinks.classList.toggle('active');
         hamburger.setAttribute('aria-expanded', isActive);
         bodyForNav.classList.toggle('nav-active', isActive);
     });
 } else {
      logger.warn('Hamburger menu elements (.hamburger, .nav-links) not found for inline script.');
 }
</script>

<!-- Optional: Analytics Script (Conditional for Production) -->
<% if (process.env.NODE_ENV === 'production' && process.env.GA_MEASUREMENT_ID) { %> <!-- Check for ID -->
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= process.env.GA_MEASUREMENT_ID %>"></script>
<script>
 window.dataLayer = window.dataLayer || [];
 function gtag(){dataLayer.push(arguments);}
 gtag('js', new Date());
 gtag('config', '<%= process.env.GA_MEASUREMENT_ID %>'); // Use env variable
</script>
<% } else if (process.env.NODE_ENV === 'production' && !process.env.GA_MEASUREMENT_ID) { %>
<!-- Warning if in production but ID is missing -->
<script>logger.warn('Google Analytics Measurement ID (GA_MEASUREMENT_ID) is not configured for production.');</script>
<% } %>

