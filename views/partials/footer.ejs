<!-- Main application script (should contain most JS logic) -->
<script src="/js/apps.js"></script>

<!-- Inline script for essential immediate execution (like dynamic year) -->
<script>
 // Set Dynamic Copyright Year
 const yearSpan = document.getElementById('current-year');
 if(yearSpan) { yearSpan.textContent = new Date().getFullYear(); }

 // Basic Hamburger Menu Toggle Logic (RECOMMENDATION: Move to apps.js)
 // This ensures basic nav works even if apps.js has an error or is deferred
 const hamburger = document.querySelector('.hamburger');
 const navLinks = document.querySelector('.nav-links');
 const bodyForNav = document.body;

 if (hamburger && navLinks) {
     if (!navLinks.id) navLinks.id = 'nav-links-list'; // Ensure ID for aria
     hamburger.setAttribute('aria-controls', navLinks.id);
     hamburger.setAttribute('aria-expanded', 'false');

     // Ensure default mobile state is hidden
     if (window.matchMedia('(max-width: 767px)').matches) {
         navLinks.classList.add('hidden');
     }

     hamburger.addEventListener('click', () => {
         const nowOpen = navLinks.classList.toggle('hidden');
         // If hidden returned true, we just added hidden -> menu closed
         const isOpen = !nowOpen;
         if (isOpen) {
             navLinks.classList.remove('hidden');
             navLinks.classList.add('flex', 'flex-col', 'gap-4', 'mt-4');
         } else {
             navLinks.classList.add('hidden');
             navLinks.classList.remove('flex', 'flex-col', 'gap-4', 'mt-4');
         }
         hamburger.setAttribute('aria-expanded', String(isOpen));
         bodyForNav.classList.toggle('nav-active', isOpen);
     });
 } else {
     console.warn('Hamburger menu elements (.hamburger, .nav-links) not found for inline script.');
 }
</script>

<!-- Sticky header translucency and blur on scroll -->
<script>
 (function(){
     const header = document.getElementById('site-header');
     if (!header) return;
     const apply = () => {
         const y = window.scrollY || document.documentElement.scrollTop;
         if (y > 2) {
             header.style.backgroundColor = 'rgba(255,255,255,0.85)';
             header.style.backdropFilter = 'blur(12px)';
             header.style.boxShadow = '0 6px 20px rgba(0,0,0,0.06)';
             header.style.borderBottom = 'none';
         } else {
             header.style.backgroundColor = 'transparent';
             header.style.backdropFilter = 'blur(0px)';
             header.style.boxShadow = 'none';
             header.style.borderBottom = 'none';
         }
     };
     apply();
     window.addEventListener('scroll', apply, { passive: true });
 })();
</script>

