<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= pageTitle %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>body { font-family: system-ui, sans-serif; background: #f8fafc; margin: 0; padding: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }</style>
    
    <script src="https://cdn.jsdelivr.net/npm/@clerk/clerk-js@4/dist/clerk.browser.js"
            async
            crossorigin="anonymous"
    ></script>
</head>
<body>
    <div id="sign-up"></div>

    <script>
        window.addEventListener("load", async function () {
            // Use the unescaped EJS tag <%- ... %> to be safe
            const publishableKey = "<%- clerkPublishableKey %>";

            if (!publishableKey) {
                console.error("Clerk Publishable Key is missing!");
                return;
            }

            // Clerk is loaded on the window object
            const Clerk = window.Clerk;
            Clerk.publishableKey = publishableKey;

            try {
                await Clerk.load({
                    // Customization options
                });
                
                const signUpDiv = document.getElementById("sign-up");
                Clerk.mountSignUp(signUpDiv);

            } catch (err) {
                console.error("Clerk failed to load:", err);
            }
        });
    </script>
</body>
</html>
