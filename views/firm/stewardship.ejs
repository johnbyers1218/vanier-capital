<!-- views/firm/stewardship.ejs -->
<%- include('../partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: path,
    structuredData: typeof structuredData !== 'undefined' ? structuredData : []
}) %>

<!-- Hero — Deep Evergreen -->
<section class="bg-[#0f2e22] pt-24 md:pt-32 pb-14 md:pb-20 px-6 md:px-16">
  <div class="max-w-screen-xl mx-auto">
    <span class="font-sans text-sm font-bold text-white/60 uppercase tracking-widest block mb-4">Stewardship</span>
    <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white tracking-tight mb-6">Operational Excellence</h1>
    <p class="font-sans text-xl text-white/80 max-w-3xl leading-relaxed"></p>
  </div>
</section>

<!-- Core Pillars — Editorial Grid, No Icons -->
<section class="max-w-screen-xl mx-auto px-6 md:px-16 py-12 md:py-20 grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16 border-b border-[#0f2e22]/10">
  <div class="border-t-2 border-[#0f2e22] pt-6">
    <h3 class="font-serif text-2xl text-[#1a1a1a] mb-4">Capital Preservation</h3>
    <p class="font-sans text-gray-600 leading-relaxed">Every operational decision is evaluated through the lens of downside protection. We mandate strict risk thresholds and prioritize cash flow stability over speculative, high-risk acquisitions.</p>
  </div>
  <div class="border-t-2 border-[#0f2e22] pt-6">
    <h3 class="font-serif text-2xl text-[#1a1a1a] mb-4">Lifecycle Management</h3>
    <p class="font-sans text-gray-600 leading-relaxed">We continuously reinvest in our physical assets. By executing rigorous preventive maintenance schedules, we protect our returns and significantly reduce long-term operational drag.</p>
  </div>
  <div class="border-t-2 border-[#0f2e22] pt-6">
    <h3 class="font-serif text-2xl text-[#1a1a1a] mb-4">Yield Optimization</h3>
    <p class="font-sans text-gray-600 leading-relaxed">Frictionless resident experiences directly translate to institutional stability. By prioritizing operational responsiveness and transparency, we maximize resident retention and minimize turnover costs.</p>
  </div>
</section>

<!-- Operational Framework — White, 2x2 Grid -->
<section class="bg-white">
  <div class="max-w-screen-xl mx-auto px-6 md:px-16 pt-12 md:pt-20 pb-8 md:pb-12">
    <h2 class="font-serif text-3xl md:text-4xl text-[#0f2e22] mb-4">Our Operational Framework</h2>
    <p class="font-sans text-lg text-gray-700 max-w-2xl">Institutional-grade systems and standard operating procedures (SOPs) that ensure consistent, scalable execution across the portfolio.</p>
  </div>
  <div class="max-w-screen-xl mx-auto px-6 md:px-16 pb-12 md:pb-20 grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="bg-white border border-[#0f2e22]/20 p-10">
      <span class="font-sans text-xs font-bold text-gray-400 block mb-4">01</span>
      <h3 class="font-serif text-2xl text-[#0f2e22] mb-3">Procurement & Vendor SOPs</h3>
      <p class="font-sans text-gray-600">Curated relationships with vetted contractors, structured bidding processes, and strict performance-based accountability ensure on-time, on-budget execution.</p>
    </div>
    <div class="bg-white border border-[#0f2e22]/20 p-10">
      <span class="font-sans text-xs font-bold text-gray-400 block mb-4">02</span>
      <h3 class="font-serif text-2xl text-[#0f2e22] mb-3">Financial Controls</h3>
      <p class="font-sans text-gray-600">Rigorous zero-based budgeting, automated monthly variance analysis, and institutional-grade reporting maintain absolute financial transparency.</p>
    </div>
    <div class="bg-white border border-[#0f2e22]/20 p-10">
      <span class="font-sans text-xs font-bold text-gray-400 block mb-4">03</span>
      <h3 class="font-serif text-2xl text-[#0f2e22] mb-3">Proprietary Tech Stack</h3>
      <p class="font-sans text-gray-600">API-driven property management software, automated rent collection, and proprietary data models built by our quantitative team streamline overhead.</p>
    </div>
    <div class="bg-white border border-[#0f2e22]/20 p-10">
      <span class="font-sans text-xs font-bold text-gray-400 block mb-4">04</span>
      <h3 class="font-serif text-2xl text-[#0f2e22] mb-3">Compliance & Risk</h3>
      <p class="font-sans text-gray-600">Aggressive insurance procurement, standardized lease enforcement, and proactive regulatory compliance insulate the portfolio from legal and physical exposure.</p>
    </div>
  </div>
</section>

<!-- Execution by the Numbers -->
<section class="max-w-screen-xl mx-auto px-6 md:px-16 py-14 md:py-24">
  <h2 class="font-serif text-3xl text-[#0f2e22] border-b border-[#0f2e22]/20 pb-6 mb-12">Execution by the Numbers</h2>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
    <div class="flex flex-col min-w-0 px-0 md:px-2">
      <span class="font-serif text-2xl md:text-3xl lg:text-4xl text-slate-900 mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.occupancyRate) ? siteSettings.occupancyRate : '96%' %></span>
      <span class="font-sans text-xs tracking-widest uppercase text-gray-500">Portfolio Occupancy</span>
    </div>
    <div class="flex flex-col min-w-0 px-0 md:px-2">
      <span class="font-serif text-2xl md:text-3xl lg:text-4xl text-slate-900 mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.maintenanceResponse) ? siteSettings.maintenanceResponse : '<24hr' %></span>
      <span class="font-sans text-xs tracking-widest uppercase text-gray-500">Maintenance Response</span>
    </div>
    <div class="flex flex-col min-w-0 px-0 md:px-2">
      <span class="font-serif text-2xl md:text-3xl lg:text-4xl text-slate-900 mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.avgResidentTenure) ? siteSettings.avgResidentTenure : '18mo' %></span>
      <span class="font-sans text-xs tracking-widest uppercase text-gray-500">Avg. Resident Tenure</span>
    </div>
    <div class="flex flex-col min-w-0 px-0 md:px-2">
      <span class="font-serif text-2xl md:text-3xl lg:text-4xl text-slate-900 mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.rentCollectionRate) ? siteSettings.rentCollectionRate : '98%' %></span>
      <span class="font-sans text-xs tracking-widest uppercase text-gray-500">Rent Collection Rate</span>
    </div>
  </div>
</section>

<!-- CTA — Institutional -->
<section class="bg-slate-50 border-t border-[#0f2e22]/10 py-14 md:py-24 text-center px-6">
  <h2 class="font-serif text-3xl md:text-4xl text-[#0f2e22] mb-6">Review Our Track Record</h2>
  <a href="/portfolio" class="inline-block font-sans text-sm font-bold uppercase tracking-widest text-white bg-[#0f2e22] px-8 py-4 hover:bg-[#1a3a2a] transition-colors">View Portfolio</a>
</section>

<%- include('../partials/footer') %>