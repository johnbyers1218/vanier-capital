<!-- views/firm/overview.ejs -->
<%- include('../partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: path
}) %>

<!-- Hero -->
<section class="bg-[#0f2e22] pt-24 md:pt-32 pb-14 md:pb-20 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <span class="font-sans text-sm font-bold text-white/60 uppercase tracking-widest block mb-4">The Firm</span>
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white tracking-tight mb-6">Disciplined Capital.<br/>Durable Returns.</h1>
        <p class="font-sans text-xl text-white/80 max-w-3xl leading-relaxed">Vanier Capital is a real estate investment firm built on the partnership of West Point alumni. We focus on the acquisition and operation of residential assets in the Columbus, Georgia market, emphasizing operational stability and long-term value.</p>
    </div>
</section>

<!-- Track Record Metrics -->
<section class="bg-[#0f2e22] text-white pt-24 py-12 md:py-16 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 divide-y md:divide-y-0 md:divide-x divide-white/20">
        <div class="flex flex-col md:pl-8 first:pl-0 pt-8 md:pt-0">
            <span class="font-serif text-4xl md:text-6xl text-white mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.aum) ? siteSettings.aum : '$1M+' %></span>
            <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/60">Assets Under Management</span>
        </div>
        <div class="flex flex-col md:pl-8 pt-8 md:pt-0">
            <span class="font-serif text-4xl md:text-6xl text-white mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.occupancyRate) ? siteSettings.occupancyRate : '96%' %></span>
            <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/60">Portfolio Occupancy</span>
        </div>
        <div class="flex flex-col md:pl-8 pt-8 md:pt-0">
            <span class="font-serif text-4xl md:text-6xl text-white mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.firmInceptionYear) ? siteSettings.firmInceptionYear : '2025' %></span>
            <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/60">Firm Inception &amp; Cash Flow</span>
        </div>
    </div>
</section>

<!-- ═══════════════ DISCIPLINED EXECUTION ═══════════════ -->
<section class="bg-white py-16 md:py-24 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <span class="font-sans text-sm font-bold text-[#0f2e22]/50 uppercase tracking-widest block mb-4">Our Approach</span>
        <h2 class="font-serif text-3xl md:text-4xl text-[#1a1a1a] tracking-tight mb-6">Disciplined Execution.</h2>
        <p class="font-sans text-lg text-gray-700 max-w-3xl leading-relaxed">Founded by West Point alumni, Vanier Capital applies military precision to real estate asset management. We prioritize operational efficiency, risk mitigation, and unwavering discipline to generate consistent, long-term yield for our partners.</p>
    </div>
</section>

<!-- ═══════════════ THE COLUMBUS ADVANTAGE ═══════════════ -->
<section class="bg-[#f9f8f6] py-16 md:py-24 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <span class="font-sans text-sm font-bold text-[#0f2e22]/50 uppercase tracking-widest block mb-4">Market Focus</span>
        <h2 class="font-serif text-3xl md:text-4xl text-[#1a1a1a] tracking-tight mb-6">The Columbus Advantage.</h2>
        <p class="font-sans text-lg text-gray-700 max-w-3xl leading-relaxed">We focus exclusively on residential assets in the Columbus, Georgia market. By concentrating our expertise in a region with stable rental demand and strong economic fundamentals, we identify underperforming assets and unlock their true value through hands-on management.</p>
    </div>
</section>

<!-- ═══════════════ INVESTMENT STRATEGY ═══════════════ -->
<section class="bg-white py-16 md:py-24 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <span class="font-sans text-sm font-bold text-[#0f2e22]/50 uppercase tracking-widest block mb-4">Investment Strategy</span>
        <h2 class="font-serif text-3xl md:text-4xl text-[#1a1a1a] tracking-tight mb-8">Acquire. Optimize. Hold.</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16">
            <div>
                <span class="font-sans text-xs font-bold uppercase tracking-widest text-[#0f2e22]/50 block mb-3">01 &mdash; Acquire</span>
                <p class="font-sans text-base text-gray-700 leading-relaxed">Identifying high-potential residential properties in markets where fundamentals outpace pricing.</p>
            </div>
            <div>
                <span class="font-sans text-xs font-bold uppercase tracking-widest text-[#0f2e22]/50 block mb-3">02 &mdash; Optimize</span>
                <p class="font-sans text-base text-gray-700 leading-relaxed">Implementing robust property management and operational improvements that drive occupancy and reduce waste.</p>
            </div>
            <div>
                <span class="font-sans text-xs font-bold uppercase tracking-widest text-[#0f2e22]/50 block mb-3">03 &mdash; Hold</span>
                <p class="font-sans text-base text-gray-700 leading-relaxed">Maintaining stability to ensure durable, long-term cash flow and compounding asset value for our partners.</p>
            </div>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>