<!-- views/firm/overview.ejs -->
<%- include('../partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: path
}) %>

<!-- Hero -->
<section class="bg-[#0f2e22] pt-24 md:pt-32 pb-14 md:pb-20 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <span class="font-sans text-sm font-bold text-white/60 uppercase tracking-widest block mb-4">The Firm</span>
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white tracking-tight mb-6">Disciplined Capital.<br/>Durable Returns.</h1>
        <p class="font-sans text-xl text-white/80 max-w-3xl leading-relaxed">Vanier Capital is a real estate investment firm built on the partnership of West Point alumni. We focus on the acquisition and operation of residential assets in the Columbus, Georgia market, emphasizing operational stability and long-term value.</p>
    </div>
</section>

<!-- Track Record Metrics -->
<section class="bg-[#0f2e22] text-white pt-24 py-12 md:py-16 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 divide-y md:divide-y-0 md:divide-x divide-white/20">
        <div class="flex flex-col md:pl-8 first:pl-0 pt-8 md:pt-0">
            <span class="font-serif text-4xl md:text-6xl text-white mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.aum) ? siteSettings.aum : '$1M+' %></span>
            <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/60">Assets Under Management</span>
        </div>
        <div class="flex flex-col md:pl-8 pt-8 md:pt-0">
            <span class="font-serif text-4xl md:text-6xl text-white mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.occupancyRate) ? siteSettings.occupancyRate : '96%' %></span>
            <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/60">Portfolio Occupancy</span>
        </div>
        <div class="flex flex-col md:pl-8 pt-8 md:pt-0">
            <span class="font-serif text-4xl md:text-6xl text-white mb-2 whitespace-nowrap tracking-tight"><%= (typeof siteSettings !== 'undefined' && siteSettings.firmInceptionYear) ? siteSettings.firmInceptionYear : '2025' %></span>
            <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/60">Firm Inception &amp; Cash Flow</span>
        </div>
    </div>
</section>

<%- include('../partials/footer') %>