<!-- views/articles-index.ejs -->
<%# Public Perspectives / Research Listing Page %>

<%- include('partials/header', {
    pageTitle: (typeof pageHeading !== 'undefined' ? pageHeading.replace('.', '') : 'Perspectives') + ' - Vanier Capital',
    pageDescription: typeof pageDescription !== 'undefined' ? pageDescription : 'Market research and operational case studies from the Vanier Capital investment team.',
    path: '/blog',
    isHeroPage: true,
    structuredData: typeof structuredData !== 'undefined' ? structuredData : []
}) %>

<!-- ═══════════════ PAGE HEADER ═══════════════ -->
<section class="bg-[#0f2e22] pt-24 md:pt-32 pb-14 md:pb-20 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <% if (typeof pageOverline !== 'undefined' && pageOverline) { %>
        <p class="font-sans text-xs font-bold uppercase tracking-widest text-white/50 mb-4"><%= pageOverline %></p>
        <% } %>
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white tracking-tight mb-6"><%= typeof pageHeading !== 'undefined' ? pageHeading : 'Perspectives.' %></h1>
        <p class="font-sans text-xl text-white/80 max-w-3xl leading-relaxed"><%= typeof pageDescription !== 'undefined' ? pageDescription : 'Market research and operational case studies from the Vanier Capital investment team.' %></p>
    </div>
</section>

<!-- ═══════════════ CATEGORY FILTER BAR ═══════════════ -->
<% if (blogCategories && blogCategories.length > 0) { %>
<section class="bg-white border-b border-[#0f2e22]/10 sticky top-[88px] z-30">
    <div class="max-w-screen-xl mx-auto px-4 md:px-16">
        <% const perspBase = typeof perspectivesBaseUrl !== 'undefined' ? perspectivesBaseUrl : null; %>
        <nav class="flex items-center gap-4 md:gap-6 py-4 overflow-x-auto -mx-1 px-1" role="navigation" aria-label="Research categories" data-current-category="<%= typeof categoryQuery !== 'undefined' && categoryQuery ? categoryQuery : '' %>">
            <a href="<%= perspBase || '/blog' %>" class="font-sans text-sm font-bold uppercase tracking-wider whitespace-nowrap pb-2 border-b-2 <%= (!categoryQuery) ? 'text-[#0f2e22] border-[#0f2e22]' : 'text-gray-400 border-transparent hover:text-[#1a1a1a]' %> transition-colors">All</a>
            <% (blogCategories || []).forEach(c => { %>
                <a href="<%= perspBase ? perspBase + '/' + c.slug : '/blog?category=' + c.slug %>" class="font-sans text-sm font-bold uppercase tracking-wider whitespace-nowrap pb-2 border-b-2 <%= (categoryQuery === c.slug) ? 'text-[#0f2e22] border-[#0f2e22]' : 'text-gray-400 border-transparent hover:text-[#1a1a1a]' %> transition-colors"><%= c.name %></a>
            <% }) %>
        </nav>
    </div>
</section>
<% } %>

<!-- ═══════════════ ARTICLE FEED ═══════════════ -->
<section class="bg-white">
    <div class="max-w-screen-xl mx-auto px-4 md:px-16 py-10 md:py-16" id="article-grid">
        <% if (posts && posts.length > 0) { %>

            <div class="divide-y divide-gray-200">
            <% (posts || []).forEach((post) => { %>
                <div class="flex flex-col md:flex-row gap-8 py-10">
                    <% if (post.featuredImage) { %>
                    <a href="/blog/<%= post.slug %>" class="md:w-1/3 shrink-0 block group">
                        <div class="aspect-video bg-gray-100 overflow-hidden border border-gray-200">
                            <img src="<%= post.featuredImage %>" alt="" loading="lazy" decoding="async" class="w-full h-full object-cover rounded-none group-hover:scale-[1.02] transition-transform duration-500">
                        </div>
                    </a>
                    <% } else { %>
                    <div class="md:w-1/3 shrink-0">
                        <div class="aspect-video bg-gray-100 border border-gray-200 flex items-center justify-center">
                            <span class="font-sans text-xs text-gray-300 uppercase tracking-widest">No Image</span>
                        </div>
                    </div>
                    <% } %>
                    <div class="md:w-2/3 flex flex-col justify-center">
                        <p class="font-sans text-[11px] font-bold text-slate-500 tracking-widest uppercase mb-3">
                            <% if (post.publicationType) { %><%= post.publicationType %><% } else if (post.categories && post.categories.length) { %><%= post.categories[0].name %><% } else { %>Market Research<% } %>
                            <% if (post.publishedAt || post.publishedDate) { %> | <%= new Date(post.publishedAt || post.publishedDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %><% } %>
                        </p>
                        <h2 class="font-serif text-2xl lg:text-3xl text-[#0f2e22] mb-3 leading-tight"><a href="/blog/<%= post.slug %>" class="hover:text-slate-600 transition-colors"><%= typeof decodeHtmlEntities === 'function' ? decodeHtmlEntities(post.title) : post.title %></a></h2>
                        <% if (post.subtitle) { %>
                        <p class="font-sans text-lg text-slate-600 italic mb-3"><%= typeof decodeHtmlEntities === 'function' ? decodeHtmlEntities(post.subtitle) : post.subtitle %></p>
                        <% } %>
                        <% if (post.excerpt) { %>
                        <% const _exc = typeof decodeHtmlEntities === 'function' ? decodeHtmlEntities(post.excerpt) : post.excerpt; %>
                        <p class="font-sans text-slate-600 leading-relaxed mb-6"><%= _exc.length > 220 ? _exc.substring(0, 220) + '…' : _exc %></p>
                        <% } %>
                        <a href="/blog/<%= post.slug %>" class="font-sans text-sm font-bold tracking-widest text-[#0f2e22] uppercase border-b border-[#0f2e22] pb-1 self-start hover:text-slate-600 hover:border-slate-600 transition-all">Read Report &rarr;</a>
                    </div>
                </div>
            <% }) %>
            </div>

            <!-- Pagination -->
            <% if (lastPage > 1) { %>
            <%
                const _pBase = typeof baseUrl !== 'undefined' ? baseUrl : '/blog';
                // For /blog route with category filter, append category param before page
                const _pCat = (typeof categoryQuery !== 'undefined' && categoryQuery && _pBase === '/blog')
                    ? '?category=' + encodeURIComponent(categoryQuery) + '&'
                    : '?';
            %>
            <div class="flex justify-between items-center py-12 border-t border-[#0f2e22]/20 mt-8">
                <% if (hasPreviousPage) { %>
                    <a href="<%= _pBase %><%= _pCat %>page=<%= previousPage %>#article-grid" class="font-sans text-sm font-bold uppercase tracking-wider text-[#0f2e22] hover:text-slate-600 transition-colors">&larr; Previous</a>
                <% } else { %>
                    <span></span>
                <% } %>
                <span class="font-sans text-xs text-gray-400 uppercase tracking-widest">Page <%= currentPage %> of <%= lastPage %></span>
                <% if (hasNextPage) { %>
                    <a href="<%= _pBase %><%= _pCat %>page=<%= nextPage %>#article-grid" class="font-sans text-sm font-bold uppercase tracking-wider text-[#0f2e22] hover:text-slate-600 transition-colors">Next &rarr;</a>
                <% } else { %>
                    <span></span>
                <% } %>
            </div>
            <% } %>

        <% } else { %>
            <div class="py-20 text-center">
                <h3 class="font-serif text-3xl text-[#1a1a1a] mb-4">No reports published yet.</h3>
                <p class="font-sans text-lg text-gray-600 mb-8">Check back for market research and case studies.</p>
                <% if (categoryQuery) { %>
                    <a href="<%= typeof perspectivesBaseUrl !== 'undefined' ? perspectivesBaseUrl : '/blog' %>" class="inline-block font-sans text-sm font-bold text-white bg-[#0f2e22] px-8 py-4 uppercase tracking-wider hover:bg-[#1a1a1a] transition-colors rounded-none">View All Perspectives</a>
                <% } %>
            </div>
        <% } %>
    </div>
</section>

<%- include('partials/footer') %>