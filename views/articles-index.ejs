<!-- views/articles-index.ejs -->
<%# Public Perspectives / Research Listing Page %>

<%- include('partials/header', {
    pageTitle: (typeof pageHeading !== 'undefined' ? pageHeading.replace('.', '') : 'Perspectives') + ' - Vanier Capital',
    pageDescription: typeof pageDescription !== 'undefined' ? pageDescription : 'Market research, operational case studies, and firm updates from the Vanier Capital investment team.',
    path: '/blog',
    isHeroPage: true
}) %>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="bg-[#0f2e22] pt-32 pb-20 px-8 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <h1 class="font-serif text-5xl md:text-6xl text-white tracking-tight mb-6"><%= typeof pageHeading !== 'undefined' ? pageHeading : 'Perspectives.' %></h1>
        <p class="font-sans text-xl text-white/80 max-w-3xl leading-relaxed"><%= typeof pageDescription !== 'undefined' ? pageDescription : 'Market research, operational case studies, and firm updates from the Vanier Capital investment team.' %></p>
    </div>
</section>

<!-- ═══════════════ FEATURED REPORT ═══════════════ -->
<% if (featuredOverride && featuredOverride.length > 0) { %>
<% const primary = featuredOverride[0]; %>
<section class="bg-[#0f2e22]">
    <div class="max-w-screen-xl mx-auto px-8 md:px-16 py-16 md:py-20">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-center">
            <div class="md:col-span-8">
                <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/40 mb-4 block">Featured Report</span>
                <h2 class="font-serif text-3xl md:text-5xl text-white mb-6 leading-tight">
                    <a href="/blog/<%= primary.slug %>" class="hover:text-white/80 transition-colors"><%- decodeHtmlEntities(primary.title) %></a>
                </h2>
                <% if (primary.featuredExcerpt) { %>
                    <p class="font-sans text-lg text-white/60 leading-relaxed mb-8 max-w-2xl"><%= primary.featuredExcerpt %></p>
                <% } %>
                <a href="/blog/<%= primary.slug %>" class="inline-block font-sans text-sm font-bold text-[#0f2e22] bg-white px-8 py-4 uppercase tracking-wider hover:bg-[#f9f8f6] transition-colors">Read Report &rarr;</a>
            </div>
            <div class="md:col-span-4 hidden md:flex flex-col items-end justify-center">
                <% if (primary.publishedDate) { %>
                    <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/30 mb-2">Published</span>
                    <span class="font-serif text-2xl text-white/70"><%= primary.publishedDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></span>
                <% } %>
                <% if (primary.categories && primary.categories.length) { %>
                    <span class="font-sans text-xs font-bold uppercase tracking-widest text-white/30 mt-6 mb-2">Category</span>
                    <span class="font-sans text-sm text-white/70 uppercase tracking-wider"><%= primary.categories[0].name %></span>
                <% } %>
            </div>
        </div>
    </div>
</section>
<% } %>

<!-- ═══════════════ CATEGORY FILTER BAR ═══════════════ -->
<% if (blogCategories && blogCategories.length > 0) { %>
<section class="bg-white border-b border-[#0f2e22]/10 sticky top-[88px] z-30">
    <div class="max-w-screen-xl mx-auto px-8 md:px-16">
        <% const perspBase = typeof perspectivesBaseUrl !== 'undefined' ? perspectivesBaseUrl : null; %>
        <nav class="flex items-center gap-6 py-4 overflow-x-auto" role="navigation" aria-label="Research categories" data-current-category="<%= typeof categoryQuery !== 'undefined' && categoryQuery ? categoryQuery : '' %>">
            <a href="<%= perspBase || '/blog' %>" class="font-sans text-sm font-bold uppercase tracking-wider whitespace-nowrap pb-2 border-b-2 <%= (!categoryQuery) ? 'text-[#0f2e22] border-[#0f2e22]' : 'text-gray-400 border-transparent hover:text-[#1a1a1a]' %> transition-colors">All</a>
            <% (blogCategories || []).forEach(c => { %>
                <a href="<%= perspBase ? perspBase + '/' + c.slug : '/blog?category=' + c.slug %>" class="font-sans text-sm font-bold uppercase tracking-wider whitespace-nowrap pb-2 border-b-2 <%= (categoryQuery === c.slug) ? 'text-[#0f2e22] border-[#0f2e22]' : 'text-gray-400 border-transparent hover:text-[#1a1a1a]' %> transition-colors"><%= c.name %></a>
            <% }) %>
        </nav>
    </div>
</section>
<% } %>

<!-- ═══════════════ ARTICLE FEED ═══════════════ -->
<section class="bg-white">
    <div class="max-w-screen-xl mx-auto px-8 md:px-16 py-16" id="article-grid">
        <% if ((posts && posts.length > 0) || (featuredOverride && featuredOverride.length > 0)) { %>

            <% const featuredSlugs = (featuredOverride || []).map(p => p.slug); %>
            <% (posts || []).forEach((post) => { %>
                <% if (featuredSlugs.includes(post.slug)) { return; } %>
                <div class="group border-b border-[#0f2e22]/20 py-6 flex flex-col md:flex-row md:items-center justify-between hover:bg-[#f9f8f6] transition-colors px-4 -mx-4" data-categories="<%= post.categories && post.categories.length ? post.categories.map(c => c.slug).join(',') : '' %>">
                    <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-8 flex-1 min-w-0">
                        <span class="font-sans text-xs font-bold uppercase tracking-widest text-gray-400 w-28 shrink-0">
                            <%= post.publishedDate ? post.publishedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '' %>
                        </span>
                        <% if (post.categories && post.categories.length) { %>
                            <span class="font-sans text-xs font-bold uppercase tracking-widest text-[#0f2e22] bg-[#0f2e22]/5 px-3 py-1 w-max shrink-0"><%= post.categories[0].name %></span>
                        <% } else { %>
                            <span class="font-sans text-xs font-bold uppercase tracking-widest text-[#0f2e22] bg-[#0f2e22]/5 px-3 py-1 w-max shrink-0">Market Research</span>
                        <% } %>
                        <a href="/blog/<%= post.slug %>" class="font-serif text-xl md:text-2xl text-[#1a1a1a] group-hover:text-[#0f2e22] transition-colors mt-2 md:mt-0 truncate"><%- decodeHtmlEntities(post.title) %></a>
                    </div>
                    <a href="/blog/<%= post.slug %>" class="hidden md:inline-flex font-sans text-xs font-bold uppercase tracking-widest text-[#0f2e22] border border-[#0f2e22] px-6 py-3 hover:bg-[#0f2e22] hover:text-white transition-colors shrink-0 ml-8">Read Report</a>
                </div>
            <% }) %>

            <!-- Pagination -->
            <div class="border-t border-[#0f2e22]/20 pt-10">
                <%- include('partials/pagination', { currentPage, hasNextPage, hasPreviousPage, nextPage, previousPage, lastPage, baseUrl: (typeof baseUrl !== 'undefined' ? baseUrl : '/blog'), categoryQuery: (typeof perspectivesBaseUrl !== 'undefined' ? null : (typeof categoryQuery !== 'undefined' ? categoryQuery : null)) }) %>
            </div>

        <% } else { %>
            <div class="py-20 text-center">
                <h3 class="font-serif text-3xl text-[#1a1a1a] mb-4">No reports published yet.</h3>
                <p class="font-sans text-lg text-gray-600 mb-8">Check back for market research, case studies, and firm updates.</p>
                <% if (categoryQuery) { %>
                    <a href="<%= typeof perspectivesBaseUrl !== 'undefined' ? perspectivesBaseUrl : '/blog' %>" class="inline-block font-sans text-sm font-bold text-white bg-[#0f2e22] px-8 py-4 uppercase tracking-wider hover:bg-[#1a1a1a] transition-colors rounded-none">View All Perspectives</a>
                <% } %>
            </div>
        <% } %>
    </div>
</section>

<!-- ═══════════════ CTA BLOCK ═══════════════ -->
<section class="bg-[#0f2e22]">
    <div class="max-w-screen-xl mx-auto px-8 md:px-16 py-20 flex flex-col md:flex-row md:items-center md:justify-between gap-8">
        <div>
            <h2 class="font-serif text-3xl md:text-4xl text-white mb-3">Stay Informed.</h2>
            <p class="font-sans text-lg text-white/70 max-w-xl">Join our private distribution list to receive market research, operational case studies, and periodic firm updates.</p>
        </div>
        <a href="/investor-club/apply" class="inline-block font-sans text-sm font-bold text-[#0f2e22] bg-white px-10 py-4 uppercase tracking-wider hover:bg-[#f9f8f6] transition-colors rounded-none whitespace-nowrap">Join Distribution List</a>
    </div>
</section>

<%- include('partials/footer') %>