<%# views/articles-post.ejs - Institutional Research Report Layout %>
<%- include('partials/header', { pageTitle: pageTitle, pageDescription: pageDescription, path: '/blog', isHeroPage: false }) %>

<!-- Structured Data: Article -->
<script type="application/ld+json">
<%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.title,
    "alternativeHeadline": post.subtitle || undefined,
    "description": pageDescription,
    "datePublished": post.publishedAt || post.publishedDate || undefined,
    "dateModified": post.updatedAt || post.publishedAt || post.publishedDate || undefined,
    "author": post.author || 'Vanier Capital',
    "image": post.featuredImage || undefined,
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": shareUrl
    },
    "publisher": {
        "@type": "Organization",
        "name": "Vanier Capital",
        "logo": {
            "@type": "ImageObject",
            "url": "https://www.vaniercapital.com/images/vanier-logo.svg"
        }
    }
}, null, 2) %>
</script>

<!-- ═══════════════ ARTICLE HERO ═══════════════ -->
<section class="bg-[#f9f8f6] pt-24 md:pt-32 pb-10 md:pb-16 px-6 md:px-16">
    <div class="max-w-3xl mx-auto">
        <!-- Eyebrow: Date & Category -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
            <% if (post.publishedAt || post.publishedDate) { %>
                <span class="font-sans text-sm font-bold text-gray-500 uppercase tracking-widest"><%= new Date(post.publishedAt || post.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
            <% } %>
            <% if (primaryTag) { %>
                <span class="font-sans text-sm text-gray-400">|</span>
                <a href="/blog?tag=<%= primaryTag %>" class="font-sans text-sm font-bold text-[#0f2e22] uppercase tracking-widest hover:underline"><%= typeof primaryTagLabel !== 'undefined' && primaryTagLabel ? primaryTagLabel : primaryTag %></a>
            <% } %>
            <% if (typeof readTimeMinutes === 'number') { %>
                <span class="font-sans text-sm text-gray-400">|</span>
                <span class="font-sans text-sm text-gray-500"><%= readTimeMinutes %> min read</span>
            <% } %>
        </div>

        <!-- Title -->
        <h1 class="font-serif text-3xl md:text-5xl lg:text-6xl text-[#0f2e22] font-bold tracking-tight leading-tight mb-4"><%= decodeHtmlEntities(post.title) %></h1>

        <!-- Subtitle -->
        <% if (post.subtitle) { %>
        <p class="font-serif text-lg md:text-2xl text-gray-500 italic font-light tracking-wide border-t border-[#0f2e22]/10 pt-6 mt-6"><%= typeof decodeHtmlEntities === 'function' ? decodeHtmlEntities(post.subtitle) : post.subtitle %></p>
        <% } %>

        <!-- Author Line -->
        <% 
            const authorRaw = post.author || 'Vanier Capital';
            const dashIdx = authorRaw.indexOf(' - ');
            let authorName, authorTitle;
            if (dashIdx > -1) {
                authorName = authorRaw.substring(0, dashIdx).trim();
                authorTitle = authorRaw.substring(dashIdx + 3).trim();
            } else {
                authorName = authorRaw;
                authorTitle = null;
            }
        %>
        <p class="font-sans text-base text-gray-500 mt-6">By <span class="text-[#1a1a1a] font-medium"><%= authorName %></span><% if (authorTitle) { %> &mdash; <%= authorTitle %><% } %></p>
    </div>
</section>

<!-- ═══════════════ FEATURED IMAGE ═══════════════ -->
<% if (post.featuredImage) { %>
<section class="bg-white border-b border-[#0f2e22]/10">
    <div class="max-w-4xl mx-auto px-6 md:px-16 py-8">
        <img src="<%= post.featuredImage %>" alt="<%= post.title %>" loading="eager" fetchpriority="high" decoding="async" class="w-full h-auto rounded-none">
    </div>
</section>
<% } %>

<!-- ═══════════════ ARTICLE BODY ═══════════════ -->
<style>
  .editorial-content table {
    display: block;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-collapse: collapse;
  }
  .editorial-content td,
  .editorial-content th {
    min-width: 120px;
  }
</style>
<section class="bg-white">
    <article class="editorial-content max-w-3xl mx-auto px-6 md:px-8 py-10 md:py-16 font-serif text-lg text-gray-800 leading-loose
                    [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:md:text-3xl [&_h2]:text-[#0f2e22] [&_h2]:mt-12 [&_h2]:mb-4 [&_h2]:leading-tight
                    [&_h3]:font-serif [&_h3]:text-xl [&_h3]:md:text-2xl [&_h3]:text-[#1a1a1a] [&_h3]:mt-10 [&_h3]:mb-3 [&_h3]:leading-tight
                    [&_p]:mb-6
                    [&_blockquote]:border-l-4 [&_blockquote]:border-[#0f2e22] [&_blockquote]:pl-6 [&_blockquote]:italic [&_blockquote]:text-gray-600 [&_blockquote]:my-8
                    [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-6 [&_ul]:font-sans [&_ul]:text-base
                    [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-6 [&_ol]:font-sans [&_ol]:text-base
                    [&_img]:rounded-none [&_img]:shadow-none [&_img]:my-8
                    [&_a]:text-[#0f2e22] [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-[#1a1a1a]">
        <%- post.content %>
    </article>
</section>

<!-- ═══════════════ SHARE & AUTHOR ═══════════════ -->
<section class="bg-white border-t border-[#0f2e22]/10">
    <div class="max-w-3xl mx-auto px-6 md:px-8 py-8 md:py-12">
        <%/* Share links — uncomment when social accounts are live
        <div class="flex items-center gap-4 mb-10">
            <span class="font-sans text-sm font-bold text-gray-500 uppercase tracking-wider">Share</span>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent(shareUrl) %>" target="_blank" rel="noopener" class="font-sans text-sm text-[#0f2e22] hover:underline" aria-label="Share on LinkedIn">LinkedIn</a>
            <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(shareUrl) %>&text=<%= encodeURIComponent(post.title) %>" target="_blank" rel="noopener" class="font-sans text-sm text-[#0f2e22] hover:underline" aria-label="Share on X">X</a>
        </div>
        */%>

        <!-- Author Block -->
        <div class="border-t border-[#0f2e22]/20 pt-8">
            <p class="font-sans text-base text-gray-600">
                By <span class="font-medium text-[#1a1a1a]"><%= authorName %></span><% if (authorTitle) { %> &mdash; <%= authorTitle %><% } %>
            </p>
            <p class="font-sans text-base text-gray-500 mt-2">Vanier Capital Investment Team</p>
        </div>
    </div>
</section>

<!-- ═══════════════ RELATED REPORTS ═══════════════ -->
<% if (relatedPosts && relatedPosts.length) { %>
<section class="bg-white border-t border-[#0f2e22]/10">
    <div class="max-w-screen-xl mx-auto px-6 md:px-16 py-10 md:py-16">
        <h3 class="font-serif text-2xl md:text-3xl text-[#1a1a1a] mb-10">Related Reports</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-0">
            <% relatedPosts.forEach(rp => { %>
                <a href="/blog/<%= rp.slug %>" class="block border-t md:border-t-0 md:border-l first:border-l-0 first:border-t-0 border-[#0f2e22]/20 px-0 md:px-8 first:md:pl-0 last:md:pr-0 py-8 md:py-0 group" aria-label="Read: <%= rp.title %>">
                    <% if (rp.featuredImage) { %>
                        <img src="<%= rp.featuredImage %>" alt="" loading="lazy" decoding="async" class="w-full h-48 object-cover rounded-none mb-4">
                    <% } %>
                    <span class="font-sans text-xs font-bold text-gray-500 uppercase tracking-widest block mb-2">
                        <%= (rp.publishedAt || rp.publishedDate) ? new Date(rp.publishedAt || rp.publishedDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) : '' %>
                    </span>
                    <h4 class="font-serif text-xl text-[#1a1a1a] group-hover:text-[#0f2e22] transition-colors leading-tight mb-2"><%= rp.title %></h4>
                    <% if (rp.excerpt) { %>
                        <p class="font-sans text-base text-gray-600 leading-relaxed"><%= rp.excerpt.length > 120 ? rp.excerpt.substring(0, 120) + '…' : rp.excerpt %></p>
                    <% } %>
                </a>
            <% }) %>
        </div>
        <div class="mt-12 pt-8 border-t border-[#0f2e22]/20">
            <a href="/perspectives" class="font-sans text-sm font-bold text-[#0f2e22] uppercase tracking-wider hover:underline">View All Perspectives &rarr;</a>
        </div>
    </div>
</section>
<% } %>

<%- include('partials/footer') %>