<!-- views/404.ejs -->
<%# Custom 404 Page Not Found %>

<%- include('partials/header', {
    pageTitle: 'Page Not Found (404)',
    pageDescription: 'The page you were looking for could not be found on Vanier Capital.',
    path: '/404'
}) %>

<!-- 404 Error — Institutional -->
<section class="bg-[#f9f8f6] pt-24 md:pt-32 pb-16 md:pb-24 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto text-center">
        <span class="font-serif text-[8rem] md:text-[10rem] leading-none text-[#0f2e22]/10 block mb-4">404</span>
        <h2 class="font-serif text-3xl md:text-4xl text-[#1a1a1a] mb-4">Page Not Found</h2>
        <p class="font-sans text-lg text-gray-600 max-w-xl mx-auto mb-12">
            The page you are looking for may have been moved, removed, or is temporarily unavailable.
        </p>

        <a href="/" class="inline-block bg-[#0f2e22] text-white font-sans text-sm font-bold uppercase tracking-widest px-10 py-4 border border-[#0f2e22] hover:bg-transparent hover:text-[#0f2e22] transition-colors">Return to Homepage</a>

        <div class="mt-12 flex flex-wrap items-center justify-center gap-8">
            <a href="/strategies" class="font-sans text-sm text-[#0f2e22] font-medium uppercase tracking-wider border-b border-[#0f2e22]/30 hover:border-[#0f2e22] transition-colors pb-1">Investment Strategy</a>
            <a href="/portfolio" class="font-sans text-sm text-[#0f2e22] font-medium uppercase tracking-wider border-b border-[#0f2e22]/30 hover:border-[#0f2e22] transition-colors pb-1">Portfolio</a>
            <a href="/perspectives" class="font-sans text-sm text-[#0f2e22] font-medium uppercase tracking-wider border-b border-[#0f2e22]/30 hover:border-[#0f2e22] transition-colors pb-1">Perspectives</a>
            <a href="/contact" class="font-sans text-sm text-[#0f2e22] font-medium uppercase tracking-wider border-b border-[#0f2e22]/30 hover:border-[#0f2e22] transition-colors pb-1">Contact</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>