<!-- views/public-error.ejs -->

<%
    const errStatusCode = typeof status !== 'undefined' ? status : 500;
    const displayTitle = typeof pageTitle !== 'undefined' ? pageTitle : 'Error';
    const displayMessage = typeof message !== 'undefined' ? message : 'An unexpected error occurred.';
%>

<%- include('partials/header', { pageTitle: `Error ${errStatusCode}`, path: '/error' }) %>

<!-- Error — Institutional -->
<section class="bg-[#f9f8f6] pt-24 md:pt-32 pb-16 md:pb-24 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto text-center">
        <span class="font-serif text-[8rem] md:text-[10rem] leading-none text-[#0f2e22]/10 block mb-4"><%= errStatusCode %></span>
        <h2 class="font-serif text-3xl md:text-4xl text-[#1a1a1a] mb-4"><%= displayTitle %></h2>
        <p class="font-sans text-lg text-gray-600 max-w-xl mx-auto mb-8">
            <%= displayMessage %>
        </p>

        <% if (process.env.NODE_ENV !== 'production' && typeof error !== 'undefined' && error && error.stack) { %>
            <pre class="text-left bg-[#1a1a1a] text-gray-300 font-mono text-xs p-6 max-w-2xl mx-auto mb-12 overflow-auto max-h-40 border border-[#0f2e22]/20"><%= error.stack %></pre>
        <% } %>

        <div class="flex flex-wrap items-center justify-center gap-6">
            <a href="javascript:history.back()" class="inline-block bg-transparent text-[#0f2e22] font-sans text-sm font-bold uppercase tracking-widest px-10 py-4 border border-[#0f2e22] hover:bg-[#0f2e22] hover:text-white transition-colors">Go Back</a>
            <a href="/" class="inline-block bg-[#0f2e22] text-white font-sans text-sm font-bold uppercase tracking-widest px-10 py-4 border border-[#0f2e22] hover:bg-transparent hover:text-[#0f2e22] transition-colors">Return to Homepage</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>