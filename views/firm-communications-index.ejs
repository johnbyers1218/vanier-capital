<!-- views/firm-communications-index.ejs -->
<%# Executive Communications — SEC-style minimalist listing %>

<%- include('partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: '/firm',
    isHeroPage: true
}) %>

<!-- ═══════════════ PAGE HEADER ═══════════════ -->
<section class="bg-[#0f2e22] pt-24 md:pt-32 pb-14 md:pb-20 px-6 md:px-16">
    <div class="max-w-screen-xl mx-auto">
        <p class="font-sans text-xs font-bold text-white/50 uppercase tracking-[0.2em] mb-4">The Firm</p>
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white tracking-tight mb-6">Executive Communications.</h1>
        <p class="font-sans text-xl text-white/80 max-w-3xl leading-relaxed">Periodic communications from Vanier Capital leadership regarding investment philosophy, portfolio updates, and firm operations.</p>
    </div>
</section>

<!-- ═══════════════ COMMUNICATIONS TABLE ═══════════════ -->
<section class="bg-white">
    <div class="max-w-screen-xl mx-auto px-4 md:px-16 py-10 md:py-16">
        <% if (posts && posts.length > 0) { %>

        <!-- Table Header -->
        <div class="hidden md:grid grid-cols-12 gap-4 pb-4 border-b-2 border-[#0f2e22]">
            <div class="col-span-3">
                <span class="font-sans text-[11px] font-bold text-gray-500 uppercase tracking-[0.15em]">Date</span>
            </div>
            <div class="col-span-7">
                <span class="font-sans text-[11px] font-bold text-gray-500 uppercase tracking-[0.15em]">Title</span>
            </div>
            <div class="col-span-2 text-right">
                <span class="font-sans text-[11px] font-bold text-gray-500 uppercase tracking-[0.15em]">Format</span>
            </div>
        </div>

        <!-- Table Rows -->
        <div class="divide-y divide-gray-200">
            <% posts.forEach((post) => { %>
            <a href="/firm/communications/<%= post.slug %>" class="grid grid-cols-1 md:grid-cols-12 gap-2 md:gap-4 py-5 md:py-6 group hover:bg-[#f9f8f6] transition-colors -mx-4 px-4">
                <div class="md:col-span-3">
                    <span class="font-sans text-sm text-gray-500">
                        <% if (post.publishedAt || post.publishedDate) { %>
                            <%= new Date(post.publishedAt || post.publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        <% } %>
                    </span>
                </div>
                <div class="md:col-span-7">
                    <span class="font-serif text-lg md:text-xl text-[#0f2e22] group-hover:text-[#1a1a1a] transition-colors font-semibold"><%= post.title %></span>
                </div>
                <div class="md:col-span-2 md:text-right">
                    <% if (post.pdfDocumentUrl) { %>
                        <span class="font-sans text-xs font-bold text-gray-500 uppercase tracking-[0.12em]">PDF</span>
                    <% } else { %>
                        <span class="font-sans text-xs font-bold text-gray-500 uppercase tracking-[0.12em]">Article</span>
                    <% } %>
                </div>
            </a>
            <% }) %>
        </div>

        <!-- Pagination -->
        <% if (lastPage > 1) { %>
        <div class="flex justify-between items-center py-12 border-t border-[#0f2e22]/20 mt-8">
            <% if (hasPreviousPage) { %>
                <a href="/firm/communications?page=<%= previousPage %>" class="font-sans text-sm font-bold uppercase tracking-wider text-[#0f2e22] hover:text-slate-600 transition-colors">&larr; Previous</a>
            <% } else { %>
                <span></span>
            <% } %>
            <span class="font-sans text-xs text-gray-400 uppercase tracking-widest">Page <%= currentPage %> of <%= lastPage %></span>
            <% if (hasNextPage) { %>
                <a href="/firm/communications?page=<%= nextPage %>" class="font-sans text-sm font-bold uppercase tracking-wider text-[#0f2e22] hover:text-slate-600 transition-colors">Next &rarr;</a>
            <% } else { %>
                <span></span>
            <% } %>
        </div>
        <% } %>

        <% } else { %>
            <div class="py-20 text-center">
                <h3 class="font-serif text-3xl text-[#1a1a1a] mb-4">No communications published yet.</h3>
                <p class="font-sans text-lg text-gray-600">Check back for updates from firm leadership.</p>
            </div>
        <% } %>
    </div>
</section>

<%- include('partials/footer') %>
