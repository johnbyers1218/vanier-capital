<%- include('partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: path,
    isHeroPage: true
}) %>

<!-- ═══════════════ HERO ═══════════════ -->
<section class="bg-[#0f2e22] pt-24 md:pt-32 pb-14 md:pb-20 px-6 md:px-16">
    <div class="max-w-[1200px] mx-auto">
        <p class="font-sans text-xs font-bold uppercase tracking-widest text-white/50 mb-4">Portfolio Track Record</p>
        <h1 class="font-serif text-3xl sm:text-4xl md:text-5xl lg:text-6xl text-white tracking-tight mb-6">Representative Assets.</h1>
        <p class="font-sans text-xl text-white/80 max-w-2xl leading-relaxed">A curated selection of our stabilized and value-add residential assets, demonstrating our disciplined approach to capital stewardship and operational execution.</p>
    </div>
</section>

<!-- ═══════════════ ASSET PROFILES ═══════════════ -->
<section class="bg-white">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16 py-12 md:py-20 divide-y divide-[#0f2e22]/10">

        <% const portfolioAssets = (properties || []).filter(p => p.assetClass); %>
        <% if (portfolioAssets.length === 0) { %>
        <div class="py-16 text-center">
            <p class="font-sans text-lg text-gray-500">Portfolio assets are being prepared. Check back soon.</p>
        </div>
        <% } %>
        <% portfolioAssets.forEach(function(property, idx) { %>
        <article class="grid grid-cols-1 lg:grid-cols-12 gap-10 py-16 <%= idx === 0 ? 'pt-0' : '' %>">

            <!-- Image (Span 4 — Constrained) -->
            <div class="lg:col-span-4">
                <a href="/portfolio/<%= property.slug %>" class="block">
                    <div class="aspect-[4/3] bg-gray-200 overflow-hidden border border-gray-200">
                        <img
                            src="<%= property.image %>"
                            alt="<%= property.title %>"
                            class="w-full h-full object-cover rounded-none grayscale transform-gpu backface-hidden will-change-transform"
                            loading="<%= idx === 0 ? 'eager' : 'lazy' %>"
                            onerror="this.src='https://placehold.co/600x450/0f2e22/ffffff?text=<%= encodeURIComponent(property.title) %>'"
                        >
                    </div>
                </a>
            </div>

            <!-- Content (Span 8) -->
            <div class="lg:col-span-8 flex flex-col pt-2 lg:pt-0">
                <span class="font-sans text-sm font-bold text-[#1a1a1a]/50 uppercase tracking-widest mb-3"><%= property.subtitle || '' %><% if (property.subtitle && property.strategy) { %> | <% } %><%= property.strategy || '' %></span>
                <a href="/portfolio/<%= property.slug %>" class="hover:text-[#1a1a1a] transition-colors"><h2 class="font-serif text-3xl text-[#0f2e22] mb-4"><%= property.portfolioName || property.title %></h2></a>
                <p class="font-sans text-lg text-gray-700 leading-relaxed mb-8"><%= property.summary || property.excerpt || '' %></p>

                <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-6 border-t border-[#0f2e22]/10 pt-6 mt-auto">
                    <% if (property.doors) { %>
                    <div>
                        <p class="font-sans text-xs uppercase tracking-widest text-[#1a1a1a]/40 mb-1">Doors</p>
                        <p class="font-serif text-lg font-semibold text-[#0f2e22]"><%= property.doors %></p>
                    </div>
                    <% } %>
                    <% if (property.occupancy) { %>
                    <div>
                        <p class="font-sans text-xs uppercase tracking-widest text-[#1a1a1a]/40 mb-1">Occupancy</p>
                        <p class="font-serif text-lg font-semibold text-[#0f2e22]"><%= property.occupancy %></p>
                    </div>
                    <% } %>
                    <% if (property.targetIRR) { %>
                    <div>
                        <p class="font-sans text-xs uppercase tracking-widest text-[#1a1a1a]/40 mb-1">Target IRR</p>
                        <p class="font-serif text-lg font-semibold text-[#0f2e22]"><%= property.targetIRR %></p>
                    </div>
                    <% } %>
                </div>

                <div class="mt-8">
                    <a href="/portfolio/<%= property.slug %>" class="font-sans text-sm font-bold uppercase tracking-widest text-[#0f2e22] border-b border-[#0f2e22] pb-1 hover:text-[#1a1a1a] hover:border-[#1a1a1a] transition-all">View Case Study &rarr;</a>
                </div>
            </div>

        </article>
        <% }); %>

    </div>
</section>

<!-- ═══════════════ CTA BLOCK ═══════════════ -->
<section class="bg-slate-50 border-t border-[#0f2e22]/10">
    <div class="max-w-[1200px] mx-auto px-6 md:px-16 py-14 md:py-20 flex flex-col md:flex-row md:items-center md:justify-between gap-8">
        <div>
            <h2 class="font-serif text-3xl md:text-4xl text-[#0f2e22] mb-3">Explore Our Approach.</h2>
            <p class="font-sans text-lg text-gray-600 max-w-xl">Learn more about our investment strategy, underwriting discipline, and how we create value across our portfolio.</p>
        </div>
        <a href="/strategy" class="inline-block font-sans text-sm font-bold text-white bg-[#0f2e22] px-10 py-4 uppercase tracking-wider hover:bg-[#1a3a2a] transition-colors rounded-none whitespace-nowrap">Investment Strategy</a>
    </div>
</section>

<%- include('partials/footer') %>
