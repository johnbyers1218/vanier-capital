<%- include('partials/header', {
    pageTitle: pageTitle,
    pageDescription: pageDescription,
    path: path
}) %>

<section class="section portfolio-hero" style="background-color: #f1f5f9; color: #1e293b; padding: 4rem 0;">
    <div class="container">
        <div class="section-header" style="text-align: center;">
            <h1 class="section-title" style="color: #1e293b; font-family: 'Merriweather', serif; font-size: 2.5rem; margin-bottom: 1rem;">Our Portfolio</h1>
            <p class="section-description" style="color: #64748b; max-width: 700px; margin: 0 auto;">A disciplined collection of high-performing assets delivering durable cash flow and long-term appreciation.</p>
        </div>
    </div>
</section>

<section class="section" style="background-color: #f8fafc; padding: 4rem 0;">
    <div class="container">
        
        <!-- Portfolio Grid -->
        <div id="properties-grid-container" class="grid-container grid-3-col" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem;">
            
            <% if (properties && properties.length > 0) { %>
                <% properties.forEach(property => { %>
                    <div class="content-card project-card" style="background: white; border-radius: 0.75rem; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);">
                        <div style="aspect-ratio: 16/9; background: #e2e8f0; position: relative; overflow: hidden;">
                            <img src="<%= property.image %>" alt="<%= property.title %>" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='https://placehold.co/600x400/0b4d3a/ffffff?text=<%= encodeURIComponent(property.title) %>'">
                            <div style="position: absolute; top: 1rem; right: 1rem; background: rgba(11, 77, 58, 0.9); color: white; padding: 0.25rem 0.75rem; border-radius: 0.25rem; font-size: 0.875rem; font-weight: 600;">Residential</div>
                        </div>
                        <div style="padding: 1.5rem;">
                            <h3 style="font-family: 'Merriweather', serif; font-size: 1.25rem; font-weight: 700; color: #1e293b; margin-bottom: 0.5rem;"><%= property.title %></h3>
                            <p style="color: #64748b; font-size: 0.875rem; margin-bottom: 0.5rem;"><i class="fas fa-map-marker-alt" style="color: #0b4d3a; margin-right: 0.5rem;"></i><%= property.address || property.location %></p>
                            <p style="color: #475569; font-size: 0.95rem; line-height: 1.5; margin-bottom: 1rem;"><%= property.summary %></p>
                            
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; border-top: 1px solid #e2e8f0; padding-top: 1rem; margin-top: 1rem;">
                                <% if (property.metrics) { %>
                                    <% property.metrics.forEach(metric => { %>
                                        <div>
                                            <div style="font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;"><%= metric.label %></div>
                                            <div style="font-size: 1.125rem; font-weight: 600; color: <%= metric.highlight ? '#0b4d3a' : '#0f172a' %>;"><%= metric.value %></div>
                                        </div>
                                    <% }); %>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                    <p>No properties currently listed.</p>
                </div>
            <% } %>

        </div>
    </div>
</section>

<%- include('partials/footer') %>
