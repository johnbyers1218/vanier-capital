<!-- views/testimonials.ejs -->
<%# Modern Testimonials Page with Carousel Design %>

<%- include('partials/header', {
    pageTitle: 'Client Testimonials - Vanier Capital',
    pageDescription: 'Read what our clients say about Vanier Capital and the results delivered across our portfolio.',
    path: '/testimonials'
}) %>

<!-- Hero Section -->
<section class="page-header">
    <div class="container">
    <h1>Client Testimonials</h1>
    <p class="page-subtitle">Real results from partners and residents we serve</p>
    </div>
</section>

<!-- Featured Testimonial Carousel -->
<section class="testimonial-carousel-section">
    <div class="container">
        <div class="testimonial-carousel-container">
            <div class="carousel-header">
                <h2 class="section-title">Client Success Stories</h2>
                <div class="carousel-controls">
                    <button class="carousel-btn prev-btn" aria-label="Previous testimonial">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                    <button class="carousel-btn next-btn" aria-label="Next testimonial">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
            </div>
            
            <div class="testimonial-carousel" id="testimonials-carousel" role="region" aria-roledescription="carousel" aria-label="Client Success Stories" tabindex="0" aria-live="off">
                <div class="carousel-track" id="carousel-track">
                    <!-- Loading state -->
                    <div class="testimonial-loading">
                        <div class="loading-spinner"></div>
                        <p>Loading testimonials...</p>
                    </div>
                </div>
            </div>
            
            <div class="carousel-dots" id="carousel-dots">
                <!-- Dots will be generated dynamically -->
            </div>

            <!-- Progress bar removed in favor of dots-only indicators -->

            <!-- Screen reader announcer for slide changes -->
            <div id="carousel-announcer" class="sr-only" aria-live="polite" aria-atomic="true"></div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="testimonial-stats-section">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-number" data-prefix="$" data-count="<%= metrics ? Math.max(0, Math.round((metrics.totalValuation || 0) / 1000000)) : 0 %>" data-suffix="M+">$0M+</div>
                <div class="stat-label">Combined Partner Valuation</div>
            </div>
            <div class="stat-item">
                <div class="stat-number" data-prefix="$" data-count="<%= metrics ? Math.max(0, Math.round((metrics.totalRevenue || 0) / 1000000)) : 0 %>" data-suffix="M+">$0M+</div>
                <div class="stat-label">Combined Partner Revenue</div>
            </div>
            <div class="stat-item">
                <div class="stat-number" data-count="<%= metrics && metrics.projectsCompleted || 0 %>" data-suffix="+">0+</div>
                <div class="stat-label">Projects Completed</div>
            </div>
            <div class="stat-item">
                <div class="stat-number" data-count="<%= metrics && metrics.manualHoursAutomated || 0 %>" data-suffix="+">0+</div>
                <div class="stat-label">Manual Hours Automated</div>
            </div>
        </div>
    </div>
</section>

<!-- All Testimonials Grid -->
<section class="all-testimonials-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">All Client Feedback</h2>
            <p class="section-subtitle">Explore our complete collection of client testimonials and success stories</p>
        </div>
    <div id="testimonial-filters"></div>
        
        <div class="testimonials-grid" id="testimonials-grid-container">
            <div class="testimonial-loading grid-loading">
                <div class="loading-spinner"></div>
                <p>Loading all testimonials...</p>
            </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="cta-section cta-alt full-bleed">
    <div class="container">
        <div class="cta-content">
            <h2 class="cta-title">Ready to Join Our Satisfied Clients?</h2>
            <p class="cta-description">Contact us to discuss how our disciplined approach can deliver measurable results.</p>
            <div class="cta-actions">
                <a href="/contact" class="btn btn-primary">Start Your Project</a>
                <a href="/services" class="btn btn-secondary">Explore Our Services</a>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>