<!-- views/testimonials.ejs -->
<%# Testimonials Page Shell for FND Automations %>

<%- include('partials/header', {
    pageTitle: 'Client Testimonials - FND Automations',
    pageDescription: 'Read what our clients say about FND Automations\' impact on their business through successful AI and process automation solutions.',
    path: '/testimonials' /* Pass path for active nav highlighting */
}) %>

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1>Client Testimonials</h1>
        <div class="breadcrumbs">
            <a href="/">Home</a> <span class="separator">/</span> <span class="current">Testimonials</span>
        </div>
    </div>
</section>

<!-- Intro Section -->
<section id="testimonials-intro" class="section testimonials-intro-section">
    <div class="container section-header">
        <h2 class="section-title">What Our Clients Say</h2>
        <p class="section-description">Don't just take our word for it. Here's what our clients have to say about our automation solutions and the impact they've had on their businesses.</p>
    </div>
</section>

 <!-- Optional Featured Testimonial Section (Static Example - Make dynamic via JS/API if desired) -->
 <section id="featured-testimonial" class="section featured-testimonial-section" style="padding-top: 0;">
     <div class="container">
           <!-- Featured Testimonial Section -->
 <section id="featured-testimonial-section-dynamic" class="section" style="padding-top: 0;"> <!-- Changed ID slightly -->
    <div class="container">
        <!-- Container for dynamic featured testimonial -->
        <div id="featured-testimonial-container">
             <!-- Loading message inserted by JS -->
            <p style="text-align: center; padding: 1rem; color: var(--gray-text);">Loading featured testimonial...</p>
        </div>
    </div>
</section>
      </div>
 </section>

<!-- Testimonials Grid Section -->
<section id="testimonials-grid-section" class="section section-darker">
    <div class="container">
         <div class="section-header" style="margin-bottom: 2rem;">
             <h2 class="section-title">More Client Feedback</h2>
             <!-- Optional: Add intro text for this specific grid if needed -->
        </div>

        <!-- Container where JavaScript (apps.js) will inject testimonial cards -->
        <!-- The loadTestimonials function in apps.js targets this ID -->
        <div id="testimonials-grid-container" class="grid-container grid-2-col">
             <!-- Initial Loading State (Rendered by JS) -->
             <div class="content-card is-loading" style="grid-column: 1 / -1; text-align: center; padding: 3rem 1rem; justify-content: center; align-items: center;">
                 <i class="fas fa-spinner fa-spin fa-2x" style="color: var(--primary-color);"></i>
                 <p style="margin-top: 1rem; color: var(--gray-text);">Loading Testimonials...</p>
             </div>
             <!-- JS will clear this and append actual testimonial cards -->
        </div>
         <!-- Optional: Pagination for testimonials if needed -->
         <!-- <nav class="pagination" id="testimonials-pagination"></nav> -->
    </div>
</section>

