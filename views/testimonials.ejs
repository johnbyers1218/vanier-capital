<!-- CTA Section -->
<section id="cta" class="cta-section">
    <div class="container">
        <div class="cta-content">
            <h2>Ready to Join Our Satisfied Clients?</h2>
            <p>Contact us today to discuss how our automation solutions can transform your business operations.</p>
            <a href="/contact" class="cta-button primary-btn glow-button">Get Started</a>
        </div>
    </div>
</section>

<%- include('partials/footer') %>