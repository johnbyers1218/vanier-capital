<!-- views/subscribe-complete-profile.ejs -->
<%- include('partials/header', {
  pageTitle: "You're Almost In!",
  pageDescription: 'One last quick step before you get your first issue.',
  path: '/subscribe/complete-profile'
}) %>

<section class="section">
  <div class="container">
    <div class="content-card" style="max-width: 720px; margin-inline: auto; background: #f9fafb; border: 1px solid var(--color-border-subtle); border-radius: .875rem; box-shadow: 0 6px 30px rgba(0,0,0,.06); padding: clamp(2rem, 4vw, 2.5rem);">
  <h1 class="section-title" style="text-align:center; font-size: clamp(1.6rem, 3vw, 2rem); font-weight: 800; letter-spacing: -0.01em;">You're Almost In!</h1>
  <p class="section-description" style="text-align:center; max-width: 60ch; margin: .375rem auto 1rem;">One last step! Let us know your name for a personal touch. Your role and company are optional, but they help us send you more relevant content.</p>

      <form id="finalizeForm" class="signup-form" onsubmit="return false;" style="margin-top: .75rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: end;">
        <input type="hidden" id="email" value="<%= email ? email : '' %>" />

        <div>
          <label for="firstName" style="display:block; font-weight: 600; margin-bottom: .4rem;">First Name <span style="color:#dc2626">*</span></label>
          <input id="firstName" name="firstName" type="text" placeholder="Enter your first name" required aria-required="true" autocomplete="given-name" />
        </div>
        <div>
          <label for="lastName" style="display:block; font-weight: 600; margin-bottom: .4rem;">Last Name <span style="color:#dc2626">*</span></label>
          <input id="lastName" name="lastName" type="text" placeholder="Enter your last name" required aria-required="true" autocomplete="family-name" />
        </div>

        <div>
          <label for="role" style="display:block; font-weight: 600; margin-bottom: .4rem;">Your Role <span style="font-weight:400; color: var(--color-text-muted);">(Optional)</span></label>
          <select id="role" name="role">
            <option value="">Select your role (optional)</option>
            <option>Business Leader / C-Suite</option>
            <option>Manager / Department Head</option>
            <option>Developer / Engineer</option>
            <option>Marketing / Sales Professional</option>
            <option>Student / Researcher</option>
            <option>Other</option>
          </select>
        </div>
        <div>
          <label for="companyName" style="display:block; font-weight: 600; margin-bottom: .4rem;">Company Name <span style="font-weight:400; color: var(--color-text-muted);">(Optional)</span></label>
          <input id="companyName" name="companyName" type="text" placeholder="Enter your company (optional)" />
        </div>

        <div style="grid-column: 1 / -1; display: flex; justify-content: flex-end; gap: .75rem; margin-top: .25rem;">
          <button id="finalizeSubmit" type="submit" class="cta-button primary-btn glow-button">Get My First Issue</button>
        </div>

        <p id="finalizeMessage" class="form-message" aria-live="polite" hidden style="grid-column: 1 / -1;"></p>
      </form>
    </div>
  </div>
</section>

<script>
(function(){
  const form = document.getElementById('finalizeForm');
  if(!form) return;
  const email = (document.getElementById('email')?.value || '').trim();
  const first = document.getElementById('firstName');
  const last = document.getElementById('lastName');
  const role = document.getElementById('role');
  const company = document.getElementById('companyName');
  const msg = document.getElementById('finalizeMessage');
  const btn = document.getElementById('finalizeSubmit');

  function showMessage(text, type){
    msg.textContent = text; msg.hidden = false; msg.classList.remove('error','success'); if(type) msg.classList.add(type);
  }

  form.addEventListener('submit', async function(e){
    e.preventDefault();
    if (!email) { window.location.href = '/'; return; }
    const firstVal = first.value.trim();
    const lastVal = last.value.trim();
    if (!firstVal) { showMessage('First name is required.', 'error'); first.focus(); return; }
    if (!lastVal) { showMessage('Last name is required.', 'error'); last.focus(); return; }
    btn.disabled = true;
    try {
      const resp = await fetch('/api/subscribe/finalize', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, firstName: firstVal, lastName: lastVal, role: role.value || undefined, companyName: company.value.trim() || undefined })
      });
      const data = await resp.json().catch(()=>({success:false,message:'Unexpected response.'}));
      if(resp.ok && data.success){
        if (data.redirect) { window.location.href = data.redirect; return; }
        window.location.href = '/newsletter/welcome' + (email ? ('?email=' + encodeURIComponent(email)) : '');
      } else {
        showMessage(data.message || 'Sorry, something went wrong.', 'error');
      }
    } catch(err){
      showMessage('Network error. Please try again.', 'error');
    } finally {
      btn.disabled = false;
    }
  });
})();
</script>

<style>
  /* Enhanced input styling for clarity */
  #finalizeForm input[type=text], #finalizeForm select {
    width:100%;
    background:#ffffff;
    border:1px solid #cbd5e1;
    border-radius:8px;
    padding:.65rem .75rem;
    font-size:.95rem;
    line-height:1.25rem;
    transition:border-color .15s ease, box-shadow .15s ease, background-color .15s ease;
  }
  #finalizeForm input[type=text]:focus, #finalizeForm select:focus {
    outline:2px solid #2563eb;
    outline-offset:2px;
    border-color:#2563eb;
    box-shadow:0 0 0 3px rgba(37,99,235,.35);
    background:#ffffff;
  }
  #finalizeForm input[aria-required="true"]:invalid {
    border-color:#dc2626;
  }
  #finalizeForm .error { color:#dc2626; font-weight:500; }
  #finalizeForm .success { color:#15803d; font-weight:500; }
  /* Funnel card styling (inherits site-wide background now) */
  .content-card { background:#ffffff !important; }
  #finalizeForm label { color:#1e293b; }
  #finalizeForm input[type=text]::placeholder { color:#64748b; }
</style>

<%- include('partials/footer') %>
