                 <i class="fas fa-exclamation-triangle"></i> <!-- Default Error Icon -->
            </div>

            <!-- Basic Title and Message Output -->
            <h2 class="error-message"><%= displayTitle %> (<%= errStatusCode %>)</h2>
            <p class="error-description">
                <%= displayMessage %>
