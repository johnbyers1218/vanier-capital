        </nav>

        <% if (posts && posts.length > 0) { %>
            <!-- Blog Post Grid -->
            <div class="grid-container grid-3-col blog-list"> <%# Use 3 columns for blog list %>
                <% posts.forEach(post => { %>
                    <article class="content-card blog-post-summary" data-tags="<%= post.tags ? post.tags.join(',') : '' %>">
                        <%# Featured Image Link %>
                        <% if (post.featuredImage) { %>
                          <a href="/blog/<%= post.slug %>" class="blog-post-image-link" aria-hidden="true" tabindex="-1">
                              <img src="<%= post.featuredImage %>" alt="" class="blog-post-summary-image">
                          </a>
                        <% } else { %>
                           <div class="blog-post-placeholder-image">
                               <i class="fas fa-file-alt"></i>
                           </div>
                        <% } %>

                        <div class="blog-post-summary-content">
                             <%# Post Title (Link) %>
