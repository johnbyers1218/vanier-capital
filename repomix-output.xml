<file path="views/project-single.ejs">
<%# views/project-single.ejs %>
<%# Template for displaying a single public project %>

<%- include('partials/header', { pageTitle: pageTitle, pageDescription: pageDescription }) %>

<main>
    <section class="page-header" style="padding-bottom: 1.5rem; margin-bottom: 0;">
        <div class="container">
            <div class="breadcrumbs" style="margin-top: 1rem;">
                 <a href="/">Home</a>
                 <span class="separator">/</span>
                 <a href="/projects">Projects</a>
                 <span class="separator">/</span>
                 <span class="current"><%= project.title.length > 50 ? project.title.substring(0, 50) + '...' : project.title %></span>
            </div>
        </div>
    </section>

    <section class="content-section project-details-section">
        <div class="container">
            <article class="project-full-content">
                <header class="project-header" style="margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--card-border);">
                    <h1><%= project.title %></h1>
                    <div class="project-meta" style="font-size: 0.9rem; color: var(--gray-text); margin-top: 0.5rem;">
                        <% if (project.category) { %>
                            <span><i class="fas fa-folder-open"></i> Category: <a href="/projects?category=<%= project.category %>" style="color: var(--primary-color);"><%= project.category %></a></span>
                        <% } %>
                        <% if (project.projectDate) { %>
                            <span style="margin-left: 15px;"><i class="fas fa-calendar-alt"></i> Completed: <%= new Date(project.projectDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) %></span>
                        <% } %>
                        <% if (project.clientName) { %>
                            <span style="margin-left: 15px;"><i class="fas fa-user-tie"></i> Client: <%= project.clientName %></span>
                        <% } %>
                    </div>
                </header>

                <% if (project.image) { %>
                    <figure class="featured-project-image" style="margin-bottom: 2.5rem; text-align: center;">
                        <img src="<%= project.image %>" alt="<%= project.title %> - Main Image" style="max-width: 100%; height: auto; max-height: 500px; border-radius: var(--border-radius); box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
                    </figure>
                <% } %>

                <div class="project-description-content blog-post-content"> <%# Reuse blog post content styling for rich text %>
                    <%- project.description %> <%# Output raw HTML from TinyMCE %>
                </div>

                <% if (project.technologiesUsed && project.technologiesUsed.length > 0) { %>
                    <div class="project-technologies" style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--card-border);">
                        <h3 style="font-size: 1.3rem; color: var(--light-text); margin-bottom: 1rem;">Technologies Used:</h3>
                        <ul style="list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem;">
                            <% project.technologiesUsed.forEach(tech => { %>
                                <li style="background-color: rgba(0,168,232,0.1); color: var(--primary-color); padding: 5px 10px; border-radius: 3px; font-size: 0.9em;"><%= tech %></li>
                            <% }) %>
                        </ul>
                    </div>
                <% } %>

                <% if (project.link) { %>
                    <div class="project-external-link" style="margin-top: 2.5rem; text-align: center;">
                        <a href="<%= project.link %>" class="cta-button primary-btn" target="_blank" rel="noopener noreferrer">
                            <i class="fas fa-external-link-alt"></i> View Live Project / Learn More
                        </a>
                    </div>
                <% } %>

                <hr style="border: none; border-top: 1px solid var(--card-border); margin: 3rem 0;">
                <div class="post-navigation" style="display: flex; justify-content: center;">
                     <a href="/projects" class="cta-button secondary-btn">← Back to All Projects</a>
                     <%# TODO: Add Prev/Next Project links here similar to blog posts if desired %>
                </div>

            </article>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
</file>

