            <%- include('partials/pagination', { currentPage, hasNextPage, hasPreviousPage, nextPage, previousPage, lastPage, baseUrl: '/blog', tagQuery: (typeof tagQuery !== 'undefined' ? tagQuery : null) }) %>

        <% } else { %>
