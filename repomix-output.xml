function initProjectFilters() {
    const filterButtons = document.querySelectorAll('.filter-navigation .filter-btn');
    const projectGrid = document.getElementById('projects-grid-container');
    if (!filterButtons.length || !projectGrid) return;

    // Update filter counts on load
    updateFilterCounts();

    filterButtons.forEach(button => {
        button.addEventListener('click', (e) => {
            e.preventDefault();
            const filterValue = button.getAttribute('data-filter');
            
            // Update active states
            filterButtons.forEach(btn => {
                btn.classList.remove('active');
                btn.setAttribute('aria-pressed', 'false');
            });
            button.classList.add('active');
            button.setAttribute('aria-pressed', 'true');

            // Filter projects with smooth animation
            filterProjects(filterValue);
        });
    });
}

function updateFilterCounts() {
    const projectCards = document.querySelectorAll('.project-card');
    const filterButtons = document.querySelectorAll('.filter-navigation .filter-btn');
    
    // Count projects by category
    const categoryCounts = {};
    let totalCount = 0;

    projectCards.forEach(card => {
        const category = card.dataset.category || 'uncategorized';
        categoryCounts[category] = (categoryCounts[category] || 0) + 1;
        totalCount++;
    });

    // Update count displays
    filterButtons.forEach(button => {
        const filterValue = button.getAttribute('data-filter');
        const countElement = button.querySelector('.filter-count');
        
        if (countElement) {
            if (filterValue === 'all') {
                countElement.textContent = totalCount;
            } else {
                const count = categoryCounts[filterValue] || 0;
                countElement.textContent = count;
            }
        }
    });
}

function filterProjects(filterValue) {
    const projectCards = document.querySelectorAll('.project-card');
    
    projectCards.forEach((card, index) => {
        const category = card.dataset.category;
        const shouldShow = (filterValue === 'all' || category === filterValue);
        
        if (shouldShow) {
            card.style.display = 'flex';
            card.style.animation = `fadeInUp 0.6s ease forwards ${index * 0.1}s`;
        } else {
            card.style.animation = 'fadeOut 0.3s ease forwards';
            setTimeout(() => {
                if (!shouldShow) card.style.display = 'none';
            }, 300);
        }
    });
}

