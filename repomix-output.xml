<file path="views/blog-index.ejs">
<!-- views/blog-index.ejs -->
<%# Public Blog Listing Page %>

<%- include('partials/header', {
    pageTitle: 'Blog - FND Automations',
    pageDescription: 'Read the latest insights on AI, automation, business efficiency, and technology trends from FND Automations.',
    path: '/blog'
}) %>

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1>Blog</h1>
    </div>
</section>

<!-- Blog Introduction Section -->
<section class="blog-intro-section">
    <div class="container">
        <div class="blog-intro-content">
            <p class="blog-intro-text">
                Discover cutting-edge insights and proven strategies from our team of automation experts. 
                Explore how AI and intelligent automation are transforming businesses across industries, 
                and learn actionable approaches to drive efficiency, growth, and competitive advantage in your organization.
            </p>
            <div class="blog-intro-stats">
                <div class="intro-stat">
                    <span class="stat-number">50+</span>
                    <span class="stat-label">Expert Articles</span>
                </div>
                <div class="intro-stat">
                    <span class="stat-number">1000+</span>
                    <span class="stat-label">Business Leaders Informed</span>
                </div>
                <div class="intro-stat">
                    <span class="stat-number">5</span>
                    <span class="stat-label">Years of Industry Expertise</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Main Blog Content Section -->
<section class="section blog-posts-section">
    <div class="container">

        <!-- Filter Navigation -->
        <nav class="filter-navigation blog-filter-navigation" role="navigation" aria-label="Blog categories">
            <div class="filter-group">
                <button class="filter-btn active" data-filter="all" aria-pressed="true">
                    <span class="filter-label">All Posts</span>
                    <span class="filter-count" data-count="all">—</span>
                </button>
                <button class="filter-btn" data-filter="automation" aria-pressed="false">
                    <span class="filter-label">Automation</span>
                    <span class="filter-count" data-count="automation">—</span>
                </button>
                <button class="filter-btn" data-filter="ai" aria-pressed="false">
                    <span class="filter-label">AI & Machine Learning</span>
                    <span class="filter-count" data-count="ai">—</span>
                </button>
                <button class="filter-btn" data-filter="business" aria-pressed="false">
                    <span class="filter-label">Business Strategy</span>
                    <span class="filter-count" data-count="business">—</span>
                </button>
                <button class="filter-btn" data-filter="technology" aria-pressed="false">
                    <span class="filter-label">Technology</span>
                    <span class="filter-count" data-count="technology">—</span>
                </button>
                <button class="filter-btn" data-filter="case-studies" aria-pressed="false">
                    <span class="filter-label">Case Studies</span>
                    <span class="filter-count" data-count="case-studies">—</span>
                </button>
